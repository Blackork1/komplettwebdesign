<%
// Avatar-Helfer: deterministische Initialen + Farbe aus dem Namen.
// Datensparsam (kein externer Service), generiert pro Person ein unverwechselbares Bild.
//
// hasAvatar(): prüft, ob eine Avatar-URL als "echt" gilt.
// - leerer String, Whitespace, relative Default-Pfade (/images/avatar*.*, /images/default*.*,
//   /images/user*.*, /uploads/default*.*) werden als fehlend behandelt
// - nur http(s)-URLs oder /uploads/-Pfade mit konkretem Dateinamen zählen als echter Avatar
function hasAvatar(url) {
  if (!url || typeof url !== 'string') return false;
  const u = url.trim();
  if (!u) return false;
  // Absolute URLs (http/https) gelten als echt
  if (/^https?:\/\//i.test(u)) return true;
  // Relative Pfade mit bekannten Platzhalter-Namen → ignorieren
  if (/\/(default|placeholder|avatar[-_]?default|user[-_]?default|no[-_]?avatar)/i.test(u)) return false;
  // Alles andere akzeptieren (/uploads/max.webp etc.)
  return true;
}
function avatarInitials(name) {
  if (!name || typeof name !== 'string') return '?';
  const parts = name.trim().replace(/[^\p{L}\p{N}\s&.-]/gu, '').split(/\s+/).filter(Boolean);
  if (parts.length === 0) return '?';
  const first = parts[0][0] || '';
  const last = parts.length > 1 ? parts[parts.length - 1][0] : '';
  return (first + last).toUpperCase().slice(0, 2);
}
function avatarColor(name) {
  const palette = [
    '#1e3a8a', '#0f766e', '#b45309', '#9f1239', '#047857',
    '#c2410c', '#0e7490', '#6b21a8', '#475569', '#be185d'
  ];
  let sum = 0;
  for (const ch of (name || '')) sum = (sum + ch.charCodeAt(0)) % 9973;
  return palette[sum % palette.length];
}

const currentLang = typeof lng !== 'undefined' ? lng : 'de';
const isEn = currentLang === 'en';
const schemaBase = (typeof canonicalBaseUrl !== 'undefined' && canonicalBaseUrl
  ? canonicalBaseUrl
  : 'https://komplettwebdesign.de').replace(/\/$/, '');
const schemaHomeUrl = `${schemaBase}/`;
const schemaOrgId = `${schemaBase}/#organization`;
const schemaWebsiteId = `${schemaBase}/#website`;
const schemaPersonId = `${schemaBase}/#person`;
const faqEntries = (typeof faq !== 'undefined' && Array.isArray(faq)) ? faq : [];
const homeLowestPackagePriceLabel = typeof lowestPackagePriceLabel !== 'undefined' && lowestPackagePriceLabel
  ? lowestPackagePriceLabel
  : '';
const homePackagesPriceText = homeLowestPackagePriceLabel
  ? (isEn ? `clear website packages from ${homeLowestPackagePriceLabel}` : `klare Website-Pakete ab ${homeLowestPackagePriceLabel}`)
  : (isEn ? 'clear website packages' : 'klare Website-Pakete');
function homePackageAllowsDetail(pkg) {
  return pkg && pkg.allowDetailPage !== false && pkg.slug;
}
function homePackageTarget(pkg) {
  if (homePackageAllowsDetail(pkg)) return `${isEn ? '/en' : ''}/pakete/${pkg.slug}`;
  const packageValue = pkg && (pkg.packageKey || pkg.slug);
  return `${isEn ? '/en/kontakt' : '/kontakt'}${packageValue ? `?paket=${encodeURIComponent(packageValue)}` : ''}`;
}
function homePackageCtaLabel(pkg) {
  if (!homePackageAllowsDetail(pkg)) return isEn ? 'Request package' : 'Paket anfragen';
  return isEn ? 'View details' : 'Details ansehen';
}
const faqSchema = faqEntries.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqEntries.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
} : null;
const structuredDataBlocks = [
  faqSchema,
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': schemaOrgId,
    name: 'Komplett Webdesign',
    url: schemaHomeUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${schemaBase}/images/LogoTransparent.webp`,
      width: 400,
      height: 400
    },
    image: [
      `${schemaBase}/images/LogoTransparent.webp`,
      `${schemaBase}/images/heroBg.webp`
    ],
    description: `Persönliches Webdesign, technische SEO-Grundlagen und ${homePackagesPriceText}.`,
    areaServed: [
      { '@type': 'Country', name: 'Deutschland' },
      { '@type': 'City', name: 'Berlin' },
      { '@type': 'State', name: 'Brandenburg' }
    ],
    priceRange: homeLowestPackagePriceLabel ? `ab ${homeLowestPackagePriceLabel}` : 'nach Angebot',
    email: 'kontakt@komplettwebdesign.de',
    telephone: '+49 1551 245048',
    sameAs: [
      'https://www.instagram.com/KomplettWebdesign',
      'https://www.facebook.com/profile.php?id=61579580713573',
      'https://www.youtube.com/@KomplettWebdesign',
      'https://www.threads.com/@komplettwebdesign',
      'https://www.tiktok.com/@komplett.webdesign',
      'https://www.linkedin.com/in/komplettwebdesign'
    ],
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+49 1551 245048',
      email: 'kontakt@komplettwebdesign.de',
      contactType: 'customer support',
      availableLanguage: ['de', 'en']
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': schemaPersonId,
    name: 'Sören Blocksdorf',
    jobTitle: 'Webdesigner und Webentwickler',
    description: 'Freiberuflicher Webdesigner und Entwickler aus Berlin mit Schwerpunkt auf individuellen Websites, technischer SEO-Grundlage und klarer Angebotsstruktur.',
    url: schemaHomeUrl,
    email: 'kontakt@komplettwebdesign.de',
    telephone: '+49 1551 245048',
    worksFor: { '@id': schemaOrgId },
    knowsAbout: ['Webdesign', 'Webentwicklung', 'technische SEO-Grundlagen', 'Local SEO', 'Node.js', 'EJS'],
    knowsLanguage: ['de', 'en'],
    sameAs: [
      'https://www.linkedin.com/in/komplettwebdesign',
      'https://www.instagram.com/KomplettWebdesign',
      'https://www.youtube.com/@KomplettWebdesign'
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': schemaWebsiteId,
    name: 'Komplett Webdesign',
    url: schemaHomeUrl,
    description: `Website erstellen lassen in Berlin: individuelles Webdesign mit Node.js/EJS, technischer SEO-Grundlage und ${homePackagesPriceText}.`,
    publisher: { '@id': schemaOrgId },
    inLanguage: isEn ? 'en-US' : 'de-DE'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${schemaBase}/#webdesign-service`,
    name: 'Individuelles Webdesign',
    serviceType: 'Webdesign und Webentwicklung',
    provider: { '@id': schemaOrgId },
    areaServed: [
      { '@type': 'City', name: 'Berlin' },
      { '@type': 'State', name: 'Brandenburg' },
      { '@type': 'Country', name: 'Deutschland' }
    ],
    description: 'Individuelle Websites mit serverseitig gerendertem HTML, klarer Seitenstruktur und technischer SEO-Grundlage im vereinbarten Umfang.'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${schemaBase}/#webpage`,
    name: 'Website erstellen lassen in Berlin',
    description: `Komplett Webdesign plant und entwickelt individuelle Websites für kleine Unternehmen in Berlin. Technische SEO-Grundlagen, ${homePackagesPriceText} und separate Zusatzleistungen werden transparent abgegrenzt.`,
    url: schemaHomeUrl,
    inLanguage: isEn ? 'en-US' : 'de-DE',
    datePublished: '2024-01-01',
    dateModified: new Date().toISOString().split('T')[0],
    isPartOf: { '@id': schemaWebsiteId },
    about: { '@id': schemaOrgId },
    author: { '@id': schemaPersonId },
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: `${schemaBase}/images/heroBg.webp`,
      width: 1200,
      height: 630
    },
    relatedLink: [
      `${schemaBase}/webdesign-berlin`,
      `${schemaBase}/pakete`,
      `${schemaBase}/leistungen/website-audit`,
      `${schemaBase}/kontakt`
    ],
    breadcrumb: {
      '@type': 'BreadcrumbList',
      itemListElement: [{
        '@type': 'ListItem',
        position: 1,
        name: 'Startseite',
        item: schemaHomeUrl
      }]
    }
  }
].filter(Boolean);
%>
<%- include('partials/head', { structuredDataBlocks, alternateUrls: (typeof alternateUrls !== 'undefined' ? alternateUrls : null) }) %>
<style>
  .linkColor {
    color: #d75b36;
  }

  .primaryColor {
    color: var(--color-primary);
  }

  .card-back a.btn {
    position: relative;
    bottom: 60px;
  }

  .heroImage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .heroImage {
    position: absolute;
    width: 100%;
    z-index: -5;
    height: 1026px;
  }

  .hero-content.home-hero-sequence {
    overflow: hidden;
  }

  .hero-main .home-hero-reveal.animate-on-scroll {
    opacity: 0;
    transform: translate3d(0, 28px, 0);
    transition:
      opacity 0.68s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.68s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--home-hero-reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .hero-main .home-hero-reveal.animate-on-scroll.visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .hero-main .home-hero-reveal.animate-on-scroll.out {
    opacity: 0;
    transform: translate3d(0, 20px, 0);
  }

  .home-hero-reveal--h1 {
    --home-hero-reveal-delay: 0ms;
  }

  .home-hero-reveal--support {
    --home-hero-reveal-delay: 180ms;
  }

  .home-hero-reveal--actions {
    --home-hero-reveal-delay: 620ms;
  }

  .home-hero-reveal--prices {
    --home-hero-reveal-delay: 720ms;
  }

  .hero-main .home-hero-reveal--support.animate-on-scroll,
  .hero-main .home-hero-bullets .home-hero-reveal.animate-on-scroll {
    transform: translate3d(-18px, 18px, 0);
  }

  .hero-main .home-hero-reveal--support.animate-on-scroll.visible,
  .hero-main .home-hero-bullets .home-hero-reveal.animate-on-scroll.visible {
    transform: translate3d(0, 0, 0);
  }

  .home-hero-bullets {
    display: grid;
    gap: 0.35rem;
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .home-hero-bullets li {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
  }

  .home-hero-bullets li:nth-child(1) {
    --home-hero-reveal-delay: 300ms;
  }

  .home-hero-bullets li:nth-child(2) {
    --home-hero-reveal-delay: 390ms;
  }

  .home-hero-bullets li:nth-child(3) {
    --home-hero-reveal-delay: 480ms;
  }

  .home-hero-bullets img {
    flex: 0 0 auto;
    margin-top: 0.05rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-main .home-hero-reveal.animate-on-scroll {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  .review-card {
    align-items: center;
    display: flex;
    grid-template-columns: 1fr 2fr;
    height: 100%;
    justify-items: center;
    margin-top: -50px;
    padding: 1.5rem;
    text-align: center;
    flex-direction: column;
  }

  .badge {
    transition: all 0.2s ease;
  }

  .badge:hover {
    transform: scale(1.02) translateY(-2px);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  .service-list {
    margin-top: 1rem;
  }

  @media (max-width: 400px) {
    .hero-section {
      padding: 0px;
    }
  }

  @media (max-width: 768px) {
    .scroll-snap-align {
      scroll-snap-align: start;
    }

    .scroll-snap-container {
      scroll-snap-type: x mandatory;
      flex-wrap: nowrap;
      overflow-y: auto;
    }

    .heroImage {
      height: 1200px;
    }
  }

  @media (max-width: 1050px) {
    .latest-blog article h4 a {
      color: var(--color-primary);
      font-family: var(--font-heading);
      font-size: 1rem;
    }

    .home-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Trust-Sektion ---------- */
  .trust-summary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin: 1.5rem 0 2rem;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.05);
  }

  .trust-summary-score {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .trust-score-value {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  .trust-score-stars i,
  .trust-review-stars i {
    color: #f5b301;
    margin-right: 1px;
  }

  .trust-summary-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 0.95rem;
  }

  .trust-reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .trust-review-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.04);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .trust-review-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }

  .trust-review-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .trust-review-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .trust-review-avatar--initials,
  .review-avatar--initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.5px;
    font-family: "Poppins", "Inter", system-ui, -apple-system, sans-serif;
    text-transform: uppercase;
    user-select: none;
  }

  .trust-review-avatar--initials {
    font-size: 1rem;
    line-height: 1;
  }

  .review-avatar--initials {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin: 0 auto 1rem;
    font-size: 1.35rem;
    line-height: 1;
  }

  .trust-review-author {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .trust-review-stars {
    font-size: 0.85rem;
  }

  .trust-review-source {
    margin-left: auto;
    flex-shrink: 0;
    opacity: 0.8;
    color: #0b2f4f;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .trust-review-content {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: #333;
    border-left: 3px solid var(--color-primary);
    padding-left: 0.85rem;
  }

  .trust-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
    justify-content: center;
  }

  .trust-empty {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.65);
    border: 1px dashed rgba(0, 0, 0, 0.15);
    border-radius: 12px;
    text-align: center;
  }

  .trust-empty h3 {
    margin-top: 0;
  }

  /* ---------- FAQ-Sektion ---------- */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.25rem;
  }

  .faq-item {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    padding: 0 1.25rem;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .faq-item[open] {
    border-color: var(--color-primary);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
    font-weight: 600;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: #222;
    cursor: pointer;
    list-style: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    transition: transform 0.2s ease;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 0 1rem;
    color: #444;
    line-height: 1.6;
  }

  .faq-answer p {
    margin: 0;
  }

  .faq-more-help {
    margin-top: 1.5rem;
    color: #555;
  }

  .home-section-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .home-section-lead {
    max-width: 820px;
    color: #444;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .home-usp-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .home-usp-item,
  .home-card,
  .home-note,
  .home-cta-panel {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.04);
  }

  .home-usp-item {
    padding: 1rem;
  }

  .home-usp-item strong,
  .home-usp-item span {
    display: block;
  }

  .home-usp-item span {
    margin-top: 0.35rem;
    color: #555;
    font-size: 0.94rem;
    line-height: 1.45;
  }

  .home-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .home-card {
    padding: 1.2rem;
  }

  .home-card h3 {
    margin-top: 0;
    font-size: 1.18rem;
  }

  .home-card p {
    color: #444;
    line-height: 1.6;
  }

  .home-list {
    display: grid;
    gap: 0.65rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }

  .home-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    color: #333;
    line-height: 1.55;
  }

  .home-list li::before {
    content: "✓";
    flex: 0 0 auto;
    color: var(--color-primary);
    font-weight: 700;
  }

  .home-list--caution li::before {
    content: "•";
  }

  .home-split {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .home-pricing-grid {
    align-items: stretch;
  }

  .home-pricing-card {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .home-pricing-card .p1rem {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
  }

  .home-pricing-card .btn {
    margin-top: auto;
  }

  .home-pricing-card.is-featured {
    border: 2px solid var(--color-primary);
  }

  .home-page .home-price-tag {
    display: inline-flex;
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1;
    align-self: flex-start;
    max-width: calc(100% - 2rem);
    margin-bottom: 0;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    background: rgba(215, 91, 54, 0.1);
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.82rem;
  }

  .home-note {
    margin-top: 1.25rem;
    padding: 1rem;
    color: #444;
    line-height: 1.65;
  }

  .home-tech-grid {
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
  }

  .home-process-list {
    counter-reset: process;
  }

  .home-process-list li::before {
    counter-increment: process;
    content: counter(process);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.85rem;
  }

  .home-cta-panel {
    padding: clamp(1.5rem, 4vw, 3rem);
    text-align: center;
  }

  .home-cta-panel p {
    max-width: 720px;
    margin: 0.75rem auto 1.25rem;
    color: #444;
    line-height: 1.7;
  }

  .home-muted {
    color: #555;
    font-size: 0.95rem;
  }

  @media (max-width: 600px) {
    .trust-summary {
      flex-direction: column;
      align-items: flex-start;
    }

    .trust-summary-score {
      flex-direction: row;
      align-items: baseline;
      gap: 0.75rem;
    }

    .trust-review-content {
      font-size: 0.9rem;
    }

    .faq-question {
      font-size: 0.98rem;
    }

    .home-usp-strip,
    .home-split,
    .home-tech-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Startseite: visuelle Überarbeitung nach Phase 3 ---------- */
  .home-page {
    --home-ink: #0b2a46;
    --home-muted: #526173;
    --home-line: rgba(11, 42, 70, 0.14);
    --home-soft: #f4f7fb;
    --home-warm: #fff4ee;
    --home-accent: #e94a1b;
    --home-accent-dark: #b93618;
    background: #f7fafc;
    color: var(--home-ink);
    overflow-x: hidden;
