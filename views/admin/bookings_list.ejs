<%- include('../partials/admin_header') %>

<h1>Buchungen</h1>

<table class="table admin-bookings-table">
  <thead>
    <tr>
      <th>Termin</th><th>Name</th><th>E-Mail</th><th>Sprache</th><th>Status</th><th>Aktion</th>
    </tr>
  </thead>
  <tbody>
  <% bookings.forEach(b => { %>
    <tr>
      <td>
        <% if (b.appointment_title === 'Ohne Termin') { %>
          Ohne Termin
        <% } else { %>
          <%= new Date(b.start_time)
                .toLocaleString('de-DE',{ weekday:'short', day:'2-digit',
                                          month:'2-digit', hour:'2-digit',
                                          minute:'2-digit' }) %>
        <% } %>
      </td>
      <td><%= b.name %></td>
      <td><%= b.email %></td>
      <td><%= b.booking_locale || 'de' %></td>
      <td><%= b.status %></td>
      <td>
        <% if (b.status === 'pending') { %>
          <form method="POST"
                action="/admin/bookings/<%= b.id %>/confirm"
                class="admin-inline-form">
            <button class="btn">Bestätigen</button>
          </form>
        <% } %>
        <% if (b.status !== 'cancelled') { %>
          <form method="POST"
                action="/admin/bookings/<%= b.id %>/cancel"
                class="admin-inline-form">
            <button class="btn admin-btn-alt">Stornieren</button>
          </form>
        <% } %>
      </td>
    </tr>
  <% }) %>
  </tbody>
</table>

<% include('../partials/admin_footer') %>
