<%- include('../../partials/admin_header') %>
<%
  const safeJobs = Array.isArray(jobs) ? jobs : [];
  const csrf = typeof csrfToken !== 'undefined' ? csrfToken : '';
%>
<div class="content-agent-page">
  <header class="content-agent-pagehead"><div><p class="content-agent-eyebrow">Nachvollziehbarkeit</p><h1 class="admin-page-title mb-1"><i class="fa-solid fa-list-check" aria-hidden="true"></i> Jobs &amp; Protokolle</h1><p class="content-agent-lead">Bereinigte Abläufe, Kosten und sichere Fortsetzung auf einen Blick.</p></div></header>
  <%- include('_tabs', { activeTab: 'jobs' }) %>
  <% if (typeof providerRecoveryQueued !== 'undefined' && providerRecoveryQueued === true) { %><div class="alert alert-success" role="status"><i class="fa-solid fa-circle-check" aria-hidden="true"></i> Die Wiederholung wurde sicher eingeplant. Der Worker setzt denselben Job an der betroffenen Stufe fort.</div><% } %>
  <% if (typeof editorialReviewRecoveryQueued !== 'undefined' && editorialReviewRecoveryQueued === true) { %><div class="alert alert-success" role="status"><i class="fa-solid fa-circle-check" aria-hidden="true"></i> Die redaktionelle Neuprüfung wurde eingeplant. Artikel und technische Validierung bleiben unverändert.</div><% } %>
  <% if (typeof draftPersistenceRecoveryQueued !== 'undefined' && draftPersistenceRecoveryQueued === true) { %><div class="alert alert-success" role="status"><i class="fa-solid fa-circle-check" aria-hidden="true"></i> Die Entwurfsfertigstellung wurde eingeplant. Der Worker verwendet alle bestandenen Text- und Prüfstufen erneut.</div><% } %>
  <section class="content-agent-panel" aria-labelledby="job-list-heading">
    <div class="content-agent-panel__head"><div><p class="content-agent-eyebrow">Letzte Aktivitäten</p><h2 id="job-list-heading"><%= safeJobs.length %> Jobs</h2></div><span class="content-agent-readonly"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> Protokolle bereinigt</span></div>
    <% if (!safeJobs.length) { %><div class="content-agent-empty"><i class="fa-solid fa-list-check" aria-hidden="true"></i><div><strong>Noch keine Jobs</strong><p>Geplante und manuelle Läufe erscheinen nach ihrer Anlage hier.</p></div></div><% } else { %>
      <div class="content-agent-job-list">
        <% safeJobs.forEach((job) => { const retryable = job.canRetry === true; const providerRecoverable = job.canRecoverProvider === true; const rejectedProviderRecoverable = job.canRecoverRejectedProvider === true; const qualityGateRecoverable = job.canRecoverQualityGate === true; const qualityGateManifestRecoverable = job.canRecoverQualityGateManifest === true; const editorialReviewRecoverable = job.canRecoverEditorialReview === true; const draftPersistenceRecoverable = job.canRecoverDraftPersistence === true; %>
          <article class="content-agent-job <%= retryable || providerRecoverable || rejectedProviderRecoverable || qualityGateRecoverable || qualityGateManifestRecoverable || editorialReviewRecoverable || draftPersistenceRecoverable ? 'is-warning' : '' %>">
            <div class="content-agent-job__status"><span class="content-agent-status-dot <%= job.status === 'completed' ? 'is-online' : retryable || providerRecoverable || rejectedProviderRecoverable || qualityGateRecoverable || qualityGateManifestRecoverable || editorialReviewRecoverable || draftPersistenceRecoverable ? 'is-error' : 'is-neutral' %>" aria-hidden="true"></span><div><span class="content-agent-eyebrow">Job #<%= job.id %></span><strong><%= job.statusLabel %></strong></div></div>
            <dl class="content-agent-job__facts"><div><dt>Typ</dt><dd><%= job.jobType %></dd></div><div><dt>Letzte sichere Stufe</dt><dd><%= job.lastSafeStageLabel %></dd></div><div><dt>Versuche</dt><dd><%= job.attempts %> / <%= job.maxAttempts %></dd></div><div><dt>Kosten</dt><dd><%= Number(job.costEur || 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> €</dd></div></dl>
            <% if (job.lastError) { %><p class="content-agent-job__error"><i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i><span><strong>Fehlerursache</strong><%= job.lastError %></span></p><% } %>
            <div class="content-agent-job__action">
              <% if (job.contentUrl && job.contentActionLabel) { %><a class="btn btn-sm btn-outline-secondary" href="<%= job.contentUrl %>"><%= job.contentActionLabel %></a><% } %>
              <% if (retryable) { %><form method="post" action="/admin/content-agent/jobs/<%= job.id %>/retry" data-confirm="Diesen Job am letzten sicheren Schritt fortsetzen?"><input type="hidden" name="_csrf" value="<%= csrf %>"><button type="submit" class="btn btn-sm btn-primary"><i class="fa-solid fa-rotate-right" aria-hidden="true"></i> Job fortsetzen</button></form><% } %>
              <% if (providerRecoverable) { %><div class="content-agent-provider-recovery"><div class="alert alert-warning mb-2" role="alert"><strong>Mögliche doppelte Providerkosten:</strong> Der frühere OpenAI-Aufruf könnte bereits berechnet worden sein. Die erneute Ausführung kann zusätzliche OpenAI-Kosten verursachen.</div><form method="post" action="/admin/content-agent/jobs/<%= job.id %>/recover-provider" data-confirm="Der frühere OpenAI-Aufruf könnte bereits berechnet worden sein. Reservierung wirklich verwerfen und diese Stufe kostenpflichtig erneut ausführen?"><input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="confirmed" value="true"><button type="submit" class="btn btn-sm btn-warning"><i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i> <%= job.providerRecoveryActionLabel %></button></form></div><% } %>
              <% if (rejectedProviderRecoverable) { %><div class="content-agent-provider-recovery"><div class="alert alert-info mb-2" role="status"><strong>Sicher vorab abgelehnt:</strong> OpenAI hat diese Stufe vor der kostenpflichtigen Ausführung abgelehnt; es besteht keine unklare Doppelberechnung. Die nächste reguläre Artikelerstellung verursacht die üblichen OpenAI-Kosten.</div><form method="post" action="/admin/content-agent/jobs/<%= job.id %>/recover-rejected-provider" data-confirm="Die korrigierte <%= job.rejectedProviderRecoveryStageLabel %> jetzt regulär und kostenpflichtig ausführen?"><input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="confirmed" value="true"><button type="submit" class="btn btn-sm btn-primary"><i class="fa-solid fa-rotate-right" aria-hidden="true"></i> <%= job.rejectedProviderRecoveryActionLabel %></button></form></div><% } %>
              <% if (qualityGateRecoverable) { const editorialQualityRecovery = job.qualityGateRecoveryKind === 'editorial'; %><div class="content-agent-provider-recovery"><div class="alert alert-info mb-2" role="status"><strong>Vorhandenen Artikel bewahren:</strong> <% if (editorialQualityRecovery) { %>Der vorhandene Artikel und alle bisherigen Recherchen bleiben erhalten. Nur eine zusätzliche redaktionelle Reparatur des Quellenbezugs und die anschließende Prüfung verursachen reguläre OpenAI-Kosten.<% } else { %>Themenrecherche, SEO-Briefing und Artikel bleiben erhalten. Nur die gezielte dritte Strukturreparatur und die anschließende Prüfung verursachen reguläre OpenAI-Kosten.<% } %></div><form method="post" action="/admin/content-agent/jobs/<%= job.id %>/recover-quality-gate" data-confirm="<%= editorialQualityRecovery ? 'Den vorhandenen Artikel mit einer zusätzlichen kostenpflichtigen Quellenreparatur erneut prüfen?' : 'Den vorhandenen Artikel mit einer zusätzlichen kostenpflichtigen HTML-Strukturreparatur erneut prüfen?' %>"><input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="confirmed" value="true"><button type="submit" class="btn btn-sm btn-primary"><i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i> <%= job.qualityGateRecoveryActionLabel %></button></form></div><% } %>
              <% if (qualityGateManifestRecoverable) { %><div class="content-agent-provider-recovery"><div class="alert alert-info mb-2" role="status"><strong>Regelstand kontrolliert übernehmen:</strong> Der abgebrochene Versuch hat keinen OpenAI-Aufruf ausgelöst. Themenrecherche, SEO-Briefing und Artikel bleiben erhalten. Nur die nächste Strukturreparatur und Prüfung verursachen reguläre OpenAI-Kosten.</div><form method="post" action="/admin/content-agent/jobs/<%= job.id %>/recover-rule-manifest" data-confirm="Den aktuellen signierten Regelstand übernehmen und die kostenpflichtige Strukturreparatur fortsetzen?"><input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="confirmed" value="true"><button type="submit" class="btn btn-sm btn-primary"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> <%= job.qualityGateManifestRecoveryActionLabel %></button></form></div><% } %>
              <% if (editorialReviewRecoverable) { const policyRecheck = job.editorialReviewRecoveryKind === 'policy_recheck'; %><div class="content-agent-provider-recovery"><div class="alert alert-info mb-2" role="status"><strong><%= policyRecheck ? 'Gespeicherten Review neu bewerten:' : 'Technische Prüfung bestanden:' %></strong> <% if (policyRecheck) { %>Artikel, Quellenreparatur und der bereits bezahlte Review bleiben erhalten. Die widersprüchlichen nicht blockierenden Hinweise werden nur mit der aktuellen deterministischen Prüfregel neu bewertet; es erfolgt kein neuer OpenAI-Aufruf.<% } else { %>Artikel und bestandene technische Validierung bleiben unverändert. Es wird nur eine neue redaktionelle OpenAI-Prüfung mit der korrigierten Aufgabenverteilung ausgeführt. Dafür entstehen die üblichen geringen Reviewkosten.<% } %></div><% if (Array.isArray(job.qualityIssues) && job.qualityIssues.length > 0) { %><ul class="mb-2"><% job.qualityIssues.forEach((issue) => { %><li><%= issue %></li><% }) %></ul><% } %><form method="post" action="/admin/content-agent/jobs/<%= job.id %>/recover-editorial-review" data-confirm="<%= policyRecheck ? 'Den bereits bezahlten Review ohne neuen OpenAI-Aufruf mit der aktuellen Prüfregel neu bewerten?' : 'Die vorhandene validierte Artikelfassung unverändert lassen und nur die redaktionelle Prüfung kostenpflichtig neu ausführen?' %>"><input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="confirmed" value="true"><button type="submit" class="btn btn-sm btn-primary"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i> <%= job.editorialReviewRecoveryActionLabel %></button></form></div><% } %>
              <% if (draftPersistenceRecoverable) { %><div class="content-agent-provider-recovery"><div class="alert alert-info mb-2" role="status"><strong>Inhalte und Prüfungen bewahren:</strong> SEO-Briefing, Artikel und Prüfungen bleiben unverändert. Das nach dem Datenbank-Rollback gelöschte Bild muss neu generiert werden; dadurch entstehen einmalig zusätzliche Bildkosten.</div><form method="post" action="/admin/content-agent/jobs/<%= job.id %>/recover-draft-persistence" data-confirm="Alle bestandenen Text- und Prüfstufen unverändert lassen, ein neues Bild kostenpflichtig erzeugen und den Entwurf fertigstellen?"><input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="confirmed" value="true"><button type="submit" class="btn btn-sm btn-primary"><i class="fa-solid fa-image" aria-hidden="true"></i> <%= job.draftPersistenceRecoveryActionLabel %></button></form></div><% } %>
              <% if (job.isAdminReviewNotification && !retryable) { %><span class="content-agent-readonly"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> Mailretry nur am Entwurf</span><% } %>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>
<script src="<%= typeof jsAsset === 'function' ? jsAsset('js/admin-content-agent.js') : '/js/admin-content-agent.js' %>" defer></script>
<%- include('../../partials/admin_footer') %>
