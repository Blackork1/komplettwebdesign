<%- include('../../partials/admin_header') %>
<%
  const safeDrafts = Array.isArray(drafts) ? drafts : [];
  const activeStatus = typeof status !== 'undefined'
    && ['review', 'approved', 'missed', 'published'].includes(status) ? status : 'review';
  const csrf = typeof csrfToken !== 'undefined' ? csrfToken : '';
%>

<div class="content-agent-page">
  <header class="content-agent-pagehead">
    <div><p class="content-agent-eyebrow">Redaktion</p><h1 class="admin-page-title mb-1"><i class="fa-solid fa-file-circle-check" aria-hidden="true"></i> Entwürfe</h1><p class="content-agent-lead"><%= safeDrafts.length %> <%= safeDrafts.length === 1 ? 'Eintrag' : 'Einträge' %> im gewählten Status</p></div>
    <a href="/admin/content-agent/existing-content" class="btn btn-outline-secondary"><i class="fa-solid fa-box-archive" aria-hidden="true"></i> Bestehende Inhalte</a>
  </header>
  <%- include('_tabs', { activeTab: 'drafts' }) %>

  <nav class="content-agent-filterbar" aria-label="Entwürfe nach Status filtern">
    <a href="/admin/content-agent/drafts?status=review" <%= activeStatus === 'review' ? 'class="is-active" aria-current="page"' : '' %>>Prüfung</a>
    <a href="/admin/content-agent/drafts?status=approved" <%= activeStatus === 'approved' ? 'class="is-active" aria-current="page"' : '' %>>Freigegeben</a>
    <a href="/admin/content-agent/drafts?status=missed" <%= activeStatus === 'missed' ? 'class="is-active" aria-current="page"' : '' %>>Verpasst</a>
    <a href="/admin/content-agent/drafts?status=published" <%= activeStatus === 'published' ? 'class="is-active" aria-current="page"' : '' %>>Veröffentlicht</a>
  </nav>

  <section class="content-agent-panel" aria-labelledby="draft-list-heading">
    <div class="content-agent-panel__head">
      <div><p class="content-agent-eyebrow">Arbeitsvorrat</p><h2 id="draft-list-heading">Redaktionsstatus</h2></div>
      <p class="content-agent-quiet mb-0">Alle Zeitangaben sind exakt in Berliner Ortszeit dargestellt.</p>
    </div>
    <% if (!safeDrafts.length) { %>
      <div class="content-agent-empty"><i class="fa-regular fa-circle-check" aria-hidden="true"></i><div><strong>Alles geprüft</strong><p>Derzeit sind keine KI-Entwürfe offen.</p></div></div>
    <% } else { %>
      <div class="content-agent-draft-grid">
        <% safeDrafts.forEach((draft) => { %>
          <article class="content-agent-draft-card <%= draft.riskBlocked ? 'is-risk' : '' %>">
            <div class="content-agent-draft-card__visual">
              <% if (draft.imageUrl) { %><img src="<%= draft.imageUrl %>" alt="" loading="lazy"><% } else { %><i class="fa-regular fa-image" aria-hidden="true"></i><% } %>
              <span class="content-agent-score <%= Number(draft.qualityScore) >= 90 ? 'is-strong' : '' %>"><%= draft.qualityScore %> Punkte</span>
            </div>
            <div class="content-agent-draft-card__body">
              <div class="content-agent-draft-card__meta"><span><%= draft.contentCluster || '–' %></span><span class="content-agent-review-state is-<%= draft.reviewState %>"><%= draft.reviewStateLabel %></span></div>
              <h2><%= draft.title %></h2>
              <p><%= draft.excerpt || 'Keine Kurzbeschreibung vorhanden.' %></p>
              <dl class="content-agent-draft-facts">
                <div><dt>Veröffentlichungstermin</dt><dd><%= draft.scheduledAtLabel || 'Noch nicht terminiert' %></dd></div>
                <div><dt>Erstellungszeitpunkt</dt><dd><%= draft.generationAtLabel || 'Nicht berechenbar' %></dd></div>
                <% if (draft.publishedAtLabel) { %><div><dt>Veröffentlicht am</dt><dd><%= draft.publishedAtLabel %></dd></div><% } %>
                <div><dt>Reviewversion</dt><dd><%= draft.reviewVersion || '–' %></dd></div>
                <div><dt>Freigabeversion</dt><dd><%= draft.approvalVersion || 'Noch nicht freigegeben' %></dd></div>
                <div><dt>Publikationsversion</dt><dd><%= draft.publicationVersion || '–' %></dd></div>
              </dl>
              <section class="content-agent-mail-state" aria-label="Status der Admin-Benachrichtigung">
                <div class="content-agent-mail-state__head"><strong><i class="fa-regular fa-envelope" aria-hidden="true"></i> <%= draft.notification?.statusLabel || 'Noch nicht versendet' %></strong><span><%= draft.notification?.attempts || 0 %> / 6 Versuche</span></div>
                <dl>
                  <div><dt>Letzter Mailversuch</dt><dd><%= draft.notification?.lastAttemptAtLabel || 'Noch kein Versuch' %></dd></div>
                  <% if (draft.notification?.lastErrorCode) { %><div><dt>Fehlercode</dt><dd><code><%= draft.notification.lastErrorCode %></code></dd></div><% } %>
                </dl>
                <% if (draft.notification?.canRetry === true) { %>
                  <form method="post" action="/admin/content-agent/drafts/<%= draft.id %>/notification/retry" data-confirm="Admin-Benachrichtigung wirklich erneut senden?">
                    <input type="hidden" name="_csrf" value="<%= csrf %>">
                    <input type="hidden" name="confirmed" value="true">
                    <button type="submit" class="btn btn-sm btn-outline-primary" aria-label="Admin-Benachrichtigung für <%= draft.title %> erneut senden"><i class="fa-solid fa-rotate-right" aria-hidden="true"></i> Mail erneut senden</button>
                  </form>
                <% } %>
              </section>
              <% if (draft.riskBlocked) { %><p class="content-agent-risk"><i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i><span><strong>Review erforderlich</strong><%= draft.riskCount %> konkrete <%= draft.riskCount === 1 ? 'Prüfstelle' : 'Prüfstellen' %></span></p><% } %>
              <div class="content-agent-card-actions">
                <% if (draft.reviewState === 'published') { %>
                  <a class="btn btn-outline-primary" href="/blog/<%= draft.slug %>"><i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i> Artikel öffnen</a>
                <% } else { %>
                  <a class="btn btn-outline-primary" href="/admin/content-agent/drafts/<%= draft.id %>/preview"><i class="fa-regular fa-eye" aria-hidden="true"></i> Vorschau</a><a class="btn btn-primary" href="/admin/content-agent/drafts/<%= draft.id %>/edit"><i class="fa-solid fa-pen" aria-hidden="true"></i> Entwurf prüfen</a>
                <% } %>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>
<script src="<%= typeof jsAsset === 'function' ? jsAsset('js/admin-content-agent.js') : '/js/admin-content-agent.js' %>" defer></script>
<%- include('../../partials/admin_footer') %>
