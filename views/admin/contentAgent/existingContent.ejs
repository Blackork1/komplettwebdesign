<%- include('../../partials/admin_header') %>
<%
  const csrf = typeof csrfToken !== 'undefined' ? csrfToken : '';
  const legacyItems = typeof existingContent !== 'undefined' && Array.isArray(existingContent)
    ? existingContent
    : [];
  const suppliedGroups = typeof existingContentGroups !== 'undefined'
    && existingContentGroups
    && typeof existingContentGroups === 'object'
    ? existingContentGroups
    : null;
  const safeGroups = suppliedGroups || {
    totalCount: legacyItems.length,
    visibleArticles: legacyItems,
    collectingArticles: [],
    zeroImpressionArticles: [],
    hiddenZeroImpressionArticles: []
  };
  const safeVisibilityMessage = typeof visibilityMessage !== 'undefined'
    && typeof visibilityMessage === 'string'
    ? visibilityMessage
    : null;
  const safeLegacyMigrationMessage = typeof legacyMigrationMessage !== 'undefined'
    && typeof legacyMigrationMessage === 'string'
    ? legacyMigrationMessage
    : null;
  const safeLegacyMigrationDashboard = typeof legacyMigrationDashboard !== 'undefined'
    && legacyMigrationDashboard
    && typeof legacyMigrationDashboard === 'object'
    ? legacyMigrationDashboard
    : {
      totalCount: 0,
      readyStaticCount: 0,
      reviewRequiredCount: 0,
      blockedCount: 0,
      migratedCount: 0,
      lastScanLabel: null,
      readyStatic: [],
      reviewRequired: [],
      blocked: [],
      migrated: []
    };
  const groups = [
    {
      key: 'visible',
      heading: 'Artikel mit Sichtbarkeit',
      description: 'Diese Artikel haben im neuesten vollständigen 28-Tage-Zeitraum mindestens eine Google-Impression erhalten.',
      items: Array.isArray(safeGroups.visibleArticles) ? safeGroups.visibleArticles : [],
      open: true,
      emptyText: 'Aktuell liegt kein Artikel mit vollständigen 28-Tage-Daten und Impressionen vor.',
      itemVisibilityAction: null,
      bulkAction: null
    },
    {
      key: 'collecting',
      heading: 'Daten werden gesammelt',
      description: 'Neue Artikel sowie Artikel ohne vollständige oder belastbare 28-Tage-Daten bleiben neutral in dieser Gruppe.',
      items: Array.isArray(safeGroups.collectingArticles) ? safeGroups.collectingArticles : [],
      open: false,
      emptyText: 'Für alle Artikel liegt bereits ein vollständiger, belastbarer 28-Tage-Zeitraum vor.',
      itemVisibilityAction: null,
      bulkAction: null
    },
    {
      key: 'zero',
      heading: '0 Impressionen in 28 Tagen',
      description: 'Diese Artikel hatten in einem vollständigen 28-Tage-Zeitraum keine Google-Impressionen und können gezielt bearbeitet oder administrativ ausgeblendet werden.',
      items: Array.isArray(safeGroups.zeroImpressionArticles) ? safeGroups.zeroImpressionArticles : [],
      open: false,
      emptyText: 'Aktuell gibt es keinen eingeblendeten Artikel mit null Impressionen.',
      itemVisibilityAction: {
        path: 'hide-zero-impressions',
        label: 'Aus Arbeitsansicht ausblenden',
        confirmation: 'Diesen Artikel nur aus der administrativen Null-Impressions-Arbeitsansicht ausblenden? Der öffentliche Artikel und seine Indexierung bleiben unverändert.'
      },
      bulkAction: {
        url: '/admin/content-agent/existing-content/zero-impressions/hide-all',
        label: 'Alle qualifizierten Artikel ausblenden',
        confirmation: 'Alle aktuell serverseitig qualifizierten Null-Impressions-Artikel aus der administrativen Arbeitsansicht ausblenden? Öffentliche Artikel und Indexierung bleiben unverändert.'
      }
    },
    {
      key: 'hidden',
      heading: 'Ausgeblendete Artikel',
      description: 'Diese Einträge sind ausschließlich in der administrativen Null-Impressions-Arbeitsansicht ausgeblendet.',
      items: Array.isArray(safeGroups.hiddenZeroImpressionArticles)
        ? safeGroups.hiddenZeroImpressionArticles
        : [],
      open: false,
      emptyText: 'Es sind keine Null-Impressions-Artikel administrativ ausgeblendet.',
      itemVisibilityAction: {
        path: 'show-zero-impressions',
        label: 'Wieder einblenden',
        confirmation: 'Diesen Artikel wieder in der administrativen Null-Impressions-Arbeitsansicht anzeigen?'
      },
      bulkAction: {
        url: '/admin/content-agent/existing-content/zero-impressions/show-all',
        label: 'Alle wieder einblenden',
        confirmation: 'Alle administrativ ausgeblendeten Null-Impressions-Artikel wieder einblenden?'
      }
    }
  ];
%>
<div class="content-agent-page">
  <header class="content-agent-pagehead">
    <div>
      <p class="content-agent-eyebrow">Bestandsprüfung</p>
      <h1 class="admin-page-title mb-1"><i class="fa-solid fa-box-archive" aria-hidden="true"></i> Bestehende Inhalte</h1>
      <p class="content-agent-lead">Veröffentlichte Artikel anhand vollständiger Search-Console-Daten priorisieren und als getrennte Revision optimieren.</p>
    </div>
    <form method="post" action="/admin/content-agent/existing-content/audit" data-confirm="Bestehende Inhalte jetzt prüfen? Dabei wird kein veröffentlichter Artikel verändert.">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <button type="submit" class="btn btn-primary"><i class="fa-solid fa-magnifying-glass-chart" aria-hidden="true"></i> Bestehende Inhalte prüfen</button>
    </form>
  </header>

  <%- include('_tabs', { activeTab: 'drafts' }) %>
  <div class="content-agent-subnav"><a href="/admin/content-agent/drafts">KI-Entwürfe</a><a class="is-active" href="/admin/content-agent/existing-content" aria-current="page">Bestehende Inhalte</a></div>

  <div class="content-agent-notice">
    <i class="fa-solid fa-lock" aria-hidden="true"></i>
    <div><strong>Liveinhalte bleiben geschützt</strong><p>Ein- und Ausblenden verändert ausschließlich diese Adminübersicht. Öffentliche Artikel, Sitemap, Canonical und Indexierung bleiben unverändert.</p></div>
  </div>

  <% if (safeVisibilityMessage) { %>
    <div class="content-agent-notice is-success" role="status">
      <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
      <div><strong>Ansicht aktualisiert</strong><p><%= safeVisibilityMessage %></p></div>
    </div>
  <% } %>

  <% if (safeLegacyMigrationMessage) { %>
    <div class="content-agent-notice is-success" role="status">
      <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
      <div>
        <strong>Legacy-Migration aktualisiert</strong>
        <p><%= safeLegacyMigrationMessage %></p>
      </div>
    </div>
  <% } %>

  <%- include('_legacyMigrationDashboard', {
    dashboard: safeLegacyMigrationDashboard,
    csrf
  }) %>

  <section class="content-agent-panel" aria-labelledby="stock-heading">
    <div class="content-agent-panel__head">
      <div>
        <p class="content-agent-eyebrow">Inventar</p>
        <h2 id="stock-heading"><%= Number(safeGroups.totalCount) || 0 %> <%= Number(safeGroups.totalCount) === 1 ? 'veröffentlichter Inhalt' : 'veröffentlichte Inhalte' %></h2>
      </div>
    </div>
    <div class="content-existing-groups">
      <% groups.forEach((group) => { %>
        <%- include('_existingContentGroup', { group, csrf }) %>
      <% }) %>
    </div>
  </section>
</div>
<script src="<%= typeof jsAsset === 'function' ? jsAsset('js/admin-content-agent.js') : '/js/admin-content-agent.js' %>" defer></script>
<script src="<%= typeof jsAsset === 'function' ? jsAsset('js/admin-existing-content-optimization.js') : '/js/admin-existing-content-optimization.js' %>" defer></script>
<%- include('../../partials/admin_footer') %>
