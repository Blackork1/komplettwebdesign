<%
  const safeDashboard = dashboard || {};
  const safeSettings = typeof settings !== 'undefined' && settings ? settings : {};
  const budgetUsed = Number(safeDashboard.budget?.usedEur || 0);
  const budgetLimit = Number(safeDashboard.budget?.limitEur || 0);
  const budgetPercent = budgetLimit > 0 ? Math.min(100, Math.max(0, (budgetUsed / budgetLimit) * 100)) : 0;
  const nextGenerationLabel = safeDashboard.schedule?.nextGenerationLabel || 'Noch nicht berechnet';
  const nextPublicationLabel = safeDashboard.schedule?.nextPublicationLabel || 'Noch nicht berechnet';
  const openDrafts = Array.isArray(safeDashboard.drafts) ? safeDashboard.drafts.length : 0;
  const blockedDrafts = Array.isArray(safeDashboard.drafts)
    ? safeDashboard.drafts.filter((draft) => draft.riskBlocked).length
    : 0;
%>
<section class="content-agent-metrics" aria-label="Betriebskennzahlen">
  <article class="content-agent-metric">
    <div class="content-agent-metric__icon content-agent-status--neutral" aria-hidden="true">
      <i class="fa-solid fa-shield-halved"></i>
    </div>
    <div>
      <p class="content-agent-metric__label">Modus</p>
      <p class="content-agent-metric__value"><%= safeDashboard.modeLabel || 'Unbekannt' %></p>
      <p class="content-agent-metric__detail"><%= safeSettings.agent_enabled ? 'Agent ist aktiviert' : 'Agent ist pausiert' %></p>
    </div>
  </article>

  <article class="content-agent-metric">
    <div class="content-agent-metric__icon content-agent-status--info" aria-hidden="true">
      <i class="fa-regular fa-clock"></i>
    </div>
    <div>
      <p class="content-agent-metric__label">Nächste Erstellung</p>
      <p class="content-agent-metric__value"><%= nextGenerationLabel %></p>
      <p class="content-agent-metric__detail">Veröffentlichung: <%= nextPublicationLabel %></p>
    </div>
  </article>

  <article class="content-agent-metric">
    <div class="content-agent-metric__icon <%= budgetPercent >= 90 ? 'content-agent-status--warning' : 'content-agent-status--success' %>" aria-hidden="true">
      <i class="fa-solid fa-wallet"></i>
    </div>
    <div class="content-agent-metric__body">
      <p class="content-agent-metric__label">Monatsbudget</p>
      <p class="content-agent-metric__value"><%= budgetUsed.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> / <%= budgetLimit.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> €</p>
      <div class="content-agent-progress" role="progressbar" aria-label="Verbrauchtes Monatsbudget" aria-valuenow="<%= Math.round(budgetPercent) %>" aria-valuemin="0" aria-valuemax="100">
        <span style="width: <%= budgetPercent.toFixed(1) %>%"></span>
      </div>
    </div>
  </article>

  <article class="content-agent-metric">
    <div class="content-agent-metric__icon <%= blockedDrafts > 0 ? 'content-agent-status--warning' : 'content-agent-status--success' %>" aria-hidden="true">
      <i class="fa-solid fa-clipboard-check"></i>
    </div>
    <div>
      <p class="content-agent-metric__label">Offene Prüfung</p>
      <p class="content-agent-metric__value"><%= openDrafts %> <%= openDrafts === 1 ? 'Entwurf' : 'Entwürfe' %></p>
      <p class="content-agent-metric__detail"><%= blockedDrafts %> mit Risikohinweis</p>
    </div>
  </article>
</section>
