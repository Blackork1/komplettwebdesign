<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <title>Seitenverwaltung</title>
  <link rel="stylesheet" href="<%= cssAsset('styles.css') %>">
</head>

<body>
  <%- include('../partials/admin_header') %> <!-- optional -->

    <h1>Seitenverwaltung</h1>
    <p><a href="/admin/pages/new">+ Neue Seite erstellen</a></p>
    <table class="pages-table">
      <tr>
        <th class="admin-table-th-spacious">ID</th>
        <th class="admin-table-th-spacious">Titel</th>
        <th class="admin-table-th-spacious">Slug</th>
        <th class="admin-table-th-spacious">Aktionen</th>
      </tr>
      <% pages.forEach(page=> { %>
        <tr>
          <td>
            <%= page.id %>
          </td>
          <td>
            <%= page.title %>
          </td>
          <td>
            <%= page.slug %>
          </td>
          <td>
            <a href="/admin/pages/<%= page.id %>/edit">Bearbeiten</a>
            <form action="/admin/pages/<%= page.id %>/delete" method="post" class="admin-inline-form" onsubmit="return confirm('Seite wirklich löschen?');">
              <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
              <button type="submit" class="link-button admin-link-button">Löschen</button>
            </form>
          </td>
        </tr>
        <% }) %>
    </table>
</body>

</html>
