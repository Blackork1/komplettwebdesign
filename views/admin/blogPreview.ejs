<%- include('../partials/admin_header') %>

<div class="container my-5">
  <div class="alert alert-warning" role="status">
    Geschützte Entwurfsvorschau – dieser Beitrag ist nicht öffentlich sichtbar.
  </div>
  <article>
    <h1 class="mb-4"><%= post.title %></h1>
    <div class="blog-content"><%- renderedContent %></div>
