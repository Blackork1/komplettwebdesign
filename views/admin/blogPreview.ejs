  <a href="/admin/blog/<%= post.id %>/edit" class="btn btn-primary mt-4">Entwurf bearbeiten</a>
  <a href="/admin/blog" class="btn btn-secondary mt-4">Zur Übersicht</a>
</div>

<%- include('../partials/admin_footer') %>
