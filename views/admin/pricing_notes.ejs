<%- include('../partials/admin_header') %>

<%
  const checked = (value) => value ? 'checked' : '';
%>

<h1 class="admin-page-title">
  <i class="fa-solid fa-circle-info"></i> Globale Hinweise
</h1>

<div class="admin-card mb-4 border-warning">
  <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
    <div>
      <h2 class="h5 mb-1">Diese Hinweise erscheinen öffentlich</h2>
      <p class="mb-0 text-muted">Bitte Formulierungen zu § 19 UStG, laufenden Kosten, Drittanbietern, Rechtsberatung, Ranking-Garantien, Feedbackrunden und Livegang vorsichtig prüfen.</p>
    </div>
    <a class="btn btn-outline-secondary" href="/admin/pricing/packages">Zur Paketliste</a>
  </div>
</div>

<% (notes || []).forEach((note) => { %>
  <% const isAddOnsTickerDuration = note.note_key === 'addons_ticker_duration_seconds'; %>
  <form method="POST" action="/admin/pricing/notes/<%= note.id %>" class="admin-card mb-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
    <h2 class="h5"><%= note.title || note.note_key %></h2>
    <div class="row g-3">
      <div class="col-md-3">
        <label class="form-label" for="note_key_<%= note.id %>">Hinweis-Key</label>
        <input id="note_key_<%= note.id %>" name="note_key" class="form-control" value="<%= note.note_key || '' %>" required>
      </div>
      <div class="col-md-3">
        <label class="form-label" for="note_title_<%= note.id %>">Titel</label>
        <input id="note_title_<%= note.id %>" name="title" class="form-control" value="<%= note.title || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label" for="note_context_<%= note.id %>">Kontext</label>
        <input id="note_context_<%= note.id %>" name="context" class="form-control" value="<%= note.context || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label" for="note_sort_<%= note.id %>">Sortierung</label>
        <input id="note_sort_<%= note.id %>" name="sort_order" type="number" class="form-control" value="<%= note.sort_order ?? 0 %>">
      </div>
      <div class="col-12">
        <% if (isAddOnsTickerDuration) { %>
          <label class="form-label" for="note_body_<%= note.id %>">Laufzeit in Sekunden</label>
          <input id="note_body_<%= note.id %>" name="body" type="number" min="8" max="180" step="1" class="form-control" value="<%= note.body || '35' %>" required>
          <div class="form-text">Steuert die Laufzeit des Zusatzleistungs-Banners auf den Paketunterseiten. Kleiner = schneller, größer = langsamer.</div>
        <% } else { %>
          <label class="form-label" for="note_body_<%= note.id %>">Text</label>
          <textarea id="note_body_<%= note.id %>" name="body" class="form-control" rows="4" required><%= note.body || '' %></textarea>
        <% } %>
      </div>
      <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
        <label class="form-check mb-0"><input class="form-check-input" name="is_active" type="checkbox" <%= checked(note.is_active) %>> aktiv</label>
        <button class="btn btn-primary" type="submit">Hinweis speichern</button>
      </div>
    </div>
  </form>
<% }) %>

<%- include('../partials/admin_footer') %>
