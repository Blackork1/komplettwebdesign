<%- include('../partials/admin_header') %>

<div class="container my-4">
  <h1 class="mb-3">Website-Tester Admin</h1>

  <% if (query && query.saved === '1') { %>
    <div class="alert alert-success" role="status">
      Einstellungen gespeichert.
    </div>
  <% } %>

  <% if (query && query.lead_action === 'doi_resent') { %>
    <div class="alert alert-success" role="status">
      Bestätigungslink wurde erneut versendet.
    </div>
  <% } %>

  <% if (query && query.lead_action === 'report_resent') { %>
    <div class="alert alert-success" role="status">
      PDF-Report wurde erneut versendet.
    </div>
  <% } %>

  <% if (query && query.lead_error) { %>
    <div class="alert alert-danger" role="alert">
      <%= query.lead_error %>
    </div>
  <% } %>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Crawler-Einstellung</h2>
      <p class="text-muted mb-3">
        Lege fest, wie viele Unterseiten beim Deep-Audit zusätzlich zur Startseite analysiert werden.
      </p>
      <form action="/admin/website-tester/config" method="POST" class="row g-2 align-items-end">
        <div class="col-sm-4 col-md-3">
          <label class="form-label" for="max_subpages">Unterseiten (1-20)</label>
          <input
            id="max_subpages"
            class="form-control"
            type="number"
            name="max_subpages"
            min="1"
            max="20"
            value="<%= config?.maxSubpages ?? 5 %>"
            required
          >
        </div>
        <div class="col-sm-auto">
          <button class="btn btn-primary" type="submit">Speichern</button>
        </div>
      </form>
      <small class="text-muted d-block mt-2">
        Aktueller Wert: <strong><%= config?.maxSubpages ?? 5 %></strong> Unterseiten + 1 Startseite.
      </small>
    </div>
  </div>

  <% 
    const currentParams = new URLSearchParams();
    Object.entries(query || {}).forEach(([key, value]) => {
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        currentParams.set(key, String(value));
      }
    });
    const returnTo = `/admin/website-tester${currentParams.toString() ? `?${currentParams.toString()}` : ''}`;
  %>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Audit-Anfrage-Archiv</h2>

      <form method="GET" action="/admin/website-tester" class="row g-2 mb-3">
        <div class="col-md-5">
          <input
            class="form-control"
            type="text"
            name="q"
            value="<%= filters?.q || '' %>"
            placeholder="Suche nach URL oder Final-URL"
          >
        </div>
        <div class="col-md-3">
          <select class="form-select" name="status">
            <option value="" <%= !filters?.status ? 'selected' : '' %>>Alle Status</option>
            <option value="success" <%= filters?.status === 'success' ? 'selected' : '' %>>Erfolg</option>
            <option value="error" <%= filters?.status === 'error' ? 'selected' : '' %>>Fehler</option>
          </select>
        </div>

        <input type="hidden" name="lead_q" value="<%= filters?.leadQ || '' %>">
        <input type="hidden" name="lead_status" value="<%= filters?.leadStatus || '' %>">
        <input type="hidden" name="lead_locale" value="<%= filters?.leadLocale || '' %>">
        <input type="hidden" name="lead_from" value="<%= filters?.leadFrom || '' %>">
        <input type="hidden" name="lead_to" value="<%= filters?.leadTo || '' %>">

        <div class="col-md-auto">
          <button class="btn btn-outline-primary" type="submit">Filtern</button>
        </div>
      </form>

      <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
          <thead>
            <tr>
              <th>Zeitpunkt</th>
              <th>Status</th>
              <th>URL</th>
              <th>Score</th>
              <th>Crawl</th>
              <th>Top-Baustellen</th>
              <th>Audit-ID</th>
            </tr>
          </thead>
          <tbody>
            <% if (!archive?.rows?.length) { %>
              <tr>
                <td colspan="7" class="text-muted">Keine Einträge gefunden.</td>
              </tr>
            <% } %>
            <% (archive?.rows || []).forEach((row) => { %>
              <tr>
                <td>
                  <%= new Date(row.created_at).toLocaleString('de-DE', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
                <td>
                  <% if (row.status === 'success') { %>
                    <span class="badge text-bg-success">Erfolg</span>
                  <% } else { %>
                    <span class="badge text-bg-danger">Fehler</span>
                  <% } %>
                </td>
                <td style="max-width: 360px;">
                  <div class="small">
                    <strong>Eingabe:</strong><br>
                    <span class="text-break"><%= row.requested_url %></span>
                  </div>
                  <% if (row.final_url) { %>
                    <div class="small mt-1">
                      <strong>Final:</strong><br>
                      <span class="text-break"><%= row.final_url %></span>
                    </div>
                  <% } %>
                  <% if (row.error_message) { %>
                    <div class="small text-danger mt-1 text-break"><%= row.error_message %></div>
                  <% } %>
                </td>
                <td>
                  <% if (row.overall_score === null || row.overall_score === undefined) { %>
                    <span class="text-muted">-</span>
                  <% } else { %>
                    <strong><%= row.overall_score %></strong>
                    <div class="small text-muted"><%= row.score_band || '-' %></div>
                  <% } %>
                </td>
                <td>
                  <span class="small">
                    <%= row.crawl_visited_pages ?? '-' %>/<%= row.crawl_planned_pages ?? '-' %>
                    <% if (row.crawl_failed_pages && row.crawl_failed_pages > 0) { %>
                      <br><span class="text-danger">Fehler: <%= row.crawl_failed_pages %></span>
                    <% } %>
                  </span>
                </td>
                <td style="max-width: 220px;">
                  <span class="small text-break"><%= row.top_issues || '-' %></span>
                </td>
                <td>
                  <span class="small text-break"><%= row.audit_id || '-' %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <%
        const requestPage = archive?.page || 1;
        const requestTotalPages = archive?.totalPages || 1;
        const buildRequestPageUrl = (targetPage) => {
          const params = new URLSearchParams();
          if (filters?.q) params.set('q', filters.q);
          if (filters?.status) params.set('status', filters.status);
          if (filters?.leadQ) params.set('lead_q', filters.leadQ);
          if (filters?.leadStatus) params.set('lead_status', filters.leadStatus);
          if (filters?.leadLocale) params.set('lead_locale', filters.leadLocale);
          if (filters?.leadFrom) params.set('lead_from', filters.leadFrom);
          if (filters?.leadTo) params.set('lead_to', filters.leadTo);
          params.set('req_page', String(targetPage));
          params.set('lead_page', String(leadArchive?.page || 1));
          return `/admin/website-tester?${params.toString()}`;
        };
      %>

      <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="small text-muted">
          Seite <strong><%= requestPage %></strong> von <strong><%= requestTotalPages %></strong> - Gesamt: <strong><%= archive?.total || 0 %></strong>
        </div>
        <div class="btn-group">
          <a class="btn btn-outline-secondary btn-sm <%= requestPage <= 1 ? 'disabled' : '' %>" href="<%= requestPage <= 1 ? '#' : buildRequestPageUrl(requestPage - 1) %>">Zurück</a>
          <a class="btn btn-outline-secondary btn-sm <%= requestPage >= requestTotalPages ? 'disabled' : '' %>" href="<%= requestPage >= requestTotalPages ? '#' : buildRequestPageUrl(requestPage + 1) %>">Weiter</a>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h2 class="h5 mb-3">Lead- und Report-Archiv</h2>

      <form method="GET" action="/admin/website-tester" class="row g-2 mb-3">
        <div class="col-md-3">
          <input class="form-control" type="text" name="lead_q" value="<%= filters?.leadQ || '' %>" placeholder="Domain, E-Mail, Audit-ID">
        </div>
        <div class="col-md-2">
          <select class="form-select" name="lead_status">
            <option value="" <%= !filters?.leadStatus ? 'selected' : '' %>>Alle Status</option>
            <option value="pending" <%= filters?.leadStatus === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="confirmed" <%= filters?.leadStatus === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
            <option value="report_sent" <%= filters?.leadStatus === 'report_sent' ? 'selected' : '' %>>Report sent</option>
            <option value="report_failed" <%= filters?.leadStatus === 'report_failed' ? 'selected' : '' %>>Report failed</option>
          </select>
        </div>
        <div class="col-md-2">
          <select class="form-select" name="lead_locale">
            <option value="" <%= !filters?.leadLocale ? 'selected' : '' %>>Alle Sprachen</option>
            <option value="de" <%= filters?.leadLocale === 'de' ? 'selected' : '' %>>DE</option>
            <option value="en" <%= filters?.leadLocale === 'en' ? 'selected' : '' %>>EN</option>
          </select>
        </div>
        <div class="col-md-2">
          <input class="form-control" type="date" name="lead_from" value="<%= filters?.leadFrom || '' %>">
        </div>
        <div class="col-md-2">
          <input class="form-control" type="date" name="lead_to" value="<%= filters?.leadTo || '' %>">
        </div>

        <input type="hidden" name="q" value="<%= filters?.q || '' %>">
        <input type="hidden" name="status" value="<%= filters?.status || '' %>">

        <div class="col-md-1 d-grid">
          <button class="btn btn-outline-primary" type="submit">Filter</button>
        </div>
      </form>

      <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
          <thead>
            <tr>
              <th>Zeitpunkt</th>
              <th>Status</th>
              <th>Domain</th>
              <th>E-Mail</th>
              <th>Score</th>
              <th>Top-Issues</th>
              <th>Audit-ID</th>
              <th>Aktionen</th>
            </tr>
          </thead>
          <tbody>
            <% if (!leadArchive?.rows?.length) { %>
              <tr>
                <td colspan="8" class="text-muted">Keine Lead-Einträge gefunden.</td>
              </tr>
            <% } %>

            <% (leadArchive?.rows || []).forEach((row) => { %>
              <tr>
                <td>
                  <%= new Date(row.created_at).toLocaleString('de-DE', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
                <td>
                  <% if (row.status === 'pending') { %>
                    <span class="badge text-bg-warning">Pending</span>
                  <% } else if (row.status === 'confirmed') { %>
                    <span class="badge text-bg-info">Confirmed</span>
                  <% } else if (row.status === 'report_sent') { %>
                    <span class="badge text-bg-success">Report sent</span>
                  <% } else { %>
                    <span class="badge text-bg-danger">Report failed</span>
                  <% } %>
                  <div class="small text-muted mt-1"><%= row.locale || 'de' %></div>
                </td>
                <td style="max-width: 210px;"><span class="small text-break"><%= row.domain || '-' %></span></td>
                <td style="max-width: 210px;"><span class="small text-break"><%= row.maskedEmail || '-' %></span></td>
                <td>
                  <strong><%= row.overall_score ?? '-' %></strong>
                  <div class="small text-muted"><%= row.score_band || '-' %></div>
                </td>
                <td style="max-width: 200px;"><span class="small text-break"><%= row.top_issues || '-' %></span></td>
                <td style="max-width: 160px;"><span class="small text-break"><%= row.audit_id || '-' %></span></td>
                <td>
                  <div class="d-grid gap-1" style="min-width: 150px;">
                    <% if (row.status === 'pending') { %>
                      <form method="POST" action="/admin/website-tester/leads/<%= row.id %>/resend-doi">
                        <input type="hidden" name="return_to" value="<%= returnTo %>">
                        <button class="btn btn-outline-secondary btn-sm" type="submit">DOI erneut senden</button>
                      </form>
                    <% } %>

                    <% if (['confirmed','report_failed','report_sent'].includes(row.status)) { %>
                      <form method="POST" action="/admin/website-tester/leads/<%= row.id %>/resend-report">
                        <input type="hidden" name="return_to" value="<%= returnTo %>">
                        <button class="btn btn-outline-primary btn-sm" type="submit">Report erneut senden</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <%
        const leadPage = leadArchive?.page || 1;
        const leadTotalPages = leadArchive?.totalPages || 1;
        const buildLeadPageUrl = (targetPage) => {
          const params = new URLSearchParams();
          if (filters?.q) params.set('q', filters.q);
          if (filters?.status) params.set('status', filters.status);
          if (filters?.leadQ) params.set('lead_q', filters.leadQ);
          if (filters?.leadStatus) params.set('lead_status', filters.leadStatus);
          if (filters?.leadLocale) params.set('lead_locale', filters.leadLocale);
          if (filters?.leadFrom) params.set('lead_from', filters.leadFrom);
          if (filters?.leadTo) params.set('lead_to', filters.leadTo);
          params.set('req_page', String(archive?.page || 1));
          params.set('lead_page', String(targetPage));
          return `/admin/website-tester?${params.toString()}`;
        };
      %>

      <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="small text-muted">
          Seite <strong><%= leadPage %></strong> von <strong><%= leadTotalPages %></strong> - Gesamt: <strong><%= leadArchive?.total || 0 %></strong>
        </div>
        <div class="btn-group">
          <a class="btn btn-outline-secondary btn-sm <%= leadPage <= 1 ? 'disabled' : '' %>" href="<%= leadPage <= 1 ? '#' : buildLeadPageUrl(leadPage - 1) %>">Zurück</a>
          <a class="btn btn-outline-secondary btn-sm <%= leadPage >= leadTotalPages ? 'disabled' : '' %>" href="<%= leadPage >= leadTotalPages ? '#' : buildLeadPageUrl(leadPage + 1) %>">Weiter</a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/admin_footer') %>
