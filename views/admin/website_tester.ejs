<%- include('../partials/admin_header') %>

<div class="container my-4">
  <h1 class="mb-3">Website-Tester Admin</h1>

  <% if (query && query.saved === '1') { %>
    <div class="alert alert-success" role="status">
      Einstellungen gespeichert.
    </div>
  <% } %>
  <% if (query && query.saved_broken === '1') { %>
    <div class="alert alert-success" role="status">
      Broken-Links-Einstellungen gespeichert.
    </div>
  <% } %>
  <% if (query && query.saved_geo === '1') { %>
    <div class="alert alert-success" role="status">
      GEO-Tester-Einstellungen gespeichert.
    </div>
  <% } %>
  <% if (query && query.saved_seo === '1') { %>
    <div class="alert alert-success" role="status">
      SEO-Tester-Einstellungen gespeichert.
    </div>
  <% } %>

  <% if (query && query.lead_action === 'doi_resent') { %>
    <div class="alert alert-success" role="status">
      Bestätigungslink wurde erneut versendet.
    </div>
  <% } %>

  <% if (query && query.lead_action === 'report_resent') { %>
    <div class="alert alert-success" role="status">
      PDF-Report wurde erneut versendet.
    </div>
  <% } %>

  <% if (query && query.lead_error) { %>
    <div class="alert alert-danger" role="alert">
      <%= query.lead_error %>
    </div>
  <% } %>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Crawler-Einstellung</h2>
      <p class="text-muted mb-3">
        Lege fest, wie viele Unterseiten beim Deep-Audit zusätzlich zur Startseite analysiert werden.
      </p>
      <form action="/admin/website-tester/config" method="POST" class="row g-2 align-items-end">
        <div class="col-sm-4 col-md-3">
          <label class="form-label" for="max_subpages">Unterseiten (1-20)</label>
          <input
            id="max_subpages"
            class="form-control"
            type="number"
            name="max_subpages"
            min="1"
            max="20"
            value="<%= config?.maxSubpages ?? 5 %>"
            required
          >
        </div>
        <div class="col-sm-auto">
          <button class="btn btn-primary" type="submit">Speichern</button>
        </div>
      </form>
      <small class="text-muted d-block mt-2">
        Aktueller Wert: <strong><%= config?.maxSubpages ?? 5 %></strong> Unterseiten + 1 Startseite.
      </small>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Broken-Links-Tester Einstellungen</h2>
      <p class="text-muted mb-3">
        Lege den Scan-Umfang für den Broken-Links-Tester fest. Startwert ist Modus <strong>maximal</strong>.
      </p>
      <form action="/admin/website-tester/broken-links/config" method="POST" class="row g-2 align-items-end">
        <div class="col-sm-4 col-md-3">
          <label class="form-label" for="broken_links_max_subpages">Unterseiten (1-20)</label>
          <input
            id="broken_links_max_subpages"
            class="form-control"
            type="number"
            name="broken_links_max_subpages"
            min="1"
            max="20"
            value="<%= config?.brokenLinksMaxSubpages ?? 5 %>"
            required
          >
        </div>
        <div class="col-sm-4 col-md-3">
          <label class="form-label" for="broken_links_scan_mode">Scan-Modus</label>
          <select id="broken_links_scan_mode" class="form-select" name="broken_links_scan_mode" required>
            <option value="schnell" <%= config?.brokenLinksScanMode === 'schnell' ? 'selected' : '' %>>schnell</option>
            <option value="balanced" <%= config?.brokenLinksScanMode === 'balanced' ? 'selected' : '' %>>balanced</option>
            <option value="maximal" <%= !config?.brokenLinksScanMode || config?.brokenLinksScanMode === 'maximal' ? 'selected' : '' %>>maximal</option>
          </select>
        </div>
        <div class="col-sm-auto">
          <button class="btn btn-primary" type="submit">Speichern</button>
        </div>
      </form>
      <small class="text-muted d-block mt-2">
        Aktueller Wert: <strong><%= config?.brokenLinksMaxSubpages ?? 5 %></strong> Unterseiten + 1 Startseite,
        Modus: <strong><%= config?.brokenLinksScanMode || 'maximal' %></strong>.
      </small>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">GEO-Tester Einstellungen</h2>
      <p class="text-muted mb-3">
        Lege den Scan-Umfang für den GEO-Tester fest. Startwert ist Modus <strong>maximal</strong>.
      </p>
      <form action="/admin/website-tester/geo/config" method="POST" class="row g-2 align-items-end">
        <div class="col-sm-4 col-md-3">
          <label class="form-label" for="geo_max_subpages">Unterseiten (1-20)</label>
          <input
            id="geo_max_subpages"
            class="form-control"
            type="number"
            name="geo_max_subpages"
            min="1"
            max="20"
            value="<%= config?.geoMaxSubpages ?? 5 %>"
            required
          >
        </div>
        <div class="col-sm-4 col-md-3">
          <label class="form-label" for="geo_scan_mode">Scan-Modus</label>
          <select id="geo_scan_mode" class="form-select" name="geo_scan_mode" required>
            <option value="schnell" <%= config?.geoScanMode === 'schnell' ? 'selected' : '' %>>schnell</option>
            <option value="balanced" <%= config?.geoScanMode === 'balanced' ? 'selected' : '' %>>balanced</option>
            <option value="maximal" <%= !config?.geoScanMode || config?.geoScanMode === 'maximal' ? 'selected' : '' %>>maximal</option>
          </select>
        </div>
        <div class="col-sm-auto">
          <button class="btn btn-primary" type="submit">Speichern</button>
        </div>
      </form>
      <small class="text-muted d-block mt-2">
        Aktueller Wert: <strong><%= config?.geoMaxSubpages ?? 5 %></strong> Unterseiten + 1 Startseite,
        Modus: <strong><%= config?.geoScanMode || 'maximal' %></strong>.
      </small>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">SEO-Tester Einstellungen</h2>
      <p class="text-muted mb-3">
        Lege den Scan-Umfang für den SEO-Tester fest. Startwert ist Modus <strong>maximal</strong>.
      </p>
      <form action="/admin/website-tester/seo/config" method="POST" class="row g-2 align-items-end">
        <div class="col-sm-4 col-md-3">
          <label class="form-label" for="seo_max_subpages">Unterseiten (1-20)</label>
          <input
            id="seo_max_subpages"
            class="form-control"
            type="number"
            name="seo_max_subpages"
            min="1"
            max="20"
            value="<%= config?.seoMaxSubpages ?? 5 %>"
            required
          >
        </div>
        <div class="col-sm-4 col-md-3">
          <label class="form-label" for="seo_scan_mode">Scan-Modus</label>
          <select id="seo_scan_mode" class="form-select" name="seo_scan_mode" required>
            <option value="schnell" <%= config?.seoScanMode === 'schnell' ? 'selected' : '' %>>schnell</option>
            <option value="balanced" <%= config?.seoScanMode === 'balanced' ? 'selected' : '' %>>balanced</option>
            <option value="maximal" <%= !config?.seoScanMode || config?.seoScanMode === 'maximal' ? 'selected' : '' %>>maximal</option>
          </select>
        </div>
        <div class="col-sm-auto">
          <button class="btn btn-primary" type="submit">Speichern</button>
        </div>
      </form>
      <small class="text-muted d-block mt-2">
        Aktueller Wert: <strong><%= config?.seoMaxSubpages ?? 5 %></strong> Unterseiten + 1 Startseite,
        Modus: <strong><%= config?.seoScanMode || 'maximal' %></strong>.
      </small>
    </div>
  </div>

  <% 
    const currentParams = new URLSearchParams();
    Object.entries(query || {}).forEach(([key, value]) => {
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        currentParams.set(key, String(value));
      }
    });
    const returnTo = `/admin/website-tester${currentParams.toString() ? `?${currentParams.toString()}` : ''}`;
  %>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Audit-Anfrage-Archiv</h2>

      <form method="GET" action="/admin/website-tester" class="row g-2 mb-3">
        <div class="col-md-5">
          <input
            class="form-control"
            type="text"
            name="q"
            value="<%= filters?.q || '' %>"
            placeholder="Suche nach URL oder Final-URL"
          >
        </div>
        <div class="col-md-3">
          <select class="form-select" name="status">
            <option value="" <%= !filters?.status ? 'selected' : '' %>>Alle Status</option>
            <option value="success" <%= filters?.status === 'success' ? 'selected' : '' %>>Erfolg</option>
            <option value="error" <%= filters?.status === 'error' ? 'selected' : '' %>>Fehler</option>
          </select>
        </div>

        <input type="hidden" name="lead_q" value="<%= filters?.leadQ || '' %>">
        <input type="hidden" name="lead_status" value="<%= filters?.leadStatus || '' %>">
        <input type="hidden" name="lead_source" value="<%= filters?.leadSource || '' %>">
        <input type="hidden" name="lead_locale" value="<%= filters?.leadLocale || '' %>">
        <input type="hidden" name="lead_from" value="<%= filters?.leadFrom || '' %>">
        <input type="hidden" name="lead_to" value="<%= filters?.leadTo || '' %>">
        <input type="hidden" name="bl_q" value="<%= filters?.brokenQ || '' %>">
        <input type="hidden" name="bl_status" value="<%= filters?.brokenStatus || '' %>">
        <input type="hidden" name="bl_mode" value="<%= filters?.brokenMode || '' %>">
        <input type="hidden" name="geo_q" value="<%= filters?.geoQ || '' %>">
        <input type="hidden" name="geo_status" value="<%= filters?.geoStatus || '' %>">
        <input type="hidden" name="geo_mode" value="<%= filters?.geoMode || '' %>">

        <div class="col-md-auto">
          <button class="btn btn-outline-primary" type="submit">Filtern</button>
        </div>
      </form>

      <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
          <thead>
            <tr>
              <th>Zeitpunkt</th>
              <th>Status</th>
              <th>URL</th>
              <th>Score</th>
              <th>Crawl</th>
              <th>Top-Baustellen</th>
              <th>Audit-ID</th>
            </tr>
          </thead>
          <tbody>
            <% if (!archive?.rows?.length) { %>
              <tr>
                <td colspan="7" class="text-muted">Keine Einträge gefunden.</td>
              </tr>
            <% } %>
            <% (archive?.rows || []).forEach((row) => { %>
              <tr>
                <td>
                  <%= new Date(row.created_at).toLocaleString('de-DE', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
                <td>
                  <% if (row.status === 'success') { %>
                    <span class="badge text-bg-success">Erfolg</span>
                  <% } else { %>
                    <span class="badge text-bg-danger">Fehler</span>
                  <% } %>
                </td>
                <td style="max-width: 360px;">
                  <div class="small">
                    <strong>Eingabe:</strong><br>
                    <span class="text-break"><%= row.requested_url %></span>
                  </div>
                  <% if (row.final_url) { %>
                    <div class="small mt-1">
                      <strong>Final:</strong><br>
                      <span class="text-break"><%= row.final_url %></span>
                    </div>
                  <% } %>
                  <% if (row.error_message) { %>
                    <div class="small text-danger mt-1 text-break"><%= row.error_message %></div>
                  <% } %>
                </td>
                <td>
                  <% if (row.overall_score === null || row.overall_score === undefined) { %>
                    <span class="text-muted">-</span>
                  <% } else { %>
                    <strong><%= row.overall_score %></strong>
                    <div class="small text-muted"><%= row.score_band || '-' %></div>
                  <% } %>
                </td>
                <td>
                  <span class="small">
                    <%= row.crawl_visited_pages ?? '-' %>/<%= row.crawl_planned_pages ?? '-' %>
                    <% if (row.crawl_failed_pages && row.crawl_failed_pages > 0) { %>
                      <br><span class="text-danger">Fehler: <%= row.crawl_failed_pages %></span>
                    <% } %>
                  </span>
                </td>
                <td style="max-width: 220px;">
                  <span class="small text-break"><%= row.top_issues || '-' %></span>
                </td>
                <td>
                  <span class="small text-break"><%= row.audit_id || '-' %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <%
        const requestPage = archive?.page || 1;
        const requestTotalPages = archive?.totalPages || 1;
        const buildRequestPageUrl = (targetPage) => {
          const params = new URLSearchParams();
          if (filters?.q) params.set('q', filters.q);
          if (filters?.status) params.set('status', filters.status);
          if (filters?.leadQ) params.set('lead_q', filters.leadQ);
          if (filters?.leadStatus) params.set('lead_status', filters.leadStatus);
          if (filters?.leadSource) params.set('lead_source', filters.leadSource);
          if (filters?.leadLocale) params.set('lead_locale', filters.leadLocale);
          if (filters?.leadFrom) params.set('lead_from', filters.leadFrom);
          if (filters?.leadTo) params.set('lead_to', filters.leadTo);
          if (filters?.brokenQ) params.set('bl_q', filters.brokenQ);
          if (filters?.brokenStatus) params.set('bl_status', filters.brokenStatus);
          if (filters?.brokenMode) params.set('bl_mode', filters.brokenMode);
          if (filters?.geoQ) params.set('geo_q', filters.geoQ);
          if (filters?.geoStatus) params.set('geo_status', filters.geoStatus);
          if (filters?.geoMode) params.set('geo_mode', filters.geoMode);
          params.set('req_page', String(targetPage));
          params.set('bl_page', String(brokenArchive?.page || 1));
          params.set('geo_page', String(geoArchive?.page || 1));
          params.set('lead_page', String(leadArchive?.page || 1));
          return `/admin/website-tester?${params.toString()}`;
        };
      %>

      <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="small text-muted">
          Seite <strong><%= requestPage %></strong> von <strong><%= requestTotalPages %></strong> - Gesamt: <strong><%= archive?.total || 0 %></strong>
        </div>
        <div class="btn-group">
          <a class="btn btn-outline-secondary btn-sm <%= requestPage <= 1 ? 'disabled' : '' %>" href="<%= requestPage <= 1 ? '#' : buildRequestPageUrl(requestPage - 1) %>">Zurück</a>
          <a class="btn btn-outline-secondary btn-sm <%= requestPage >= requestTotalPages ? 'disabled' : '' %>" href="<%= requestPage >= requestTotalPages ? '#' : buildRequestPageUrl(requestPage + 1) %>">Weiter</a>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Broken-Link-Scan Archiv</h2>

      <form method="GET" action="/admin/website-tester" class="row g-2 mb-3">
        <div class="col-md-4">
          <input
            class="form-control"
            type="text"
            name="bl_q"
            value="<%= filters?.brokenQ || '' %>"
            placeholder="Suche nach URL oder Audit-ID"
          >
        </div>
        <div class="col-md-2">
          <select class="form-select" name="bl_status">
            <option value="" <%= !filters?.brokenStatus ? 'selected' : '' %>>Alle Status</option>
            <option value="success" <%= filters?.brokenStatus === 'success' ? 'selected' : '' %>>Erfolg</option>
            <option value="error" <%= filters?.brokenStatus === 'error' ? 'selected' : '' %>>Fehler</option>
          </select>
        </div>
        <div class="col-md-2">
          <select class="form-select" name="bl_mode">
            <option value="" <%= !filters?.brokenMode ? 'selected' : '' %>>Alle Modi</option>
            <option value="schnell" <%= filters?.brokenMode === 'schnell' ? 'selected' : '' %>>schnell</option>
            <option value="balanced" <%= filters?.brokenMode === 'balanced' ? 'selected' : '' %>>balanced</option>
            <option value="maximal" <%= filters?.brokenMode === 'maximal' ? 'selected' : '' %>>maximal</option>
          </select>
        </div>

        <input type="hidden" name="q" value="<%= filters?.q || '' %>">
        <input type="hidden" name="status" value="<%= filters?.status || '' %>">
        <input type="hidden" name="bl_q" value="<%= filters?.brokenQ || '' %>">
        <input type="hidden" name="bl_status" value="<%= filters?.brokenStatus || '' %>">
        <input type="hidden" name="bl_mode" value="<%= filters?.brokenMode || '' %>">
        <input type="hidden" name="lead_q" value="<%= filters?.leadQ || '' %>">
        <input type="hidden" name="lead_status" value="<%= filters?.leadStatus || '' %>">
        <input type="hidden" name="lead_source" value="<%= filters?.leadSource || '' %>">
        <input type="hidden" name="lead_locale" value="<%= filters?.leadLocale || '' %>">
        <input type="hidden" name="lead_from" value="<%= filters?.leadFrom || '' %>">
        <input type="hidden" name="lead_to" value="<%= filters?.leadTo || '' %>">
        <input type="hidden" name="geo_q" value="<%= filters?.geoQ || '' %>">
        <input type="hidden" name="geo_status" value="<%= filters?.geoStatus || '' %>">
        <input type="hidden" name="geo_mode" value="<%= filters?.geoMode || '' %>">

        <div class="col-md-auto">
          <button class="btn btn-outline-primary" type="submit">Filtern</button>
        </div>
      </form>

      <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
          <thead>
            <tr>
              <th>Zeitpunkt</th>
              <th>Status</th>
              <th>URL</th>
              <th>Modus</th>
              <th>Crawl</th>
              <th>Link-Stats</th>
              <th>Audit-ID</th>
            </tr>
          </thead>
          <tbody>
            <% if (!brokenArchive?.rows?.length) { %>
              <tr>
                <td colspan="7" class="text-muted">Keine Broken-Link-Scans gefunden.</td>
              </tr>
            <% } %>
            <% (brokenArchive?.rows || []).forEach((row) => { %>
              <tr>
                <td>
                  <%= new Date(row.created_at).toLocaleString('de-DE', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
                <td>
                  <% if (row.status === 'success') { %>
                    <span class="badge text-bg-success">Erfolg</span>
                  <% } else { %>
                    <span class="badge text-bg-danger">Fehler</span>
                  <% } %>
                  <% if (row.partial_result) { %>
                    <div class="small text-warning mt-1">Teil-Scan</div>
                  <% } %>
                </td>
                <td style="max-width: 360px;">
                  <div class="small">
                    <strong>Eingabe:</strong><br>
                    <span class="text-break"><%= row.requested_url %></span>
                  </div>
                  <% if (row.final_url) { %>
                    <div class="small mt-1">
                      <strong>Final:</strong><br>
                      <span class="text-break"><%= row.final_url %></span>
                    </div>
                  <% } %>
                  <% if (row.error_message) { %>
                    <div class="small text-danger mt-1 text-break"><%= row.error_message %></div>
                  <% } %>
                </td>
                <td><span class="small"><%= row.scan_mode || '-' %></span></td>
                <td>
                  <span class="small">
                    <%= row.crawl_visited_pages ?? '-' %>/<%= row.crawl_planned_pages ?? '-' %>
                    <% if (row.crawl_failed_pages && row.crawl_failed_pages > 0) { %>
                      <br><span class="text-danger">Fehler: <%= row.crawl_failed_pages %></span>
                    <% } %>
                  </span>
                </td>
                <td>
                  <span class="small">
                    Geprüft: <strong><%= row.link_total_checked ?? '-' %></strong><br>
                    Broken: <strong><%= row.link_broken_count ?? '-' %></strong><br>
                    Warnings: <strong><%= row.link_warning_count ?? '-' %></strong>
                  </span>
                </td>
                <td><span class="small text-break"><%= row.audit_id || '-' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <%
        const brokenPage = brokenArchive?.page || 1;
        const brokenTotalPages = brokenArchive?.totalPages || 1;
        const buildBrokenPageUrl = (targetPage) => {
          const params = new URLSearchParams();
          if (filters?.q) params.set('q', filters.q);
          if (filters?.status) params.set('status', filters.status);
          if (filters?.brokenQ) params.set('bl_q', filters.brokenQ);
          if (filters?.brokenStatus) params.set('bl_status', filters.brokenStatus);
          if (filters?.brokenMode) params.set('bl_mode', filters.brokenMode);
          if (filters?.leadQ) params.set('lead_q', filters.leadQ);
          if (filters?.leadStatus) params.set('lead_status', filters.leadStatus);
          if (filters?.leadSource) params.set('lead_source', filters.leadSource);
          if (filters?.leadLocale) params.set('lead_locale', filters.leadLocale);
          if (filters?.leadFrom) params.set('lead_from', filters.leadFrom);
          if (filters?.leadTo) params.set('lead_to', filters.leadTo);
          if (filters?.geoQ) params.set('geo_q', filters.geoQ);
          if (filters?.geoStatus) params.set('geo_status', filters.geoStatus);
          if (filters?.geoMode) params.set('geo_mode', filters.geoMode);
          params.set('req_page', String(archive?.page || 1));
          params.set('bl_page', String(targetPage));
          params.set('geo_page', String(geoArchive?.page || 1));
          params.set('lead_page', String(leadArchive?.page || 1));
          return `/admin/website-tester?${params.toString()}`;
        };
      %>

      <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="small text-muted">
          Seite <strong><%= brokenPage %></strong> von <strong><%= brokenTotalPages %></strong> - Gesamt: <strong><%= brokenArchive?.total || 0 %></strong>
        </div>
        <div class="btn-group">
          <a class="btn btn-outline-secondary btn-sm <%= brokenPage <= 1 ? 'disabled' : '' %>" href="<%= brokenPage <= 1 ? '#' : buildBrokenPageUrl(brokenPage - 1) %>">Zurück</a>
          <a class="btn btn-outline-secondary btn-sm <%= brokenPage >= brokenTotalPages ? 'disabled' : '' %>" href="<%= brokenPage >= brokenTotalPages ? '#' : buildBrokenPageUrl(brokenPage + 1) %>">Weiter</a>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">GEO-Scan Archiv</h2>

      <form method="GET" action="/admin/website-tester" class="row g-2 mb-3">
        <div class="col-md-4">
          <input
            class="form-control"
            type="text"
            name="geo_q"
            value="<%= filters?.geoQ || '' %>"
            placeholder="Suche nach URL oder Audit-ID"
          >
        </div>
        <div class="col-md-2">
          <select class="form-select" name="geo_status">
            <option value="" <%= !filters?.geoStatus ? 'selected' : '' %>>Alle Status</option>
            <option value="success" <%= filters?.geoStatus === 'success' ? 'selected' : '' %>>Erfolg</option>
            <option value="error" <%= filters?.geoStatus === 'error' ? 'selected' : '' %>>Fehler</option>
          </select>
        </div>
        <div class="col-md-2">
          <select class="form-select" name="geo_mode">
            <option value="" <%= !filters?.geoMode ? 'selected' : '' %>>Alle Modi</option>
            <option value="schnell" <%= filters?.geoMode === 'schnell' ? 'selected' : '' %>>schnell</option>
            <option value="balanced" <%= filters?.geoMode === 'balanced' ? 'selected' : '' %>>balanced</option>
            <option value="maximal" <%= filters?.geoMode === 'maximal' ? 'selected' : '' %>>maximal</option>
          </select>
        </div>

