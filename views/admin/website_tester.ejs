                          <button class="btn btn-outline-success btn-sm" type="submit">Vollanleitung senden</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <%
          const leadPage = leadArchive?.page || 1;
          const leadTotalPages = leadArchive?.totalPages || 1;
        %>
        <div class="d-flex justify-content-between align-items-center mt-3">
          <div class="small text-muted">
            Seite <strong><%= leadPage %></strong> von <strong><%= leadTotalPages %></strong> &mdash; Gesamt: <strong><%= leadArchive?.total || 0 %></strong>
          </div>
          <div class="btn-group">
            <a class="btn btn-outline-secondary btn-sm <%= leadPage <= 1 ? 'disabled' : '' %>" href="<%= leadPage <= 1 ? '#' : buildUrl({ lead_page: leadPage - 1 }) %>">Zurück</a>
            <a class="btn btn-outline-secondary btn-sm <%= leadPage >= leadTotalPages ? 'disabled' : '' %>" href="<%= leadPage >= leadTotalPages ? '#' : buildUrl({ lead_page: leadPage + 1 }) %>">Weiter</a>
          </div>
        </div>
      <% } %>

    </div>
  </div>
</div>

<script>
  (function () {
    // Settings panel switcher
    const select = document.getElementById('settingsTesterSelect');
    if (select) {
      const panels = Array.from(document.querySelectorAll('[data-settings-panel]'));
      const showPanel = function (value) {
        panels.forEach((panel) => {
          panel.classList.toggle('d-none', panel.getAttribute('data-settings-panel') !== value);
        });
        const url = new URL(window.location.href);
        url.searchParams.set('settings_tester', value);
        window.history.replaceState({}, '', `${url.pathname}?${url.searchParams.toString()}`);
      };
      select.addEventListener('change', function () {
        showPanel(select.value);
      });
    }

    // Client-side table sorting
    const tableState = new WeakMap();

    function getValue(cell) {
      return cell.dataset.sortValue !== undefined ? cell.dataset.sortValue : cell.textContent.trim();
    }

    function compare(a, b, type) {
      if (type === 'num') {
        const na = a === '' ? -Infinity : parseFloat(a);
        const nb = b === '' ? -Infinity : parseFloat(b);
        return na - nb;
      }
      return String(a).localeCompare(String(b), 'de', { sensitivity: 'base' });
    }

    function applySort(table, col, dir) {
      const ths = Array.from(table.querySelectorAll('thead th'));
      const thIndex = ths.findIndex(function (th) { return th.dataset.sortCol === col; });
      if (thIndex === -1) return;

      const type = ths[thIndex].dataset.sortType || 'text';
      const tbody = table.querySelector('tbody');
      const rows = Array.from(tbody.querySelectorAll('tr'));

      rows.sort(function (a, b) {
        const cells = a.querySelectorAll('td');
        const cellsB = b.querySelectorAll('td');
        if (!cells[thIndex] || !cellsB[thIndex]) return 0;
        const va = getValue(cells[thIndex]);
        const vb = getValue(cellsB[thIndex]);
        const cmp = compare(va, vb, type);
        return dir === 'asc' ? cmp : -cmp;
      });

      rows.forEach(function (row) { tbody.appendChild(row); });

      // Update icons
      ths.forEach(function (th) {
        const icon = th.querySelector('.sort-icon');
        if (!icon) return;
        if (th.dataset.sortCol === col) {
          icon.innerHTML = dir === 'asc' ? '&#9650;' : '&#9660;';
          icon.classList.remove('opacity-50');
          th.classList.add('fw-semibold');
        } else {
          icon.innerHTML = '&#8597;';
          icon.classList.add('opacity-50');
          th.classList.remove('fw-semibold');
        }
      });
    }

    document.addEventListener('click', function (e) {
      const th = e.target.closest('th[data-sort-col]');
      if (!th) return;
      const table = th.closest('table');
      if (!table) return;
      const col = th.dataset.sortCol;
      const prev = tableState.get(table) || { col: null, dir: 'desc' };
      const dir = prev.col === col && prev.dir === 'desc' ? 'asc' : 'desc';
      tableState.set(table, { col: col, dir: dir });
      applySort(table, col, dir);
    });
  })();
</script>

<%- include('../partials/admin_footer') %>
