  <div class="card">
    <div class="card-body">
      <h2 class="h5 mb-3">Lead- und Report-Archiv</h2>

      <form method="GET" action="/admin/website-tester" class="row g-2 mb-3">
        <div class="col-md-3">
          <input class="form-control" type="text" name="lead_q" value="<%= filters?.leadQ || '' %>" placeholder="Domain, E-Mail, Audit-ID">
        </div>
        <div class="col-md-2">
          <select class="form-select" name="lead_status">
            <option value="" <%= !filters?.leadStatus ? 'selected' : '' %>>Alle Status</option>
            <option value="pending" <%= filters?.leadStatus === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="confirmed" <%= filters?.leadStatus === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
            <option value="report_sent" <%= filters?.leadStatus === 'report_sent' ? 'selected' : '' %>>Report sent</option>
            <option value="report_failed" <%= filters?.leadStatus === 'report_failed' ? 'selected' : '' %>>Report failed</option>
          </select>
        </div>
        <div class="col-md-2">
          <select class="form-select" name="lead_source">
            <option value="" <%= !filters?.leadSource ? 'selected' : '' %>>Alle Quellen</option>
            <option value="website" <%= filters?.leadSource === 'website' ? 'selected' : '' %>>Website</option>
            <option value="geo" <%= filters?.leadSource === 'geo' ? 'selected' : '' %>>GEO</option>
            <option value="seo" <%= filters?.leadSource === 'seo' ? 'selected' : '' %>>SEO</option>
          </select>
        </div>
        <div class="col-md-2">
          <select class="form-select" name="lead_locale">
            <option value="" <%= !filters?.leadLocale ? 'selected' : '' %>>Alle Sprachen</option>
            <option value="de" <%= filters?.leadLocale === 'de' ? 'selected' : '' %>>DE</option>
            <option value="en" <%= filters?.leadLocale === 'en' ? 'selected' : '' %>>EN</option>
          </select>
        </div>
        <div class="col-md-1">
          <input class="form-control" type="date" name="lead_from" value="<%= filters?.leadFrom || '' %>">
        </div>
        <div class="col-md-1">
          <input class="form-control" type="date" name="lead_to" value="<%= filters?.leadTo || '' %>">
        </div>

        <input type="hidden" name="q" value="<%= filters?.q || '' %>">
        <input type="hidden" name="status" value="<%= filters?.status || '' %>">
        <input type="hidden" name="bl_q" value="<%= filters?.brokenQ || '' %>">
        <input type="hidden" name="bl_status" value="<%= filters?.brokenStatus || '' %>">
        <input type="hidden" name="bl_mode" value="<%= filters?.brokenMode || '' %>">
        <input type="hidden" name="geo_q" value="<%= filters?.geoQ || '' %>">
        <input type="hidden" name="geo_status" value="<%= filters?.geoStatus || '' %>">
        <input type="hidden" name="geo_mode" value="<%= filters?.geoMode || '' %>">

        <div class="col-md-1 d-grid">
          <button class="btn btn-outline-primary" type="submit">Filter</button>
        </div>
      </form>

      <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
          <thead>
            <tr>
              <th>Zeitpunkt</th>
              <th>Status</th>
              <th>Quelle</th>
              <th>Domain</th>
              <th>E-Mail</th>
              <th>Score</th>
              <th>Top-Issues</th>
              <th>Audit-ID</th>
              <th>Aktionen</th>
            </tr>
          </thead>
          <tbody>
            <% if (!leadArchive?.rows?.length) { %>
              <tr>
                <td colspan="9" class="text-muted">Keine Lead-Einträge gefunden.</td>
              </tr>
            <% } %>

            <% (leadArchive?.rows || []).forEach((row) => { %>
              <tr>
                <td>
                  <%= new Date(row.created_at).toLocaleString('de-DE', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
                <td>
                  <% if (row.status === 'pending') { %>
                    <span class="badge text-bg-warning">Pending</span>
                  <% } else if (row.status === 'confirmed') { %>
                    <span class="badge text-bg-info">Confirmed</span>
                  <% } else if (row.status === 'report_sent') { %>
                    <span class="badge text-bg-success">Report sent</span>
                  <% } else { %>
                    <span class="badge text-bg-danger">Report failed</span>
                  <% } %>
                  <div class="small text-muted mt-1"><%= row.locale || 'de' %></div>
                </td>
                <td><span class="small"><%= row.source || 'website' %></span></td>
                <td style="max-width: 210px;"><span class="small text-break"><%= row.domain || '-' %></span></td>
                <td style="max-width: 210px;"><span class="small text-break"><%= row.maskedEmail || '-' %></span></td>
                <td>
                  <strong><%= row.overall_score ?? '-' %></strong>
                  <div class="small text-muted"><%= row.score_band || '-' %></div>
                </td>
                <td style="max-width: 200px;"><span class="small text-break"><%= row.top_issues || '-' %></span></td>
                <td style="max-width: 160px;"><span class="small text-break"><%= row.audit_id || '-' %></span></td>
                <td>
                  <div class="d-grid gap-1" style="min-width: 150px;">
                    <% if (row.status === 'pending') { %>
                      <form method="POST" action="/admin/website-tester/leads/<%= row.id %>/resend-doi">
                        <input type="hidden" name="return_to" value="<%= returnTo %>">
                        <button class="btn btn-outline-secondary btn-sm" type="submit">DOI erneut senden</button>
                      </form>
                    <% } %>

                    <% if (['confirmed','report_failed','report_sent'].includes(row.status)) { %>
                      <form method="POST" action="/admin/website-tester/leads/<%= row.id %>/resend-report">
                        <input type="hidden" name="return_to" value="<%= returnTo %>">
                        <button class="btn btn-outline-primary btn-sm" type="submit">Report erneut senden</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <%
        const leadPage = leadArchive?.page || 1;
        const leadTotalPages = leadArchive?.totalPages || 1;
        const buildLeadPageUrl = (targetPage) => {
          const params = new URLSearchParams();
          if (filters?.q) params.set('q', filters.q);
          if (filters?.status) params.set('status', filters.status);
          if (filters?.leadQ) params.set('lead_q', filters.leadQ);
          if (filters?.leadStatus) params.set('lead_status', filters.leadStatus);
