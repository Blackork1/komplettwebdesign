<%- include('../partials/admin_header') %>

<div class="container my-4">
  <h1 class="mb-3">Website-Tester Admin</h1>

  <% if (query && query.saved === '1') { %>
    <div class="alert alert-success" role="status">
      Einstellungen gespeichert.
    </div>
  <% } %>
  <% if (query && query.saved_broken === '1') { %>
    <div class="alert alert-success" role="status">
      Broken-Links-Einstellungen gespeichert.
    </div>
  <% } %>
  <% if (query && query.saved_geo === '1') { %>
    <div class="alert alert-success" role="status">
      GEO-Tester-Einstellungen gespeichert.
    </div>
  <% } %>
  <% if (query && query.saved_seo === '1') { %>
    <div class="alert alert-success" role="status">
      SEO-Tester-Einstellungen gespeichert.
    </div>
  <% } %>

  <% if (query && query.lead_action === 'doi_resent') { %>
    <div class="alert alert-success" role="status">
      Bestätigungslink wurde erneut versendet.
    </div>
  <% } %>

  <% if (query && query.lead_action === 'report_resent') { %>
    <div class="alert alert-success" role="status">
      PDF-Report wurde erneut versendet.
    </div>
  <% } %>
  <% if (query && query.lead_action === 'full_guide_sent') { %>
    <div class="alert alert-success" role="status">
      Vollanleitung wurde versendet.
    </div>
  <% } %>

  <% if (query && query.lead_error) { %>
    <div class="alert alert-danger" role="alert">
      <%= query.lead_error %>
    </div>
  <% } %>

  <% 
    const currentParams = new URLSearchParams();
    Object.entries(query || {}).forEach(([key, value]) => {
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        currentParams.set(key, String(value));
      }
    });
    const returnTo = `/admin/website-tester${currentParams.toString() ? `?${currentParams.toString()}` : ''}`;
  %>

  <% if (query && query.preview_action === 'generated') { %>
    <div class="alert alert-success" role="status">
      Test-Vorschau wurde erstellt. Es wurden keine E-Mails versendet.
    </div>
  <% } %>

  <% if (query && query.preview_error) { %>
    <div class="alert alert-danger" role="alert">
      <%= query.preview_error %>
    </div>
  <% } %>

  <%
    const settingsTesterRaw = String(query?.settings_tester || 'website');
    const settingsCards = [
      {
        id: 'website',
        title: 'Website-Tester',
        hint: 'Deep-Audit über Startseite + Unterseiten.',
        action: '/admin/website-tester/config',
        fields: [
          { type: 'number', name: 'max_subpages', label: 'Unterseiten (1-20)', min: 1, max: 20, value: config?.maxSubpages ?? 5 }
        ],
        summary: `Aktueller Wert: ${config?.maxSubpages ?? 5} Unterseiten + 1 Startseite.`
      },
      {
        id: 'broken',
        title: 'Broken-Links-Tester',
        hint: 'Interne/externe Linkziele mit konfigurierbarem Scan-Modus.',
        action: '/admin/website-tester/broken-links/config',
        fields: [
          { type: 'number', name: 'broken_links_max_subpages', label: 'Unterseiten (1-20)', min: 1, max: 20, value: config?.brokenLinksMaxSubpages ?? 5 },
          { type: 'select', name: 'broken_links_scan_mode', label: 'Scan-Modus', value: config?.brokenLinksScanMode || 'maximal', options: ['schnell', 'balanced', 'maximal'] }
        ],
        summary: `Aktueller Wert: ${config?.brokenLinksMaxSubpages ?? 5} Unterseiten + 1 Startseite, Modus: ${config?.brokenLinksScanMode || 'maximal'}.`
      },
      {
        id: 'geo',
        title: 'GEO-Tester',
        hint: 'Generative-Search/GEO-Audit mit konfigurierbarem Scan-Modus.',
        action: '/admin/website-tester/geo/config',
        fields: [
          { type: 'number', name: 'geo_max_subpages', label: 'Unterseiten (1-20)', min: 1, max: 20, value: config?.geoMaxSubpages ?? 5 },
          { type: 'select', name: 'geo_scan_mode', label: 'Scan-Modus', value: config?.geoScanMode || 'maximal', options: ['schnell', 'balanced', 'maximal'] }
        ],
        summary: `Aktueller Wert: ${config?.geoMaxSubpages ?? 5} Unterseiten + 1 Startseite, Modus: ${config?.geoScanMode || 'maximal'}.`
      },
      {
        id: 'seo',
        title: 'SEO-Tester',
        hint: 'OnPage-/Technik-SEO-Audit mit konfigurierbarem Scan-Modus.',
        action: '/admin/website-tester/seo/config',
        fields: [
          { type: 'number', name: 'seo_max_subpages', label: 'Unterseiten (1-20)', min: 1, max: 20, value: config?.seoMaxSubpages ?? 5 },
          { type: 'select', name: 'seo_scan_mode', label: 'Scan-Modus', value: config?.seoScanMode || 'maximal', options: ['schnell', 'balanced', 'maximal'] }
        ],
        summary: `Aktueller Wert: ${config?.seoMaxSubpages ?? 5} Unterseiten + 1 Startseite, Modus: ${config?.seoScanMode || 'maximal'}.`
      }
    ];
    const settingsTester = settingsCards.some((item) => item.id === settingsTesterRaw) ? settingsTesterRaw : 'website';
  %>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-2">Tester-Einstellungen (kompakt)</h2>
      <p class="text-muted mb-3">Wähle einen Tester aus, passe die Parameter an und speichere direkt im selben Block.</p>

      <div class="row g-2 align-items-end mb-3">
        <div class="col-sm-6 col-md-4">
          <label class="form-label" for="settingsTesterSelect">Tester auswählen</label>
          <select id="settingsTesterSelect" class="form-select">
            <% settingsCards.forEach((item) => { %>
              <option value="<%= item.id %>" <%= settingsTester === item.id ? 'selected' : '' %>><%= item.title %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <% settingsCards.forEach((item) => { %>
        <div data-settings-panel="<%= item.id %>" class="<%= settingsTester === item.id ? '' : 'd-none' %>">
          <h3 class="h6 mb-1"><%= item.title %></h3>
          <p class="text-muted mb-2"><%= item.hint %></p>
          <form action="<%= item.action %>" method="POST" class="row g-2 align-items-end">
            <% item.fields.forEach((field) => { %>
              <div class="col-sm-4 col-md-3">
                <label class="form-label" for="<%= field.name %>"><%= field.label %></label>
                <% if (field.type === 'select') { %>
                  <select id="<%= field.name %>" class="form-select" name="<%= field.name %>" required>
                    <% field.options.forEach((option) => { %>
                      <option value="<%= option %>" <%= field.value === option ? 'selected' : '' %>><%= option %></option>
                    <% }) %>
                  </select>
                <% } else { %>
                  <input
                    id="<%= field.name %>"
                    class="form-control"
                    type="number"
                    name="<%= field.name %>"
                    min="<%= field.min %>"
                    max="<%= field.max %>"
                    value="<%= field.value %>"
                    required
                  >
                <% } %>
              </div>
            <% }) %>
            <div class="col-sm-auto">
              <button class="btn btn-primary" type="submit">Speichern</button>
            </div>
          </form>
          <small class="text-muted d-block mt-2"><%= item.summary %></small>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-2">Test Mail / Vorschau (ohne Versand)</h2>
      <p class="text-muted mb-3">
        Erzeuge eine Testvorschau für Kurzreport + Vollanleitung. Dabei wird nichts an Kunden versendet.
      </p>
      <%
        const previewDefaults = preview || {};
        const previewContextDefaults = previewDefaults.context || {};
      %>
      <form action="/admin/website-tester/preview" method="POST" class="row g-2 align-items-end">
        <input type="hidden" name="return_to" value="<%= returnTo %>">
        <div class="col-md-2">
          <label class="form-label" for="preview_source">Tester</label>
          <select id="preview_source" class="form-select" name="preview_source" required>
            <option value="website" <%= (previewDefaults.source || 'website') === 'website' ? 'selected' : '' %>>Website</option>
            <option value="seo" <%= previewDefaults.source === 'seo' ? 'selected' : '' %>>SEO</option>
            <option value="geo" <%= previewDefaults.source === 'geo' ? 'selected' : '' %>>GEO</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label" for="preview_locale">Sprache</label>
          <select id="preview_locale" class="form-select" name="preview_locale" required>
            <option value="de" <%= (previewDefaults.locale || 'de') === 'de' ? 'selected' : '' %>>de</option>
            <option value="en" <%= previewDefaults.locale === 'en' ? 'selected' : '' %>>en</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label" for="preview_url">URL</label>
          <input id="preview_url" class="form-control" type="url" name="preview_url" placeholder="https://www.domain.de" value="<%= previewDefaults.requestedUrl || '' %>" required>
        </div>
        <div class="col-md-2">
          <label class="form-label" for="preview_business_type">Branche</label>
          <input id="preview_business_type" class="form-control" type="text" name="preview_business_type" placeholder="Webdesign" value="<%= previewContextDefaults.businessType || '' %>" required>
        </div>
        <div class="col-md-2">
          <label class="form-label" for="preview_primary_service">Hauptleistung</label>
          <input id="preview_primary_service" class="form-control" type="text" name="preview_primary_service" placeholder="Website erstellen" value="<%= previewContextDefaults.primaryService || '' %>" required>
        </div>
        <div class="col-md-2">
          <label class="form-label" for="preview_target_region">Zielregion</label>
          <input id="preview_target_region" class="form-control" type="text" name="preview_target_region" placeholder="Berlin" value="<%= previewContextDefaults.targetRegion || '' %>" required>
        </div>
        <div class="col-md-auto">
          <button class="btn btn-outline-primary" type="submit">Vorschau erzeugen</button>
        </div>
      </form>

      <% if (preview) { %>
        <div class="border rounded p-3 mt-3">
          <div class="small text-muted mb-2">
            Vorschau-ID: <strong><%= preview.id %></strong> | erstellt: <strong><%= new Date(preview.createdAt).toLocaleString('de-DE') %></strong>
          </div>
          <div class="small mb-2">
            Quelle: <strong><%= preview.source %></strong> | Sprache: <strong><%= preview.locale %></strong> | Domain: <strong><%= preview.domain %></strong>
          </div>
          <div class="small mb-3 text-break">
            URL: <%= preview.requestedUrl %><br>
            Kontext: Branche=<%= preview.context?.businessType || '-' %>, Leistung=<%= preview.context?.primaryService || '-' %>, Region=<%= preview.context?.targetRegion || '-' %>
          </div>
          <div class="d-flex flex-wrap gap-2 mb-2">
            <a class="btn btn-sm btn-outline-primary" href="/admin/website-tester/preview/<%= preview.id %>/short.pdf">Kurzanleitung PDF laden</a>
            <a class="btn btn-sm btn-outline-success" href="/admin/website-tester/preview/<%= preview.id %>/full.pdf">Vollanleitung PDF laden</a>
            <a class="btn btn-sm btn-outline-secondary" href="/admin/website-tester/preview/<%= preview.id %>/full.txt">Vollanleitung TXT laden</a>
          </div>
          <div class="small text-muted">
            Kurzreport: <%= preview.shortReport?.filename || '-' %> (<%= preview.shortReport?.pageCount || 0 %> Seiten) |
            Vollanleitung: <%= preview.fullGuide?.filename || '-' %> (<%= preview.fullGuide?.pageCount || 0 %> Seiten)
          </div>
          <% if (preview.fullGuide?.summary) { %>
            <p class="small mt-2 mb-0"><strong>Guide-Summary:</strong> <%= preview.fullGuide.summary %></p>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Audit-Anfrage-Archiv</h2>

      <form method="GET" action="/admin/website-tester" class="row g-2 mb-3">
        <div class="col-md-5">
          <input
            class="form-control"
            type="text"
            name="q"
            value="<%= filters?.q || '' %>"
            placeholder="Suche nach URL oder Final-URL"
          >
        </div>
        <div class="col-md-3">
          <select class="form-select" name="status">
            <option value="" <%= !filters?.status ? 'selected' : '' %>>Alle Status</option>
            <option value="success" <%= filters?.status === 'success' ? 'selected' : '' %>>Erfolg</option>
            <option value="error" <%= filters?.status === 'error' ? 'selected' : '' %>>Fehler</option>
          </select>
        </div>

        <input type="hidden" name="lead_q" value="<%= filters?.leadQ || '' %>">
        <input type="hidden" name="lead_status" value="<%= filters?.leadStatus || '' %>">
        <input type="hidden" name="lead_source" value="<%= filters?.leadSource || '' %>">
        <input type="hidden" name="lead_locale" value="<%= filters?.leadLocale || '' %>">
        <input type="hidden" name="lead_from" value="<%= filters?.leadFrom || '' %>">
        <input type="hidden" name="lead_to" value="<%= filters?.leadTo || '' %>">
        <input type="hidden" name="bl_q" value="<%= filters?.brokenQ || '' %>">
        <input type="hidden" name="bl_status" value="<%= filters?.brokenStatus || '' %>">
        <input type="hidden" name="bl_mode" value="<%= filters?.brokenMode || '' %>">
        <input type="hidden" name="geo_q" value="<%= filters?.geoQ || '' %>">
        <input type="hidden" name="geo_status" value="<%= filters?.geoStatus || '' %>">
        <input type="hidden" name="geo_mode" value="<%= filters?.geoMode || '' %>">

        <div class="col-md-auto">
          <button class="btn btn-outline-primary" type="submit">Filtern</button>
        </div>
      </form>

      <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
          <thead>
            <tr>
              <th>Zeitpunkt</th>
              <th>Status</th>
              <th>URL</th>
              <th>Score</th>
              <th>Crawl</th>
              <th>Top-Baustellen</th>
              <th>Audit-ID</th>
            </tr>
          </thead>
          <tbody>
            <% if (!archive?.rows?.length) { %>
              <tr>
                <td colspan="7" class="text-muted">Keine Einträge gefunden.</td>
              </tr>
            <% } %>
            <% (archive?.rows || []).forEach((row) => { %>
              <tr>
                <td>
                  <%= new Date(row.created_at).toLocaleString('de-DE', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
                <td>
                  <% if (row.status === 'success') { %>
                    <span class="badge text-bg-success">Erfolg</span>
                  <% } else { %>
                    <span class="badge text-bg-danger">Fehler</span>
                  <% } %>
                </td>
                <td style="max-width: 360px;">
                  <div class="small">
                    <strong>Eingabe:</strong><br>
                    <span class="text-break"><%= row.requested_url %></span>
                  </div>
                  <% if (row.final_url) { %>
                    <div class="small mt-1">
                      <strong>Final:</strong><br>
                      <span class="text-break"><%= row.final_url %></span>
                    </div>
                  <% } %>
                  <% if (row.error_message) { %>
                    <div class="small text-danger mt-1 text-break"><%= row.error_message %></div>
                  <% } %>
                </td>
                <td>
                  <% if (row.overall_score === null || row.overall_score === undefined) { %>
                    <span class="text-muted">-</span>
                  <% } else { %>
                    <strong><%= row.overall_score %></strong>
                    <div class="small text-muted"><%= row.score_band || '-' %></div>
                  <% } %>
                </td>
                <td>
                  <span class="small">
                    <%= row.crawl_visited_pages ?? '-' %>/<%= row.crawl_planned_pages ?? '-' %>
                    <% if (row.crawl_failed_pages && row.crawl_failed_pages > 0) { %>
                      <br><span class="text-danger">Fehler: <%= row.crawl_failed_pages %></span>
                    <% } %>
                  </span>
                </td>
                <td style="max-width: 220px;">
                  <span class="small text-break"><%= row.top_issues || '-' %></span>
                </td>
                <td>
                  <span class="small text-break"><%= row.audit_id || '-' %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <%
        const requestPage = archive?.page || 1;
        const requestTotalPages = archive?.totalPages || 1;
        const buildRequestPageUrl = (targetPage) => {
          const params = new URLSearchParams();
          if (filters?.q) params.set('q', filters.q);
          if (filters?.status) params.set('status', filters.status);
          if (filters?.leadQ) params.set('lead_q', filters.leadQ);
          if (filters?.leadStatus) params.set('lead_status', filters.leadStatus);
          if (filters?.leadSource) params.set('lead_source', filters.leadSource);
          if (filters?.leadLocale) params.set('lead_locale', filters.leadLocale);
          if (filters?.leadFrom) params.set('lead_from', filters.leadFrom);
          if (filters?.leadTo) params.set('lead_to', filters.leadTo);
          if (filters?.brokenQ) params.set('bl_q', filters.brokenQ);
          if (filters?.brokenStatus) params.set('bl_status', filters.brokenStatus);
          if (filters?.brokenMode) params.set('bl_mode', filters.brokenMode);
          if (filters?.geoQ) params.set('geo_q', filters.geoQ);
          if (filters?.geoStatus) params.set('geo_status', filters.geoStatus);
          if (filters?.geoMode) params.set('geo_mode', filters.geoMode);
          params.set('req_page', String(targetPage));
          params.set('bl_page', String(brokenArchive?.page || 1));
          params.set('geo_page', String(geoArchive?.page || 1));
          params.set('lead_page', String(leadArchive?.page || 1));
          return `/admin/website-tester?${params.toString()}`;
        };
      %>

      <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="small text-muted">
          Seite <strong><%= requestPage %></strong> von <strong><%= requestTotalPages %></strong> - Gesamt: <strong><%= archive?.total || 0 %></strong>
        </div>
        <div class="btn-group">
          <a class="btn btn-outline-secondary btn-sm <%= requestPage <= 1 ? 'disabled' : '' %>" href="<%= requestPage <= 1 ? '#' : buildRequestPageUrl(requestPage - 1) %>">Zurück</a>
          <a class="btn btn-outline-secondary btn-sm <%= requestPage >= requestTotalPages ? 'disabled' : '' %>" href="<%= requestPage >= requestTotalPages ? '#' : buildRequestPageUrl(requestPage + 1) %>">Weiter</a>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Broken-Link-Scan Archiv</h2>

      <form method="GET" action="/admin/website-tester" class="row g-2 mb-3">
        <div class="col-md-4">
          <input
            class="form-control"
            type="text"
            name="bl_q"
            value="<%= filters?.brokenQ || '' %>"
            placeholder="Suche nach URL oder Audit-ID"
          >
        </div>
        <div class="col-md-2">
          <select class="form-select" name="bl_status">
            <option value="" <%= !filters?.brokenStatus ? 'selected' : '' %>>Alle Status</option>
            <option value="success" <%= filters?.brokenStatus === 'success' ? 'selected' : '' %>>Erfolg</option>
            <option value="error" <%= filters?.brokenStatus === 'error' ? 'selected' : '' %>>Fehler</option>
          </select>
        </div>
        <div class="col-md-2">
          <select class="form-select" name="bl_mode">
            <option value="" <%= !filters?.brokenMode ? 'selected' : '' %>>Alle Modi</option>
            <option value="schnell" <%= filters?.brokenMode === 'schnell' ? 'selected' : '' %>>schnell</option>
            <option value="balanced" <%= filters?.brokenMode === 'balanced' ? 'selected' : '' %>>balanced</option>
            <option value="maximal" <%= filters?.brokenMode === 'maximal' ? 'selected' : '' %>>maximal</option>
          </select>
        </div>

        <input type="hidden" name="q" value="<%= filters?.q || '' %>">
        <input type="hidden" name="status" value="<%= filters?.status || '' %>">
        <input type="hidden" name="bl_q" value="<%= filters?.brokenQ || '' %>">
        <input type="hidden" name="bl_status" value="<%= filters?.brokenStatus || '' %>">
        <input type="hidden" name="bl_mode" value="<%= filters?.brokenMode || '' %>">
        <input type="hidden" name="lead_q" value="<%= filters?.leadQ || '' %>">
        <input type="hidden" name="lead_status" value="<%= filters?.leadStatus || '' %>">
        <input type="hidden" name="lead_source" value="<%= filters?.leadSource || '' %>">
        <input type="hidden" name="lead_locale" value="<%= filters?.leadLocale || '' %>">
        <input type="hidden" name="lead_from" value="<%= filters?.leadFrom || '' %>">
        <input type="hidden" name="lead_to" value="<%= filters?.leadTo || '' %>">
        <input type="hidden" name="geo_q" value="<%= filters?.geoQ || '' %>">
        <input type="hidden" name="geo_status" value="<%= filters?.geoStatus || '' %>">
        <input type="hidden" name="geo_mode" value="<%= filters?.geoMode || '' %>">

        <div class="col-md-auto">
          <button class="btn btn-outline-primary" type="submit">Filtern</button>
        </div>
      </form>

      <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
          <thead>
            <tr>
              <th>Zeitpunkt</th>
              <th>Status</th>
              <th>URL</th>
              <th>Modus</th>
              <th>Crawl</th>
              <th>Link-Stats</th>
              <th>Audit-ID</th>
            </tr>
          </thead>
          <tbody>
            <% if (!brokenArchive?.rows?.length) { %>
              <tr>
                <td colspan="7" class="text-muted">Keine Broken-Link-Scans gefunden.</td>
              </tr>
            <% } %>
            <% (brokenArchive?.rows || []).forEach((row) => { %>
              <tr>
                <td>
                  <%= new Date(row.created_at).toLocaleString('de-DE', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
                <td>
                  <% if (row.status === 'success') { %>
                    <span class="badge text-bg-success">Erfolg</span>
                  <% } else { %>
                    <span class="badge text-bg-danger">Fehler</span>
                  <% } %>
                  <% if (row.partial_result) { %>
                    <div class="small text-warning mt-1">Teil-Scan</div>
                  <% } %>
                </td>
                <td style="max-width: 360px;">
                  <div class="small">
                    <strong>Eingabe:</strong><br>
                    <span class="text-break"><%= row.requested_url %></span>
                  </div>
                  <% if (row.final_url) { %>
                    <div class="small mt-1">
                      <strong>Final:</strong><br>
                      <span class="text-break"><%= row.final_url %></span>
                    </div>
                  <% } %>
                  <% if (row.error_message) { %>
                    <div class="small text-danger mt-1 text-break"><%= row.error_message %></div>
                  <% } %>
                </td>
                <td><span class="small"><%= row.scan_mode || '-' %></span></td>
                <td>
                  <span class="small">
                    <%= row.crawl_visited_pages ?? '-' %>/<%= row.crawl_planned_pages ?? '-' %>
                    <% if (row.crawl_failed_pages && row.crawl_failed_pages > 0) { %>
                      <br><span class="text-danger">Fehler: <%= row.crawl_failed_pages %></span>
                    <% } %>
                  </span>
                </td>
                <td>
                  <span class="small">
                    Geprüft: <strong><%= row.link_total_checked ?? '-' %></strong><br>
                    Broken: <strong><%= row.link_broken_count ?? '-' %></strong><br>
                    Warnings: <strong><%= row.link_warning_count ?? '-' %></strong>
                  </span>
                </td>
                <td><span class="small text-break"><%= row.audit_id || '-' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

