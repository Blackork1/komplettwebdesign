        <input type="hidden" name="status" value="<%= filters?.status || '' %>">
        <input type="hidden" name="bl_q" value="<%= filters?.brokenQ || '' %>">
        <input type="hidden" name="bl_status" value="<%= filters?.brokenStatus || '' %>">
        <input type="hidden" name="bl_mode" value="<%= filters?.brokenMode || '' %>">
        <input type="hidden" name="lead_q" value="<%= filters?.leadQ || '' %>">
        <input type="hidden" name="lead_status" value="<%= filters?.leadStatus || '' %>">
        <input type="hidden" name="lead_source" value="<%= filters?.leadSource || '' %>">
        <input type="hidden" name="lead_locale" value="<%= filters?.leadLocale || '' %>">
        <input type="hidden" name="lead_from" value="<%= filters?.leadFrom || '' %>">
        <input type="hidden" name="lead_to" value="<%= filters?.leadTo || '' %>">

        <div class="col-md-auto">
          <button class="btn btn-outline-primary" type="submit">Filtern</button>
        </div>
      </form>

      <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
          <thead>
            <tr>
              <th>Zeitpunkt</th>
              <th>Status</th>
              <th>URL</th>
              <th>Modus</th>
              <th>Crawl</th>
              <th>GEO-Score</th>
              <th>Audit-ID</th>
            </tr>
          </thead>
          <tbody>
            <% if (!geoArchive?.rows?.length) { %>
              <tr>
                <td colspan="7" class="text-muted">Keine GEO-Scans gefunden.</td>
              </tr>
            <% } %>
            <% (geoArchive?.rows || []).forEach((row) => { %>
              <tr>
                <td>
                  <%= new Date(row.created_at).toLocaleString('de-DE', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
                <td>
                  <% if (row.status === 'success') { %>
                    <span class="badge text-bg-success">Erfolg</span>
                  <% } else { %>
                    <span class="badge text-bg-danger">Fehler</span>
                  <% } %>
                  <% if (row.partial_result) { %>
                    <div class="small text-warning mt-1">Teil-Scan</div>
                  <% } %>
                </td>
                <td style="max-width: 360px;">
                  <div class="small">
                    <strong>Eingabe:</strong><br>
                    <span class="text-break"><%= row.requested_url %></span>
                  </div>
                  <% if (row.final_url) { %>
                    <div class="small mt-1">
                      <strong>Final:</strong><br>
                      <span class="text-break"><%= row.final_url %></span>
                    </div>
                  <% } %>
                  <% if (row.error_message) { %>
                    <div class="small text-danger mt-1 text-break"><%= row.error_message %></div>
                  <% } %>
                </td>
                <td><span class="small"><%= row.scan_mode || '-' %></span></td>
                <td>
                  <span class="small">
                    <%= row.crawl_visited_pages ?? '-' %>/<%= row.crawl_planned_pages ?? '-' %>
                    <% if (row.crawl_failed_pages && row.crawl_failed_pages > 0) { %>
                      <br><span class="text-danger">Fehler: <%= row.crawl_failed_pages %></span>
                    <% } %>
                  </span>
                </td>
                <td>
                  <strong><%= row.geo_score ?? '-' %></strong>
                  <div class="small text-muted"><%= row.geo_band || '-' %></div>
                </td>
                <td><span class="small text-break"><%= row.audit_id || '-' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <%
        const geoPage = geoArchive?.page || 1;
        const geoTotalPages = geoArchive?.totalPages || 1;
        const buildGeoPageUrl = (targetPage) => {
          const params = new URLSearchParams();
          if (filters?.q) params.set('q', filters.q);
          if (filters?.status) params.set('status', filters.status);
          if (filters?.brokenQ) params.set('bl_q', filters.brokenQ);
          if (filters?.brokenStatus) params.set('bl_status', filters.brokenStatus);
          if (filters?.brokenMode) params.set('bl_mode', filters.brokenMode);
          if (filters?.geoQ) params.set('geo_q', filters.geoQ);
          if (filters?.geoStatus) params.set('geo_status', filters.geoStatus);
          if (filters?.geoMode) params.set('geo_mode', filters.geoMode);
          if (filters?.leadQ) params.set('lead_q', filters.leadQ);
          if (filters?.leadStatus) params.set('lead_status', filters.leadStatus);
          if (filters?.leadSource) params.set('lead_source', filters.leadSource);
          if (filters?.leadLocale) params.set('lead_locale', filters.leadLocale);
          if (filters?.leadFrom) params.set('lead_from', filters.leadFrom);
          if (filters?.leadTo) params.set('lead_to', filters.leadTo);
          params.set('req_page', String(archive?.page || 1));
          params.set('bl_page', String(brokenArchive?.page || 1));
          params.set('geo_page', String(targetPage));
          params.set('lead_page', String(leadArchive?.page || 1));
          return `/admin/website-tester?${params.toString()}`;
        };
      %>

      <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="small text-muted">
          Seite <strong><%= geoPage %></strong> von <strong><%= geoTotalPages %></strong> - Gesamt: <strong><%= geoArchive?.total || 0 %></strong>
        </div>
        <div class="btn-group">
          <a class="btn btn-outline-secondary btn-sm <%= geoPage <= 1 ? 'disabled' : '' %>" href="<%= geoPage <= 1 ? '#' : buildGeoPageUrl(geoPage - 1) %>">Zurück</a>
          <a class="btn btn-outline-secondary btn-sm <%= geoPage >= geoTotalPages ? 'disabled' : '' %>" href="<%= geoPage >= geoTotalPages ? '#' : buildGeoPageUrl(geoPage + 1) %>">Weiter</a>
        </div>
      </div>
    </div>
  </div>

