<%- include('../partials/admin_header') %>

<%
  const checked = (value) => value ? 'checked' : '';
  const valueFor = (rowId, packageId) => (values || []).find((entry) =>
    Number(entry.row_id) === Number(rowId) && Number(entry.package_id) === Number(packageId)
  ) || {};
%>

<h1 class="admin-page-title">
  <i class="fa-solid fa-table-columns"></i> Paketvergleich
</h1>

<div class="admin-card mb-4">
  <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
    <p class="mb-0">Vergleichszeilen und Werte pro Paket zentral pflegen.</p>
    <a class="btn btn-outline-secondary" href="/admin/pricing/packages">Zur Paketliste</a>
  </div>
</div>

<section class="admin-card mb-4">
  <h2 class="h5">Neue Vergleichszeile</h2>
  <form method="POST" action="/admin/pricing/comparison/rows" class="row g-2 align-items-end">
    <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
    <div class="col-md-3"><label class="form-label">Row-Key</label><input name="row_key" class="form-control" required></div>
    <div class="col-md-3"><label class="form-label">Label</label><input name="label" class="form-control" required></div>
    <div class="col-md-4"><label class="form-label">Beschreibung</label><input name="description" class="form-control"></div>
    <div class="col-md-1"><label class="form-label">Sort.</label><input name="sort_order" type="number" class="form-control" value="<%= (rows || []).length + 1 %>"></div>
    <div class="col-md-1"><button class="btn btn-primary w-100" type="submit">+</button></div>
    <div class="col-12"><label class="form-check"><input class="form-check-input" name="is_visible" type="checkbox" checked> sichtbar</label></div>
  </form>
</section>

<% (rows || []).forEach((row) => { %>
  <section class="admin-card mb-4">
    <h2 class="h5">Zeile: <%= row.label %></h2>
    <form method="POST" action="/admin/pricing/comparison/rows/<%= row.id %>" class="row g-2 align-items-end mb-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
      <div class="col-md-3"><label class="form-label">Row-Key</label><input name="row_key" class="form-control" value="<%= row.row_key || '' %>" required></div>
      <div class="col-md-3"><label class="form-label">Label</label><input name="label" class="form-control" value="<%= row.label || '' %>" required></div>
      <div class="col-md-4"><label class="form-label">Beschreibung</label><input name="description" class="form-control" value="<%= row.description || '' %>"></div>
      <div class="col-md-1"><label class="form-label">Sort.</label><input name="sort_order" type="number" class="form-control" value="<%= row.sort_order ?? 0 %>"></div>
      <div class="col-md-1"><button class="btn btn-primary w-100" type="submit">Speichern</button></div>
      <div class="col-12"><label class="form-check"><input class="form-check-input" name="is_visible" type="checkbox" <%= checked(row.is_visible) %>> sichtbar</label></div>
    </form>

    <div class="row g-2">
      <% (packages || []).forEach((pkg) => {
        const comparisonValue = valueFor(row.id, pkg.id);
      %>
        <div class="col-md-6 col-xl-3">
          <form method="POST" action="/admin/pricing/comparison/values" class="border rounded p-3 h-100">
            <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
            <input type="hidden" name="row_id" value="<%= row.id %>">
            <input type="hidden" name="package_id" value="<%= pkg.id %>">
            <h3 class="h6"><%= pkg.display_name || pkg.name %></h3>
            <label class="form-label" for="comparison_value_<%= row.id %>_<%= pkg.id %>">Wert</label>
            <textarea id="comparison_value_<%= row.id %>_<%= pkg.id %>" name="value" class="form-control" rows="3" required><%= comparisonValue.value || '' %></textarea>
            <label class="form-label mt-2" for="comparison_sort_<%= row.id %>_<%= pkg.id %>">Sortierung</label>
            <input id="comparison_sort_<%= row.id %>_<%= pkg.id %>" name="sort_order" type="number" class="form-control" value="<%= comparisonValue.sort_order ?? pkg.sort_order ?? 0 %>">
            <label class="form-check mt-2"><input class="form-check-input" name="highlight" type="checkbox" <%= checked(comparisonValue.highlight) %>> hervorheben</label>
            <button class="btn btn-sm btn-primary mt-2" type="submit">Wert speichern</button>
          </form>
        </div>
      <% }) %>
    </div>
  </section>
<% }) %>

<%- include('../partials/admin_footer') %>
