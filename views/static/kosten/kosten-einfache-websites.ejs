<%
const startPriceLabel = (typeof packagePriceLabel === 'function' ? packagePriceLabel('start') : '') || 'nach Angebot';
const businessPriceLabel = (typeof packagePriceLabel === 'function' ? packagePriceLabel('business') : '') || 'nach Angebot';
const wachstumPriceLabel = (typeof packagePriceLabel === 'function' ? packagePriceLabel('wachstum') : '') || 'nach Angebot';
const structuredDataRaw = `<script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Start","item":"https://komplettwebdesign.de/"},
      {"@type":"ListItem","position":2,"name":"Ratgeber","item":"https://komplettwebdesign.de/ratgeber"},
      {"@type":"ListItem","position":3,"name":"Kosten einfache Website"}
    ]
  }
  </script>

<script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"FAQPage",
    "mainEntity":[
      {"@type":"Question","name":"Brauche ich eine FAQ-Seite?","acceptedAnswer":{"@type":"Answer","text":"Kurz beantwortete Fragen erhöhen Vertrauen und werden oft in Google angezeigt."}},
      {"@type":"Question","name":"Kann ich später erweitern?","acceptedAnswer":{"@type":"Answer","text":"Ja – wir starten schlank und erweitern bei Bedarf."}},
      {"@type":"Question","name":"Übernimmst du Hosting & Wartung?","acceptedAnswer":{"@type":"Answer","text":"Ja, Hosting und Wartung können bei Bedarf separat vereinbart werden. Laufende Kosten werden getrennt vom einmaligen Website-Projekt eingeordnet."}}
    ]
  }
  </script>`;
%>
<%- include('../../partials/head', { structuredDataRaw, extraCssAssets: ['cost-pages.css'] }) %>
<%- include('../../partials/header') %>
  <meta charset="utf-8" />
  <title>Kosten einer einfachen Website – Beispiele & Checkliste</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Ehrliche Preisbeispiele und eine 8-Punkte-Checkliste für einen schnellen, sauberen Start – responsive, mobilfreundlich und klar strukturiert." />

  <!-- OG (optional) -->
  <meta property="og:title" content="Kosten einer einfachen Website – Beispiele & Checkliste" />
  <meta property="og:description" content="Preisbeispiele (Start/Business/Wachstum) und eine 8-Punkte-Checkliste für einen schnellen, sauberen Start." />
  <link rel="canonical" href="https://komplettwebdesign.de/ratgeber/kosten-einfache-website" />
</head>
<body>
  <!-- HERO -->
  <header class="hero py-5">
    <div class="container py-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a class="text-white-50" href="/">Start</a></li>
          <li class="breadcrumb-item text-white-50">Ratgeber</li>
          <li class="breadcrumb-item active text-white" aria-current="page">Kosten einfache Website</li>
        </ol>
      </nav>
      <div class="col-lg-8">
        <h1 class="display-6 fw-bold text-white">Kosten einer einfachen Website – Beispiele & Checkliste</h1>
        <p class="lead mt-2 text-white">Schnell professionell online gehen – ohne Schnickschnack, aber sauber und wirkungsvoll.</p>
        <div class="mt-3 d-flex gap-2">
          <a href="/pakete" class="btn btn-primary">Pakete vergleichen</a>
          <a href="/kontakt" class="btn btn-secondary">Kurzberatung</a>
        </div>
      </div>
    </div>
  </header>

  <main>

    <!-- Preisbeispiele -->
    <section class="container my-5">
      <h2 class="h3">Preisbeispiele nach Umfang</h2>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="border rounded-3 p-4 h-100 card-shadow">
            <h3 class="h5">Start (<%= startPriceLabel %>)</h3>
            <p class="small text-muted">1–3 Seiten – ideal zum Start</p>
            <ul class="small mb-0">
              <li>Startseite + 1–2 Unterseiten</li>
              <li>Kontakt/Impressum/Datenschutz</li>
              <li>Mobilfreundlich & schnell</li>
            </ul>
          </div>
        </div>
        <div class="col-md-4">
          <div class="border rounded-3 p-4 h-100 card-shadow">
            <h3 class="h5">Business (<%= businessPriceLabel %>)</h3>
            <p class="small text-muted">4–6 Seiten – klar & überzeugend</p>
            <ul class="small mb-0">
              <li>Leistungen, Über mich, FAQ</li>
              <li>Saubere Struktur & interne Links</li>
              <li>Feinschliff für Google</li>
            </ul>
          </div>
        </div>
        <div class="col-md-4">
          <div class="border rounded-3 p-4 h-100 card-shadow">
            <h3 class="h5">Wachstum (<%= wachstumPriceLabel %>)</h3>
            <p class="small text-muted">Mehr Seiten + Extras nach Umfang</p>
            <ul class="small mb-0">
              <li>Blog, Buchung oder Mehrsprachigkeit separat kalkuliert</li>
              <li>stärkere Seitenstruktur</li>
              <li>individuelle Bereiche nach Angebot</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Checkliste -->
    <section class="container my-5">
      <h2 class="h3">8-Punkte-Checkliste</h2>
      <div class="row g-4">
        <div class="col-md-6">
          <ul class="list-group list-group-flush">
            <li class="list-group-item">Ziele & Zielgruppe in 3 Stichpunkten</li>
            <li class="list-group-item">Seitenplan: Start, Leistungen, Über mich, Kontakt, FAQ</li>
            <li class="list-group-item">Texte: 150–250 Wörter pro Seite reichen oft</li>
            <li class="list-group-item">Bilder: 10–20 passende Fotos (Web-optimiert)</li>
          </ul>
        </div>
        <div class="col-md-6">
          <ul class="list-group list-group-flush">
            <li class="list-group-item">Logo/CI: Farben & Schriften festlegen</li>
            <li class="list-group-item">Kontaktwege: E-Mail, Telefon, Formular</li>
            <li class="list-group-item">Rechtliches: Impressum, Datenschutz, Cookies</li>
            <li class="list-group-item">SEO-Basics: gute Überschriften, kurze Ladezeiten</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="container my-5">
      <h2 class="h3">Häufige Fragen</h2>
      <div class="accordion" id="faq2">
        <div class="accordion-item">
          <h2 class="accordion-header" id="q2a">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#a2a" aria-expanded="true" aria-controls="a2a">
              Brauche ich eine FAQ-Seite?
            </button>
          </h2>
          <div id="a2a" class="accordion-collapse collapse show" aria-labelledby="q2a" data-bs-parent="#faq2">
            <div class="accordion-body">Ja – kurz beantwortete Fragen erhöhen Vertrauen und werden oft in Google angezeigt.</div>
          </div>
        </div>

        <div class="accordion-item">
          <h2 class="accordion-header" id="q2b">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#a2b" aria-expanded="false" aria-controls="a2b">
              Kann ich später erweitern?
            </button>
          </h2>
          <div id="a2b" class="accordion-collapse collapse" aria-labelledby="q2b" data-bs-parent="#faq2">
            <div class="accordion-body">Klar. Wir starten schlank und fügen Seiten/Features hinzu, sobald du sie brauchst.</div>
          </div>
        </div>

        <div class="accordion-item">
          <h2 class="accordion-header" id="q2c">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#a2c" aria-expanded="false" aria-controls="a2c">
              Übernimmst du Hosting & Wartung?
            </button>
          </h2>
          <div id="a2c" class="accordion-collapse collapse" aria-labelledby="q2c" data-bs-parent="#faq2">
            <div class="accordion-body">Ja, Hosting und Wartung können bei Bedarf separat vereinbart werden. Laufende Kosten werden getrennt vom einmaligen Website-Projekt eingeordnet.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="container my-5">
      <div class="p-4 border rounded-3 d-lg-flex justify-content-between align-items-center">
        <div class="me-3">
          <h3 class="h5 mb-1">Lass uns deine einfache Website starten</h3>
          <p class="mb-0 text-muted small">Ich schätze Aufwand & Preis transparent ein.</p>
        </div>
        <div class="mt-3 mt-lg-0 d-flex gap-2">
          <a href="/kontakt" class="btn btn-primary">Anfragen</a>
          <a href="/pakete" class="btn btn-secondary">Pakete ansehen</a>
        </div>
      </div>
    </section>

  </main>

<%- include('../../partials/footer') %>

  <!-- JSON-LD Breadcrumbs + FAQ -->
  </body>
</html>
