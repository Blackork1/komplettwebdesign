<%
const startPriceLabel = (typeof packagePriceLabel === 'function' ? packagePriceLabel('start') : '') || 'nach Angebot';
const businessPriceLabel = (typeof packagePriceLabel === 'function' ? packagePriceLabel('business') : '') || 'nach Angebot';
const wachstumPriceLabel = (typeof packagePriceLabel === 'function' ? packagePriceLabel('wachstum') : '') || 'nach Angebot';
const structuredDataRaw = `<script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Start","item":"https://komplettwebdesign.de/"},
      {"@type":"ListItem","position":2,"name":"Ratgeber","item":"https://komplettwebdesign.de/ratgeber"},
      {"@type":"ListItem","position":3,"name":"Website-Kosten & Zeitplan"}
    ]
  }
  </script>

<script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"FAQPage",
    "mainEntity":[
      {"@type":"Question","name":"Was kostet eine einfache Website?","acceptedAnswer":{"@type":"Answer","text":"Das Start-Paket beginnt bei ${startPriceLabel}. Business startet bei ${businessPriceLabel}, Wachstum bei ${wachstumPriceLabel}; Extras und laufende Kosten werden separat eingeordnet."}},
      {"@type":"Question","name":"Wie lange dauert die Erstellung?","acceptedAnswer":{"@type":"Answer","text":"Typisch 2 bis 8 Wochen. Wenn Inhalte und Freigaben früh vorliegen, kann der Zeitplan kürzer ausfallen."}},
      {"@type":"Question","name":"Was ist im Preis enthalten?","acceptedAnswer":{"@type":"Answer","text":"Design, Umsetzung, technische SEO-Grundlagen, technische Einrichtung und Beratung im vereinbarten Umfang. Rechtstexte, Hosting, Wartung und externe Tools werden separat geklärt."}}
    ]
  }
  </script>`;
%>
<%- include('../../partials/head', { structuredDataRaw, extraCssAssets: ['cost-pages.css'] }) %>
<%- include('../../partials/header') %>
  <meta charset="utf-8" />
  <title>Website-Kosten 2025 & realistischer Zeitplan – einfach erklärt</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Was kostet eine Website 2025 – und wie lange dauert’s? Klare Preisbeispiele, 2/4/8-Wochen-Zeitpläne und Tipps für Selbstständige in Berlin." />

  <!-- OG (optional) -->
  <meta property="og:title" content="Website-Kosten 2025 & realistischer Zeitplan – einfach erklärt" />
  <meta property="og:description" content="Was kostet eine Website 2025 – und wie lange dauert’s? Klare Spannen, 2/4/8-Wochen-Beispiele und praktische Tipps." />
  <link rel="canonical" href="https://komplettwebdesign.de/ratgeber/website-kosten-zeitplan" />
</head>
<body>


  <!-- HERO -->
  <header class="hero py-5">
    <div class="container py-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a class="text-white-50" href="/">Start</a></li>
          <li class="breadcrumb-item text-white-50">Ratgeber</li>
          <li class="breadcrumb-item active text-white" aria-current="page">Website-Kosten & Zeitplan</li>
        </ol>
      </nav>
      <div class="col-lg-8">
        <h1 class="display-5 fw-bold text-white">Website-Kosten 2025 & realistischer Zeitplan – einfach erklärt</h1>
        <p class="lead mt-2 text-white">Klare Preisrahmen, echte Beispiele und ein ehrlicher Ablauf – speziell für Selbstständige & kleine Unternehmen in Berlin.</p>
        <div class="mt-3 d-flex gap-2">
          <a href="/pakete" class="btn btn-primary">Pakete ansehen</a>
          <a href="/kontakt" class="btn btn-secondary">15-Min-Beratung</a>
        </div>
      </div>
    </div>
  </header>

  <main>

    <!-- Preise/Pakete -->
    <section class="container my-5">
      <h2 class="h3">Was kostet eine Website?</h2>
      <p class="lead-small">Transparente Pakete – Extras (z. B. zusätzliche Seiten, Buchung, Mehrsprachigkeit) kalkulieren wir fair dazu.</p>

      <div class="row g-4 mt-1">
        <div class="col-md-4">
          <div class="card h-100 card-shadow">
            <div class="card-body">
              <span class="badge badge-accent mb-2">Beliebt</span>
              <h3 class="h5">Start</h3>
              <p class="text-muted mb-2">Startseite + 1–2 Unterseiten</p>
              <p class="h2 fw-bold mb-3"><%= startPriceLabel %></p>
              <ul class="small mb-0">
                <li>Mobilfreundlich, schnell</li>
                <li>Saubere Struktur & Grund-SEO</li>
                <li>Kontakt + Einbindung gelieferter Rechtstextseiten</li>
              </ul>
            </div>
            <div class="card-footer bg-white border-0">
              <a href="/pakete/start" class="btn btn-secondary w-100">Details</a>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card h-100 card-shadow border-2">
            <div class="card-body">
              <span class="badge text-bg-dark mb-2">Empfehlung</span>
              <h3 class="h5">Business</h3>
              <p class="text-muted mb-2">Startseite + 3–6 Unterseiten</p>
              <p class="h2 fw-bold mb-3"><%= businessPriceLabel %></p>
              <ul class="small mb-0">
                <li>Leistungen, Über mich, FAQ</li>
                <li>Interne Verlinkung</li>
                <li>Feinschliff für Google</li>
              </ul>
            </div>
            <div class="card-footer bg-white border-0">
              <a href="/pakete/business" class="btn btn-primary w-100">Jetzt anfragen</a>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card h-100 card-shadow">
            <div class="card-body">
              <h3 class="h5">Wachstum</h3>
              <p class="text-muted mb-2">Mehr Seiten + Extras</p>
              <p class="h2 fw-bold mb-3"><%= wachstumPriceLabel %></p>
              <ul class="small mb-0">
                <li>Blog oder Buchung als Zusatzleistung</li>
                <li>Mehrsprachigkeit separat planbar</li>
                <li>Individuelle Bereiche</li>
              </ul>
            </div>
            <div class="card-footer bg-white border-0">
              <a href="/pakete/wachstum" class="btn btn-secondary w-100">Details</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Zeitpläne -->
    <section class="container my-5">
      <h2 class="h3">Wie lange dauert es realistisch?</h2>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="p-4 border rounded-3 h-100">
            <h3 class="h5">2 Wochen</h3>
            <p class="small mb-0">Mini-Website – wenn Texte/Bilder vorliegen. Sauber, schnell online.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-4 border rounded-3 h-100">
            <h3 class="h5">4 Wochen</h3>
            <p class="small mb-0">Standard (5–8 Seiten), Basis-SEO, klare Struktur, mobile Feinschliff.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-4 border rounded-3 h-100">
            <h3 class="h5">8 Wochen</h3>
            <p class="small mb-0">Mehr Inhalte, ggf. Fotoshooting & Spezialfunktionen (z. B. Buchung).</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Kosten-Treiber / Sparen -->
    <section class="container my-5">
      <div class="row g-4">
        <div class="col-md-6">
          <h2 class="h3">Was treibt Kosten hoch?</h2>
          <ul class="list-unstyled mb-0">
            <li>Viele Unterseiten & individuelle Funktionen</li>
            <li>Texte neu erstellen, Fotos/Videos produzieren</li>
            <li>Mehrsprachigkeit & Spezial-Integrationen</li>
          </ul>
        </div>
        <div class="col-md-6">
          <h2 class="h3">So sparst du Budget & Zeit</h2>
          <ul class="list-unstyled mb-0">
            <li>Inhalte früh liefern (Texte/Bilder)</li>
            <li>Klare Seitenstruktur von Beginn an</li>
            <li>Schnelle Feedback-Schleifen & Freigaben</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="container my-5">
      <h2 class="h3">FAQ – kurz & auf den Punkt</h2>
      <div class="accordion" id="faq1">
        <div class="accordion-item">
          <h2 class="accordion-header" id="q1a">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#a1a" aria-expanded="true" aria-controls="a1a">
              Was kostet eine einfache Website?
            </button>
          </h2>
        <div id="a1a" class="accordion-collapse collapse show" aria-labelledby="q1a" data-bs-parent="#faq1">
            <div class="accordion-body">
              Das Start-Paket beginnt bei <%= startPriceLabel %>. Business startet bei <%= businessPriceLabel %>, Wachstum bei <%= wachstumPriceLabel %>; Extras und laufende Kosten werden separat eingeordnet.
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <h2 class="accordion-header" id="q1b">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#a1b" aria-expanded="false" aria-controls="a1b">
              Wie lange dauert die Erstellung?
            </button>
          </h2>
          <div id="a1b" class="accordion-collapse collapse" aria-labelledby="q1b" data-bs-parent="#faq1">
            <div class="accordion-body">
              Typisch 2 bis 8 Wochen. Wenn Inhalte und Freigaben früh vorliegen, kann der Zeitplan kürzer ausfallen.
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <h2 class="accordion-header" id="q1c">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#a1c" aria-expanded="false" aria-controls="a1c">
              Was ist im Preis enthalten?
            </button>
          </h2>
          <div id="a1c" class="accordion-collapse collapse" aria-labelledby="q1c" data-bs-parent="#faq1">
            <div class="accordion-body">
              Design, Umsetzung, technische SEO-Grundlagen, technische Einrichtung und Beratung im vereinbarten Umfang. Rechtstexte, Hosting, Wartung und externe Tools werden separat geklärt.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="container my-5">
      <div class="cta-strip p-4 d-lg-flex justify-content-between align-items-center">
        <div class="me-3">
          <h3 class="h5 mb-1">Bereit für eine grobe Kostenschätzung in 24 Stunden?</h3>
          <p class="mb-0 text-muted small">Schick mir kurz dein Ziel & den Umfang – ich melde mich fix zurück.</p>
        </div>
        <div class="mt-3 mt-lg-0 d-flex gap-2">
          <a href="/kontakt" class="btn btn-primary">Kontakt aufnehmen</a>
          <a href="/pakete" class="btn btn-secondary">Pakete ansehen</a>
        </div>
      </div>
    </section>

  </main>

<%- include('../../partials/footer') %>

  <!-- JSON-LD Breadcrumbs + FAQ -->
  </body>
</html>
