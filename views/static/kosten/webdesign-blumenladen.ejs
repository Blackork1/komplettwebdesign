<%
const pageBase = (typeof canonicalBaseUrl !== 'undefined' && canonicalBaseUrl ? canonicalBaseUrl : 'https://komplettwebdesign.de').replace(/\/$/, '');
const startPriceLabel = (typeof packagePriceLabel === 'function' ? packagePriceLabel('start') : '') || 'nach Angebot';
const wachstumPriceLabel = (typeof packagePriceLabel === 'function' ? packagePriceLabel('wachstum') : '') || 'nach Angebot';
const structuredDataRaw = `<script type="application/ld+json">
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[
    {"@type":"ListItem","position":1,"name":"Start","item":"${pageBase}/"},
    {"@type":"ListItem","position":2,"name":"Branchen","item":"${pageBase}/branchen"},
    {"@type":"ListItem","position":3,"name":"Blumenladen-Website"}
  ]}
  </script>

<script type="application/ld+json">
  {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"Brauche ich direkt einen kompletten Shop?","acceptedAnswer":{"@type":"Answer","text":"Nicht unbedingt. Lokal reicht oft ein Produkt- oder Anfragebereich. Bezahl-Lösungen und Shop-Funktionen können später separat ergänzt werden."}},
    {"@type":"Question","name":"Wie pflege ich mein Sortiment?","acceptedAnswer":{"@type":"Answer","text":"Ein Editor kann vereinbart werden, wenn du Kategorien, Bilder oder Preise selbst pflegen möchtest. Umfang und Pflegeweg werden vorab festgelegt."}},
    {"@type":"Question","name":"Wie mache ich Saison-Angebote sichtbar?","acceptedAnswer":{"@type":"Answer","text":"Saison-Box auf der Startseite und kurze Landingpages, die du schnell ein- und ausblendest."}}
  ]}
  </script>`;
const seoExtra = `
  <meta property="og:title" content="Blumenladen-Website: Kosten & 4-Wochen-Zeitplan (Sortiment, Lieferung, Saison)" />
  <meta property="og:description" content="Klarer Preisrahmen, 4-Wochen-Ablauf und Tipps zu Sortiment, Lieferanfrage & saisonalen Specials." />
`;
%>
<%- include('../../partials/head', {
  title: 'Blumenladen-Website: Kosten & 4-Wochen-Zeitplan',
  description: 'Klarer Preisrahmen, 4-Wochen-Ablauf und Tipps zu Sortiment, Lieferanfrage und saisonalen Specials.',
  canonicalUrl: `${pageBase}/webdesign-blumenladen/kosten`,
  seoExtra,
  structuredDataRaw,
  extraCssAssets: ['cost-pages.css']
}) %>
<%- include('../../partials/header') %>

  <!-- Hero -->
  <header class="hero py-5">
    <div class="container py-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a class="text-white-50" href="/">Start</a></li>
          <li class="breadcrumb-item text-white-50"><a class="text-white-50" href="/branchen/webdesign-blumenladen">Webdesign-Blumenladen</a></li>
          <li class="breadcrumb-item active text-white" aria-current="page">Kosten und Zeitplan</li>
        </ol>
      </nav>
      <div class="col-lg-9">
        <h1 class="display-6 fw-bold text-white">Kosten & Zeitplan für eine Blumenladen-Website (Sortiment, Lieferanfrage, Saison-Specials)</h1>
        <p class="lead mt-2 text-white">Anlässe, Verfügbarkeit und schöne Bilder: So überzeugt dein Blumenladen online.</p>
        <div class="mt-3 d-flex gap-2">
          <a href="/branchen/webdesign-blumenladen" class="btn btn-primary">Blumenladen-Details</a>
          <a href="/kontakt" class="btn btn-secondary">Kostenschätzung</a>
        </div>
      </div>
    </div>
  </header>

  <main>

    <!-- Inhalte -->
    <section class="container my-5">
      <h2 class="h3">Was gehört in eine gute Blumenladen-Website?</h2>
      <div class="row g-4">
        <div class="col-md-6">
          <ul class="list-group list-group-flush">
            <li class="list-group-item">Start & Story: kurze Vorstellung, Ladenfotos</li>
            <li class="list-group-item">Sortiment: Sträuße nach Anlass, Pflanzen, Deko</li>
            <li class="list-group-item">Liefer-/Abholanfrage: Datum, Uhrzeit, Budget, Adresse</li>
            <li class="list-group-item">Galerie: 12–20 aussagekräftige Fotos</li>
          </ul>
        </div>
        <div class="col-md-6">
          <ul class="list-group list-group-flush">
            <li class="list-group-item">Anlässe & Services: Hochzeit, Trauer, Abo-Sträuße, Workshops</li>
            <li class="list-group-item">Infos: Öffnungszeiten, Lage/Anfahrt (Google Maps)</li>
            <li class="list-group-item">Bewertungen: Google-Reviews dezent</li>
            <li class="list-group-item">Saison: Valentinstag, Muttertag, Weihnachten</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Preise -->
    <section class="container my-5">
      <h2 class="h3">Preisrahmen</h2>
      <div class="row g-4">
        <div class="col-md-6">
          <div class="border rounded-3 p-4 h-100 card-shadow">
            <h3 class="h5">Kompakt (<%= startPriceLabel %>)</h3>
            <p class="small mb-0">Start, Sortiment (1–2 Kategorien), Galerie, Kontakt/Öffnungszeiten.</p>
          </div>
        </div>
        <div class="col-md-6">
          <div class="border rounded-3 p-4 h-100 card-shadow">
            <h3 class="h5">Plus (<%= wachstumPriceLabel %>)</h3>
            <p class="small mb-0">Liefer-/Abholanfrage, Anlässe-Seiten, Saison-Bereich und eine zweite Sprache können separat eingeordnet werden.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="container my-5">
      <h2 class="h3">Was den Preis bei einem Blumenladen beeinflusst</h2>
      <p>
        Der Umfang hängt vor allem davon ab, wie viele Angebote wirklich erklärt werden müssen und wie aktuell die Inhalte gehalten werden sollen.
        Eine kompakte Seite kann reichen, wenn Öffnungszeiten, Sortiment, Kontakt und wenige Beispielbilder im Mittelpunkt stehen.
        Wird zusätzlich mit Anlassseiten, Lieferanfrage, saisonalen Bereichen, Google-Business-Profil, Bildbearbeitung oder späterer Inhaltsverwaltung gearbeitet,
        entsteht Zusatzaufwand, der vorab separat eingeordnet wird.
      </p>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="border rounded-3 p-4 h-100 card-shadow">
            <h3 class="h5">Typische Basis</h3>
            <p class="small mb-0">Startseite, Sortiment, Öffnungszeiten, Kontakt, Anfahrt und ausgewählte Fotos im vereinbarten Umfang.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="border rounded-3 p-4 h-100 card-shadow">
            <h3 class="h5">Mögliche Erweiterungen</h3>
            <p class="small mb-0">Anlassseiten, Liefer- oder Abholanfrage, Saisonbereiche, Bilderrecherche, Local SEO oder einfache Inhaltsverwaltung.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="border rounded-3 p-4 h-100 card-shadow">
            <h3 class="h5">Laufende Kosten</h3>
            <p class="small mb-0">Domain, E-Mail, Hosting, Wartung, externe Tools und Lizenzen gehören nicht automatisch zum einmaligen Projektpreis.</p>
          </div>
        </div>
      </div>
      <p class="text-muted small mt-3">Alle Preise verstehen sich gemäß § 19 UStG ohne Ausweis der Umsatzsteuer. Die Beispiele sind Orientierung, keine verbindliche Endpreisgarantie.</p>
    </section>

    <!-- Zeitplan -->
    <section class="container my-5">
      <h2 class="h3">Realistischer 4-Wochen-Ablauf</h2>
      <div class="row g-4">
        <div class="col-md-3"><div class="p-3 border rounded-3 h-100 card-shadow"><strong>Woche 1</strong><br>Kickoff, Inhalte (Kategorien/Anlässe, Liefergebiet), Bilder</div></div>
        <div class="col-md-3"><div class="p-3 border rounded-3 h-100 card-shadow"><strong>Woche 2</strong><br>Design & Struktur, erste Vorschau</div></div>
        <div class="col-md-3"><div class="p-3 border rounded-3 h-100 card-shadow"><strong>Woche 3</strong><br>Umsetzung, Formular-Logik, Maps & Bewertungen</div></div>
        <div class="col-md-3"><div class="p-3 border rounded-3 h-100 card-shadow"><strong>Woche 4</strong><br>Tests (Formular/Mails), technische Einbindung vorhandener Rechtstexte, Go-Live</div></div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="container my-5">
      <h2 class="h3">Kurze FAQ</h2>
      <div class="accordion" id="faq4">
        <div class="accordion-item">
          <h2 class="accordion-header" id="q4a">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#a4a" aria-expanded="true" aria-controls="a4a">
              Brauche ich direkt einen kompletten Shop?
            </button>
          </h2>
          <div id="a4a" class="accordion-collapse collapse show" aria-labelledby="q4a" data-bs-parent="#faq4">
            <div class="accordion-body">Nicht unbedingt. Lokal reicht oft ein Produkt- oder Anfragebereich. Bezahl-Lösungen und Shop-Funktionen können später separat ergänzt werden.</div>
          </div>
        </div>
        <div class="accordion-item">
          <h2 class="accordion-header" id="q4b">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#a4b" aria-expanded="false" aria-controls="a4b">
              Wie pflege ich mein Sortiment?
            </button>
          </h2>
          <div id="a4b" class="accordion-collapse collapse" aria-labelledby="q4b" data-bs-parent="#faq4">
            <div class="accordion-body">Ein Editor kann vereinbart werden, wenn du Kategorien, Bilder oder Preise selbst pflegen möchtest. Umfang und Pflegeweg werden vorab festgelegt.</div>
          </div>
        </div>
        <div class="accordion-item">
          <h2 class="accordion-header" id="q4c">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#a4c" aria-expanded="false" aria-controls="a4c">
              Wie mache ich Saison-Angebote sichtbar?
            </button>
          </h2>
          <div id="a4c" class="accordion-collapse collapse" aria-labelledby="q4c" data-bs-parent="#faq4">
            <div class="accordion-body">Mit einer Saison-Box auf der Startseite und kurzen Landingpages (z. B. Valentinstag, Muttertag), die du schnell ein- und ausblendest.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="container my-5">
      <div class="p-4 border rounded-3 d-lg-flex justify-content-between align-items-center">
        <div class="me-3">
          <h3 class="h5 mb-1">Starte deine Blumenladen-Website</h3>
          <p class="mb-0 text-muted small">Sortiment & Lieferanfrage klar präsentiert – in 4 Wochen machbar.</p>
        </div>
        <div class="mt-3 mt-lg-0 d-flex gap-2">
          <a href="/kontakt" class="btn btn-primary">Kostenschätzung</a>
          <a href="/branchen/webdesign-blumenladen" class="btn btn-secondary">Details ansehen</a>
          <a href="/webdesign-berlin/kosten-preise-pakete" class="btn btn-secondary">Preise vergleichen</a>
        </div>
      </div>
    </section>

  </main>

<%- include('../../partials/footer') %>


  <!-- JSON-LD -->
  </body>
</html>
