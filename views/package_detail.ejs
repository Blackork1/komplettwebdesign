    </section>

    <section class="package-mid-cta" aria-label="<%= isEnglish ? 'Mid-page call to action' : 'Call-to-Action in der Seitenmitte' %>">
      <div class="container">
        <div class="mid-cta-inner">
          <div class="mid-cta-copy">
            <h2>
              <%= isEnglish
                ? `Ready to launch your ${displayPackName} website in Berlin?`
                : `Bereit für deine ${displayPackName}-Website in Berlin?`
              %>
            </h2>
            <p>
              <%= isEnglish
                ? 'Request a non-binding consultation or book a project call directly - we reply within one business day and prepare a transparent roadmap with timeline and fixed price.'
                : 'Fordere eine unverbindliche Beratung an oder buche direkt ein Projektgespräch - wir melden uns innerhalb eines Werktags und erstellen eine transparente Roadmap mit Zeitplan und Festpreis.'
              %>
            </p>
          </div>
          <div class="mid-cta-actions">
            <a class="btn btn-white" href="<%= isEnglish ? '/en/kontakt' : '/kontakt' %>">
              <%= isEnglish ? 'Request consultation' : 'Beratung anfragen' %>
            </a>
            <a class="btn btn-ghost" href="<%= isEnglish ? '/en/booking' : '/booking' %>">
              <%= isEnglish ? 'Book a project call' : 'Projektgespräch buchen' %>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="package-timeline-detail">
      <div class="container">
        <h2><%= isEnglish ? `Realistic timeline for the ${displayPackName} package` : `Realistischer Zeitplan für das ${displayPackName}-Paket` %></h2>
        <p class="timeline-lead">
          <%= isEnglish
            ? 'Every phase has a clear goal, a defined deliverable and an expected duration. You know at any point what we are working on, what we need from you and when the next milestone is due.'
            : 'Jede Phase hat ein klares Ziel, eine definierte Lieferung und eine erwartete Dauer. Du weißt jederzeit, woran wir arbeiten, was wir von dir benötigen und wann der nächste Meilenstein ansteht.'
          %>
        </p>
        <ol class="timeline-phases">
          <% timeline.forEach((step, index) => { %>
          <li>
            <span class="timeline-index"><%= String(index + 1).padStart(2, '0') %></span>
            <div class="timeline-content">
              <h3><%= step.label %></h3>
              <p><%= step.text %></p>
            </div>
          </li>
          <% }) %>
        </ol>
      </div>
    </section>

    <% if (faqs && faqs.length) { %>
    <section class="package-faq-detail" id="faq">
      <div class="container">
        <h2><%= isEnglish ? `FAQ about the ${displayPackName} package` : `Häufige Fragen zum ${displayPackName}-Paket` %></h2>
        <p class="faq-detail-lead">
          <%= isEnglish
            ? 'Precise answers to the most common questions about scope, timeline, SEO, GEO visibility and pricing - so you can request your offer with confidence.'
            : 'Präzise Antworten auf die wichtigsten Fragen zu Umfang, Zeitplan, SEO, GEO-Sichtbarkeit und Preisen - damit du dein Angebot mit Klarheit anfragen kannst.'
          %>
        </p>
        <div class="faq-detail-list">
          <% faqs.forEach((item, idx) => { %>
          <details class="faq-detail-item" <%= idx === 0 ? 'open' : '' %>>
            <summary><%= item.q %></summary>
            <p><%= item.a %></p>
          </details>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <section class="package-contact" id="kontaktformular">
      <div class="container contact-inner">
        <div class="contact-copy">
          <h2><%= isEnglish ? `Request ${displayPackName} package now` : `Jetzt ${displayPackName}-Paket anfragen` %></h2>
          <p>
            <%= isEnglish
              ? 'We get back to you within one business day, clarify open questions and show a live preview of what your new website can look like. The consultation is free and non-binding.'
              : 'Wir melden uns innerhalb eines Werktags, klären offene Fragen und zeigen dir anhand einer Live-Vorschau, wie deine neue Website aussehen kann. Das Beratungsgespräch ist kostenlos und unverbindlich.'
            %>
          </p>
          <% if (successMessage) { %>
          <div class="alert alert-success"><%= successMessage %></div>
          <% } %>
          <ul class="contact-highlights">
            <li><%= isEnglish ? 'Custom project roadmap with transparent pricing' : 'Individueller Projektplan und transparente Kostenaufstellung' %></li>
            <li><%= isEnglish ? 'Optional: choose a slot for an initial strategy call' : 'Optional: Termin für ein erstes Strategie-Gespräch wählen' %></li>
            <li><%= isEnglish ? 'Personal contact from concept to launch' : 'Persönliche Ansprechpartner von Konzeption bis Launch' %></li>
          </ul>
        </div>
        <div class="contact-form-wrapper">
          <form action="<%= isEnglish ? '/en' : '' %>/pakete/<%= slug %>/kontakt" method="POST" class="contact-form" data-recaptcha="v3" data-recaptcha-action="package_contact">
            <div class="form-group">
              <label for="inputName"><%= isEnglish ? 'Your name' : 'Ihr Name' %></label>
              <input type="text" id="inputName" name="name" placeholder="<%= isEnglish ? 'John Doe' : 'Max Mustermann' %>" required>
            </div>
            <div class="form-group">
              <label for="inputEmail"><%= isEnglish ? 'Your email address' : 'Ihre E-Mail-Adresse' %></label>
              <input type="email" id="inputEmail" name="email" placeholder="<%= isEnglish ? 'email@example.com' : 'email@beispiel.de' %>" required>
            </div>
            <% if (slots && slots.length > 0) { %>
            <div class="form-group">
              <label for="slot"><%= isEnglish ? 'Preferred consultation slot' : 'Wunschtermin für Beratungsgespräch' %></label>
              <select id="slot" name="slot">
                <% slots.forEach(s => { %>
                <option value="<%= s.id %>">
                  <%= new Date(s.start_time).toLocaleString(isEnglish ? 'en-US' : 'de-DE', {
                    weekday: 'short', day: '2-digit', month: 'short',
                    hour: '2-digit', minute: '2-digit'
                  }) %>
                </option>
                <% }) %>
              </select>
            </div>
            <% } else { %>
            <p class="no-slots"><%= isEnglish ? 'No free appointment slots are currently available. We will contact you shortly with proposed times.' : 'Zurzeit sind keine freien Termine buchbar. Wir melden uns zeitnah mit Terminvorschlägen.' %></p>
            <% } %>
            <input type="hidden" name="token"><!-- reCAPTCHA -->
            <input type="hidden" name="locale" value="<%= isEnglish ? 'en' : 'de' %>">
            <input type="hidden" name="package" value="<%= pack.name %>">
            <button type="submit" class="btn btn-hero w-100"><%= isEnglish ? 'Send non-binding request' : 'Unverbindliche Anfrage senden' %></button>
          </form>
        </div>
      </div>
    </section>

    <section class="package-previews" aria-label="<%= isEnglish ? 'Additional package overview' : 'Weitere Pakete im Überblick' %>">
      <div class="container">
        <h2><%= isEnglish ? 'Compare all options' : 'Alle Varianten im Vergleich' %></h2>
        <p class="previews-subtitle"><%= isEnglish ? 'See the key differences at a glance, including a preview for each option.' : 'Hier siehst du die wichtigsten Unterschiede auf einen Blick – inklusive Vorschau für jede Variante.' %></p>
        <div class="previews-grid">
          <% previewPackages.forEach(preview => { %>
          <article class="preview-card <%= isCurrent(preview) ? 'is-current' : '' %>">
            <div class="preview-image">
              <img src="<%= preview.image %>" alt="<%= isEnglish ? `Design preview of the ${preview.name} package` : `Design-Vorschau des ${preview.name}-Pakets` %>" loading="lazy">
            </div>
            <div class="preview-body">
              <span class="preview-label"><%= isEnglish ? 'Website package' : 'Website-Paket' %></span>
              <h3><%= preview.name %></h3>
              <p><%= preview.description %></p>
              <div class="preview-meta">
                <span class="preview-price"><%= preview.price %></span>
                <% if (isCurrent(preview)) { %>
                <span class="preview-current"><%= isEnglish ? 'Currently selected' : 'Aktuell ausgewählt' %></span>
                <% } %>
              </div>
              <a class="btn btn-soft-outline" href="<%= isEnglish ? '/en' : '' %>/pakete/<%= preview.slug %>"><%= isEnglish ? 'View preview' : 'Vorschau ansehen' %></a>
            </div>
          </article>
          <% }) %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>

</html>
