<%
const structuredDataBlocks = (typeof jsonLd !== 'undefined' && Array.isArray(jsonLd)) ? jsonLd : [];
%>
<%- include('partials/head', { structuredDataBlocks, extraCssAssets: ['package-list.css', 'package-detail.css'] }) %>

<body>
  <%- include('partials/header') %>

  <main class="packages-page package-detail-page">
    <%
      const isEnglish = typeof isEn !== 'undefined' && isEn;
      const slug = String(pack.slug || '').trim();
      const displayPackName = pack.displayName || pack.name || (isEnglish ? 'Website package' : 'Website-Paket');
      const packageName = pack.name || displayPackName;
      const priceDisplay = pack.priceLabel || '';
      const priceDisplayText = String(priceDisplay || '');
      const priceBreakMatch = priceDisplayText.match(/^(.+?€)\s+(oder nach Aufwand)$/);
      const detailPath = pack.canonicalPath || ('/pakete/' + slug);
      const localizedDetailPath = (isEnglish ? '/en' : '') + detailPath;
      const overviewPath = isEnglish ? '/en/pakete' : '/pakete';
      const overviewComparePath = overviewPath + '#vergleich';
      const contactPath = isEnglish ? '/en/kontakt' : '/kontakt';

      const imageByPackage = {
        start: '/images/paket-start.webp',
        business: '/images/paket-business.webp',
        wachstum: '/images/paket-wachstum.webp',
        individuell: '/images/paket-individuell.webp'
      };

      function textOf(item) {
        if (!item) return '';
        if (typeof item === 'string') return item;
        return item.text || item.body || item.value || item.label || item.title || '';
      }

      function packageTitle(pkg) {
        if (!pkg) return '';
        return pkg.displayName || pkg.name || '';
      }

      function packageUrl(pkg) {
        if (pkg && pkg.allowDetailPage === false) {
          const packageValue = pkg.packageKey || pkg.slug || '';
          return `${contactPath}${packageValue ? `?paket=${encodeURIComponent(packageValue)}` : ''}`;
        }
        const canonical = pkg && pkg.canonicalPath ? pkg.canonicalPath : ('/pakete/' + (pkg && pkg.slug ? pkg.slug : ''));
        return (isEnglish ? '/en' : '') + canonical;
      }

      function packageImage(pkg) {
        if (pkg && pkg.image) return pkg.image;
        return imageByPackage[pkg && pkg.slug] || '/images/preiseHero.webp';
      }

      function faqQuestion(item) {
        return item && (item.question || item.q || item.title || '');
      }

      function faqAnswer(item) {
        return item && (item.answer || item.a || item.text || '');
      }

      const featureItems = Array.isArray(pack.features) ? pack.features : [];
      const notIncludedItems = Array.isArray(pack.notIncluded) ? pack.notIncluded : [];
      const useCaseItems = Array.isArray(pack.useCases) ? pack.useCases : [];
      const packageFaqItems = Array.isArray(pack.faqs) ? pack.faqs : [];
      const noteItems = Array.isArray(globalNotes) ? globalNotes : [];
      const optionalAddOnItems = typeof optionalAddOns !== 'undefined' && Array.isArray(optionalAddOns) ? optionalAddOns : [];
      const rawAddOnsTickerDuration = typeof addOnsTickerDurationSeconds !== 'undefined' ? addOnsTickerDurationSeconds : 35;
      const addOnsTickerDurationValue = Number(rawAddOnsTickerDuration);
      const addOnsTickerDuration = Number.isFinite(addOnsTickerDurationValue)
        ? Math.min(180, Math.max(8, addOnsTickerDurationValue))
        : 35;
      const previewItems = Array.isArray(previewPackages)
        ? previewPackages.filter((preview) => preview && preview.allowDetailPage !== false)
        : [];
      const shortDescription = pack.shortDescription || pack.description || pack.positioning || '';
      const longDescription = pack.longDescription || shortDescription;
      const heroHighlights = [
        pack.pageScope ? (isEnglish ? 'Page scope: ' : 'Seitenumfang: ') + pack.pageScope : '',
        pack.feedbackRounds ? (isEnglish ? 'Review rounds: ' : 'Feedbackrunden: ') + pack.feedbackRounds : '',
        pack.timeline ? (isEnglish ? 'Timeline: ' : 'Zeitplan: ') + pack.timeline : ''
      ].filter(Boolean);

      const detailEntries = [
        [isEnglish ? 'Page scope' : 'Seitenumfang', pack.pageScope],
        [isEnglish ? 'Text scope' : 'Textumfang', pack.textScope],
        [isEnglish ? 'SEO scope' : 'SEO-Umfang', pack.seoScope],
        [isEnglish ? 'Technical scope' : 'Technik-Umfang', pack.techScope],
        [isEnglish ? 'Review rounds' : 'Feedbackrunden', pack.feedbackRounds],
        [isEnglish ? 'Timeline' : 'Zeitplan', pack.timeline],
        [isEnglish ? 'Target group' : 'Zielgruppe', pack.targetGroup],
        [isEnglish ? 'Not ideal for' : 'Nicht ideal für', pack.notFor]
      ].filter((entry) => entry[1]);

      const overviewCards = [
        {
          title: isEnglish ? 'Clear package scope' : 'Klarer Paketumfang',
          text: pack.pageScope || shortDescription
        },
        {
          title: isEnglish ? 'Defined feedback' : 'Definierte Abstimmung',
          text: pack.feedbackRounds ? (isEnglish ? 'Feedback rounds: ' : 'Feedbackrunden: ') + pack.feedbackRounds : (isEnglish ? 'Feedback and changes are agreed before implementation.' : 'Feedback und Änderungen werden vor der Umsetzung eingeordnet.')
        },
        {
          title: isEnglish ? 'Separate add-ons' : 'Saubere Abgrenzung',
          text: notIncludedItems.length ? textOf(notIncludedItems[0]) : (isEnglish ? 'Add-ons and external costs are clarified separately.' : 'Zusatzleistungen und externe Kosten werden separat geklärt.')
        }
      ].filter((item) => item.text);

      const scopeBoundaryBlocks = [
        {
          title: isEnglish ? 'Included services' : 'Enthaltene Leistungen',
          type: 'included',
          items: featureItems.map(textOf).filter(Boolean).slice(0, 10)
        },
        {
          title: isEnglish ? 'Not automatically included' : 'Nicht automatisch enthalten',
          type: 'excluded',
          items: notIncludedItems.map(textOf).filter(Boolean).slice(0, 10)
        },
        {
          title: isEnglish ? 'Typical use cases' : 'Typische Einsatzfälle',
          type: 'use-cases',
          items: useCaseItems.map(textOf).filter(Boolean).slice(0, 10)
        },
        {
          title: isEnglish ? 'Important notes' : 'Wichtige Hinweise',
          type: 'neutral',
          items: noteItems.map(textOf).filter(Boolean).slice(0, 6)
        }
      ].filter((block) => block.items.length);

      const processSteps = [
        {
          label: isEnglish ? 'Inquiry and scope' : 'Anfrage und Einordnung',
          text: isEnglish ? 'We clarify goals, scope, existing content and whether this package fits.' : 'Ich kläre Ziele, Umfang, vorhandene Inhalte und ob dieses Paket zum Projekt passt.'
        },
        {
          label: isEnglish ? 'Offer and structure' : 'Angebot und Struktur',
          text: isEnglish ? 'The agreed scope, add-ons, feedback rounds and timeline are documented before implementation.' : 'Vereinbarter Umfang, Zusatzleistungen, Feedbackrunden und Zeitplan werden vor der Umsetzung festgehalten.'
        },
        {
          label: isEnglish ? 'Implementation and approval' : 'Umsetzung und Freigabe',
          text: isEnglish ? 'The website is implemented server-side and prepared for approval, launch and optional support.' : 'Die Website wird serverseitig umgesetzt und für Freigabe, Livegang und optionale Betreuung vorbereitet.'
        }
      ];

      const heroImage = packageImage(pack);
      const isCurrent = (preview) => preview && preview.slug === slug;
    %>

    <section class="packages-hero package-detail-hero unified-hero" data-reveal-immediate>
      <div class="container hero-grid unified-hero__grid">
        <div class="hero-copy unified-hero__copy">
          <nav class="unified-hero__breadcrumbs" aria-label="Breadcrumb">
            <ol>
              <li><a href="<%= isEnglish ? '/en' : '/' %>"><%= isEnglish ? 'Home' : 'Startseite' %></a></li>
              <li><a href="<%= overviewPath %>"><%= isEnglish ? 'Packages' : 'Pakete' %></a></li>
              <li aria-current="page"><%= displayPackName %></li>
            </ol>
          </nav>
          <h1 class="hero-title home-hero-reveal home-hero-reveal--h1 animate-on-scroll"><%= pack.h1 || displayPackName %></h1>
          <% if (shortDescription) { %>
          <p class="hero-subtitle unified-hero__lead home-hero-reveal home-hero-reveal--support animate-on-scroll"><%= shortDescription %></p>
          <% } %>
          <% if (heroHighlights.length) { %>
          <ul class="hero-highlights">
            <% heroHighlights.forEach(item => { %>
            <li class="home-hero-reveal home-hero-reveal--bullet animate-on-scroll">
              <img src="/images/icons/check.svg" alt="" width="26" height="26" loading="lazy">
              <span><%= item %></span>
            </li>
            <% }) %>
          </ul>
          <% } %>
          <div class="hero-meta">
            <% if (priceDisplay) { %>
            <div class="hero-price home-hero-reveal home-hero-reveal--price animate-on-scroll">
              <div class="hero-price-copy">
                <span class="price-label"><%= isEnglish ? 'Investment' : 'Investition' %></span>
                <span class="price-amount">
                  <% if (priceBreakMatch) { %>
                  <%= priceBreakMatch[1] %><br><span class="price-amount__suffix"><%= priceBreakMatch[2] %></span>
                  <% } else { %>
                  <%= priceDisplay %>
                  <% } %>
                </span>
              </div>
              <div class="hero-actions unified-hero__actions">
                <a class="btn btn-primary" href="#kontaktformular" data-track="cta" data-event-name="package_detail_cta_click" data-cta-name="package_detail_hero_contact_<%= slug %>" data-cta-location="package_detail_hero" data-package-id="<%= slug %>"><%= pack.ctaLabel || (isEnglish ? 'Request package' : 'Paket anfragen') %></a>
                <a class="btn btn-secondary" href="<%= overviewComparePath %>" data-track="cta" data-event-name="package_detail_cta_click" data-cta-name="package_detail_hero_compare_<%= slug %>" data-cta-location="package_detail_hero" data-package-id="<%= slug %>"><%= isEnglish ? 'Compare packages' : 'Pakete vergleichen' %></a>
              </div>
            </div>
            <% } %>
            <% if (pack.recommendationLabel) { %>
            <p class="hero-note"><%= pack.recommendationLabel %></p>
            <% } %>
          </div>
        </div>
        <div class="hero-visual">
          <div class="hero-image-frame unified-hero__media-frame">
            <img src="<%= heroImage %>" alt="<%= isEnglish ? 'Preview of the package' : 'Vorschau des Pakets' %>" loading="lazy">
          </div>
        </div>
      </div>
    </section>

    <section class="package-overview">
      <div class="container overview-grid">
        <div class="overview-intro">
          <h2><%= isEnglish ? 'Package overview' : 'Paket im Überblick' %></h2>
          <% if (longDescription) { %>
          <p><%= longDescription %></p>
          <% } %>
        </div>
        <% if (overviewCards.length) { %>
        <div class="overview-cards">
          <% overviewCards.forEach(block => { %>
          <article class="overview-card">
            <h3><%= block.title %></h3>
            <p><%= block.text %></p>
          </article>
          <% }) %>
        </div>
        <% } %>
      </div>
    </section>

    <% if (detailEntries.length) { %>
    <section class="package-detail-sections">
      <div class="container">
        <h2><%= isEnglish ? 'Detailed scope of services' : 'Leistungsumfang im Detail' %></h2>
        <div class="detail-grid">
          <% detailEntries.forEach(([title, text]) => { %>
          <article class="detail-card">
            <h3><%= title %></h3>
            <div class="detail-text"><%= text %></div>
          </article>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <% if (scopeBoundaryBlocks.length) { %>
    <section class="package-scope-boundaries">
      <div class="container">
        <h2><%= isEnglish ? 'Scope boundaries before implementation starts' : 'Leistungsgrenzen vor der Umsetzung' %></h2>
        <p class="scope-lead">
          <%= isEnglish
            ? 'The package price covers the agreed website scope. Add-ons, running costs, external tools and legal review remain separate unless they are explicitly included in the offer.'
            : 'Der Paketpreis gilt für den vereinbarten Website-Umfang. Zusatzleistungen, laufende Kosten, externe Tools und rechtliche Prüfung bleiben separat, sofern sie nicht ausdrücklich im Angebot stehen.'
          %>
        </p>
        <div class="scope-grid">
          <% scopeBoundaryBlocks.forEach(block => { %>
          <article class="scope-card scope-card--<%= block.type || 'neutral' %>">
            <h3><%= block.title %></h3>
            <ul>
              <% block.items.forEach(item => { %>
              <li><%= item %></li>
              <% }) %>
            </ul>
          </article>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <section class="package-process">
      <div class="container">
        <h2><%= isEnglish ? 'How the project runs' : 'So läuft das Projekt ab' %></h2>
        <div class="process-timeline">
          <% processSteps.forEach((step, index) => { %>
          <div class="process-step">
            <span class="process-index"><%= String(index + 1).padStart(2, '0') %></span>
            <div class="process-content">
              <h3><%= step.label %></h3>
              <p><%= step.text %></p>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </section>

    <section class="package-addons">
      <div class="container addons-grid">
        <div class="addons-intro">
          <h2><%= isEnglish ? 'Optional extensions and services' : 'Optionale Erweiterungen und Services' %></h2>
          <p>
            <%= isEnglish
              ? 'Optional services are scoped separately so the package remains clear and does not promise functions that are not needed.'
              : 'Optionale Leistungen werden separat eingeordnet, damit das Paket klar bleibt und keine Funktionen verspricht, die dein Projekt nicht braucht.'
            %>
          </p>
        </div>
        <aside class="addons-ticker" data-addons-ticker data-ticker-duration="<%= addOnsTickerDuration %>" aria-label="<%= isEnglish ? 'Optional add-ons' : 'Optionale Zusatzleistungen' %>">
          <div class="addons-ticker__track">
            <ul class="addons-list addons-ticker__group">
              <% if (optionalAddOnItems.length) { %>
              <% optionalAddOnItems.slice(0, 8).forEach(addOn => { %>
              <li>
                <span aria-hidden="true">+</span>
                <span>
                  <strong><%= addOn.name %><% if (addOn.priceLabel) { %> · <%= addOn.priceLabel %><% } %></strong>
                  <% if (addOn.shortDescription) { %><br><%= addOn.shortDescription %><% } %>
                </span>
              </li>
              <% }) %>
              <% } else { %>
              <% (notIncludedItems.length ? notIncludedItems : noteItems).map(textOf).filter(Boolean).slice(0, 8).forEach(item => { %>
              <li><span aria-hidden="true">+</span><span><%= item %></span></li>
              <% }) %>
              <% } %>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <% if (pack.targetGroup || pack.notFor || useCaseItems.length) { %>
    <section class="package-who-for">
      <div class="container">
        <h2><%= isEnglish ? 'Who this package fits' : 'Für wen dieses Paket passt' %></h2>
        <% if (pack.targetGroup) { %>
        <p class="package-who-intro"><%= pack.targetGroup %></p>
        <% } %>
        <% if (useCaseItems.length) { %>
        <ul class="who-for-list">
          <% useCaseItems.map(textOf).filter(Boolean).forEach(item => { %>
          <li><%= item %></li>
          <% }) %>
        </ul>
        <% } %>
        <% if (pack.notFor) { %>
        <p class="package-who-intro"><strong><%= isEnglish ? 'Not ideal:' : 'Nicht ideal:' %></strong> <%= pack.notFor %></p>
        <% } %>
      </div>
    </section>
    <% } %>

    <section class="package-outcomes">
      <div class="container">
        <h2><%= isEnglish ? 'What this package clarifies' : 'Was dieses Paket klärt' %></h2>
        <div class="outcomes-grid">
          <% [pack.positioning, pack.seoScope, pack.techScope].filter(Boolean).forEach((item, index) => { %>
          <article class="outcome-card">
            <h3><%= [isEnglish ? 'Positioning' : 'Positionierung', isEnglish ? 'SEO foundation' : 'SEO-Grundlage', isEnglish ? 'Technical foundation' : 'Technische Grundlage'][index] || (isEnglish ? 'Result' : 'Ergebnis') %></h3>
            <p><%= item %></p>
          </article>
          <% }) %>
        </div>
      </div>
    </section>

    <section class="package-mid-cta" aria-label="<%= isEnglish ? 'Mid-page inquiry section' : 'Anfragebereich in der Seitenmitte' %>">
      <div class="container">
        <div class="mid-cta-inner">
          <div class="mid-cta-copy">
            <h2><%= isEnglish ? 'Clarify this package' : 'Dieses Paket einordnen lassen' %></h2>
            <p>
              <%= isEnglish
                ? 'Start with a non-binding request. Scope, add-ons and running costs are clarified before implementation.'
                : 'Starte mit einer unverbindlichen Anfrage. Umfang, Zusatzleistungen und laufende Kosten werden vor der Umsetzung sauber geklärt.'
              %>
            </p>
          </div>
          <div class="mid-cta-actions">
            <a class="btn btn-primary" href="<%= contactPath %>" data-track="cta" data-event-name="package_detail_cta_click" data-cta-name="package_detail_mid_contact_<%= slug %>" data-cta-location="package_detail_mid" data-package-id="<%= slug %>"><%= isEnglish ? 'Request project' : 'Projekt anfragen' %></a>
            <a class="btn btn-secondary" href="<%= overviewComparePath %>" data-track="cta" data-event-name="package_detail_cta_click" data-cta-name="package_detail_mid_compare_<%= slug %>" data-cta-location="package_detail_mid" data-package-id="<%= slug %>"><%= isEnglish ? 'Compare packages' : 'Pakete vergleichen' %></a>
          </div>
        </div>
      </div>
    </section>

    <% if (packageFaqItems.length) { %>
    <section class="package-faq-detail" id="faq">
      <div class="container">
        <h2><%= isEnglish ? 'Frequently asked questions' : 'Häufige Fragen' %></h2>
        <p class="faq-detail-lead">
          <%= isEnglish
            ? 'These answers summarize the most important questions about scope, boundaries and project flow for this package.'
            : 'Diese Antworten fassen die wichtigsten Fragen zu Umfang, Abgrenzung und Ablauf dieses Pakets zusammen.'
          %>
        </p>
        <div class="faq-detail-list">
          <% packageFaqItems.forEach((item, idx) => { %>
          <details class="faq-detail-item" <%= idx === 0 ? 'open' : '' %>>
            <summary><%= faqQuestion(item) %></summary>
            <p><%= faqAnswer(item) %></p>
          </details>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <section class="package-contact" id="kontaktformular">
      <div class="container contact-inner">
        <div class="contact-copy">
          <h2><%= isEnglish ? 'Request this package' : 'Dieses Paket anfragen' %></h2>
          <p>
            <%= isEnglish
              ? 'Send a non-binding request. I will review the project scope and come back with the next realistic step.'
              : 'Sende eine unverbindliche Anfrage. Ich prüfe den Projektumfang und melde mich mit dem nächsten sinnvollen Schritt.'
            %>
          </p>
          <% if (successMessage) { %>
          <div class="alert alert-success"><%= successMessage %></div>
          <% } %>
          <ul class="contact-highlights">
            <li>
              <img src="/images/icons/check.svg" alt="" width="26" height="26" loading="lazy">
              <span><%= isEnglish ? 'Package scope and add-ons clarified before implementation' : 'Paketumfang und Zusatzleistungen werden vor der Umsetzung geklärt' %></span>
            </li>
            <li>
              <img src="/images/icons/check.svg" alt="" width="26" height="26" loading="lazy">
              <span><%= isEnglish ? 'Optional appointment slot for an initial call' : 'Optionaler Termin für ein erstes Gespräch' %></span>
            </li>
            <li>
              <img src="/images/icons/check.svg" alt="" width="26" height="26" loading="lazy">
              <span><%= isEnglish ? 'Personal contact from concept to launch' : 'Persönliche Betreuung von Konzept bis Livegang' %></span>
            </li>
          </ul>
        </div>
        <div class="contact-form-wrapper">
          <form action="<%= localizedDetailPath %>/kontakt" method="POST" class="contact-form" data-recaptcha="v3" data-recaptcha-action="package_contact">
            <div class="form-group">
              <label for="inputName"><%= isEnglish ? 'Your name' : 'Dein Name' %></label>
              <input type="text" id="inputName" name="name" placeholder="<%= isEnglish ? 'John Doe' : 'Max Mustermann' %>" required>
            </div>
            <div class="form-group">
              <label for="inputEmail"><%= isEnglish ? 'Your email address' : 'Deine E-Mail-Adresse' %></label>
              <input type="email" id="inputEmail" name="email" placeholder="<%= isEnglish ? 'email@example.com' : 'email@beispiel.de' %>" required>
            </div>
            <% if (slots && slots.length > 0) { %>
            <div class="form-group">
              <label for="slot"><%= isEnglish ? 'Preferred consultation slot' : 'Wunschtermin für Beratungsgespräch' %></label>
              <select id="slot" name="slot" data-package-slot-select>
                <% slots.forEach(s => { %>
                <option value="<%= s.id %>">
                  <%= new Date(s.start_time).toLocaleString(isEnglish ? 'en-US' : 'de-DE', {
                    weekday: 'short', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit'
                  }) %>
                </option>
                <% }) %>
                <option value="__custom" data-package-custom-slot><%= isEnglish ? 'Other appointment' : 'Anderen Termin' %></option>
              </select>
              <p class="package-slot-selected" data-package-selected-summary hidden></p>
            </div>
            <% } else { %>
            <p class="no-slots"><%= isEnglish ? 'No free appointment slots are currently available. We will contact you shortly with proposed times.' : 'Zurzeit sind keine freien Termine buchbar. Ich melde mich zeitnah mit Terminvorschlägen.' %></p>
            <% } %>
            <input type="hidden" name="token">
            <input type="hidden" name="locale" value="<%= isEnglish ? 'en' : 'de' %>">
            <input type="hidden" name="package" value="<%= packageName %>">
            <button type="submit" class="btn btn-primary w-100"><%= isEnglish ? 'Send non-binding request' : 'Unverbindliche Anfrage senden' %></button>
          </form>
          <% if (slots && slots.length > 0) { %>
          <div class="package-slot-overlay" data-package-slot-overlay data-lng="<%= isEnglish ? 'en' : 'de' %>" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="package-slot-overlay-title" hidden>
            <button type="button" class="package-slot-backdrop" data-package-slot-close aria-label="<%= isEnglish ? 'Close appointment calendar' : 'Terminkalender schließen' %>"></button>
            <div class="package-slot-dialog" role="document">
              <div class="package-slot-dialog__header">
                <div>
                  <p class="package-slot-eyebrow"><%= isEnglish ? 'Calendar' : 'Kalender' %></p>
                  <h3 id="package-slot-overlay-title"><%= isEnglish ? 'Choose another appointment' : 'Anderen Termin auswählen' %></h3>
                  <p data-package-slot-status><%= isEnglish ? 'First choose a day with available appointments.' : 'Wähle zuerst einen Tag mit freien Terminen.' %></p>
                </div>
                <button type="button" class="package-slot-close" data-package-slot-close aria-label="<%= isEnglish ? 'Close' : 'Schließen' %>">×</button>
              </div>

              <div class="package-slot-dialog__grid">
                <section class="package-slot-calendar" aria-label="<%= isEnglish ? 'Available days' : 'Freie Tage' %>">
                  <div class="package-slot-calendar__header">
                    <button type="button" class="package-slot-nav" data-package-slot-dir="-1" aria-label="<%= isEnglish ? 'Previous month' : 'Vorheriger Monat' %>">‹</button>
                    <h4 data-package-month-label></h4>
                    <button type="button" class="package-slot-nav" data-package-slot-dir="1" aria-label="<%= isEnglish ? 'Next month' : 'Nächster Monat' %>">›</button>
                  </div>
                  <div class="package-slot-weekdays" data-package-calendar-weekdays></div>
                  <div class="package-slot-calendar-grid" data-package-calendar-days></div>
                </section>

                <section class="package-slot-times" aria-live="polite">
                  <div class="package-slot-step" data-package-day-panel>
                    <h4><%= isEnglish ? '1. Select day' : '1. Tag auswählen' %></h4>
                    <p><%= isEnglish ? 'Only days with free backend slots can be selected.' : 'Auswählbar sind nur Tage mit freien Backend-Terminen.' %></p>
                  </div>
                  <div class="package-slot-step" data-package-time-panel hidden>
                    <button type="button" class="package-slot-back" data-package-back-to-days>← <%= isEnglish ? 'Back to days' : 'Zurück zu den Tagen' %></button>
                    <h4 data-package-selected-date></h4>
                    <p><%= isEnglish ? '2. Select time' : '2. Uhrzeit auswählen' %></p>
                    <div class="package-slot-time-list" data-package-time-list></div>
                  </div>
                </section>
              </div>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </section>

    <% if (previewItems.length) { %>
    <section class="package-previews" aria-label="<%= isEnglish ? 'Additional package overview' : 'Weitere Pakete im Überblick' %>">
      <div class="container">
        <h2><%= isEnglish ? 'Compare all package options' : 'Alle Paketoptionen vergleichen' %></h2>
        <p class="previews-subtitle"><%= isEnglish ? 'Compare the other package options and choose the smallest sensible scope for your project.' : 'Vergleiche die weiteren Paketoptionen und wähle den kleinsten sinnvollen Umfang für dein Projekt.' %></p>
        <div class="previews-grid">
          <% previewItems.forEach(preview => { %>
          <article class="preview-card <%= isCurrent(preview) ? 'is-current' : '' %>">
            <div class="preview-image">
              <img src="<%= packageImage(preview) %>" alt="<%= packageTitle(preview) %>" loading="lazy">
            </div>
            <div class="preview-body">
              <span class="preview-eyebrow"><%= preview.priceLabel %></span>
              <h3><%= packageTitle(preview) %></h3>
              <p><%= preview.shortDescription || preview.positioning || '' %></p>
              <a class="btn btn-secondary" href="<%= packageUrl(preview) %>" data-track="cta" data-event-name="package_card_click" data-cta-name="package_detail_preview_<%= preview.slug %>" data-cta-location="package_detail_preview" data-package-id="<%= preview.slug %>"><%= isEnglish ? 'View package' : 'Paket ansehen' %></a>
            </div>
          </article>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>
  </main>

  <script>
    (() => {
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      const durationSecondsFrom = (ticker) => {
        const rawDuration = String(ticker.dataset.tickerDuration || '').trim();
        const numericValue = Number.parseFloat(rawDuration);
        if (!Number.isFinite(numericValue)) return 35;
        return Math.min(180, Math.max(8, numericValue));
      };

      document.querySelectorAll('[data-addons-ticker]').forEach((ticker) => {
        if (ticker.dataset.tickerReady === 'true') return;

        const track = ticker.querySelector('.addons-ticker__track');
        const group = ticker.querySelector('.addons-ticker__group');
        if (!track || !group || group.children.length < 2) return;

        const clone = group.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        track.appendChild(clone);
        ticker.dataset.tickerReady = 'true';

        let groupWidth = 0;
        let pixelsPerMs = 0;
        let lastFrame = null;

        const measure = () => {
          groupWidth = group.getBoundingClientRect().width;
          pixelsPerMs = groupWidth / (durationSecondsFrom(ticker) * 1000);
          normalizeScrollPosition();
        };

        const normalizeScrollPosition = () => {
          if (!groupWidth) return;
          if (ticker.scrollLeft >= groupWidth) {
            ticker.scrollLeft -= groupWidth;
          }
        };

        const tick = (timestamp) => {
          if (lastFrame === null) lastFrame = timestamp;
          const delta = timestamp - lastFrame;
          lastFrame = timestamp;

          const canAutoScroll = !reducedMotion.matches;

          if (canAutoScroll && groupWidth > 0) {
            ticker.scrollLeft += delta * pixelsPerMs;
            normalizeScrollPosition();
          }

          window.requestAnimationFrame(tick);
        };

        measure();
        window.addEventListener('resize', measure, {
          passive: true
        });

        window.requestAnimationFrame(tick);
      });
    })();
  </script>
  <script src="<%= (typeof jsAsset === 'function' ? jsAsset('js/package-detail.js') : '/js/package-detail.js?v=' + encodeURIComponent(assetVersion || '1')) %>" defer></script>

  <%- include('partials/footer') %>
</body>

</html>
