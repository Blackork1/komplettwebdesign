          const parsed = Number(priceValue);
          if (!Number.isNaN(parsed)) {
            return parsed.toLocaleString(isEnglish ? 'en-US' : 'de-DE', { style: 'currency', currency: 'EUR' });
          }
          return pkg.price;
        }
        if (pkg.price_formatted) return pkg.price_formatted;
        if (pkg.price_amount_cents != null) {
          return (Number(pkg.price_amount_cents) / 100).toLocaleString(isEnglish ? 'en-US' : 'de-DE', {
            style: 'currency',
            currency: 'EUR'
          });
        }
        if (pkg.price_amount != null) {
          return Number(pkg.price_amount).toLocaleString(isEnglish ? 'en-US' : 'de-DE', {
