<%- include('partials/head') %>
<% const isEn = typeof lng !== 'undefined' && lng === 'en'; %>
<body class="website-tester-page">
  <%- include('partials/header') %>

  <main id="hero">
    <link rel="stylesheet" href="<%= cssAsset('website-tester.css') %>">

    <section class="wt-section wt-section-compact">
      <div class="wt-shell">
        <nav class="breadcrumbs" aria-label="breadcrumb">
          <ol>
            <li><a href="<%= isEn ? '/en' : '/' %>"><%= isEn ? 'Home' : 'Startseite' %></a></li>
            <li><a href="<%= isEn ? '/en/website-tester' : '/website-tester' %>"><%= isEn ? 'Website Tester' : 'Website-Tester' %></a></li>
            <li aria-current="page"><%= isEn ? 'Broken Links Tester' : 'Broken Links Tester' %></li>
          </ol>
        </nav>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-cta-card wt-cta-inline">
          <h2><%= isEn ? 'Want expert help improving your website results?' : 'Du möchtest deine Website-Ergebnisse professionell verbessern?' %></h2>
          <p>
            <%= isEn
              ? 'Get a short, practical consultation: we prioritize your biggest SEO and UX blockers and define a clear action plan.'
              : 'Hol dir eine kurze, praktische Beratung: Wir priorisieren deine größten SEO- und UX-Bremsen und erstellen einen klaren Maßnahmenplan.' %>
          </p>
          <div class="wt-result-meta">
            <a class="wt-button" href="<%= isEn ? '/en/kontakt' : '/kontakt' %>">
              <i class="fa-solid fa-comments"></i>
              <%= isEn ? 'Get consultation' : 'Beratung anfragen' %>
            </a>
            <a class="wt-button-secondary" href="/booking">
              <i class="fa-solid fa-calendar-check"></i>
              <%= isEn ? 'Book appointment' : 'Termin buchen' %>
            </a>
          </div>
        </article>
      </div>
    </section>

    <section class="wt-hero">
      <div class="wt-shell">
        <div class="wt-hero-grid">
          <div class="wt-hero-copy">
            <span class="wt-eyebrow">
              <i class="fa-solid fa-link-slash"></i>
              <%= isEn ? 'Broken Links Tester' : 'Broken Links Tester' %>
            </span>
            <h1><%= isEn ? 'Find broken internal and external links on your website.' : 'Finde defekte interne und externe Links auf deiner Website.' %></h1>
            <p class="wt-lead">
              <%= isEn
                ? 'Enter your website URL and scan for broken links across subpages. You get an instant summary plus a detailed list with source page and target URL.'
                : 'Gib deine Website-URL ein und scanne Unterseiten auf defekte Links. Du erhältst sofort eine Zusammenfassung plus detaillierte Liste mit Quellseite und Ziel-URL.' %>
            </p>
            <ul class="wt-pill-list">
              <li><i class="fa-solid fa-sitemap"></i> <%= isEn ? 'Looks at important internal pages' : 'Betrachtet wichtige interne Seiten' %></li>
              <li><i class="fa-solid fa-link"></i> <%= isEn ? 'Checks internal + external links' : 'Prüft interne + externe Links' %></li>
              <li><i class="fa-solid fa-triangle-exclamation"></i> <%= isEn ? 'Shows where visitors may hit dead ends' : 'Zeigt, wo Besucher ins Leere laufen können' %></li>
            </ul>
          </div>

          <div class="wt-form-card">
            <h2><%= isEn ? 'Enter website URL' : 'Website-Adresse eingeben' %></h2>
            <p><%= isEn ? 'No signup required. Start scan now.' : 'Kein Login nötig. Starte den Scan direkt.' %></p>
            <form data-broken-links-form>
              <label class="visually-hidden" for="broken-links-url"><%= isEn ? 'Website URL' : 'Website-URL' %></label>
              <div class="wt-form-row">
                <input id="broken-links-url" name="url" type="text" inputmode="url" placeholder="<%= isEn ? 'https://your-website.com' : 'https://deine-website.de' %>" required>
                <button class="wt-button" type="submit">
                  <i class="fa-solid fa-bolt"></i>
                  <%= isEn ? 'Run Scan' : 'Scan starten' %>
                </button>
              </div>
            </form>
            <p class="wt-form-note">
              <%= isEn
                ? 'Result includes scan scope, broken links, warnings, and source pages.'
                : 'Das Ergebnis zeigt defekte Links, Warnungen und die betroffenen Quellseiten.' %>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel" data-broken-links-loading hidden>
          <h3><%= isEn ? 'Scan in progress…' : 'Scan läuft…' %></h3>
          <p><%= isEn ? 'We are crawling pages and validating all discovered links.' : 'Wir crawlen Seiten und validieren alle gefundenen Links.' %></p>
          <ul class="wt-progress">
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Validate target URL and crawl start page' : 'Ziel-URL validieren und Startseite laden' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Crawl internal pages' : 'Interne Seiten crawlen' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Check link targets (HEAD/GET)' : 'Link-Ziele prüfen (HEAD/GET)' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Build summary and detail list' : 'Zusammenfassung und Detail-Liste erstellen' %></span></li>
          </ul>
        </div>

        <div class="wt-error" data-broken-links-error hidden></div>
        <div id="broken-links-results" class="wt-results" data-broken-links-results hidden></div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel wt-methodology">
          <h2><%= isEn ? 'How the Broken Links Tester scans your website' : 'So scannt der Broken-Links-Tester deine Website' %></h2>
          <p>
            <%= isEn
              ? 'The scanner starts at your URL, extracts every internal and external link on the page, and for larger sites follows the internal page graph within a defined scan scope. Each discovered link is requested via HEAD (falling back to GET) and classified by HTTP status. The result separates hard errors (4xx/5xx) from warnings (3xx chains, slow responses, protocol mismatches) so you can focus fixes where they matter.'
              : 'Der Link-Check startet an deiner Website und prüft wichtige interne und externe Links. Du siehst, welche Links nicht erreichbar sind, wo Weiterleitungen auffallen und auf welchen Seiten die Korrektur zuerst Sinn ergibt.' %>
          </p>
          <div class="wt-method-grid">
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-triangle-exclamation"></i> <%= isEn ? 'Hard errors (4xx)' : 'Harte Fehler (4xx)' %></h3>
              <p><%= isEn
                ? '404 Not Found, 410 Gone, 403 Forbidden, 401 Unauthorized — immediately visible to users and crawlers. Highest priority for fixing.'
                : '404 Not Found, 410 Gone, 403 Forbidden, 401 Unauthorized — für Nutzer und Crawler sofort sichtbar. Höchste Priorität beim Beheben.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-server"></i> <%= isEn ? 'Server errors (5xx)' : 'Serverfehler (5xx)' %></h3>
              <p><%= isEn
                ? '500 Internal Server Error, 502/503/504 gateway errors, connection timeouts. Often intermittent, always hurt crawl budget and UX.'
                : '500 Internal Server Error, 502/503/504 Gateway-Fehler, Connection-Timeouts. Oft intermittierend, schaden immer Crawl-Budget und UX.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-arrow-turn-down"></i> <%= isEn ? 'Redirect chains' : 'Weiterleitungsketten' %></h3>
              <p><%= isEn
                ? '301/302 redirects are fine — unless they chain. 3+ hops cost crawl budget and link equity. The scanner flags chains and their length.'
                : '301/302-Weiterleitungen sind okay — außer sie verketten sich. 3+ Hops kosten Crawl-Budget und Link-Equity. Der Scanner markiert Ketten und ihre Länge.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-globe"></i> <%= isEn ? 'External link health' : 'Externe Link-Gesundheit' %></h3>
              <p><%= isEn
                ? 'Outbound references to third-party resources that disappeared, moved, or are now parked. Erodes credibility on long-lived content.'
                : 'Ausgehende Verweise auf Drittseiten, die verschwunden, verschoben oder geparkt sind. Untergräbt Glaubwürdigkeit auf langlebigen Inhalten.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-lock"></i> <%= isEn ? 'Mixed-content warnings' : 'Mixed-Content-Warnungen' %></h3>
              <p><%= isEn
                ? 'HTTP links on HTTPS pages trigger browser warnings and break SSL trust signals. The scanner flags every HTTP link.'
                : 'HTTP-Links auf HTTPS-Seiten lösen Browser-Warnungen aus und beschädigen SSL-Vertrauen. Der Scanner markiert jeden HTTP-Link.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-stopwatch"></i> <%= isEn ? 'Slow targets' : 'Langsame Ziele' %></h3>
              <p><%= isEn
                ? 'Destinations that take > 3s to respond. Frustrates users, bleeds ad-click value, and weakens perceived site quality for Google.'
                : 'Ziele, die > 3s zum Antworten brauchen. Frustriert Nutzer, verschwendet Ad-Click-Wert und schwächt die Seitenqualität-Wahrnehmung bei Google.' %></p>
            </div>
          </div>
          <p>
            <%= isEn
              ? 'The public result shows broken-link count, warning count, and the top 3 affected source pages so you know immediately if your site has a problem. The detailed PDF report delivered after double opt-in lists every broken link with source page, anchor text, HTTP status, and a concrete fix recommendation — typically 50–200 entries on a mid-sized site, ordered by traffic impact.'
              : 'Das öffentliche Ergebnis zeigt die Anzahl defekter Links, die Zahl der Warnungen und die drei am stärksten betroffenen Quellseiten — damit weißt du sofort, ob deine Seite ein Problem hat. Der detaillierte PDF-Report nach Double-Opt-in listet jeden Broken Link mit Quellseite, Anchor-Text, HTTP-Status und konkreter Fix-Empfehlung — typischerweise 50-200 Einträge auf einer mittelgroßen Site, sortiert nach Traffic-Impact.' %>
          </p>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel">
          <h2><%= isEn ? 'What clients say' : 'Was Kunden sagen' %></h2>
          <div class="wt-reviews-grid">
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“The broken links scan surfaced 38 dead outbound references we had no idea about. Cleaning them up noticeably improved organic trust signals.”'
                : '„Der Broken-Links-Scan hat 38 tote externe Verweise gefunden, von denen wir nichts wussten. Das Aufräumen hat die organischen Trust-Signale spürbar verbessert."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“Very thorough scan, clear priorities. Our content team actually uses the PDF as a working backlog.”'
                : '„Sehr gründlicher Scan, klare Prioritäten. Unser Content-Team nutzt das PDF tatsächlich als Arbeits-Backlog."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“Fast and precise — a full SaaS-tool replacement for free. Very recommended.”'
                : '„Schnell und präzise — ersetzt bei uns ein kostenpflichtiges SaaS-Tool. Sehr empfehlenswert."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
          </div>
          <p class="wt-reviews-link">
            <a href="https://www.google.com/search?q=komplett+webdesign+bewertungen" target="_blank" rel="noopener">
              <i class="fa-brands fa-google"></i>
              <%= isEn ? 'Read all Google reviews' : 'Alle Google-Bewertungen lesen' %>
            </a>
          </p>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel wt-trust-panel">
          <h3><%= isEn ? 'Transparent and privacy-friendly' : 'Transparent und datenschutzfreundlich' %></h3>
          <ul class="wt-trust-list">
            <li><i class="fa-solid fa-shield-halved"></i> <%= isEn ? 'The check only uses publicly visible website information.' : 'Der Check nutzt nur öffentlich sichtbare Website-Informationen.' %></li>
            <li><i class="fa-solid fa-clock"></i> <%= isEn ? 'You receive a compact result quickly.' : 'Du erhältst schnell ein kompaktes Ergebnis.' %></li>
            <li><i class="fa-solid fa-database"></i> <%= isEn ? 'Anonymous check data is used only for quality assurance.' : 'Anonyme Check-Daten werden nur zur Qualitätssicherung genutzt.' %></li>
            <li><i class="fa-solid fa-envelope-open"></i> <%= isEn ? 'We use double opt-in for email delivery. Unsubscribe in one click any time.' : 'Wir nutzen Double-Opt-in für Mail-Versand. Abmeldung jederzeit mit einem Klick.' %></li>
          </ul>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel">
          <h2><%= isEn ? 'FAQ: Broken links checker' : 'FAQ: Broken-Links-Checker' %></h2>
          <div class="wt-faq">
            <% (typeof faq !== 'undefined' && Array.isArray(faq) ? faq : []).forEach(function(item){ %>
              <details>
                <summary><%= item.q %></summary>
                <p><%= item.a %></p>
              </details>
            <% }); %>
          </div>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-cta-card">
          <h2><%= isEn ? 'Ready to turn findings into measurable improvements?' : 'Bereit, Befunde in messbare Verbesserungen umzusetzen?' %></h2>
          <p>
            <%= isEn
              ? 'We help you fix technical blockers, improve content structure, and increase search visibility step by step.'
              : 'Wir helfen dir, technische Blocker zu beheben, Content-Struktur zu verbessern und die Suchsichtbarkeit Schritt für Schritt zu erhöhen.' %>
          </p>
          <div class="wt-result-meta">
            <a class="wt-button" href="<%= isEn ? '/en/kontakt' : '/kontakt' %>" data-tester-cta="broken" data-tester-action="contact" data-broken-links-cta="primary">
              <i class="fa-solid fa-paper-plane"></i>
              <%= isEn ? 'Request website consultation' : 'Website-Beratung anfragen' %>
            </a>
            <a class="wt-button-secondary" href="/booking" data-tester-cta="broken" data-tester-action="booking" data-broken-links-cta="secondary">
              <i class="fa-solid fa-calendar-days"></i>
              <%= isEn ? 'Book a call' : 'Call buchen' %>
            </a>
          </div>
        </article>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <style>
    .wt-section-compact { padding-top: 16px; padding-bottom: 0; }
    .breadcrumbs ol { margin: 0; padding: 0; list-style: none; display: flex; gap: 10px; flex-wrap: wrap; }
    .breadcrumbs li { color: #6b7280; font-size: .95rem; }
    .breadcrumbs li+li::before { content: '›'; margin-right: 10px; color: #9ca3af; }
    .breadcrumbs a { color: #374151; text-decoration: none; }
    .breadcrumbs a:hover { text-decoration: underline; }
    .bl-table-wrap { overflow-x: auto; }
    .bl-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
    .bl-table th, .bl-table td { border-bottom: 1px solid #e5e7eb; padding: 0.55rem 0.5rem; text-align: left; vertical-align: top; }
    .bl-table th { font-weight: 600; color: #374151; }
    .bl-table td small { color: #6b7280; display: block; }
    .bl-meta-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.8rem; }
    .wt-cta-inline { padding: 1rem; }
    .wt-faq details { border-top: 1px solid #e5e7eb; padding: 14px 0; }
    .wt-faq summary { cursor: pointer; font-weight: 600; }
    .wt-faq p { margin: 10px 0 0; }
    @media (max-width: 780px) { .bl-meta-grid { grid-template-columns: 1fr; } }
  </style>

  <script>
    window.BROKEN_LINK_TESTER_CONFIG = {
      locale: "<%= isEn ? 'en' : 'de' %>",
      endpoint: "/api/broken-link-audit",
      leadEndpoint: "/api/broken-link-audit/lead",
      i18n: {
        scanFor: "<%= isEn ? 'Scan for' : 'Scan für' %>",
        modeLabel: "<%= isEn ? 'Mode' : 'Modus' %>",
        checkedLinks: "<%= isEn ? 'Checked links' : 'Geprüfte Links' %>",
        brokenLinks: "<%= isEn ? 'Broken links' : 'Broken Links' %>",
        warnings: "<%= isEn ? 'Warnings' : 'Warnings' %>",
        okLinks: "<%= isEn ? 'OK links' : 'OK Links' %>",
        scannedPages: "<%= isEn ? 'Scanned pages' : 'Gescannten Seiten' %>",
        crawlFailed: "<%= isEn ? 'Crawl failures' : 'Crawl-Fehler' %>",
        partialResult: "<%= isEn ? 'Partial result' : 'Teil-Ergebnis' %>",
        topPagesTitle: "<%= isEn ? 'Top 3 affected source pages' : 'Top 3 betroffene Quellseiten' %>",
        topPagesEmpty: "<%= isEn ? 'No affected pages detected.' : 'Keine betroffenen Seiten gefunden.' %>",
        brokenListTitle: "<%= isEn ? 'Broken links details' : 'Broken-Links Details' %>",
        warningsListTitle: "<%= isEn ? 'Warnings details' : 'Warnings Details' %>",
        sourcePage: "<%= isEn ? 'Source page' : 'Quellseite' %>",
        targetUrl: "<%= isEn ? 'Target URL' : 'Ziel-URL' %>",
        type: "<%= isEn ? 'Type' : 'Typ' %>",
        status: "<%= isEn ? 'Status' : 'Status' %>",
        error: "<%= isEn ? 'Error' : 'Fehler' %>",
        noBroken: "<%= isEn ? 'No broken links found.' : 'Keine defekten Links gefunden.' %>",
        noWarnings: "<%= isEn ? 'No warnings found.' : 'Keine Warnungen gefunden.' %>",
        limitations: "<%= isEn ? 'Limitations' : 'Hinweise' %>",
        errorFallback: "<%= isEn ? 'The scan could not be completed.' : 'Der Scan konnte nicht durchgeführt werden.' %>",
        lockedTitle: "<%= isEn ? 'Detailed broken-links report (PDF)' : 'Detaillierter Broken-Links-Report (PDF)' %>",
        lockedText: "<%= isEn ? 'Enter your email to receive the full list with source page, target URL, HTTP status, and fix hint — every broken link and warning, not only the summary.' : 'Trage deine E-Mail ein, um die vollständige Liste mit Quellseite, Ziel-URL, HTTP-Status und Fix-Hinweis zu erhalten — jeden defekten Link und jede Warnung, nicht nur die Kurzübersicht.' %>",
        leadName: "<%= isEn ? 'Name (optional)' : 'Name (optional)' %>",
        leadEmail: "<%= isEn ? 'Email address' : 'E-Mail-Adresse' %>",
        leadConsent: "<%= isEn ? 'I want to receive the detailed broken-links report by email and agree to be added to the Komplett Webdesign newsletter (weekly practical website-quality tips, one-click unsubscribe).' : 'Ich möchte den detaillierten Broken-Links-Report per E-Mail erhalten und stimme zu, in den Komplett-Webdesign-Newsletter aufgenommen zu werden (wöchentlich praktische Website-Qualitäts-Tipps, Abmeldung mit einem Klick).' %>",
        leadSubmit: "<%= isEn ? 'Send confirmation link' : 'Bestätigungslink senden' %>",
        leadLoading: "<%= isEn ? 'Sending...' : 'Wird gesendet...' %>",
        leadSuccess: "<%= isEn ? 'Check your inbox and confirm your email address to receive the detailed broken-links report.' : 'Bitte prüfe dein Postfach und bestätige deine E-Mail-Adresse, um den detaillierten Broken-Links-Report zu erhalten.' %>",
        leadError: "<%= isEn ? 'The broken-links report request could not be processed.' : 'Die Broken-Links-Report-Anfrage konnte nicht verarbeitet werden.' %>",
        privacyHref: "<%= isEn ? '/en/datenschutz' : '/datenschutz' %>",
        privacyLabel: "<%= isEn ? 'Privacy policy' : 'Datenschutzerklärung' %>"
      }
    };
  </script>
  <script src="/js/tester-utils.js?v=<%= encodeURIComponent(assetVersion || '1') %>" defer></script>
  <script src="/js/broken-links-tester.js?v=<%= encodeURIComponent(assetVersion || '1') %>" defer></script>
</body>
</html>
