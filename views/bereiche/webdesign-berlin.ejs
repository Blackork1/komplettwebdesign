        <img src="<%= wdSectionImages.runningCosts.src %>" alt="<%= wdSectionImages.runningCosts.alt %>" width="1160" height="442" loading="lazy">
      </figure>
      <div class="wd-link-row wd-link-row--split wd-running-costs-links">
        <% page.runningCosts.links.forEach(function (link) { %>
