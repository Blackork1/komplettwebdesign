<%
const siteBase = (canonicalBaseUrl || 'https://komplettwebdesign.de').replace(/\/$/, '');
const pageUrl = `${siteBase}${page.canonicalPath}`;
const wdDistrictCards = Array.isArray(districtCards) ? districtCards : [];
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${pageUrl}#webpage`,
  "url": pageUrl,
  "name": page.title,
  "description": page.description,
  "inLanguage": "de-DE",
  "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
  "mainEntity": { "@id": `${pageUrl}#service` }
};
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${pageUrl}#service`,
  "name": "Webdesign Berlin",
  "serviceType": "Webdesign und Website-Entwicklung",
  "description": page.description,
  "provider": {
    "@type": "Organization",
    "name": "Komplettwebdesign",
    "url": siteBase
  },
  "areaServed": [
    { "@type": "City", "name": "Berlin" },
    { "@type": "AdministrativeArea", "name": "Brandenburg" }
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${pageUrl}#breadcrumb`,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteBase}/` },
    { "@type": "ListItem", "position": 2, "name": "Webdesign Berlin", "item": pageUrl }
  ]
};
const districtItemListSchema = wdDistrictCards.length ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `${pageUrl}#berliner-bezirke`,
  "name": "Webdesign in Berliner Bezirken",
  "itemListElement": wdDistrictCards.map((district, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": district.title,
    "url": `${siteBase}${district.href}`
  }))
} : null;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${pageUrl}#faq`,
  "mainEntity": page.faq.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
const structuredDataBlocks = [webPageSchema, serviceSchema, breadcrumbSchema, districtItemListSchema, faqSchema].filter(Boolean);
const wdSectionImages = {
  targetGroups: { src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1761846940/admin_gallery/qhi0ozk9fqclwv8r1fzj.webp', alt: 'Webdesign für Selbstständige und kleine Unternehmen in Berlin' },
  websiteCheck: { src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1760634492/admin_gallery/psckvurmyqzchazrx3ec.webp', alt: 'Website-Tester Vorschau für Webdesign Berlin' },
  individualWebdesign: { src: '/images/webdesign-berlin-individuelles-webdesign.webp', alt: 'Individuelles Webdesign als strukturierte Website-Vorschau' },
  localBenefits: { src: '/images/webdesign-berlin-lokaler-berlin-bezug.webp', alt: 'Lokaler Berlin-Bezug für eine Website-Struktur' },
  runningCosts: { src: '/images/hosting.webp', alt: 'Hosting und laufende Website-Kosten technisch einordnen' },
  districtMap: { src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1761847566/admin_gallery/ukiymhlne3z9yq1xcia7.webp', alt: 'Webdesign in allen Berliner Bezirken' },
  contact: { src: '/images/contact-telefonieren.webp', alt: 'Persönliche Abstimmung für ein Webdesign-Projekt' }
};
const wdPackageImages = {
  start: '/images/paket-start.webp',
  business: '/images/paket-business.webp',
  wachstum: '/images/paket-wachstum.webp',
  individuell: '/images/paket-individuell.webp'
};
const wdServiceImages = [
  { src: '/images/webdesign-berlin-individuelles-webdesign.webp', alt: 'Individuelles Webdesign und UX für Berlin' },
  { src: '/images/webdesign-berlin-lokaler-berlin-bezug.webp', alt: 'SEO und Local SEO für Berliner Websites' },
  { src: '/images/hosting.webp', alt: 'Hosting und technische Grundlage' },
  { src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1761069237/admin_gallery/bupxdaaopyjco898drrl.webp', alt: 'Buchungs- und Zahlungsprozesse als Zusatzleistung' },
  { src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1762705635/admin_gallery/swxxej4dyupgnp7vzzds.webp', alt: 'Technische Datenschutz- und Sicherheitsgrundlagen' },
  { src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1756655275/admin_gallery/hjvleomny0wd8xxtjnzi.webp', alt: 'Inhalte und Texte für Websites' }
];
const wdIndustryImages = [
  { title: 'Cafés und Gastronomie', src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1758977436/admin_gallery/vycov9ggowbm7ql3ad3t.webp', href: '/branchen/webdesign-cafe' },
  { title: 'Blumenladen und Floristik', src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1759003043/admin_gallery/jhytsfu4yzabyb1fkljr.webp', href: '/branchen/webdesign-blumenladen' },
  { title: 'Immobilien und Beratung', src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1760635862/admin_gallery/xpwedho5napbohiqr2gp.webp', href: '/branchen/webdesign-immobilienmakler' },
  { title: 'Gesundheit und Coaching', src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1761068980/admin_gallery/s1kcjikrig0zeuv2jgdq.webp', href: '/branchen/webdesign-fitnesscoach' },
  { title: 'Shop- und Produktseiten', src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1761847762/admin_gallery/fqq4ofor4dmsbszhoqqs.webp', href: '/pakete/wachstum' },
  { title: 'Weitere Branchen', src: 'https://res.cloudinary.com/dvd2cd2be/image/upload/v1760635311/admin_gallery/kgfq7wwg6aqh8ikxhce6.webp', href: '/branchen' }
];
%>
<%- include('../partials/head', {
  structuredDataBlocks,
  canonicalUrl: pageUrl,
  title: page.title,
  description: page.description,
  extraCssAssets: ['webdesign-berlin.css']
}) %>
<%- include('../partials/header') %>


<main class="webdesign-berlin-page webdesign-berlin">
  <section id="hero" class="wd-container wd-hero unified-hero" aria-labelledby="wd-hero-title">
    <div class="wd-hero__copy unified-hero__copy">
      <nav class="unified-hero__breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Startseite</a></li>
          <li aria-current="page">Webdesign Berlin</li>
        </ol>
      </nav>
      <h1 id="wd-hero-title" class="home-hero-reveal home-hero-reveal--h1 animate-on-scroll"><%= page.h1 %></h1>
      <p class="wd-lead home-hero-reveal home-hero-reveal--support animate-on-scroll"><%= page.hero.lead %></p>
      <ul class="wd-hero-bullets" aria-label="Preislogik">
        <% page.hero.highlights.forEach(function (item) { %>
          <li class="home-hero-reveal home-hero-reveal--bullet animate-on-scroll">
            <img src="/images/icons/check.svg" alt="" width="26" height="26" loading="lazy">
            <span><%= item %></span>
          </li>
        <% }) %>
      </ul>
      <div class="wd-actions home-hero-reveal home-hero-reveal--actions animate-on-scroll">
        <a class="btn btn-primary" href="<%= page.hero.primaryCta.href %>"><%= page.hero.primaryCta.label %></a>
        <a class="btn btn-secondary" href="<%= page.hero.secondaryCta.href %>"><%= page.hero.secondaryCta.label %></a>
      </div>
      <p class="wd-hero-note home-hero-reveal home-hero-reveal--trust animate-on-scroll">
        <a href="<%= page.hero.testerLink.href %>"><%= page.hero.testerLink.label %></a>
      </p>
    </div>
    <figure class="wd-hero__media home-hero-reveal home-hero-reveal--visual animate-on-scroll">
      <img src="<%= page.hero.image.src %>" width="<%= page.hero.image.width %>" height="<%= page.hero.image.height %>" alt="<%= page.hero.image.alt %>" loading="eager" fetchpriority="high">
    </figure>
  </section>

  <section id="intro" class="wd-section" aria-labelledby="wd-intro-title">
    <div class="wd-container wd-section-head animate-on-scroll">
      <span class="wd-chip">Einordnung</span>
      <h2 id="wd-intro-title"><%= page.intro.title %></h2>
      <% page.intro.text.forEach(function (paragraph) { %>
        <p class="wd-lead"><%= paragraph %></p>
      <% }) %>
      <% if (page.intro.image) { %>
        <figure class="wd-intro-image">
          <img src="<%= page.intro.image.src %>" width="1200" height="675" alt="<%= page.intro.image.alt %>" loading="lazy">
        </figure>
      <% } %>
    </div>
  </section>

  <section class="wd-section wd-section--video wd-section--soft" aria-labelledby="wd-video-title">
    <div class="wd-container">
      <div class="wd-video">
        <span class="wd-chip animate-on-scroll">Erklärung</span>
        <h2 id="wd-video-title" class="animate-on-scroll">Was wir im Erstgespräch für dein Webdesign-Projekt klären</h2>
        <p class="wd-lead animate-on-scroll">Im Erstgespräch für dein Webdesign in Berlin ordne ich deine Vorstellungen, die vorhandenen Voraussetzungen und den realistischen Projektumfang ein. So wird früh klar, ob ein kompaktes Start-Paket, eine Business-Website, ein Wachstum-Projekt oder ein individuelles Angebot sinnvoll ist.</p>
        <div class="wd-grid wd-grid--three wd-consultation-grid">
          <article class="wd-card wd-consultation-step animate-on-scroll">
            <span class="wd-consultation-step__number" aria-hidden="true">1</span>
            <h3>Ausgangslage und Ziele</h3>
            <p>Wir besprechen, ob bereits eine Website vorhanden ist, ob ein Relaunch ansteht oder ob du komplett neu startest. Dazu gehören Zielgruppe, Leistungen, gewünschte Anfragewege, vorhandene Inhalte und wichtige Anforderungen an deine neue Website.</p>
          </article>
          <article class="wd-card wd-consultation-step animate-on-scroll">
            <span class="wd-consultation-step__number" aria-hidden="true">2</span>
            <h3>Umfang, Zeitrahmen und Paketlogik</h3>
            <p>Danach klären wir den gewünschten Seitenumfang, mögliche Zusatzleistungen, Texte, Bilder, Local-SEO-Grundlagen, laufende Kosten und den zeitlichen Rahmen. Dadurch lässt sich besser einschätzen, welches Website-Paket zu deinem Vorhaben passt.</p>
          </article>
          <article class="wd-card wd-consultation-step animate-on-scroll">
            <span class="wd-consultation-step__number" aria-hidden="true">3</span>
            <h3>Preisbereich und erste Designidee</h3>
            <p>Auf Basis deiner Angaben nenne ich dir einen unverbindlichen Preisbereich für die Website-Erstellung. Wenn der Rahmen passt, starten wir mit einer ersten Designidee, besprechen diese gemeinsam und entwickeln daraus Schritt für Schritt die passende Website.</p>
          </article>
        </div>
        <div class="wd-actions wd-consultation-actions animate-on-scroll">
          <a class="btn btn-primary" href="/kontakt">Erstgespräch anfragen</a>
          <a class="btn btn-secondary" href="/pakete">Pakete ansehen</a>
        </div>
      </div>
    </div>
  </section>

  <section id="websiteCheck" class="wd-section" aria-labelledby="wd-check-title">
    <div class="wd-container wd-split animate-on-scroll">
      <article class="wd-card">
        <span class="wd-chip">Website-Tester</span>
        <h2 id="wd-check-title">Bestehende Website zuerst prüfen</h2>
        <p class="wd-lead">Wenn bereits eine Website vorhanden ist, kann der Website-Tester eine erste Orientierung zu technischen Grundlagen, Metadaten, GEO-Signalen und kaputten Links geben. Das ersetzt kein vollständiges Audit, hilft aber bei der Einordnung des passenden Paketumfangs.</p>
        <div class="wd-link-row wd-link-row--split">
          <a href="/website-tester">Website-Tester öffnen</a>
          <a href="/leistungen/website-audit">Website-Audit ansehen</a>
        </div>
      </article>
      <figure class="wd-visual">
        <img src="<%= wdSectionImages.websiteCheck.src %>" alt="<%= wdSectionImages.websiteCheck.alt %>" width="720" height="520" loading="lazy">
      </figure>
    </div>
  </section>

  <section id="targetGroups" class="wd-section wd-section--soft" aria-labelledby="wd-target-title">
    <div class="wd-container wd-grid wd-grid--two animate-on-scroll">
      <article class="wd-card">
        <h2 id="wd-target-title"><%= page.targetGroups.title %></h2>
        <ul class="wd-list wd-list--checks">
          <% page.targetGroups.goodFit.forEach(function (item) { %>
            <li><%= item %></li>
          <% }) %>
        </ul>
      </article>
      <article class="wd-card">
        <h3 class="wd-not-fit-title">Für wen Webdesign Berlin nicht passt</h3>
        <ul class="wd-list wd-list--crosses">
          <% page.targetGroups.notFit.forEach(function (item) { %>
            <li><%= item %></li>
          <% }) %>
        </ul>
      </article>
    </div>
  </section>

  <section id="individualWebdesign" class="wd-section" aria-labelledby="wd-individual-title">
    <div class="wd-container wd-split wd-split--media-third animate-on-scroll">
      <div>
        <span class="wd-chip">Individuelle Umsetzung</span>
        <h2 id="wd-individual-title"><%= page.individualWebdesign.title %></h2>
        <p class="wd-lead"><%= page.individualWebdesign.text %></p>
        <ul class="wd-list wd-list--checks">
          <% page.individualWebdesign.points.forEach(function (item) { %>
            <li><%= item %></li>
          <% }) %>
        </ul>
      </div>
      <figure class="wd-visual">
        <img src="<%= wdSectionImages.individualWebdesign.src %>" alt="<%= wdSectionImages.individualWebdesign.alt %>" width="720" height="960" loading="lazy">
      </figure>
    </div>
  </section>

  <section id="techUsp" class="wd-section wd-section--soft" aria-labelledby="wd-tech-title">
    <div class="wd-container">
      <div class="wd-section-head animate-on-scroll">
        <span class="wd-chip">Technik</span>
        <h2 id="wd-tech-title"><%= page.techUsp.title %></h2>
        <p class="wd-lead"><%= page.techUsp.lead %></p>
      </div>
      <div class="wd-grid wd-tech-grid">
        <% page.techUsp.cards.forEach(function (card) { %>
          <article class="wd-card animate-on-scroll">
            <h3><%= card.title %></h3>
            <p><%= card.text %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <section id="localBenefits" class="wd-section" aria-labelledby="wd-local-title">
    <div class="wd-container wd-split wd-split--media-third is-reversed animate-on-scroll">
      <figure class="wd-visual">
        <img src="<%= wdSectionImages.localBenefits.src %>" alt="<%= wdSectionImages.localBenefits.alt %>" width="720" height="960" loading="lazy">
      </figure>
      <div>
        <span class="wd-chip">Lokale Sichtbarkeit</span>
        <h2 id="wd-local-title"><%= page.localBenefits.title %></h2>
        <p class="wd-lead"><%= page.localBenefits.text %></p>
        <ul class="wd-list wd-list--checks">
          <% page.localBenefits.points.forEach(function (item) { %>
            <li><%= item %></li>
          <% }) %>
        </ul>
      </div>
    </div>
  </section>

  <section id="servicesOverview" class="wd-section wd-section--soft" aria-labelledby="wd-services-title">
    <div class="wd-container">
      <div class="wd-section-head animate-on-scroll">
        <span class="wd-chip">Leistungen</span>
        <h2 id="wd-services-title"><%= page.servicesOverview.title %></h2>
      </div>
      <div class="wd-grid">
        <% page.servicesOverview.items.forEach(function (item, index) { %>
          <article class="wd-card animate-on-scroll">
            <% if (wdServiceImages[index]) { %>
              <figure class="wd-card__figure">
                <img src="<%= wdServiceImages[index].src %>" alt="<%= wdServiceImages[index].alt %>" width="640" height="400" loading="lazy">
              </figure>
            <% } %>
            <h3>
              <% if (item.href) { %>
                <a class="wd-card-title-link" href="<%= item.href %>"><%= item.title %></a>
              <% } else { %>
                <%= item.title %>
              <% } %>
            </h3>
            <p><%= item.text %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <section id="berlinVisuals" class="wd-section" aria-labelledby="wd-berlin-visuals-title">
    <div class="wd-container">
      <div class="wd-section-head animate-on-scroll">
        <span class="wd-chip">Berlin und Branchen</span>
        <h2 id="wd-berlin-visuals-title">Webdesign mit lokalem Bezug und konkreter Bildsprache</h2>
        <p class="wd-lead">Die Website soll sich nicht wie ein generisches Template anfühlen. Branchen, lokale Leistungen und Einzugsgebiet werden sichtbar eingeordnet, ohne daraus pauschale Ranking- oder Anfrageversprechen zu machen.</p>
      </div>
      <div class="wd-split wd-split--balanced animate-on-scroll">
        <figure class="wd-visual">
          <img src="<%= wdSectionImages.districtMap.src %>" alt="<%= wdSectionImages.districtMap.alt %>" width="720" height="520" loading="lazy">
        </figure>
        <article class="wd-card">
          <h3>Berlin, Brandenburg und passende Leistungsseiten</h3>
          <p>Lokaler Bezug entsteht durch klare Angebote, echte Inhalte, sinnvolle Seitenstruktur und nachvollziehbare Kontaktwege. Bezirks- oder Standortseiten werden nur eingesetzt, wenn sie inhaltlich wirklich sinnvoll sind.</p>
          <div class="wd-link-row wd-link-row--split">
            <a href="/leistungen/local-seo">Local SEO Berlin ansehen</a>
            <a href="/branchen">Branchen ansehen</a>
          </div>
        </article>
      </div>
      <div class="wd-media-grid wd-media-grid--spaced">
        <% wdIndustryImages.forEach(function (item) { %>
          <a class="wd-media-card animate-on-scroll" href="<%= item.href %>">
            <img src="<%= item.src %>" alt="<%= item.title %> im Webdesign-Kontext" width="480" height="360" loading="lazy">
            <strong><%= item.title %></strong>
          </a>
        <% }) %>
      </div>
    </div>
  </section>

  <% if (wdDistrictCards.length) { %>
  <section id="districtPages" class="wd-section wd-section--soft" aria-labelledby="wd-district-pages-title">
    <div class="wd-container">
      <div class="wd-section-head animate-on-scroll">
        <span class="wd-chip">Berliner Bezirke</span>
        <h2 id="wd-district-pages-title">Webdesign in Berlin nach Bezirk einordnen</h2>
        <p class="wd-lead">Wenn dein Einzugsgebiet lokal geprägt ist, helfen passende Bezirksseiten dabei, Leistungen, Zielgruppen und Kontaktwege konkreter zu erklären. Jede Seite ordnet den Bezirk separat ein, ohne eine bestimmte Google-Platzierung zu versprechen.</p>
      </div>
      <div class="wd-district-grid" aria-label="Webdesign Bezirksseiten in Berlin">
        <% wdDistrictCards.forEach(function (district) { %>
          <a class="wd-district-card animate-on-scroll" href="<%= district.href %>" aria-label="<%= district.title %> ansehen">
            <figure class="wd-district-card__media">
              <img src="<%= district.image %>" alt="<%= district.imageAlt %>" width="560" height="350" loading="lazy">
            </figure>
            <div class="wd-district-card__body">
              <span class="wd-district-card__label"><%= district.label %></span>
              <h3><%= district.title %></h3>
              <p><%= district.text %></p>
              <% if (district.neighborhoods && district.neighborhoods.length) { %>
                <div class="wd-district-card__areas" aria-label="Beispiele für lokale Bezugspunkte">
                  <% district.neighborhoods.forEach(function (area) { %>
                    <span><%= area %></span>
                  <% }) %>
                </div>
              <% } %>
              <span class="wd-district-card__cta">Bezirk ansehen <span aria-hidden="true">→</span></span>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <section id="comparison" class="wd-section" aria-labelledby="wd-comparison-title">
    <div class="wd-container">
      <div class="wd-section-head animate-on-scroll">
        <span class="wd-chip">Einordnung</span>
        <h2 id="wd-comparison-title"><%= page.comparison.title %></h2>
      </div>
      <div class="wd-grid wd-grid--three wd-scroll-cards">
        <% page.comparison.rows.forEach(function (row) { %>
          <article class="wd-card animate-on-scroll">
            <h3><%= row.label %></h3>
            <p><%= row.text %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <section id="packageTeaser" class="wd-section wd-section--soft" aria-labelledby="wd-packages-title">
    <div class="wd-container">
      <div class="wd-section-head animate-on-scroll">
        <span class="wd-chip">Preise</span>
        <h2 id="wd-packages-title"><%= page.packageTeaser.title %></h2>
        <p class="wd-lead"><%= page.packageTeaser.lead %></p>
        <p><%= page.priceNote %></p>
      </div>
      <div class="wd-slider-shell animate-on-scroll">
        <div class="home-pricing-controls wd-pricing-controls" aria-label="Bedienung des Paket-Sliders">
          <button class="home-pricing-control wd-pricing-control" type="button" data-wd-pricing-prev aria-label="Vorheriges Paket">
            <i class="fas fa-chevron-left" aria-hidden="true"></i>
          </button>
          <button class="home-pricing-control wd-pricing-control" type="button" data-wd-pricing-next aria-label="Nächstes Paket">
            <i class="fas fa-chevron-right" aria-hidden="true"></i>
          </button>
        </div>
      <div class="wd-packages package-slider-scroll" data-wd-pricing-slider data-package-slider tabindex="0" aria-label="Website-Pakete horizontal scrollen">
        <% page.packageTeaser.packages.forEach(function (pkg) { %>
          <% const packageName = String(pkg.name || '').trim(); %>
          <% const isIndividualPackage = pkg.id === 'individuell' || packageName === 'Individuelles Projekt' || packageName === 'Individuell'; %>
          <% const packageButtonLabel = isIndividualPackage ? 'Individuelles Projekt-Paket ansehen' : (/paket$/i.test(packageName) ? packageName + ' ansehen' : packageName + '-Paket ansehen'); %>
          <article class="wd-card wd-package<%= pkg.recommended ? ' wd-package--featured' : '' %> animate-on-scroll">
            <% if (pkg.recommendationLabel) { %>
              <span class="wd-package__label"><%= pkg.recommendationLabel %></span>
            <% } else { %>
              <span class="wd-package__label wd-package__label--placeholder" aria-hidden="true">Paket</span>
            <% } %>
            <h3><%= pkg.name %></h3>
            <span class="wd-package__price"><%= pkg.priceLabel %></span>
            <p><%= pkg.description %></p>
            <ul class="wd-list">
              <% pkg.highlights.forEach(function (item) { %>
                <li><%= item %></li>
              <% }) %>
            </ul>
            <a class="btn btn-primary" href="<%= pkg.path %>"><%= packageButtonLabel %></a>
          </article>
