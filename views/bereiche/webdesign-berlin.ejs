        <h2 id="wd-cta-title"><%= wdBottomCta.title %></h2>
        <p class="wd-lead"><%= wdBottomCta.text %></p>
        <div class="wd-actions">
          <a class="btn btn-primary" href="<%= wdBottomCta.primary.href %>"><%= wdBottomCta.primary.label %></a>
          <a class="btn btn-secondary" href="<%= wdBottomCta.secondary.href %>"><%= wdBottomCta.secondary.label %></a>
        </div>
        <figure class="wd-cta__media">
          <img src="<%= wdSectionImages.contact.src %>" alt="<%= wdSectionImages.contact.alt %>" width="720" height="405" loading="lazy">
        </figure>
      </div>
    </div>
  </section>
</main>

<script>
  (() => {
    document.querySelectorAll('[data-wd-pricing-slider]').forEach((slider) => {
      const shell = slider.closest('.wd-slider-shell');
      const previousButton = shell?.querySelector('[data-wd-pricing-prev]');
      const nextButton = shell?.querySelector('[data-wd-pricing-next]');
      const getStep = () => {
        const firstCard = slider.querySelector('.wd-package');
        return firstCard ? firstCard.getBoundingClientRect().width + 16 : slider.clientWidth * 0.85;
      };

      previousButton?.addEventListener('click', () => {
        slider.scrollBy({ left: -getStep(), behavior: 'smooth' });
      });

      nextButton?.addEventListener('click', () => {
        slider.scrollBy({ left: getStep(), behavior: 'smooth' });
      });
    });
  })();
</script>

