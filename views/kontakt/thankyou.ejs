<%- include('../partials/head') %>
<%- include('../partials/header') %>
<% const isEn = lng === 'en'; %>
<link rel="stylesheet" href="<%= cssAsset('kontakt.css') %>">

<main class="section contact-thankyou" data-event="thank_you_view">
  <div class="container mt-5">
    <div class="contact-thankyou__card">
      <p class="contact-thankyou__eyebrow"><%= isEn ? 'Request received' : 'Anfrage erhalten' %></p>
      <h1><%= isEn ? 'Thank you for your request' : 'Vielen Dank für deine Anfrage' %></h1>
      <p>
        <%= isEn
          ? 'I will review your details and get back to you with a rough assessment or a useful next step. If important information is missing, I will ask for it first.'
          : 'Ich schaue mir deine Angaben an und melde mich mit einer groben Einschätzung oder einem sinnvollen nächsten Schritt. Wenn wichtige Informationen fehlen, frage ich zuerst nach.'
        %>
      </p>
      <p>
        <%= isEn
          ? 'A project only starts after scope, offer and approval are clarified.'
          : 'Ein Projekt startet erst nach Abstimmung, Angebot und Freigabe.'
        %>
      </p>

      <% if (Array.isArray(summaryRows) && summaryRows.length) { %>
        <div class="table-responsive contact-thankyou__summary">
          <table class="table">
            <tbody>
              <% summaryRows.forEach((row) => { %>
                <tr>
                  <th><%= row[0] %></th>
                  <td>
                    <% if (Array.isArray(row[1])) { %>
                      <%= row[1].join(', ') %>
                    <% } else { %>
                      <%= row[1] %>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (appointment) { %>
        <p><a href="<%= isEn ? '/en/kontakt/ics/' : '/kontakt/ics/' %><%= appointment.id %>" class="btn btn-primary"><%= isEn ? 'Download appointment as ICS' : 'Termin als ICS herunterladen' %></a></p>
      <% } %>

      <div class="contact-thankyou__actions">
        <a href="<%= isEn ? '/en/pakete' : '/pakete' %>" class="btn btn-primary"><%= isEn ? 'View packages' : 'Pakete ansehen' %></a>
        <a href="<%= isEn ? '/en/website-tester' : '/website-tester' %>" class="btn btn-secondary"><%= isEn ? 'Open website check' : 'Website-Check öffnen' %></a>
        <a href="<%= isEn ? '/en' : '/' %>" class="btn btn-secondary"><%= isEn ? 'Back to homepage' : 'Zur Startseite' %></a>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<script>
  (function() {
    var leadEventId = <%- JSON.stringify(leadEventId || '') %>;
    var successFormId = <%- JSON.stringify(typeof successFormId === 'string' && successFormId ? successFormId : 'kontaktForm') %>;
    var successFormVariant = <%- JSON.stringify(typeof successFormVariant === 'string' && successFormVariant ? successFormVariant : 'contact') %>;
    var storageKey = leadEventId ? 'kwd_contact_lead_received_' + leadEventId : '';
    var sent = false;

    function alreadySent() {
      if (!storageKey || !window.sessionStorage) return false;
      try {
        return window.sessionStorage.getItem(storageKey) === '1';
      } catch (err) {
        return false;
      }
    }

    function markSent() {
      if (!storageKey || !window.sessionStorage) return;
      try {
        window.sessionStorage.setItem(storageKey, '1');
      } catch (err) {}
    }

    function sendLeadEvent() {
      if (sent || alreadySent()) return;
      if (!window.KWDTracking || typeof window.KWDTracking.trackEvent !== 'function') return;

      var payload = {
        event_source: 'thank_you',
        form_id: successFormId,
        form_variant: successFormVariant
      };

      window.KWDTracking.trackEvent('thank_you_view', payload);
      window.KWDTracking.trackEvent('contact_form_submit_success', payload);
      window.KWDTracking.trackEvent('lead_received', payload);
      sent = true;
      markSent();
    }

    window.addEventListener('kwd:tracking-ready', sendLeadEvent, { once: true });
    document.addEventListener('DOMContentLoaded', sendLeadEvent, { once: true });
    window.setTimeout(sendLeadEvent, 250);
  })();
</script>
