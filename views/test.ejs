<%- include('partials/head') %>
<% const isEn = typeof lng !== 'undefined' && lng === 'en'; %>
<body class="website-tester-page">
  <%- include('partials/header') %>

  <main id="hero">
    <link rel="stylesheet" href="/website-tester.css?v=<%= encodeURIComponent(assetVersion || '1') %>">


    <section class="wt-section wt-section-compact">
      <div class="wt-shell">
        <nav class="breadcrumbs" aria-label="breadcrumb">
          <ol>
            <li><a href="<%= isEn ? '/en' : '/' %>"><%= isEn ? 'Home' : 'Startseite' %></a></li>
            <li aria-current="page"><%= isEn ? 'Website Tester' : 'Website-Tester' %></li>
          </ol>
        </nav>
      </div>
    </section>

    <section class="wt-hero">
      <div class="wt-shell">
        <div class="wt-hero-grid">
          <div class="wt-hero-copy">
            <span class="wt-eyebrow">
              <i class="fa-solid fa-magnifying-glass-chart"></i>
              <%= isEn ? 'Website Tester 2.3' : 'Website Tester 2.3' %>
            </span>
            <h1><%= isEn ? 'Check if your website is still modern, visible, and trustworthy.' : 'Prüfe, ob deine Website noch modern, sichtbar und vertrauenswürdig ist.' %></h1>
            <p class="wt-lead">
              <%= isEn
                ? 'Run a deep audit for SEO, technical quality, accessibility signals, trust, and conversion readiness. You get a clear score and actionable priorities in seconds.'
                : 'Starte einen Deep-Audit für SEO, Technik, Barrierefreiheits-Signale, Vertrauen und Conversion-Reife. Du erhältst in Sekunden einen klaren Score und konkrete Prioritäten.' %>
            </p>
            <ul class="wt-pill-list">
              <li><i class="fa-solid fa-list-check"></i> <%= isEn ? '6 pages max (homepage + 5 internal pages)' : 'Bis zu 6 Seiten (Startseite + 5 Unterseiten)' %></li>
              <li><i class="fa-solid fa-shield"></i> <%= isEn ? 'Security-safe analysis (SSRF protection)' : 'Sicherheitsgeprüfte Analyse (SSRF-Schutz)' %></li>
              <li><i class="fa-solid fa-clock"></i> <%= isEn ? 'Time boxed to 45 seconds' : 'Zeitbudget: max. 45 Sekunden' %></li>
            </ul>
          </div>

          <div class="wt-form-card">
            <h2><%= isEn ? 'Enter website URL' : 'Website-Adresse eingeben' %></h2>
            <p><%= isEn ? 'Add URL + business context for realistic SEO/GEO scoring.' : 'Ergänze URL + Geschäftskontext für eine realistische SEO/GEO-Bewertung.' %></p>
            <form data-website-tester-form>
              <div class="wt-context-grid">
                <input name="businessType" type="text" placeholder="<%= isEn ? 'Business type (e.g. medical practice)' : 'Branche (z. B. Arztpraxis)' %>" required>
                <input name="primaryService" type="text" placeholder="<%= isEn ? 'Primary service (e.g. dental implants)' : 'Hauptleistung (z. B. Zahnimplantate)' %>" required>
                <input name="targetRegion" type="text" placeholder="<%= isEn ? 'Target region (e.g. Berlin)' : 'Zielregion (z. B. Berlin)' %>" required>
              </div>
              <label class="visually-hidden" for="website-url"><%= isEn ? 'Website URL' : 'Website-URL' %></label>
              <div class="wt-form-row">
                <input id="website-url" name="url" type="text" inputmode="url" placeholder="<%= isEn ? 'https://your-website.com' : 'https://deine-website.de' %>" required>
                <button class="wt-button" type="submit">
                  <i class="fa-solid fa-bolt"></i>
                  <%= isEn ? 'Run Audit' : 'Audit starten' %>
                </button>
              </div>
            </form>
            <p class="wt-form-note">
              <%= isEn
                ? 'No signup required. You can see the full result directly and decide what to improve next.'
                : 'Kein Login nötig. Du siehst das volle Ergebnis direkt und kannst danach gezielt entscheiden, was verbessert werden soll.' %>
            </p>
            <div class="wt-panel" style="margin-top:0.9rem;">
              <h3 style="margin:0 0 0.35rem;"><%= isEn ? 'Need only a link health check?' : 'Nur Link-Gesundheit prüfen?' %></h3>
              <p style="margin:0 0 0.6rem;">
                <%= isEn
                  ? 'Use the dedicated Broken Links Tester for internal and external link checks with detailed issue list.'
                  : 'Nutze den separaten Broken-Links-Tester für interne und externe Link-Checks mit detaillierter Fehlerliste.' %>
              </p>
              <a class="wt-button-secondary" href="<%= isEn ? '/en/website-tester/broken-links' : '/website-tester/broken-links' %>">
                <i class="fa-solid fa-link-slash"></i>
                <%= isEn ? 'Open Broken Links Tester' : 'Broken-Links-Tester öffnen' %>
              </a>
            </div>

            <div class="wt-panel" style="margin-top:0.9rem;">
              <h3 style="margin:0 0 0.35rem;"><%= isEn ? 'Need a dedicated GEO analysis?' : 'Du brauchst eine dedizierte GEO-Analyse?' %></h3>
              <p style="margin:0 0 0.6rem;">
                <%= isEn
                  ? 'Use the GEO Tester for a focused generative-search visibility check with gated detailed report.'
                  : 'Nutze den GEO-Tester für einen fokussierten Check der generativen Suchsichtbarkeit mit gated Detailreport.' %>
              </p>
              <a class="wt-button-secondary" href="<%= isEn ? '/en/website-tester/geo' : '/website-tester/geo' %>">
                <i class="fa-solid fa-wand-magic-sparkles"></i>
                <%= isEn ? 'Open GEO Tester' : 'GEO-Tester öffnen' %>
              </a>
            </div>

            <div class="wt-panel" style="margin-top:0.9rem;">
              <h3 style="margin:0 0 0.35rem;"><%= isEn ? 'Need a dedicated SEO audit?' : 'Du brauchst einen dedizierten SEO-Audit?' %></h3>
              <p style="margin:0 0 0.6rem;">
                <%= isEn
                  ? 'Use the SEO Tester for a focused on-site SEO + technical check with gated detailed report.'
                  : 'Nutze den SEO-Tester für einen fokussierten Onsite-SEO- und Technik-Check mit gated Detailreport.' %>
              </p>
              <a class="wt-button-secondary" href="<%= isEn ? '/en/website-tester/seo' : '/website-tester/seo' %>">
                <i class="fa-solid fa-magnifying-glass-chart"></i>
                <%= isEn ? 'Open SEO Tester' : 'SEO-Tester öffnen' %>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel" data-audit-loading hidden>
          <h3><%= isEn ? 'Analysis in progress…' : 'Analyse läuft…' %></h3>
          <p><%= isEn ? 'We are crawling and evaluating the most important public signals now.' : 'Wir crawlen und bewerten gerade die wichtigsten öffentlichen Signale.' %></p>
          <ul class="wt-progress">
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Validate and secure target URL' : 'URL validieren und absichern' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Load homepage and metadata' : 'Startseite und Metadaten laden' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Crawl internal pages (up to 5)' : 'Unterseiten crawlen (bis zu 5)' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Evaluate SEO and technical checks' : 'SEO- und Technik-Checks auswerten' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Evaluate accessibility and trust signals' : 'Barrierefreiheits- und Vertrauenssignale auswerten' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Build score, priorities, and recommendations' : 'Score, Prioritäten und Empfehlungen erstellen' %></span></li>
          </ul>
        </div>

        <div class="wt-error" data-audit-error hidden></div>
        <div id="website-tester-results" class="wt-results" data-audit-results hidden></div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-check-grid">
          <article class="wt-check-card">
            <i class="fa-solid fa-magnifying-glass"></i>
            <h3><%= isEn ? 'SEO & Discoverability' : 'SEO & Auffindbarkeit' %></h3>
            <p><%= isEn ? 'Titles, descriptions, H1 structure, canonical tags, robots, sitemap, schema.' : 'Title, Description, H1-Struktur, Canonical, Robots, Sitemap, Schema.' %></p>
          </article>
          <article class="wt-check-card">
            <i class="fa-solid fa-universal-access"></i>
            <h3><%= isEn ? 'Accessibility Signals' : 'Barrierefreiheits-Signale' %></h3>
            <p><%= isEn ? 'Language attributes, alt texts, form labels, semantic landmarks, usable controls.' : 'Sprachattribute, ALT-Texte, Form-Labels, semantische Bereiche, nutzbare Controls.' %></p>
          </article>
          <article class="wt-check-card">
            <i class="fa-solid fa-gauge-high"></i>
            <h3><%= isEn ? 'Technical & Speed' : 'Technik & Geschwindigkeit' %></h3>
            <p><%= isEn ? 'Load times, HTML size, script complexity, stylesheet count, optional PSI signal.' : 'Ladezeiten, HTML-Größe, Script-Komplexität, Stylesheets, optionales PSI-Signal.' %></p>
          </article>
          <article class="wt-check-card">
            <i class="fa-solid fa-shield-heart"></i>
            <h3><%= isEn ? 'Trust & Conversion' : 'Vertrauen & Conversion' %></h3>
            <p><%= isEn ? 'HTTPS, legal/contact visibility, security headers, modernity and CTA clarity.' : 'HTTPS, sichtbare Rechtstexte/Kontakt, Security-Header, Modernität und CTA-Klarheit.' %></p>
          </article>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel">
          <h2><%= isEn ? 'Free website test: Is your website still up to date?' : 'Website kostenlos testen: Ist deine Website noch aktuell?' %></h2>
          <p><%= isEn
            ? 'Many users search for terms like “free website tester”, “website test free”, “is my website outdated”, or “does my website need an update”. This page is built to answer exactly that intent with a practical, instant audit.'
            : 'Viele Nutzer suchen nach Begriffen wie „Website testen“, „kostenloser Website Tester“, „Website kostenlos testen“, „Ist meine Website noch aktuell?“ oder „Muss ich meine Website updaten?“. Genau dafür ist dieser kostenlose Sofort-Check aufgebaut.' %></p>
          <p><%= isEn
            ? 'You get actionable priorities for SEO, GEO visibility, technical quality, trust, and conversion readiness—without registration.'
            : 'Du erhältst klare Prioritäten für SEO, GEO-Sichtbarkeit, Technik, Vertrauen und Conversion-Reife – ohne Registrierung.' %></p>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel">
          <h2><%= isEn ? 'FAQ: website tester & website update check' : 'FAQ: Website-Tester & Website-Update-Check' %></h2>
          <div class="wt-faq">
            <details>
              <summary><%= isEn ? 'How can I test my website for free?' : 'Wie kann ich meine Website kostenlos testen?' %></summary>
              <p><%= isEn ? 'Enter your URL and business context. You instantly get a score and concrete recommendations.' : 'Gib deine URL und den Geschäftskontext ein. Du bekommst sofort einen Score und konkrete Maßnahmen.' %></p>
            </details>
            <details>
              <summary><%= isEn ? 'How do I know if my website is outdated?' : 'Woran erkenne ich, ob meine Website veraltet ist?' %></summary>
              <p><%= isEn ? 'Weak metadata, poor load speed, missing trust signals, and unclear structure are common indicators.' : 'Schwache Metadaten, langsame Ladezeit, fehlende Vertrauenssignale und unklare Struktur sind typische Hinweise.' %></p>
            </details>
            <details>
              <summary><%= isEn ? 'Should I update my website now?' : 'Sollte ich meine Website jetzt updaten?' %></summary>
              <p><%= isEn ? 'If your score is low or critical in SEO/GEO, technical quality, or trust, an update should be prioritized.' : 'Wenn dein Score bei SEO/GEO, Technik oder Vertrauen niedrig bzw. kritisch ist, sollte ein Update priorisiert werden.' %></p>
            </details>
          </div>
        </div>
      </div>
    </section>

  </main>

  <%- include('partials/footer') %>


  <style>
    .wt-section-compact { padding-top: 16px; padding-bottom: 0; }
    .breadcrumbs ol { margin: 0; padding: 0; list-style: none; display: flex; gap: 10px; flex-wrap: wrap; }
    .breadcrumbs li { color: #6b7280; font-size: .95rem; }
    .breadcrumbs li+li::before { content: '›'; margin-right: 10px; color: #9ca3af; }
    .breadcrumbs a { color: #374151; text-decoration: none; }
    .breadcrumbs a:hover { text-decoration: underline; }
    .wt-faq details { border-top: 1px solid #e5e7eb; padding: 14px 0; }
    .wt-faq summary { cursor: pointer; font-weight: 600; }
    .wt-faq p { margin: 10px 0 0; }
  </style>


  <script>
    window.WEBSITE_TESTER_CONFIG = {
      locale: "<%= isEn ? 'en' : 'de' %>",
      endpoint: "/api/website-audit",
      leadEndpoint: "/api/website-audit/lead",
      mode: "deep",
      i18n: {
        scoreOf: "<%= isEn ? 'of 100' : 'von 100' %>",
        auditFor: "<%= isEn ? 'Audit for' : 'Analyse für' %>",
        statusModern: "<%= isEn ? 'Modern' : 'Modern' %>",
        statusMedium: "<%= isEn ? 'Needs work' : 'Ausbaufähig' %>",
        statusCritical: "<%= isEn ? 'Critical' : 'Kritisch' %>",
        categoriesTitle: "<%= isEn ? 'Category details' : 'Kategorien im Detail' %>",
        topFindingsTitle: "<%= isEn ? 'Top findings' : 'Wichtigste Befunde' %>",
        topActionsTitle: "<%= isEn ? 'Top actions' : 'Wichtigste Maßnahmen' %>",
        strengthsTitle: "<%= isEn ? 'Detected strengths' : 'Erkannte Stärken' %>",
        factsTitle: "<%= isEn ? 'Detected facts' : 'Erkannte Fakten' %>",
        limitationsTitle: "<%= isEn ? 'Limitations' : 'Hinweise' %>",
        crawlTitle: "<%= isEn ? 'Crawl scope' : 'Crawl-Umfang' %>",
        noStrengths: "<%= isEn ? 'No clear strengths detected yet.' : 'Es konnten noch keine klaren Stärken erkannt werden.' %>",
        noFindings: "<%= isEn ? 'No critical findings detected.' : 'Keine kritischen Befunde erkannt.' %>",
        noActions: "<%= isEn ? 'No urgent actions detected.' : 'Keine dringenden Maßnahmen erkannt.' %>",
        nextStepsTitle: "<%= isEn ? 'Next steps' : 'Nächste Schritte' %>",
        consultationTitle: "<%= isEn ? 'Discuss your result with us' : 'Ergebnis gemeinsam priorisieren' %>",
        consultationText: "<%= isEn ? 'Book a short consultation and get a concrete implementation roadmap.' : 'Buche ein kurzes Beratungsgespräch und erhalte einen konkreten Umsetzungsplan.' %>",
        consultationButton: "<%= isEn ? 'Book consultation' : 'Beratung buchen' %>",
        reportTitle: "<%= isEn ? 'Get the detailed PDF optimization report' : 'Detaillierten PDF-Optimierungsreport erhalten' %>",
        reportText: "<%= isEn ? 'Enter your email and we will send your in-depth report after confirmation.' : 'Trage deine E-Mail ein und wir senden dir nach Bestätigung den ausführlichen Report.' %>",
        reportNamePlaceholder: "<%= isEn ? 'Name (optional)' : 'Name (optional)' %>",
        reportEmailPlaceholder: "<%= isEn ? 'Email address' : 'E-Mail-Adresse' %>",
        reportConsentLabel: "<%= isEn ? 'I want to receive the requested PDF report by email.' : 'Ich möchte den angeforderten PDF-Report per E-Mail erhalten.' %>",
        reportSubmit: "<%= isEn ? 'Send confirmation link' : 'Bestätigungslink senden' %>",
        reportLoading: "<%= isEn ? 'Sending…' : 'Wird gesendet…' %>",
        leadSuccessDefault: "<%= isEn ? 'Please check your inbox and confirm your email. We will then send the report.' : 'Bitte prüfe dein Postfach und bestätige deine E-Mail. Danach senden wir den Report.' %>",
        leadErrorFallback: "<%= isEn ? 'The report request could not be processed.' : 'Die Report-Anfrage konnte nicht verarbeitet werden.' %>",
        contextRequired: "<%= isEn ? 'Please provide business type, primary service, and target region.' : 'Bitte ergänze Branche, Hauptleistung und Zielregion.' %>",
        contextBusiness: "<%= isEn ? 'Business type' : 'Branche' %>",
        contextService: "<%= isEn ? 'Primary service' : 'Hauptleistung' %>",
        contextRegion: "<%= isEn ? 'Target region' : 'Zielregion' %>",
        relevanceTitle: "<%= isEn ? 'Relevance scores' : 'Relevanz-Scores' %>",
        scannedPagesTitle: "<%= isEn ? 'Pages loaded for this scan' : 'Für den Scan geladene Seiten' %>",
        failedScansTitle: "<%= isEn ? 'Targets not loaded' : 'Nicht geladene Ziele' %>",
        noScannedPages: "<%= isEn ? 'No pages could be loaded.' : 'Es konnten keine Seiten geladen werden.' %>",
        scannedLegalForced: "<%= isEn ? 'Required legal check' : 'Pflichtseiten-Check' %>",
        legalImpressumTag: "<%= isEn ? 'Imprint' : 'Impressum' %>",
        legalPrivacyTag: "<%= isEn ? 'Privacy' : 'Datenschutz' %>",
        seoGeoScore: "<%= isEn ? 'SEO/GEO' : 'SEO/GEO' %>",
        valueScore: "<%= isEn ? 'Value score' : 'Mehrwert' %>",
        intentScore: "<%= isEn ? 'Intent match' : 'Intent-Match' %>",
        legalRiskTitle: "<%= isEn ? 'Legal risk' : 'Abmahn-Risiko' %>",
        legalBlockers: "<%= isEn ? 'Blockers' : 'Blocker' %>",
        noLegalRiskReasons: "<%= isEn ? 'No elevated legal risk hints detected.' : 'Keine erhöhten Risikohinweise erkannt.' %>",
        scoreWhyTitle: "<%= isEn ? 'Why this score?' : 'Warum dieser Score?' %>",
        rawScore: "<%= isEn ? 'Raw score' : 'Rohscore' %>",
        finalScore: "<%= isEn ? 'Final score' : 'Finaler Score' %>",
        scorePenalty: "<%= isEn ? 'Penalty' : 'Abzug' %>",
        capApplied: "<%= isEn ? 'active' : 'aktiv' %>",
        noCaps: "<%= isEn ? 'No score caps active.' : 'Keine Score-Caps aktiv.' %>",
        noPenalties: "<%= isEn ? 'No active penalties.' : 'Keine aktiven Penalties.' %>",
        trackingDetected: "<%= isEn ? 'Tracking detected' : 'Tracking erkannt' %>",
        consentSignal: "<%= isEn ? 'Consent signal' : 'Consent-Signal' %>",
        ctaPrimaryTrack: "tester_cta_primary",
        ctaSecondaryTrack: "tester_cta_secondary",
        detailActionLabel: "<%= isEn ? 'Recommendation' : 'Empfehlung' %>",
        errorFallback: "<%= isEn ? 'Analysis could not be completed.' : 'Die Analyse konnte nicht durchgeführt werden.' %>"
      }
    };
  </script>
  <script src="/js/website-tester.js?v=<%= encodeURIComponent(assetVersion || '1') %>" defer></script>
</body>
</html>
