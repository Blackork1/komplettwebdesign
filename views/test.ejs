<%- include('partials/head') %>
<% const isEn = typeof lng !== 'undefined' && lng === 'en'; %>
<body class="website-tester-page">
  <%- include('partials/header') %>

  <main id="hero">
    <link rel="stylesheet" href="<%= cssAsset('website-tester.css') %>">


    <section class="wt-section wt-section-compact">
      <div class="wt-shell">
        <nav class="breadcrumbs" aria-label="breadcrumb">
          <ol>
            <li><a href="<%= isEn ? '/en' : '/' %>"><%= isEn ? 'Home' : 'Startseite' %></a></li>
            <li aria-current="page"><%= isEn ? 'Website Tester' : 'Website-Tester' %></li>
          </ol>
        </nav>
      </div>
    </section>

    <section class="wt-hero">
      <div class="wt-shell">
        <div class="wt-hero-grid">
          <div class="wt-hero-copy">
            <span class="wt-eyebrow">
              <i class="fa-solid fa-magnifying-glass-chart"></i>
              <%= isEn ? 'Free website check' : 'Kostenloser Website-Check' %>
            </span>
            <h1><%= isEn ? 'Find out why your website is not generating enough requests.' : 'Finde heraus, warum deine Website zu wenig Anfragen bringt.' %></h1>
            <p class="wt-lead">
              <%= isEn
                ? 'Get a clear, easy-to-understand assessment of visibility, trust, usability and contact paths. The result shows what should be improved first.'
                : 'Du erhältst eine verständliche Einschätzung zu Sichtbarkeit, Vertrauen, Nutzerführung und Kontaktwegen. Das Ergebnis zeigt dir, was zuerst verbessert werden sollte.' %>
            </p>
            <ul class="wt-pill-list">
              <li><i class="fa-solid fa-list-check"></i> <%= isEn ? 'Clear recommendations instead of a technical checklist' : 'Klare Empfehlungen statt Technikliste' %></li>
              <li><i class="fa-solid fa-shield"></i> <%= isEn ? 'Useful before a relaunch or optimization' : 'Sinnvoll vor Relaunch oder Optimierung' %></li>
              <li><i class="fa-solid fa-clock"></i> <%= isEn ? 'Result directly in the browser' : 'Ergebnis direkt im Browser' %></li>
            </ul>
          </div>

          <div class="wt-form-card">
            <h2><%= isEn ? 'Check your website briefly' : 'Website kurz prüfen lassen' %></h2>
            <p><%= isEn ? 'Business type, service and region help us assess the site in the right context.' : 'Branche, Leistung und Region helfen dabei, den Check realistisch einzuordnen.' %></p>
            <form data-website-tester-form>
              <div class="wt-context-grid">
                <input name="businessType" type="text" placeholder="<%= isEn ? 'Business type (e.g. medical practice)' : 'Branche (z. B. Arztpraxis)' %>" required>
                <input name="primaryService" type="text" placeholder="<%= isEn ? 'Primary service (e.g. dental implants)' : 'Hauptleistung (z. B. Zahnimplantate)' %>" required>
                <input name="targetRegion" type="text" placeholder="<%= isEn ? 'Target region (e.g. Berlin)' : 'Zielregion (z. B. Berlin)' %>" required>
              </div>
              <label class="visually-hidden" for="website-url"><%= isEn ? 'Website URL' : 'Website-URL' %></label>
              <div class="wt-form-row">
                <input id="website-url" name="url" type="text" inputmode="url" placeholder="<%= isEn ? 'https://your-website.com' : 'https://deine-website.de' %>" required>
                <button class="wt-button" type="submit">
                  <i class="fa-solid fa-bolt"></i>
                  <%= isEn ? 'Start check' : 'Check starten' %>
                </button>
              </div>
            </form>
            <p class="wt-form-note">
              <%= isEn
                ? 'No signup required. You can see the full result directly and decide what to improve next.'
                : 'Kein Login nötig. Du siehst das volle Ergebnis direkt und kannst danach gezielt entscheiden, was verbessert werden soll.' %>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="wt-section wt-tool-overview" aria-labelledby="specialized-testers-title">
      <div class="wt-shell">
        <div class="wt-section-heading">
          <span class="wt-eyebrow">
            <i class="fa-solid fa-toolbox"></i>
            <%= isEn ? 'Specialized checks' : 'Spezialisierte Checks' %>
          </span>
          <h2 id="specialized-testers-title"><%= isEn ? 'Choose a focused check if you already know the topic' : 'Wähle einen fokussierten Check, wenn du das Thema schon kennst' %></h2>
          <p>
            <%= isEn
              ? 'The full website check gives you the overview. These checks focus on one area when you want to look deeper into links, SEO, AI visibility or meta data.'
              : 'Der komplette Website-Check gibt dir den Überblick. Diese Checks schauen gezielt auf Links, SEO, KI-Sichtbarkeit oder Meta-Daten.' %>
          </p>
        </div>
        <div class="wt-tool-grid">
          <article class="wt-tool-card">
            <div class="wt-tool-icon"><i class="fa-solid fa-link-slash"></i></div>
            <h3><%= isEn ? 'Broken-Links-Tester' : 'Broken-Links-Tester' %></h3>
            <p>
              <%= isEn
                ? 'Check internal and external links and find broken targets, redirects, warnings and affected source pages.'
                : 'Prüft interne und externe Links und findet defekte Ziele, Weiterleitungen, Warnungen und betroffene Quellseiten.' %>
            </p>
            <a class="wt-button-secondary" href="<%= isEn ? '/en/website-tester/broken-links' : '/website-tester/broken-links' %>">
              <%= isEn ? 'Open tester' : 'Tester öffnen' %>
            </a>
          </article>
          <article class="wt-tool-card">
            <div class="wt-tool-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
            <h3><%= isEn ? 'GEO-Tester' : 'GEO-Tester' %></h3>
            <p>
              <%= isEn
                ? 'Analyze AI visibility signals such as entities, snippets, FAQ structure and crawler access.'
                : 'Analysiert KI-Sichtbarkeitssignale wie Entitäten, Snippets, FAQ-Struktur und Crawler-Zugriff.' %>
            </p>
            <a class="wt-button-secondary" href="<%= isEn ? '/en/website-tester/geo' : '/website-tester/geo' %>">
              <%= isEn ? 'Open tester' : 'Tester öffnen' %>
            </a>
          </article>
          <article class="wt-tool-card">
            <div class="wt-tool-icon"><i class="fa-solid fa-magnifying-glass-chart"></i></div>
            <h3><%= isEn ? 'SEO-Tester' : 'SEO-Tester' %></h3>
            <p>
              <%= isEn
                ? 'Audit on-page SEO, indexing, technical quality, content, internal linking and structured data.'
                : 'Prüft Inhalte, Auffindbarkeit, Seitenstruktur, interne Verlinkung und wichtige Google-Signale.' %>
            </p>
            <a class="wt-button-secondary" href="<%= isEn ? '/en/website-tester/seo' : '/website-tester/seo' %>">
              <%= isEn ? 'Open tester' : 'Tester öffnen' %>
            </a>
          </article>
          <article class="wt-tool-card">
            <div class="wt-tool-icon"><i class="fa-solid fa-code"></i></div>
            <h3><%= isEn ? 'Meta-Tester' : 'Meta-Tester' %></h3>
            <p>
              <%= isEn
                ? 'Check title, description, H1, canonical, Open Graph, social tags, icons and head signals.'
                : 'Prüft Title, Description, H1, Canonical, Open Graph, Social-Tags, Icons und Head-Signale.' %>
            </p>
            <a class="wt-button-secondary" href="<%= isEn ? '/en/website-tester/meta' : '/website-tester/meta' %>">
              <%= isEn ? 'Open tester' : 'Tester öffnen' %>
            </a>
          </article>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel" data-audit-loading hidden>
          <h3><%= isEn ? 'Analysis in progress…' : 'Analyse läuft…' %></h3>
          <p><%= isEn ? 'We are crawling and evaluating the most important public signals now.' : 'Wir crawlen und bewerten gerade die wichtigsten öffentlichen Signale.' %></p>
          <ul class="wt-progress">
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Validate and secure target URL' : 'URL validieren und absichern' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Load homepage and metadata' : 'Startseite und Metadaten laden' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Crawl internal pages (up to 5)' : 'Unterseiten crawlen (bis zu 5)' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Evaluate SEO and technical checks' : 'SEO- und Technik-Checks auswerten' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Evaluate accessibility and trust signals' : 'Barrierefreiheits- und Vertrauenssignale auswerten' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Build score, priorities, and recommendations' : 'Score, Prioritäten und Empfehlungen erstellen' %></span></li>
          </ul>
        </div>

        <div class="wt-error" data-audit-error hidden></div>
        <div id="website-tester-results" class="wt-results" data-audit-results hidden></div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-check-grid">
          <article class="wt-check-card">
            <i class="fa-solid fa-magnifying-glass"></i>
            <h3><%= isEn ? 'SEO & Discoverability' : 'SEO & Auffindbarkeit' %></h3>
            <p><%= isEn ? 'Titles, descriptions, H1 structure, canonical tags, robots, sitemap, schema.' : 'Title, Description, H1-Struktur, Canonical, Robots, Sitemap, Schema.' %></p>
          </article>
          <article class="wt-check-card">
            <i class="fa-solid fa-universal-access"></i>
            <h3><%= isEn ? 'Accessibility Signals' : 'Barrierefreiheits-Signale' %></h3>
            <p><%= isEn ? 'Language attributes, alt texts, form labels, semantic landmarks, usable controls.' : 'Sprachattribute, ALT-Texte, Form-Labels, semantische Bereiche, nutzbare Controls.' %></p>
          </article>
          <article class="wt-check-card">
            <i class="fa-solid fa-gauge-high"></i>
            <h3><%= isEn ? 'Technical & Speed' : 'Technik & Geschwindigkeit' %></h3>
            <p><%= isEn ? 'Load times, HTML size, script complexity, stylesheet count, optional PSI signal.' : 'Ladezeiten, HTML-Größe, Script-Komplexität, Stylesheets, optionales PSI-Signal.' %></p>
          </article>
          <article class="wt-check-card">
            <i class="fa-solid fa-shield-heart"></i>
            <h3><%= isEn ? 'Trust & Conversion' : 'Vertrauen & Conversion' %></h3>
            <p><%= isEn ? 'HTTPS, legal/contact visibility, security headers, modernity and CTA clarity.' : 'HTTPS, sichtbare Rechtstexte/Kontakt, Security-Header, Modernität und CTA-Klarheit.' %></p>
          </article>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel wt-methodology">
          <h2><%= isEn ? 'How the Website Tester evaluates your site' : 'So bewertet der Website-Tester deine Seite' %></h2>
          <p>
            <%= isEn
              ? 'The Website Tester looks at your homepage and important public signals for visibility, trust, usability and requests. The result is translated into clear priorities so you can decide what matters next.'
              : 'Der Website-Tester betrachtet deine Startseite und wichtige öffentliche Signale für Sichtbarkeit, Vertrauen, Nutzerführung und Anfragen. Das Ergebnis wird in klare Prioritäten übersetzt, damit du schnell erkennst, was als Nächstes zählt.' %>
          </p>
          <div class="wt-method-grid">
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-magnifying-glass"></i> <%= isEn ? 'SEO & discoverability' : 'SEO & Auffindbarkeit' %></h3>
              <p><%= isEn
                ? 'Title, description, H-structure, canonical, hreflang, robots, sitemap, schema. We check signal presence and intent fit against your business context.'
                : 'Title, Description, H-Struktur, Canonical, Hreflang, Robots, Sitemap, Schema. Wir prüfen Präsenz und Intent-Fit gegen deinen Geschäftskontext.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-wand-magic-sparkles"></i> <%= isEn ? 'AI visibility' : 'KI-Sichtbarkeit' %></h3>
              <p><%= isEn
                ? 'Entity clarity, LLM crawler access, question-answer structure, factual verifiability. Whether AI systems can retrieve and cite you.'
                : 'Entity-Klarheit, LLM-Crawler-Zugang, Frage-Antwort-Struktur, Fakten-Belegbarkeit. Ob KI-Systeme dich abrufen und zitieren können.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-gauge-high"></i> <%= isEn ? 'Technical & speed' : 'Technik & Speed' %></h3>
              <p><%= isEn
                ? 'HTTPS, HTTP/2, compression, response time, HTML weight, render-blocking resources, mobile viewport, Core Web Vitals proxies.'
                : 'HTTPS, HTTP/2, Komprimierung, Antwortzeit, HTML-Gewicht, render-blockierende Ressourcen, Mobile-Viewport, Core-Web-Vitals-Proxies.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-universal-access"></i> <%= isEn ? 'Accessibility' : 'Barrierefreiheit' %></h3>
              <p><%= isEn
                ? 'Whether images, forms, headings and page structure are easy to understand for people and search systems.'
                : 'Ob Bilder, Formulare, Überschriften und Seitenstruktur für Menschen und Suchsysteme verständlich sind.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-shield-heart"></i> <%= isEn ? 'Trust & legal' : 'Vertrauen & Rechtliches' %></h3>
              <p><%= isEn
                ? 'HTTPS, impressum/privacy visibility, security headers, modernity cues, tracking + consent detection. Proxies for BGH/LfDI risk.'
                : 'HTTPS, Sichtbarkeit von Impressum/Datenschutz, Security-Header, Modernitäts-Signale, Tracking- und Consent-Erkennung. Proxies für BGH/LfDI-Risiko.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-bullseye"></i> <%= isEn ? 'Conversion readiness' : 'Conversion-Reife' %></h3>
              <p><%= isEn
                ? 'CTA clarity, above-the-fold value proposition, contact accessibility, form quality, social proof presence. What actually drives inquiries.'
                : 'CTA-Klarheit, Above-the-Fold-Value-Proposition, Kontakt-Erreichbarkeit, Form-Qualität, Social-Proof. Was tatsächlich Anfragen generiert.' %></p>
            </div>
          </div>
          <p>
            <%= isEn
              ? 'After the audit you immediately see the overall score, six category scores, the top findings, a prioritized action list, detected strengths, and identified facts — all in your browser without registration. A detailed PDF report with every finding, priority, and implementation recommendation is sent after double opt-in; the full guide (28+ pages) typically captures 2–4 hours of consulting work.'
              : 'Nach dem Check siehst du den Gesamt-Score, die wichtigsten Befunde, erkannte Stärken und eine priorisierte Maßnahmen-Liste direkt im Browser. Danach kannst du entscheiden, ob du die Punkte selbst angehst oder ein Erstgespräch vereinbarst.' %>
          </p>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel">
          <h2><%= isEn ? 'What clients say about working with us' : 'Was Kunden sagen' %></h2>
          <div class="wt-reviews-grid">
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“The audit and implementation roadmap gave us more organic leads in three months than our previous agency delivered in a year.”'
                : '„Der Website-Check und der Umsetzungsplan haben uns in drei Monaten mehr organische Leads gebracht als die vorherige Agentur in einem Jahr."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“Honest, fast, transparent. Every recommendation was rooted in data and worked in practice.”'
                : '„Ehrlich, schnell, transparent. Jede Empfehlung war datenbasiert und hat in der Praxis funktioniert."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“The free tester already convinced us. After the paid project our rankings moved from page 3 to top 5.”'
                : '„Der kostenlose Tester hat uns überzeugt. Nach dem Folgeprojekt ging unser Ranking von Seite 3 in die Top 5."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
          </div>
          <p class="wt-reviews-link">
            <a href="https://www.google.com/search?q=komplett+webdesign+bewertungen" target="_blank" rel="noopener">
              <i class="fa-brands fa-google"></i>
              <%= isEn ? 'Read all Google reviews' : 'Alle Google-Bewertungen lesen' %>
            </a>
          </p>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel wt-trust-panel">
          <h3><%= isEn ? 'Transparent and privacy-friendly' : 'Transparent und datenschutzfreundlich' %></h3>
          <ul class="wt-trust-list">
            <li><i class="fa-solid fa-shield-halved"></i> <%= isEn ? 'The check only looks at publicly visible website signals.' : 'Der Check betrachtet nur öffentlich sichtbare Website-Signale.' %></li>
            <li><i class="fa-solid fa-clock"></i> <%= isEn ? 'You receive a compact result quickly, without a long waiting process.' : 'Du erhältst schnell ein kompaktes Ergebnis, ohne langen Warteprozess.' %></li>
            <li><i class="fa-solid fa-database"></i> <%= isEn ? 'Anonymous check data is used only for quality assurance.' : 'Anonyme Check-Daten werden nur zur Qualitätssicherung genutzt.' %></li>
            <li><i class="fa-solid fa-lock"></i> <%= isEn ? 'No login required and no changes are made to your website.' : 'Kein Login nötig und an deiner Website wird nichts verändert.' %></li>
          </ul>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel">
          <h2><%= isEn ? 'FAQ: website tester & website update check' : 'FAQ: Website-Tester & Website-Update-Check' %></h2>
          <div class="wt-faq">
            <% (typeof faq !== 'undefined' && Array.isArray(faq) ? faq : []).forEach(function(item){ %>
              <details>
                <summary><%= item.q %></summary>
                <p><%= item.a %></p>
              </details>
            <% }); %>
          </div>
        </div>
      </div>
    </section>

  </main>

  <%- include('partials/footer') %>


  <style>
    .wt-section-compact { padding-top: 16px; padding-bottom: 0; }
    .breadcrumbs ol { margin: 0; padding: 0; list-style: none; display: flex; gap: 10px; flex-wrap: wrap; }
    .breadcrumbs li { color: #6b7280; font-size: .95rem; }
    .breadcrumbs li+li::before { content: '›'; margin-right: 10px; color: #9ca3af; }
    .breadcrumbs a { color: #374151; text-decoration: none; }
    .breadcrumbs a:hover { text-decoration: underline; }
    .wt-faq details { border-top: 1px solid #e5e7eb; padding: 14px 0; }
    .wt-faq summary { cursor: pointer; font-weight: 600; }
    .wt-faq p { margin: 10px 0 0; }
  </style>


  <script>
    window.WEBSITE_TESTER_CONFIG = {
      locale: "<%= isEn ? 'en' : 'de' %>",
      endpoint: "/api/website-audit",
      leadEndpoint: "/api/website-audit/lead",
      mode: "deep",
      i18n: {
        scoreOf: "<%= isEn ? 'of 100' : 'von 100' %>",
        auditFor: "<%= isEn ? 'Audit for' : 'Analyse für' %>",
        statusModern: "<%= isEn ? 'Modern' : 'Modern' %>",
        statusMedium: "<%= isEn ? 'Needs work' : 'Ausbaufähig' %>",
        statusCritical: "<%= isEn ? 'Critical' : 'Kritisch' %>",
        categoriesTitle: "<%= isEn ? 'Category details' : 'Kategorien im Detail' %>",
        topFindingsTitle: "<%= isEn ? 'Top findings' : 'Wichtigste Befunde' %>",
        topActionsTitle: "<%= isEn ? 'Top actions' : 'Wichtigste Maßnahmen' %>",
        strengthsTitle: "<%= isEn ? 'Detected strengths' : 'Erkannte Stärken' %>",
        factsTitle: "<%= isEn ? 'Detected facts' : 'Erkannte Fakten' %>",
        limitationsTitle: "<%= isEn ? 'Limitations' : 'Hinweise' %>",
        crawlTitle: "<%= isEn ? 'Crawl scope' : 'Crawl-Umfang' %>",
        noStrengths: "<%= isEn ? 'No clear strengths detected yet.' : 'Es konnten noch keine klaren Stärken erkannt werden.' %>",
        noFindings: "<%= isEn ? 'No critical findings detected.' : 'Keine kritischen Befunde erkannt.' %>",
        noActions: "<%= isEn ? 'No urgent actions detected.' : 'Keine dringenden Maßnahmen erkannt.' %>",
        nextStepsTitle: "<%= isEn ? 'Next steps' : 'Nächste Schritte' %>",
        consultationTitle: "<%= isEn ? 'Discuss your result with us' : 'Ergebnis gemeinsam priorisieren' %>",
        consultationText: "<%= isEn ? 'Book a short consultation and get a concrete implementation roadmap.' : 'Buche ein kurzes Beratungsgespräch und erhalte einen konkreten Umsetzungsplan.' %>",
        consultationButton: "<%= isEn ? 'Book consultation' : 'Beratung buchen' %>",
        reportTitle: "<%= isEn ? 'Get the detailed PDF optimization report' : 'Detaillierten PDF-Optimierungsreport erhalten' %>",
        reportText: "<%= isEn ? 'Enter your email. After double opt-in confirmation, we send the detailed report and activate your newsletter subscription.' : 'Trage deine E-Mail ein. Nach Double-Opt-in-Bestätigung senden wir den detaillierten Report und aktivieren deine Newsletter-Anmeldung.' %>",
        reportNamePlaceholder: "<%= isEn ? 'Name (optional)' : 'Name (optional)' %>",
        reportEmailPlaceholder: "<%= isEn ? 'Email address' : 'E-Mail-Adresse' %>",
        reportConsentLabel: "<%= isEn ? 'I agree to newsletter signup, want to receive the requested report by email, and have read the privacy policy.' : 'Ich stimme der Newsletter-Anmeldung zu, möchte den angeforderten Report per E-Mail erhalten und habe die Datenschutzerklärung gelesen.' %>",
        privacyHref: "/datenschutz",
        privacyLabel: "<%= isEn ? 'Privacy policy' : 'Datenschutzerklärung' %>",
        reportSubmit: "<%= isEn ? 'Send confirmation link' : 'Bestätigungslink senden' %>",
        reportLoading: "<%= isEn ? 'Sending…' : 'Wird gesendet…' %>",
        leadSuccessDefault: "<%= isEn ? 'Please check your inbox and confirm your email. We will then send the report.' : 'Bitte prüfe dein Postfach und bestätige deine E-Mail. Danach senden wir den Report.' %>",
        leadErrorFallback: "<%= isEn ? 'The report request could not be processed.' : 'Die Report-Anfrage konnte nicht verarbeitet werden.' %>",
        contextRequired: "<%= isEn ? 'Please provide business type, primary service, and target region.' : 'Bitte ergänze Branche, Hauptleistung und Zielregion.' %>",
        contextBusiness: "<%= isEn ? 'Business type' : 'Branche' %>",
        contextService: "<%= isEn ? 'Primary service' : 'Hauptleistung' %>",
        contextRegion: "<%= isEn ? 'Target region' : 'Zielregion' %>",
        relevanceTitle: "<%= isEn ? 'Relevance scores' : 'Relevanz-Scores' %>",
        scannedPagesTitle: "<%= isEn ? 'Pages loaded for this scan' : 'Für den Scan geladene Seiten' %>",
        failedScansTitle: "<%= isEn ? 'Targets not loaded' : 'Nicht geladene Ziele' %>",
        noScannedPages: "<%= isEn ? 'No pages could be loaded.' : 'Es konnten keine Seiten geladen werden.' %>",
