<% /* views/component.ejs – universelles Partial für alle Komponenten */ %>
<%
const c = component || {};
const children = Array.isArray(c.children) ? c.children : [];
const escapeFallback = (value) => String(value || '').replace(/[&<>"']/g, function(ch) {
  return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[ch];
});
const h = typeof sanitizeHtml === 'function'
  ? sanitizeHtml
  : escapeFallback;
const url = typeof safeUrl === 'function'
  ? safeUrl
  : (value) => String(value || '#');
const componentType = typeof safeComponentTag === 'function'
  ? safeComponentTag(c.type)
  : String(c.type || 'div').toLowerCase();
const inputType = typeof safeInputType === 'function'
  ? safeInputType(c.input_type || 'text')
  : String(c.input_type || 'text').toLowerCase();
const formMethod = typeof safeFormMethod === 'function'
  ? safeFormMethod(c.method || 'post')
  : String(c.method || 'post').toLowerCase();
%>

<% if (componentType === 'form') { %>
  <form
    action="<%= url(c.action || '#') %>"
    method="<%= formMethod %>"
    class="<%= c.classes || '' %>"
  >
    <% children.forEach(child => { %>
      <%- include('component', { component: child }) %>
    <% }) %>
  </form>

<% } else if (componentType === 'input') { %>
  <input
    type="<%= inputType %>"
    name="<%= c.name || '' %>"
    value="<%= c.value || '' %>"
    placeholder="<%= c.placeholder || '' %>"
    <% if (c.required) { %> required <% } %>
    <% if (c.pattern) { %> pattern="<%= c.pattern %>" <% } %>
    <% if (c.minlength) { %> minlength="<%= c.minlength %>" <% } %>
    class="<%= c.classes || '' %>"
  />

<% } else if (componentType === 'textarea') { %>
  <textarea
    name="<%= c.name || '' %>"
    placeholder="<%= c.placeholder || '' %>"
    <% if (c.required) { %> required <% } %>
    <% if (c.pattern) { %> pattern="<%= c.pattern %>" <% } %>
    <% if (c.minlength) { %> minlength="<%= c.minlength %>" <% } %>
    class="<%= c.classes || '' %>"
  ><%= c.value || '' %></textarea>

<% } else if (componentType === 'select') {
     const opts = (c.options||'').split('|'); %>
  <select
    name="<%= c.name || '' %>"
    class="<%= c.classes || '' %>"
    <% if (c.required) { %> required <% } %>
  >
    <% opts.forEach(o => {
         const t = o.trim();
         if (!t) return;
    %>
      <option value="<%= t %>"><%= t %></option>
    <% }) %>
  </select>

<% } else if (componentType === 'radio') {
     const opts = (c.options||'').split('|'); %>
  <div class="<%= c.classes || '' %>">
    <% opts.forEach((o,i) => {
         const t = o.trim();
         if (!t) return;
         const id = 'r' + c.id + '_' + i;
    %>
      <label for="<%= id %>">
        <input
          id="<%= id %>"
          type="radio"
          name="<%= c.name || '' %>"
          value="<%= t %>"
          <% if (c.required) { %> required <% } %>
        />
        <%= t %>
      </label>
    <% }) %>
  </div>

<% } else if (componentType === 'checkbox') { %>
  <label class="<%= c.classes || '' %>">
    <input
      type="checkbox"
      name="<%= c.name || '' %>"
      value="<%= c.value || 'on' %>"
      <% if (c.required) { %> required <% } %>
    />
    <%= c.value && isNaN(c.value) ? c.value : '' %>
  </label>

<% } else if (componentType === 'submit' || componentType === 'button') { %>
  <button
    type="<%= componentType === 'submit' ? 'submit' : 'button' %>"
    class="<%= c.classes || '' %>"
  >
    <%= c.value || 'Button' %>
  </button>

<% } else if (componentType === 'img') { %>
  <img
    src="<%= url(c.src || '#') %>"
    alt="<%= c.alt || '' %>"
    class="<%= c.classes || '' %>"
  />

<% } else if (componentType === 'iframe') { %>
  <iframe
    src="<%= url(c.src || 'about:blank', { allowedProtocols: ['http:', 'https:'], allowRelative: false, fallback: 'about:blank' }) %>"
    class="<%= c.classes || '' %>"
    <% if (c.width)  { %> width="<%= c.width %>"  <% } %>
    <% if (c.height) { %> height="<%= c.height %>" <% } %>
  ></iframe>

<% } else if (['br','hr'].includes(componentType)) { %>
  <<%- componentType %> class="<%= c.classes || '' %>" />

<% } else if (componentType === 'a') { %>
  <a href="<%= url(c.href || '#') %>" class="<%= c.classes || '' %>">
    <% if (children.length) { %>
      <% children.forEach(child => { %>
        <%- include('component', { component: child }) %>
      <% }) %>
    <% } else { %>
      <%- h(c.content) %>
    <% } %>
  </a>

<% } else if (componentType === 'ul' || componentType === 'ol') { %>
  <<%- componentType %> class="<%= c.classes || '' %>">
    <% children.forEach(child => { %>
      <%- include('component', { component: child }) %>
    <% }) %>
  </<%- componentType %>>

<% } else if (componentType === 'li') { %>
  <li class="<%= c.classes || '' %>">
    <% if (children.length) { %>
      <% children.forEach(child => { %>
        <%- include('component', { component: child }) %>
      <% }) %>
    <% } else { %>
      <%- h(c.content) %>
    <% } %>
  </li>

<% } else if (componentType === 'div') { %>
  <div class="<%= c.classes || '' %>">
    <% children.forEach(child => { %>
      <%- include('component', { component: child }) %>
    <% }) %>
    <% if (!children.length && c.content) { %><%- h(c.content) %><% } %>
  </div>

<% } else if (componentType === 'p') { %>
  <p class="<%= c.classes || '' %>">
    <%- h(c.content) %>
  </p>

<% } else if (['h1','h2','h3','h4','h5','h6'].includes(componentType)) { %>
  <<%- componentType %> class="<%= c.classes || '' %>">
    <%- h(c.content) %>
  </<%- componentType %>>

<% } else { %>
  <div class="<%= c.classes || '' %>">
    <% if (c.content) { %><%- h(c.content) %><% } %>
    <% children.forEach(child => { %>
      <%- include('component', { component: child }) %>
    <% }) %>
  </div>
<% } %>
