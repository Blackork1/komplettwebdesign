<%
  const siteBaseUrl = (typeof canonicalBaseUrl !== 'undefined' && canonicalBaseUrl
    ? canonicalBaseUrl
    : 'https://komplettwebdesign.de').replace(/\/$/, '');
  const packagePathHints = ['/pakete/start', '/pakete/business', '/pakete/wachstum', '/pakete/individuell'];
  const visiblePackages = Array.isArray(packages) ? packages.filter((pkg) => pkg && pkg.isVisible !== false) : [];
  const contactPath = isEn ? '/en/kontakt' : '/kontakt';
  const tablePackages = Array.isArray(comparisonPackages) && comparisonPackages.length ? comparisonPackages : visiblePackages;
  const dbComparisonRows = Array.isArray(comparisonRows) ? comparisonRows : [];
  const dbOverviewFaqs = Array.isArray(overviewFaqs) ? overviewFaqs : [];
  const dbGlobalNotes = Array.isArray(globalNotes) ? globalNotes : [];
  const heroPriceLabel = lowestPriceLabel || (visiblePackages[0] && visiblePackages[0].priceLabel) || '';
  const packageSummary = packageSummaryLabel || visiblePackages
    .slice(0, 3)
    .map((pkg) => `${pkg.name}: ${pkg.priceLabel}`)
    .join(', ');
  const schemaFaqs = dbOverviewFaqs.filter((faq) => faq && faq.schemaEligible && faq.question && faq.answer);
  function canShowPackageDetail(pkg) {
    return pkg && pkg.allowDetailPage !== false && (pkg.canonicalPath || pkg.slug);
  }

  const schemaPackages = visiblePackages.map((pkg, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    ...(canShowPackageDetail(pkg) ? { "url": `${siteBaseUrl}${pkg.canonicalPath || `/pakete/${pkg.slug}`}` } : {}),
    "name": isEn ? `${pkg.name} package` : `${pkg.name}-Paket`
  }));
  const structuredDataBlocks = [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": isEn ? "Home" : "Startseite", "item": `${siteBaseUrl}/` },
        { "@type": "ListItem", "position": 2, "name": isEn ? "Packages" : "Pakete", "item": `${siteBaseUrl}/pakete` }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title || (isEn ? "Website Packages - Komplett Webdesign Berlin" : "Website-Pakete - Komplett Webdesign Berlin"),
      "url": `${siteBaseUrl}/pakete`,
      "description": description || "",
      "inLanguage": isEn ? "en" : "de",
      "isPartOf": { "@type": "WebSite", "name": "Komplett Webdesign", "url": `${siteBaseUrl}/` }
    },
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "url": `${siteBaseUrl}/pakete`,
      "itemListElement": schemaPackages
    },
    ...(schemaFaqs.length ? [{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": schemaFaqs.map((faq) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      }))
    }] : [])
  ];

  function packageUrl(pkg) {
    if (!canShowPackageDetail(pkg)) {
      const packageValue = pkg && (pkg.packageKey || pkg.slug);
      return `${contactPath}${packageValue ? `?paket=${encodeURIComponent(packageValue)}` : ''}`;
    }
    return `${isEn ? '/en' : ''}${pkg.canonicalPath || `/pakete/${pkg.slug}`}`;
  }

  function packagePrimaryCtaLabel(pkg) {
    if (!canShowPackageDetail(pkg)) return isEn ? 'Request package' : 'Paket anfragen';
    return isEn ? 'View details' : 'Details ansehen';
  }

  function packageTitle(pkg) {
    if (isEn) return `${pkg.name} package`;
    return pkg.displayName || `${pkg.name}-Paket`;
  }

  function packageText(pkg) {
    return pkg.shortDescription || pkg.description || pkg.positioning || pkg.longDescription || '';
  }

  function featureText(item) {
    return item && typeof item === 'object' ? item.text : item;
  }

  function packageImage(pkg) {
    const imageMap = {
      start: '/images/paket-start.webp',
      business: '/images/paket-business.webp',
      wachstum: '/images/paket-wachstum.webp',
      individuell: '/images/paket-individuell.webp'
    };
    return imageMap[pkg.packageKey || pkg.slug] || '/images/preiseHero.webp';
  }
%>
<%- include('partials/head', { structuredDataBlocks, extraCssAssets: ['package-list.css'] }) %>

<body>
  <%- include('partials/header') %>

  <main class="packages-page">
    <section class="packages-hero unified-hero" data-reveal-immediate>
      <div class="container hero-grid unified-hero__grid">
        <div class="hero-copy unified-hero__copy">
          <nav class="unified-hero__breadcrumbs" aria-label="Breadcrumb">
            <ol>
              <li><a href="<%= isEn ? '/en' : '/' %>"><%= isEn ? 'Home' : 'Startseite' %></a></li>
              <li aria-current="page"><%= isEn ? 'Packages' : 'Pakete' %></li>
            </ol>
          </nav>
          <h1 class="hero-title home-hero-reveal home-hero-reveal--h1 animate-on-scroll">
            <%= isEn
              ? `Create a website in Berlin: packages${heroPriceLabel ? ` from ${heroPriceLabel.replace('€', 'EUR')}` : ''}`
              : `Website erstellen lassen in Berlin: Pakete${heroPriceLabel ? ` ab ${heroPriceLabel}` : ''}`
            %>
          </h1>
          <h2 class="hero-subtitle unified-hero__lead home-hero-reveal home-hero-reveal--support animate-on-scroll">
            <%= isEn
              ? 'Choose the right scope for your business: compact start, structured company website, growth-oriented relaunch or custom functionality.'
              : 'Wähle den passenden Umfang für dein Unternehmen: kompakter Start, strukturierte Unternehmenswebsite, wachstumsorientierter Relaunch oder Sonderfunktionen.'
            %>
          </h2>
          <ul class="hero-highlights">
            <% if (packageSummary) { %>
            <li class="home-hero-reveal home-hero-reveal--bullet animate-on-scroll">
              <img src="/images/icons/check.svg" alt="" width="26" height="26" loading="lazy">
              <span><%= packageSummary %></span>
            </li>
            <% } %>
            <li class="home-hero-reveal home-hero-reveal--bullet animate-on-scroll">
              <img src="/images/icons/check.svg" alt="" width="26" height="26" loading="lazy">
              <span><%= isEn ? 'Technical SEO basics and supplied-content structure by scope' : 'Technische SEO-Grundlagen und Strukturierung gelieferter Inhalte je nach Umfang' %></span>
            </li>
            <li class="home-hero-reveal home-hero-reveal--bullet animate-on-scroll">
              <img src="/images/icons/check.svg" alt="" width="26" height="26" loading="lazy">
              <span><%= isEn ? 'Domain, email, hosting, maintenance and third-party tools are separated clearly' : 'Domain, E-Mail, Hosting, Wartung und Drittanbieter-Tools werden klar getrennt' %></span>
            </li>
          </ul>
          <div class="hero-actions unified-hero__actions home-hero-reveal home-hero-reveal--actions animate-on-scroll">
            <a class="btn btn-primary" href="<%= isEn ? '/en/kontakt' : '/kontakt' %>" data-track="cta" data-cta-name="packages_hero_contact" data-cta-location="packages_hero"><%= isEn ? 'Request consultation' : 'Beratung anfragen' %></a>
            <a class="btn btn-secondary" href="<%= isEn ? '/en/kontakt?projektart=unsure' : '/kontakt?projektart=unsure' %>" data-track="cta" data-cta-name="packages_hero_scope" data-cta-location="packages_hero"><%= isEn ? 'Clarify project scope' : 'Projektumfang klären' %></a>
          </div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <div class="hero-image-frame unified-hero__media-frame">
            <picture>
              <source srcset="/images/heroPakete.webp" type="image/webp" />
              <img src="/images/heroPakete.webp" alt="<%= isEn ? 'Website packages overview' : 'Websitepakete im Überblick' %>" loading="eager" fetchpriority="high" decoding="async" />
            </picture>
          </div>
        </div>
      </div>
    </section>

    <section class="packages-intro">
      <div class="container">
        <p class="packages-intro-lead">
          <%= isEn
            ? 'Here you can quickly see which website package fits your current situation, what is included, what remains optional and which ongoing costs should be considered separately.'
            : 'Hier siehst du schnell, welches Website-Paket zu deiner aktuellen Situation passt, was enthalten ist, was optional bleibt und welche laufenden Kosten separat zu betrachten sind.'
          %>
        </p>
      </div>
      <div class="container intro-grid">
        <article class="intro-card">
          <h2><%= isEn ? 'Choose by scope' : 'Auswahl nach Umfang' %></h2>
          <p><%= isEn ? 'Each package has clear boundaries for page scope, feedback and optional extensions.' : 'Jedes Paket hat klare Grenzen für Seitenumfang, Feedbackrunden und optionale Erweiterungen.' %></p>
        </article>
        <article class="intro-card">
          <h2><%= isEn ? 'Clear limits, fair prices' : 'Klare Grenzen, faire Preise' %></h2>
          <p><%= isEn ? 'One-time project costs, monthly services and third-party tools are separated before implementation.' : 'Einmalige Projektkosten, Monatsleistungen und Drittanbieter-Tools werden vor der Umsetzung getrennt eingeordnet.' %></p>
        </article>
        <article class="intro-card">
          <h2><%= isEn ? 'Planned launch' : 'Planbarer Launch' %></h2>
          <p><%= isEn ? 'The exact timeline depends on content, feedback and technical access.' : 'Der genaue Zeitrahmen hängt von Inhalten, Feedback und technischen Zugängen ab.' %></p>
        </article>
      </div>
    </section>

    <section id="paket-angebote" class="package-collection">
      <div class="container">
        <% if (visiblePackages.length) { %>
        <% visiblePackages.forEach((pkg, index) => { %>
        <% const features = Array.isArray(pkg.features) ? pkg.features.map(featureText).filter(Boolean).slice(0, 4) : []; %>
        <article class="package-row <%= index % 2 === 1 ? 'is-reversed' : '' %>">
          <div class="package-visual">
            <div class="package-frame">
              <a class="package-image-link" href="<%= packageUrl(pkg) %>" aria-label="<%= canShowPackageDetail(pkg) ? (isEn ? `Learn more about ${pkg.name}` : `Mehr erfahren über ${pkg.name}`) : (isEn ? `Request ${pkg.name}` : `${pkg.name}-Paket anfragen`) %>" data-track="cta" data-cta-name="packages_image_<%= pkg.slug %>" data-cta-location="packages_list" data-package-id="<%= pkg.packageKey %>">
                <img src="<%= packageImage(pkg) %>" alt="<%= packageTitle(pkg) %>" loading="lazy" />
              </a>
            </div>
            <div class="package-actions package-actions--image">
              <a class="btn btn-primary" href="<%= packageUrl(pkg) %>" data-track="cta" data-cta-name="packages_details_<%= pkg.slug %>" data-cta-location="packages_list" data-package-id="<%= pkg.packageKey %>">
                <%= packagePrimaryCtaLabel(pkg) %>
              </a>
              <a class="btn btn-secondary" href="<%= isEn ? '/en/kontakt' : '/kontakt' %>" data-track="cta" data-cta-name="packages_consult_<%= pkg.slug %>" data-cta-location="packages_list" data-package-id="<%= pkg.packageKey %>"><%= isEn ? 'Get consultation now' : 'Jetzt beraten lassen' %></a>
            </div>
          </div>
          <div class="package-content">
            <div class="package-header">
              <span class="package-index">0<%= index + 1 %></span>
              <span class="package-eyebrow"><%= isEn ? `${pkg.name} package` : `Paket ${pkg.name}` %></span>
              <% if (pkg.isRecommended && pkg.recommendationLabel) { %>
              <span class="package-eyebrow"><%= pkg.recommendationLabel %></span>
              <% } %>
            </div>
            <h2 class="package-title"><%= packageTitle(pkg) %></h2>
            <p class="package-description"><%= packageText(pkg) %></p>
            <% if (features.length) { %>
            <ul class="package-features">
              <% features.forEach(feature => { %>
              <li>
                <img class="feature-icon" src="/images/icons/check.svg" alt="" width="26" height="26" loading="lazy">
                <span><%= feature %></span>
              </li>
              <% }) %>
            </ul>
            <% } %>
            <div class="package-meta">
              <span class="price-label"><%= isEn ? 'Starting at' : 'Preis' %></span>
              <span class="price-amount"><%= pkg.priceLabel %></span>
            </div>
          </div>
        </article>
        <% }) %>
        <% } else { %>
        <div class="text-center py-5">
          <p><%= isEn ? 'No packages are currently available. Please check back later.' : 'Aktuell sind keine Pakete verfügbar. Bitte schau später noch einmal vorbei.' %></p>
        </div>
        <% } %>
      </div>
    </section>

    <% if (visiblePackages.length) { %>
    <section id="paketwahl" class="packages-section packages-fit">
      <div class="container">
        <header class="section-header">
          <span class="section-eyebrow"><%= isEn ? 'Self-selection' : 'Selbstselektion' %></span>
          <h2><%= isEn ? 'Which package fits which situation?' : 'Für wen welches Paket passt' %></h2>
          <p class="section-lead">
            <%= isEn
              ? 'Use page scope, target group and use cases to choose the smallest sensible package for your current goal.'
              : 'Nutze Seitenumfang, Zielgruppe und Einsatzfälle, um das kleinste sinnvolle Paket für dein aktuelles Ziel zu wählen.'
            %>
          </p>
        </header>
        <div class="fit-grid">
          <% visiblePackages.slice(0, 3).forEach((pkg) => { %>
          <article class="fit-card <%= pkg.isRecommended ? 'is-highlighted' : '' %>">
            <span class="fit-phase"><%= pkg.priceLabel %></span>
            <h3><%= packageTitle(pkg) %></h3>
            <p><%= pkg.targetGroup || pkg.pageScope || packageText(pkg) %></p>
          </article>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <% if (dbComparisonRows.length && tablePackages.length) { %>
    <section id="vergleich" class="packages-section packages-compare">
      <div class="container">
        <header class="section-header">
          <span class="section-eyebrow"><%= isEn ? 'Package comparison' : 'Paketvergleich' %></span>
          <h2><%= isEn ? 'Scope and limits at a glance' : 'Vergleich mit klaren Leistungsgrenzen' %></h2>
          <p class="section-lead">
            <%= isEn
              ? 'Deliverables, limits and decision points are kept visible so add-ons do not become hidden assumptions.'
              : 'Leistungsumfang, Grenzen und Entscheidungspunkte bleiben sichtbar, damit Zusatzleistungen keine versteckten Annahmen werden.'
            %>
          </p>
        </header>
        <div class="compare-table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th scope="col"><%= isEn ? 'Criterion' : 'Kriterium' %></th>
                <% tablePackages.forEach((pkg) => { %>
                <th scope="col"><%= pkg.name %></th>
                <% }) %>
              </tr>
            </thead>
            <tbody>
              <% dbComparisonRows.forEach(row => { %>
              <tr>
                <th scope="row"><%= row.label %></th>
                <% tablePackages.forEach((pkg) => { %>
                <td><%= row.valuesByPackage[pkg.packageKey] || '—' %></td>
                <% }) %>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
    <% } %>

    <% if (dbGlobalNotes.length) { %>
    <section id="hinweise" class="packages-section packages-addons">
      <div class="container">
        <header class="section-header">
          <span class="section-eyebrow"><%= isEn ? 'Notes' : 'Hinweise' %></span>
          <h2><%= isEn ? 'Costs, add-ons and boundaries' : 'Kosten, Zusatzleistungen und Grenzen' %></h2>
          <p class="section-lead"><%= isEn ? 'These notes are part of the public pricing logic.' : 'Diese Hinweise gehören zur öffentlichen Preis- und Angebotslogik.' %></p>
        </header>
        <div class="addons-grid">
          <% dbGlobalNotes.forEach((note) => { %>
          <article class="addon-card">
            <h3><%= note.title %></h3>
            <p><%= note.body %></p>
          </article>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <% if (dbOverviewFaqs.length) { %>
    <section id="faq" class="packages-section packages-faq">
      <div class="container">
        <header class="section-header">
          <span class="section-eyebrow">FAQ</span>
          <h2><%= isEn ? 'FAQ on packages and scope' : 'FAQ zu Paketen und Umfang' %></h2>
          <p class="section-lead"><%= isEn ? 'Visible FAQ entries are maintained in the pricing admin.' : 'Sichtbare FAQ-Einträge werden im Preis-Admin gepflegt.' %></p>
        </header>
        <div class="faq-list">
          <% dbOverviewFaqs.forEach((faq, idx) => { %>
          <details class="faq-item" <%= idx === 0 ? 'open' : '' %>>
            <summary><%= faq.question %></summary>
            <p><%= faq.answer %></p>
          </details>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <section class="packages-cta">
      <div class="container cta-inner">
        <div>
          <h2><%= isEn ? 'Request a tailored website offer' : 'Individuelles Website-Angebot anfragen' %></h2>
          <p>
            <%= isEn
              ? 'Send a short message about your project. I will classify the scope and recommend the suitable package or add-on path.'
              : 'Schick mir eine kurze Nachricht zu deinem Projekt. Ich ordne den Umfang ein und empfehle dir das passende Paket oder den passenden Zusatzleistungsweg.'
            %>
          </p>
        </div>
        <div class="cta-actions">
          <a class="btn btn-primary" href="<%= isEn ? '/en/kontakt' : '/kontakt' %>" data-track="cta" data-cta-name="packages_final_contact" data-cta-location="packages_final_cta"><%= isEn ? 'Request consultation' : 'Beratung anfragen' %></a>
          <a class="btn btn-secondary" href="<%= isEn ? '/en/kontakt?projektart=unsure' : '/kontakt?projektart=unsure' %>" data-track="cta" data-cta-name="packages_final_scope" data-cta-location="packages_final_cta"><%= isEn ? 'Clarify project scope' : 'Projektumfang klären' %></a>
        </div>
      </div>
      <div class="container cta-internal-links">
        <p class="cta-links-lead"><%= isEn ? 'Continue on these pages:' : 'Weitere passende Seiten:' %></p>
        <ul>
          <li><a href="<%= isEn ? '/en' : '' %>/kontakt"><%= isEn ? 'Contact & initial meeting' : 'Kontakt und Erstgespräch' %></a></li>
          <li><a href="#paket-angebote"><%= isEn ? 'Packages & price overview' : 'Pakete und Preisübersicht' %></a></li>
          <li><a href="/faq"><%= isEn ? 'Frequent questions' : 'Häufige Fragen' %></a></li>
        </ul>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
</body>

</html>
