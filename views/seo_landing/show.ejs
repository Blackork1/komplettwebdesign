<%- include('../partials/head', { extraCssAssets: ['leistungen.css'] }) %>
<%- include('../partials/header') %>

<% const heroImage = page.heroImage || null; %>
<main class="service-page service-page--seo-landing seo-landing" id="hero">
  <article>
    <header class="service-hero seo-landing__hero unified-hero <%= heroImage?.src ? 'has-service-hero-image' : '' %>"<% if (heroImage?.src) { %> style="--service-hero-image: url('<%= heroImage.src %>');"<% } %>>
      <div class="service-hero__grid seo-landing__container seo-landing__hero-grid unified-hero__grid">
        <div class="seo-landing__hero-copy unified-hero__copy">
          <nav class="service-hero-breadcrumbs unified-hero__breadcrumbs" aria-label="Breadcrumb">
            <ol>
              <% (breadcrumbs || []).forEach(function(item) { %>
              <% if (item.current) { %>
              <li aria-current="page"><%= item.label %></li>
              <% } else { %>
              <li><a href="<%= item.href %>"><%= item.label %></a></li>
              <% } %>
              <% }); %>
            </ol>
          </nav>
          <p class="service-kicker seo-landing__hero-kicker service-hero-kicker home-hero-reveal home-hero-reveal--support animate-on-scroll"><i class="fa-solid <%= heroKicker.icon %>" aria-hidden="true"></i><%= heroKicker.label %></p>
          <h1 class="home-hero-reveal home-hero-reveal--h1 animate-on-scroll"><%= page.h1 %></h1>
          <p class="seo-landing__lead unified-hero__lead home-hero-reveal home-hero-reveal--support animate-on-scroll"><%= page.intro %></p>
          <div class="service-hero__actions seo-landing__actions unified-hero__actions" aria-label="Projektaktionen">
            <a class="btn btn-primary home-hero-reveal home-hero-reveal--actions animate-on-scroll" href="<%= page.cta.href %>" data-track="cta" data-cta-name="seo_landing_hero_primary" data-cta-location="seo_landing_hero"><%= page.cta.label %></a>
            <a class="btn btn-secondary home-hero-reveal home-hero-reveal--actions animate-on-scroll" href="<%= page.secondaryCta.href %>" data-track="cta" data-cta-name="seo_landing_hero_secondary" data-cta-location="seo_landing_hero"><%= page.secondaryCta.label %></a>
          </div>
        </div>
        <aside class="service-hero__panel seo-landing__hero-panel unified-hero__panel" aria-label="Kurzüberblick">
          <div class="seo-landing__hero-panel-reveal home-hero-reveal home-hero-reveal--visual animate-on-scroll">
            <h2><%= heroPanel.title %></h2>
            <p><%= heroPanel.text %></p>
            <div class="seo-landing__hero-mini-list">
              <% heroPanel.items.forEach(function(item) { %>
              <div><i class="fa-solid <%= item.icon %>" aria-hidden="true"></i><span><%= item.text %></span></div>
              <% }); %>
            </div>
          </div>
        </aside>
      </div>
    </header>

    <% if (page.visual?.image?.src) { %>
    <section class="seo-landing__container seo-landing__visual-feature" aria-labelledby="seo-landing-visual-title">
      <figure class="seo-landing__visual-frame">
        <img src="<%= page.visual.image.src %>" alt="<%= page.visual.image.alt %>" width="941" height="1672" loading="lazy">
      </figure>
      <div class="seo-landing__visual-copy">
        <% if (page.visual.eyebrow) { %>
        <p class="seo-landing__eyebrow"><%= page.visual.eyebrow %></p>
        <% } %>
        <h2 id="seo-landing-visual-title"><%= page.visual.heading %></h2>
        <p><%= page.visual.text %></p>
      </div>
    </section>
    <% } %>

    <section class="seo-landing__container seo-landing__section-list" aria-label="Leistungsdetails">
      <% page.sections.forEach(function(section, index) { %>
      <section class="seo-landing__section" id="<%= section.id || ('section-' + index) %>" aria-labelledby="seo-landing-section-<%= index %>">
        <div class="seo-landing__section-copy">
          <% if (section.eyebrow) { %>
          <p class="seo-landing__eyebrow"><%= section.eyebrow %></p>
          <% } %>
          <h2 id="seo-landing-section-<%= index %>"><%= section.heading %></h2>
          <p><%= section.body %></p>
        </div>
        <% if (Array.isArray(section.points) && section.points.length) { %>
        <ul class="seo-landing__check-list">
          <% section.points.forEach(function(point) { %>
          <li><%= point %></li>
          <% }); %>
        </ul>
        <% } %>
      </section>
      <% }); %>
    </section>

    <section class="seo-landing__container seo-landing__links" aria-labelledby="seo-landing-links-title">
      <div class="seo-landing__section-head">
        <p class="seo-landing__eyebrow">Weiterlesen</p>
        <h2 id="seo-landing-links-title">Passende nächste Seiten</h2>
      </div>
      <div class="seo-landing__link-grid">
        <% page.internalLinks.forEach(function(link) { %>
        <a class="seo-landing__link-card" href="<%= link.href %>">
          <span><%= link.label %></span>
          <small><%= link.text %></small>
        </a>
        <% }); %>
      </div>
    </section>

    <% if (Array.isArray(page.faq) && page.faq.length) { %>
    <section class="seo-landing__container seo-landing__faq" id="faq" aria-labelledby="seo-landing-faq-title">
      <div class="seo-landing__section-head">
        <p class="seo-landing__eyebrow">FAQ</p>
        <h2 id="seo-landing-faq-title">Häufige Fragen</h2>
      </div>
      <div class="seo-landing__faq-list">
        <% page.faq.forEach(function(item, index) { %>
        <details<%= index === 0 ? ' open' : '' %>>
          <summary><%= item.question %></summary>
          <p><%= item.answer %></p>
        </details>
        <% }); %>
      </div>
    </section>
    <% } %>

    <% const bottomCta = page.finalCta || page.cta; %>
    <section class="seo-landing__container seo-landing__cta" id="cta" aria-labelledby="seo-landing-cta-title">
      <div>
        <p class="seo-landing__eyebrow">Nächster Schritt</p>
        <h2 id="seo-landing-cta-title"><%= bottomCta.label %></h2>
        <p><%= bottomCta.text %></p>
      </div>
      <div class="seo-landing__actions">
        <a class="btn btn-primary" href="<%= bottomCta.href %>" data-track="cta" data-cta-name="seo_landing_final_primary" data-cta-location="seo_landing_final"><%= bottomCta.label %></a>
        <% if (bottomCta.secondaryHref && bottomCta.secondaryLabel) { %>
        <a class="btn btn-secondary" href="<%= bottomCta.secondaryHref %>" data-track="cta" data-cta-name="seo_landing_final_secondary" data-cta-location="seo_landing_final"><%= bottomCta.secondaryLabel %></a>
        <% } else { %>
        <a class="btn btn-secondary" href="<%= page.secondaryCta.href %>" data-track="cta" data-cta-name="seo_landing_final_secondary" data-cta-location="seo_landing_final"><%= page.secondaryCta.label %></a>
        <% } %>
      </div>
    </section>
  </article>
</main>

<%- include('../partials/footer') %>
