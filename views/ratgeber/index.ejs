<%- include('../partials/head') %>
<%- include('../partials/header') %>

<link rel="stylesheet" href="<%= cssAsset('ratgeber.css') %>" />

<main class="rg-page rg-index-page" id="hero">
  <section class="rg-hero" aria-labelledby="rg-hero-title">
    <div class="rg-hero-noise" aria-hidden="true"></div>
    <div class="container rg-hero-grid">
      <div class="rg-hero-copy">
        <p class="rg-eyebrow">Komplett Webdesign Ratgeber</p>
        <h1 id="rg-hero-title">Website-Wissen für kleine Unternehmen in Berlin.</h1>
        <p class="rg-lead">
          Klare Antworten zu Kosten, Ablauf, Relaunch, SEO und Branchen-Websites.
          Für alle, die professionell online gehen wollen, ohne sich durch Technik-Blabla zu kämpfen.
        </p>

        <div class="rg-hero-actions">
          <a class="btn btn-accent" href="/website-tester">Website kostenlos prüfen</a>
          <a class="btn btn-outline-light" href="/pakete">Pakete ansehen</a>
        </div>

        <div class="rg-kpi-row" aria-label="Ratgeber Überblick">
          <article class="rg-kpi-card">
            <span><%= (posts || []).length %>+</span>
            <small>Ratgeber</small>
          </article>
          <article class="rg-kpi-card">
            <span><%= (featuredPosts || []).length %></span>
            <small>Empfohlen</small>
          </article>
          <article class="rg-kpi-card">
            <span>100%</span>
            <small>Praxisfokus</small>
          </article>
        </div>
      </div>

      <aside class="rg-hero-panel" aria-label="Newsletter Anmeldung">
        <p class="rg-panel-eyebrow">Newsletter</p>
        <h2>Website-Tipps, die du wirklich umsetzen kannst.</h2>
        <p>
          Kurze Impulse zu Sichtbarkeit, Struktur und Anfragen. Ohne Buzzwords, ohne Agentur-Blackbox.
        </p>
        <div class="rg-newsletter-form">
          <%- include('../partials/newsletter_form') %>
        </div>
      </aside>
    </div>
  </section>

  <section class="container rg-cluster" aria-labelledby="seo-cluster-title">
    <div class="rg-cluster-copy">
      <p class="rg-section-kicker">Schneller Einstieg</p>
      <h2 id="seo-cluster-title">SEO-Ratgeber für Berliner Unternehmen</h2>
      <p>
        Starte mit den Fragen, die vor fast jedem Website-Projekt auftauchen: Was kostet es, wie lange dauert es und wann lohnt sich ein Relaunch?
      </p>
      <div class="rg-cluster-actions">
        <a href="/ratgeber/website-kosten-berlin">Website-Kosten verstehen</a>
        <a href="/ratgeber/website-erstellen-berlin-ablauf-dauer-kosten">Ablauf & Dauer ansehen</a>
        <a href="/ratgeber/website-relaunch-berlin">Relaunch richtig planen</a>
      </div>
    </div>
    <div class="rg-cluster-list-wrap">
      <p class="rg-cluster-list-title">Weitere beliebte Themen</p>
      <ul class="rg-cluster-list">
        <li><a href="/ratgeber/baukasten-vs-professionelle-website">Baukasten vs. professionelle Website</a></li>
        <li><a href="/ratgeber/website-fuer-handwerker-berlin">Website für Handwerker in Berlin</a></li>
        <li><a href="/ratgeber/website-fuer-restaurants-cafes-berlin">Website für Restaurants und Cafés in Berlin</a></li>
      </ul>
    </div>
  </section>

  <section class="container rg-content-grid" aria-labelledby="rg-list-heading">
    <div class="rg-main-column">
      <div class="rg-section-head">
        <p class="rg-section-kicker">Neu im Ratgeber</p>
        <h2 id="rg-list-heading">Aktuelle Beiträge</h2>
      </div>

      <div class="rg-card-grid">
        <% (posts || []).forEach(function(post, idx) { %>
        <article class="rg-guide-card" style="--rg-delay: <%= idx %>;">
          <a href="/ratgeber/<%= post.slug %>" class="rg-guide-link" aria-label="<%= post.title %>">
            <div class="rg-guide-image-wrap">
              <img src="<%= post.image_url || '/images/default-blog.webp' %>" alt="<%= post.title %>" loading="lazy" />
              <% if (post.category) { %>
              <span class="rg-chip"><%= post.category %></span>
              <% } %>
            </div>
            <div class="rg-guide-content">
              <h3><%= post.title %></h3>
              <% if (post.excerpt || post.description) { %>
              <p><%= post.excerpt || post.description %></p>
              <% } %>
              <span class="rg-readmore">Artikel lesen</span>
            </div>
          </a>
        </article>
        <% }); %>
      </div>
    </div>

    <aside class="rg-side-column">
      <div class="rg-sticky-wrap">
        <section class="rg-featured-box" aria-labelledby="rg-featured-heading">
          <h3 id="rg-featured-heading">Empfohlene Ratgeber</h3>
          <div class="rg-featured-list">
            <% (featuredPosts || []).forEach(function(post) { %>
            <a href="/ratgeber/<%= post.slug %>" class="rg-featured-item" aria-label="<%= post.title %>">
              <img src="<%= post.image_url || '/images/default-blog.webp' %>" alt="<%= post.title %>" loading="lazy" />
              <div>
                <strong><%= post.title %></strong>
                <% if (post.excerpt) { %>
                <p><%= post.excerpt %></p>
                <% } %>
              </div>
            </a>
            <% }); %>
          </div>
        </section>

        <section class="rg-cta-box" aria-label="Beratungs CTA">
          <p class="rg-cta-kicker">Nächster Schritt</p>
          <h3>Du willst wissen, wo deine Website gerade steht?</h3>
          <p>
            Starte mit dem kostenlosen Website-Check und bekomme eine klare Grundlage für die nächsten Schritte.
          </p>
          <a class="btn btn-accent" href="/website-tester">Website-Check starten</a>
        </section>
      </div>
    </aside>
  </section>

  <section class="container rg-featured-mobile" aria-labelledby="rg-featured-mobile-heading">
    <div class="rg-section-head">
      <p class="rg-section-kicker">Kuratiert</p>
      <h2 id="rg-featured-mobile-heading">Empfohlene Ratgeber</h2>
    </div>
    <div class="rg-featured-scroll">
      <% (featuredPosts || []).forEach(function(post) { %>
      <article class="rg-featured-mobile-card">
        <a href="/ratgeber/<%= post.slug %>" aria-label="<%= post.title %>">
          <img src="<%= post.image_url || '/images/default-blog.webp' %>" alt="<%= post.title %>" loading="lazy" />
          <h3><%= post.title %></h3>
        </a>
      </article>
      <% }); %>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
