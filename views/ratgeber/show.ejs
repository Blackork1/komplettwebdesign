<%- include('../partials/head') %>
<%- include('../partials/header') %>

<link rel="stylesheet" href="<%= cssAsset('ratgeber.css') %>" />

<main class="rg-page rg-detail-page" id="hero">
  <section class="rg-detail-hero unified-hero" aria-labelledby="rg-detail-title">
    <div class="container rg-detail-hero-inner unified-hero__grid">
      <div class="rg-detail-copy unified-hero__copy">
        <nav class="unified-hero__breadcrumbs" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Startseite</a></li>
            <li><a href="/ratgeber">Ratgeber</a></li>
            <li aria-current="page"><%= post.title %></li>
          </ol>
        </nav>

        <h1 id="rg-detail-title"><%= post.title %></h1>
        <p class="rg-detail-lead unified-hero__lead"><%= post.description %></p>

        <div class="rg-detail-meta">
          <span>
            Veröffentlicht am
            <time datetime="<%= publishedISO %>"><%= new Date(publishedISO).toLocaleDateString('de-DE') %></time>
          </span>
          <% if (modifiedISO && modifiedISO !== publishedISO) { %>
          <span>
            Aktualisiert am
            <time datetime="<%= modifiedISO %>"><%= new Date(modifiedISO).toLocaleDateString('de-DE') %></time>
          </span>
          <% } %>
        </div>

        <div class="rg-detail-actions unified-hero__actions">
          <a href="/pakete" class="btn btn-primary">Pakete vergleichen</a>
          <a href="/kontakt" class="btn btn-secondary">Projekt kurz besprechen</a>
        </div>
      </div>

      <figure class="rg-detail-media unified-hero__media-frame">
        <img src="<%= post.image_url || '/images/default-blog.webp' %>" alt="<%= post.title %>" loading="eager" fetchpriority="high">
      </figure>
    </div>
  </section>

  <div class="container rg-detail-layout">
    <article class="rg-article" aria-label="Ratgeber Inhalt">
      <div class="rg-article-body">
        <%- renderedContent %>
      </div>

      <section class="rg-inline-cta" aria-labelledby="website-check-ratgeber-title">
        <p class="rg-cta-kicker">Kostenloser Audit</p>
        <h2 id="website-check-ratgeber-title">Website-Check vor dem Gespräch starten</h2>
        <p>
          Prüfe Technik, SEO, GEO-Sichtbarkeit, Meta-Daten und fehlerhafte Links.
          Danach ist im Erstgespräch schneller klar, welche Optimierungen Priorität haben.
        </p>
        <div class="rg-inline-cta-actions">
          <a href="/website-tester" class="btn btn-primary" data-track="ratgeber_website_tester_cta">Website-Check starten</a>
          <a href="/kontakt" class="btn btn-secondary" data-track="ratgeber_contact_cta">Ergebnis besprechen lassen</a>
        </div>
      </section>

      <% if (post.faq_json && post.faq_json.length) { %>
      <section class="rg-faq-block" aria-labelledby="rg-faq-title">
        <p class="rg-section-kicker">FAQ</p>
        <h2 id="rg-faq-title">Häufige Fragen</h2>

        <div class="rg-faq-list">
          <% post.faq_json.forEach(function(faq, idx){ %>
          <details class="rg-faq-item" <%= idx === 0 ? 'open' : '' %>>
            <summary><%= faq.name || (faq.question || 'Frage') %></summary>
            <p><%= (faq.acceptedAnswer && faq.acceptedAnswer.text) || faq.answer || '' %></p>
          </details>
          <% }); %>
        </div>
      </section>
      <% } %>
    </article>

    <aside class="rg-detail-side" aria-label="Weitere Inhalte und Newsletter">
      <div class="rg-sticky-wrap">
        <section class="rg-newsletter-card">
          <p class="rg-panel-eyebrow">Newsletter</p>
          <h3>Neue Ratgeber direkt ins Postfach</h3>
          <p>Kurze Tipps zu Webdesign, Performance und SEO mit Fokus auf lokale Sichtbarkeit.</p>
          <div class="rg-newsletter-form">
            <%- include('../partials/newsletter_form') %>
          </div>
        </section>

        <% if (typeof others !== 'undefined' && others && others.length) { %>
        <section class="rg-other-guides" aria-labelledby="rg-others-title">
          <h3 id="rg-others-title">Weitere Ratgeber</h3>
          <div class="rg-other-list">
            <% others.slice(0, 4).forEach(function(o) { if (o.slug === post.slug) return; %>
            <a href="/ratgeber/<%= o.slug %>" class="rg-other-item" aria-label="<%= o.title %>">
              <strong><%= o.title %></strong>
              <% if (o.excerpt) { %>
              <p><%= o.excerpt %></p>
              <% } %>
            </a>
            <% }); %>
          </div>
        </section>
        <% } %>
      </div>
    </aside>
  </div>
</main>

<%- include('../partials/footer') %>
