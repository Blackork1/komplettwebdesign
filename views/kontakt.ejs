<script>
  document.addEventListener('DOMContentLoaded', function() {
    var buttons = Array.from(document.querySelectorAll('[data-contact-mode]'));
    var panels = {
      quick: document.getElementById('contact-quick-panel'),
      detailed: document.getElementById('contact-detailed-panel')
    };

    function showPanel(mode, shouldScroll) {
      Object.keys(panels).forEach(function(key) {
        var panel = panels[key];
        if (!panel) return;
        var active = key === mode;
        panel.hidden = !active;
        panel.classList.toggle('is-active', active);
      });

      buttons.forEach(function(button) {
        var active = button.dataset.contactMode === mode;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-expanded', active ? 'true' : 'false');
      });

      if (shouldScroll && panels[mode]) {
        panels[mode].scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    function hidePanels(shouldScroll) {
      Object.keys(panels).forEach(function(key) {
        var panel = panels[key];
        if (!panel) return;
        panel.hidden = true;
        panel.classList.remove('is-active');
      });

      buttons.forEach(function(button) {
        button.classList.remove('is-active');
        button.setAttribute('aria-expanded', 'false');
      });

      if (shouldScroll) {
        document.getElementById('anfrage')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    window.KWDContactPanels = {
      showPanel: showPanel,
      hidePanels: hidePanels
    };

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        var mode = button.dataset.contactMode;
        if (!panels[mode]) return;
        history.replaceState(null, '', mode === 'quick' ? '#schnellanfrage' : '#projektanfrage');
        showPanel(mode, true);
      });
    });

    var contactParams = new URLSearchParams(window.location.search || '');
    var hasDetailedPreselect = contactParams.has('projektart') || contactParams.has('projectType') || contactParams.get('source') === 'website-tester';

    if (window.location.hash === '#schnellanfrage') showPanel('quick', false);
    else if (window.location.hash === '#projektanfrage' || hasDetailedPreselect || document.querySelector('[data-form-has-errors="true"]')) showPanel('detailed', false);
    else hidePanels(false);
  });
</script>
<script src="<%= (typeof jsAsset === 'function' ? jsAsset('js/kontakt.js') : '/js/kontakt.js?v=' + encodeURIComponent(assetVersion || '1')) %>" defer></script>
