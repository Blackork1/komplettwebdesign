<%- include('partials/head') %>
<%- include('partials/header') %>
<%
  const isEn = lng === 'en';
  const options = contactFormOptions || {};
  const values = formValues || {};
  const errorList = Array.isArray(formErrors) ? formErrors : [];
  const getOptions = (key) => Array.isArray(options[key]) ? options[key] : [];
  const getValue = (name, fallback = '') => {
    const value = values[name];
    if (value === undefined || value === null || value === '') return fallback;
    return Array.isArray(value) ? value[0] : value;
  };
  const isSelected = (name, value, fallback = '') => String(getValue(name, fallback)) === String(value) ? 'checked' : '';
  const isOptionSelected = (name, value, fallback = '') => String(getValue(name, fallback)) === String(value) ? 'selected' : '';
  const isChecked = (name, value) => {
    const current = values[name];
    const list = Array.isArray(current) ? current : (current ? [current] : []);
    return list.map(String).includes(String(value)) ? 'checked' : '';
  };
  const inputValue = (name, fallback = '') => getValue(name, fallback);
  const formatSlotLabel = (term) => {
    const start = new Date(term.start_time);
    const end = new Date(term.end_time);
    const dateLabel = start.toLocaleDateString(isEn ? 'en-GB' : 'de-DE', {
      weekday: 'short',
      day: '2-digit',
      month: 'short',
      hour: '2-digit',
      minute: '2-digit'
    });
    const endLabel = end.toLocaleTimeString(isEn ? 'en-GB' : 'de-DE', {
      hour: '2-digit',
      minute: '2-digit'
    });
    return `${dateLabel} - ${endLabel}${isEn ? '' : ' Uhr'}`;
  };
  const contactBase = isEn ? '/en/kontakt' : '/kontakt';
  const packagesHref = isEn ? '/en/pakete' : '/pakete';
  const testerHref = isEn ? '/en/website-tester' : '/website-tester';
  const privacyHref = '/datenschutz';
  const noticesHref = '/hinweise-rechtstexte-seo-datenschutz';
%>
<link rel="stylesheet" href="<%= cssAsset('kontakt.css') %>">
<noscript>
  <link rel="stylesheet" href="<%= cssAsset('kontakt-noscript.css') %>">
</noscript>

<main class="contact-page-section">
  <section class="contact-hero" aria-labelledby="contact-title">
    <div class="container contact-hero__inner">
      <nav class="contact-breadcrumb" aria-label="<%= isEn ? 'Breadcrumb' : 'Breadcrumb' %>">
        <a href="<%= isEn ? '/en' : '/' %>"><%= isEn ? 'Home' : 'Startseite' %></a>
        <span aria-hidden="true">/</span>
        <span><%= isEn ? 'Contact' : 'Kontakt' %></span>
      </nav>

      <p class="contact-eyebrow"><%= isEn ? 'Project request' : 'Projektanfrage' %></p>
      <h1 id="contact-title"><%= isEn ? 'Request your website project in Berlin' : 'Website-Projekt in Berlin anfragen' %></h1>
      <p class="contact-hero__lead">
        <%= isEn
          ? 'Describe your website project, budget and rough scope. I review which package or project size is likely to fit.'
          : 'Beschreibe dein Website-Projekt, Budget und den groben Umfang. Ich prüfe, welches Paket oder welcher Projektumfang wahrscheinlich passt.'
        %>
      </p>
      <div class="contact-hero__actions">
        <a class="contact-button contact-button--primary" href="#anfrage" data-track="cta" data-event-name="contact_cta_click" data-cta-id="contact_hero_start" data-cta-location="contact_hero">
          <%= isEn ? 'Start request' : 'Anfrage starten' %>
        </a>
        <a class="contact-button contact-button--secondary" href="<%= packagesHref %>" data-track="cta" data-event-name="contact_cta_click" data-cta-id="contact_hero_packages" data-cta-location="contact_hero">
          <%= isEn ? 'View packages' : 'Pakete ansehen' %>
        </a>
      </div>
      <ul class="contact-hero__facts" aria-label="<%= isEn ? 'Key request notes' : 'Wichtige Hinweise zur Anfrage' %>">
        <li><%= isEn ? `Packages start from ${lowestPackagePriceLabel || 'EUR'}` : `Website-Pakete starten ab ${lowestPackagePriceLabel || ''}` %></li>
        <li><%= isEn ? 'Special features are reviewed separately' : 'Sonderfunktionen werden separat geprüft' %></li>
        <li><%= isEn ? 'The request is non-binding' : 'Die Anfrage ist unverbindlich' %></li>
      </ul>
    </div>
  </section>

  <section class="contact-intro-block">
    <div class="container contact-intro-grid">
      <article class="contact-info-card">
        <h2><%= isEn ? 'What happens after your request?' : 'Was passiert nach deiner Anfrage?' %></h2>
        <p>
          <%= isEn
            ? 'I review your details, classify the likely scope and ask follow-up questions if something important is missing.'
            : 'Ich prüfe deine Angaben, ordne den wahrscheinlichen Umfang ein und frage nach, wenn wichtige Informationen fehlen.'
          %>
        </p>
        <ul>
          <li><%= isEn ? 'A rough budget range helps with a realistic recommendation.' : 'Ein grober Budgetrahmen hilft bei einer realistischen Empfehlung.' %></li>
          <li><%= isEn ? 'If you are unsure, choose “Not sure yet”.' : 'Wenn du unsicher bist, wähle einfach „Noch unsicher“.' %></li>
          <li><%= isEn ? 'Scope, add-ons and running costs are clarified before the project starts.' : 'Umfang, Zusatzleistungen und laufende Kosten werden vor Projektstart abgestimmt.' %></li>
        </ul>
      </article>
      <article class="contact-info-card">
        <h2><%= isEn ? 'Important scope notes' : 'Wichtige Abgrenzungen' %></h2>
        <p>
          <%= isEn
            ? 'Booking systems, CMS, multilingual setup, shop functions, tracking, extensive animation and copywriting are not automatic standard package contents.'
            : 'Buchungssysteme, CMS, Mehrsprachigkeit, Shop-Funktionen, Tracking, umfangreiche Animationen und Texterstellung sind nicht automatisch Standardpaket-Bestandteil.'
          %>
        </p>
        <p>
          <%= isEn
            ? 'Hosting, domain, email, maintenance and third-party tools can create separate running costs.'
            : 'Hosting, Domain, E-Mail, Wartung und Drittanbieter-Tools können separate laufende Kosten verursachen.'
          %>
        </p>
      </article>
    </div>
  </section>

  <section id="anfrage" class="container contact-request">
    <% if (errorList.length) { %>
      <div class="contact-alert" role="alert" data-event="contact_form_error">
        <strong><%= isEn ? 'Please check your details.' : 'Bitte prüfe deine Angaben.' %></strong>
        <ul>
          <% errorList.forEach((error) => { %>
            <li><%= error.msg || error %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <% if (typeof testerPrefill !== 'undefined' && testerPrefill) { %>
      <div class="contact-alert contact-alert--info" role="status">
        <strong><%= isEn ? 'Website Tester context detected:' : 'Website-Tester-Kontext erkannt:' %></strong>
        <span>
          <%= testerPrefill.domain || (isEn ? 'Website provided' : 'Website hinterlegt') %>
          <% if (testerPrefill.scoreBand) { %>
            · <%= isEn ? 'Score band' : 'Score-Band' %>: <%= testerPrefill.scoreBand %>
          <% } %>
        </span>
      </div>
    <% } %>

    <section class="contact-choice" aria-labelledby="contact-choice-title">
      <p class="contact-eyebrow"><%= isEn ? 'Choose request type' : 'Anfrageart wählen' %></p>
      <h2 id="contact-choice-title"><%= isEn ? 'How much detail do you want to send?' : 'Wie ausführlich möchtest du anfragen?' %></h2>
      <p>
        <%= isEn
          ? 'Use the quick request for a first assessment. Use the detailed project request if you already want to define scope, package, budget and add-ons.'
          : 'Nutze die Schnellanfrage für eine erste Einschätzung. Nutze die ausführliche Projektanfrage, wenn du Umfang, Paket, Budget und Zusatzwünsche direkt einordnen möchtest.'
        %>
      </p>
      <div class="contact-choice__actions" role="group" aria-label="<%= isEn ? 'Request type' : 'Anfrageart' %>">
        <button class="contact-choice__button" type="button" data-contact-mode="quick" aria-controls="contact-quick-panel" aria-expanded="false">
          <span><%= isEn ? 'Quick request' : 'Schnellanfrage' %></span>
          <small><%= isEn ? 'Few fields for a first assessment' : 'Wenige Felder für eine erste Einschätzung' %></small>
        </button>
        <button class="contact-choice__button" type="button" data-contact-mode="detailed" aria-controls="contact-detailed-panel" aria-expanded="false">
          <span><%= isEn ? 'Detailed project request' : 'Ausführliche Projektanfrage' %></span>
          <small><%= isEn ? 'Project type, package, budget, timeline and add-ons' : 'Projektart, Paket, Budget, Zeitrahmen und Zusatzfunktionen' %></small>
        </button>
      </div>
    </section>

    <section class="contact-panel contact-quick" id="contact-quick-panel" aria-labelledby="contact-quick-title" hidden>
      <div class="contact-form-shell contact-form-shell--quick">
        <div class="contact-form-intro">
          <p class="contact-eyebrow"><%= isEn ? 'Quick request' : 'Schnellanfrage' %></p>
          <h2 id="contact-quick-title"><%= isEn ? 'Get a first assessment' : 'Erste Einschätzung anfragen' %></h2>
          <p>
            <%= isEn
              ? 'Send the essential details. If the request needs more context, I ask follow-up questions before estimating the scope.'
              : 'Schick mir die wichtigsten Eckdaten. Wenn noch Kontext fehlt, frage ich nach, bevor ich den Umfang einschätze.'
            %>
          </p>
        </div>

        <form id="contactQuickForm" class="contact-form" action="<%= isEn ? '/en/kontakt/kurzanfrage' : '/kontakt/kurzanfrage' %>" method="POST" data-recaptcha="v3" data-recaptcha-action="contact_quick" data-form-variant="quick" data-event="contact_form_view">
          <input type="hidden" name="token">
          <input type="hidden" name="source" value="contact-quick">
          <input type="hidden" name="locale" value="<%= isEn ? 'en' : 'de' %>">
          <input type="hidden" name="startedAt" value="<%= Date.now() %>">
          <div class="contact-hp" aria-hidden="true">
            <label for="quick-contact-website"><%= isEn ? 'Leave this field empty' : 'Dieses Feld bitte leer lassen' %></label>
            <input id="quick-contact-website" name="contactWebsite" type="text" tabindex="-1" autocomplete="off">
          </div>

          <div class="contact-form-grid">
            <div class="contact-field">
              <label for="quick-project-type"><%= isEn ? 'What do you want to request?' : 'Was möchtest du anfragen?' %> *</label>
              <select id="quick-project-type" name="projectType" required data-contact-event="project_type_selected">
                <% getOptions('projectType').forEach((option) => { %>
                  <option value="<%= option.value %>" <%= isOptionSelected('projectType', option.value, 'unsure') %>><%= option.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="contact-field" data-quick-package-field>
              <label for="quick-package-interest"><%= isEn ? 'If this is about a new website: which package are you interested in?' : 'Falls es um eine neue Website geht: welches Paket interessiert dich?' %></label>
              <select id="quick-package-interest" name="packageInterest" data-contact-event="package_interest_selected">
                <% getOptions('packageInterest').forEach((option) => { %>
                  <option value="<%= option.value %>" <%= isOptionSelected('packageInterest', option.value, 'unsure') %>><%= option.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="contact-field">
              <label for="quick-budget-range"><%= isEn ? 'Rough budget range' : 'Grober Budgetrahmen' %></label>
              <select id="quick-budget-range" name="budgetRange" data-contact-event="budget_range_selected">
                <% getOptions('budgetRange').forEach((option) => { %>
                  <option value="<%= option.value %>" <%= isOptionSelected('budgetRange', option.value, 'open') %>><%= option.label %></option>
                <% }) %>
              </select>
              <p class="contact-help"><%= isEn ? 'This helps with a realistic recommendation.' : 'Das hilft bei einer realistischen Empfehlung.' %></p>
            </div>
            <div class="contact-field">
              <label for="quick-name"><%= isEn ? 'Name' : 'Name' %> *</label>
              <input id="quick-name" name="name" type="text" autocomplete="name" maxlength="120" required>
            </div>
            <div class="contact-field">
              <label for="quick-email"><%= isEn ? 'Email' : 'E-Mail' %> *</label>
              <input id="quick-email" name="email" type="email" autocomplete="email" maxlength="180" required>
            </div>
            <div class="contact-field">
              <label for="quick-phone"><%= isEn ? 'Phone (optional)' : 'Telefon (optional)' %></label>
              <input id="quick-phone" name="phone" type="tel" autocomplete="tel" maxlength="80" placeholder="+49 ...">
            </div>
            <div class="contact-field contact-field--full">
              <label for="quick-message"><%= isEn ? 'What should I assess? (optional)' : 'Was soll ich einschätzen? (optional)' %></label>
              <textarea id="quick-message" name="message" rows="5" maxlength="5000" placeholder="<%= isEn ? 'Briefly describe what you need, whether a website already exists and what the next step should clarify.' : 'Beschreibe kurz, was du brauchst, ob es bereits eine Website gibt und was der nächste Schritt klären soll.' %>"></textarea>
              <p class="contact-help"><%= isEn ? 'A few bullet points are enough.' : 'Ein paar Stichpunkte reichen für den Anfang.' %></p>
            </div>
          </div>

          <label class="contact-consent" for="quick-privacy-consent">
            <input id="quick-privacy-consent" name="privacyConsent" value="yes" type="checkbox" required>
            <span>
              <% if (isEn) { %>
                I have read the <a href="<%= privacyHref %>">privacy policy</a> and the <a href="<%= noticesHref %>">notes page</a> and agree that my details may be processed to handle my request.
              <% } else { %>
                Ich habe die <a href="<%= privacyHref %>">Datenschutzerklärung</a> und die <a href="<%= noticesHref %>">Hinweisseite</a> gelesen und bin damit einverstanden, dass meine Angaben zur Bearbeitung meiner Anfrage verarbeitet werden.
              <% } %>
            </span>
          </label>

          <button class="contact-submit" type="submit" data-event="contact_form_submit"><%= isEn ? 'Request assessment' : 'Einschätzung anfragen' %></button>
          <p class="contact-submit-note"><%= isEn ? 'The request is non-binding.' : 'Die Anfrage ist unverbindlich.' %></p>
        </form>
      </div>
    </section>

    <section class="contact-panel contact-detailed" id="contact-detailed-panel" aria-labelledby="contact-detailed-title" hidden>
      <div class="contact-form-shell">
        <div class="contact-form-intro">
          <p class="contact-eyebrow"><%= isEn ? 'Detailed request' : 'Ausführliche Anfrage' %></p>
          <h2 id="contact-detailed-title"><%= isEn ? 'Describe your project clearly' : 'Erzähle kurz von deinem Projekt' %></h2>
          <p>
            <%= isEn
              ? 'This form asks for project type, package, budget, timeline, content and add-ons. Choose “not sure yet” wherever you do not know the answer.'
              : 'Dieses Formular fragt Projektart, Paket, Budget, Zeitrahmen, Texte und Zusatzfunktionen ab. Wähle „Noch unsicher“, wenn du etwas noch nicht weißt.'
            %>
          </p>
        </div>

        <form id="kontaktForm" class="contact-form contact-form--detailed" action="<%= contactAction || contactBase %>" method="POST" data-form-variant="detailed" data-event="contact_form_view" data-form-has-errors="<%= errorList.length ? 'true' : 'false' %>">
          <input type="hidden" name="token">
          <input type="hidden" name="locale" value="<%= isEn ? 'en' : 'de' %>">
          <input type="hidden" name="startedAt" value="<%= Date.now() %>">
          <% if (typeof testerPrefill !== 'undefined' && testerPrefill) { %>
            <input type="hidden" name="source" value="website-tester">
            <input type="hidden" name="auditId" value="<%= testerPrefill.auditId || '' %>">
            <input type="hidden" name="domain" value="<%= testerPrefill.domain || '' %>">
            <input type="hidden" name="scoreBand" value="<%= testerPrefill.scoreBand || '' %>">
            <input type="hidden" name="topIssues" value="<%= testerPrefill.topIssues || '' %>">
          <% } else { %>
            <input type="hidden" name="source" value="contact-detailed">
          <% } %>
          <div class="contact-hp" aria-hidden="true">
            <label for="contactWebsite"><%= isEn ? 'Leave this field empty' : 'Dieses Feld bitte leer lassen' %></label>
            <input id="contactWebsite" name="contactWebsite" type="text" tabindex="-1" autocomplete="off">
          </div>

          <div class="contact-wizard-viewport" data-contact-wizard-viewport>
            <fieldset class="contact-form-section" data-contact-step="projectType" data-contact-branch="all">
              <legend><%= isEn ? 'What do you need?' : 'Was brauchst du?' %></legend>
              <p class="contact-help"><%= isEn ? 'Choose what fits best. If you are unsure, choose “Not sure yet”.' : 'Wähle aus, was am besten passt. Wenn du unsicher bist, wähle „Noch unsicher“.' %></p>
              <div class="contact-option-grid">
                <% getOptions('projectType').forEach((option) => { %>
                  <label class="contact-option">
                    <input type="radio" name="projectType" value="<%= option.value %>" <%= isSelected('projectType', option.value) %> required data-contact-event="project_type_selected">
                    <span><%= option.label %></span>
                  </label>
                <% }) %>
              </div>
            </fieldset>

            <fieldset class="contact-form-section" data-contact-step="packageInterest" data-contact-branch="new-website">
              <legend><%= isEn ? 'Which package probably fits?' : 'Welches Paket passt wahrscheinlich?' %></legend>
              <p class="contact-help"><%= isEn ? 'If you are not sure yet, choose “Not sure yet”. I will classify the scope after your request.' : 'Wenn du noch nicht weißt, welches Paket passt, wähle „Noch unsicher“. Ich ordne dein Projekt nach der Anfrage grob ein.' %></p>
              <div class="contact-package-grid">
                <% getOptions('packageInterest').forEach((option) => { %>
                  <label class="contact-option contact-option--package">
                    <input type="radio" name="packageInterest" value="<%= option.value %>" <%= isSelected('packageInterest', option.value) %> data-required-for="new-website" data-contact-event="package_interest_selected">
                    <span class="contact-option__title"><%= option.label %></span>
                    <% if (option.hint) { %><small><%= option.hint %></small><% } %>
                  </label>
                <% }) %>
              </div>
              <p class="contact-tax-note"><%= globalNotes?.vatNote || 'Alle Preise verstehen sich gemäß § 19 UStG ohne Ausweis der Umsatzsteuer.' %></p>
            </fieldset>

            <fieldset class="contact-form-section" data-contact-step="budgetTimeline" data-contact-branch="new-website relaunch landingpage local-seo audit custom-feature unsure">
              <legend><%= isEn ? 'Budget and timeline' : 'Budget und Zeitrahmen' %></legend>
              <div class="contact-step-split">
                <div class="contact-question-group">
                  <h3><%= isEn ? 'What rough budget range is planned?' : 'Welcher Budgetrahmen ist ungefähr geplant?' %></h3>
                  <p class="contact-help"><%= isEn ? 'A rough range helps with the recommendation. It is not a commitment.' : 'Ein grober Rahmen hilft bei der Empfehlung. Er ist keine Verpflichtung.' %></p>
                  <div class="contact-option-grid contact-option-grid--compact">
                    <% getOptions('budgetRange').forEach((option) => { %>
                      <label class="contact-option">
                        <input type="radio" name="budgetRange" value="<%= option.value %>" <%= isSelected('budgetRange', option.value) %> data-required-for="new-website relaunch landingpage local-seo audit custom-feature" data-contact-event="budget_range_selected">
                        <span><%= option.label %></span>
                      </label>
                    <% }) %>
                  </div>
                </div>
                <div class="contact-question-group">
                  <h3><%= isEn ? 'When should it start/go live?' : 'Wann soll es ungefähr starten/online gehen?' %></h3>
                  <p class="contact-help"><%= isEn ? 'A concrete timeline is only agreed after coordination.' : 'Eine konkrete Zusage erfolgt erst nach Abstimmung.' %></p>
                  <div class="contact-option-grid contact-option-grid--compact">
                    <% getOptions('timeline').forEach((option) => { %>
                      <label class="contact-option">
                        <input type="radio" name="timeline" value="<%= option.value %>" <%= isSelected('timeline', option.value) %> data-required-for="new-website relaunch landingpage local-seo audit custom-feature" data-contact-event="timeline_selected">
                        <span><%= option.label %></span>
                      </label>
                    <% }) %>
                  </div>
                </div>
              </div>
            </fieldset>

            <fieldset class="contact-form-section" data-contact-step="existingWebsite" data-contact-branch="new-website">
              <legend><%= isEn ? 'Existing website' : 'Bestehende Website' %></legend>
              <div class="contact-question-group">
                <h3><%= isEn ? 'Is there already a website?' : 'Gibt es bereits eine Website?' %></h3>
                <div class="contact-option-grid">
                  <% getOptions('existingWebsiteStatus').forEach((option) => { %>
                    <label class="contact-option">
                      <input type="radio" name="existingWebsiteStatus" value="<%= option.value %>" <%= isSelected('existingWebsiteStatus', option.value) %> data-required-for="new-website" data-contact-event="contact_form_field_select">
                      <span><%= option.label %></span>
                    </label>
                  <% }) %>
                </div>
              </div>
              <div class="contact-field contact-field--full">
                <label for="existingWebsiteUrl"><%= isEn ? 'Current website URL (optional)' : 'Aktuelle Website-URL (optional)' %></label>
                <input id="existingWebsiteUrl" name="existingWebsiteUrl" type="url" maxlength="220" placeholder="https://..." value="<%= inputValue('existingWebsiteUrl') %>">
                <p class="contact-help"><%= isEn ? 'If available, this helps assess relaunch, audit or rebuild.' : 'Falls vorhanden, hilft die URL bei der Einschätzung von Relaunch, Audit oder Neubau.' %></p>
              </div>
            </fieldset>

            <fieldset class="contact-form-section" data-contact-step="pageScope" data-contact-branch="new-website">
              <legend><%= isEn ? 'Website scope' : 'Umfang der neuen Website' %></legend>
              <div class="contact-question-group">
                <h3><%= isEn ? 'How large should the website roughly be?' : 'Wie groß soll die Website ungefähr werden?' %></h3>
                <div class="contact-option-grid contact-option-grid--wide">
                  <% getOptions('pageScope').forEach((option) => { %>
                    <label class="contact-option">
                      <input type="radio" name="pageScope" value="<%= option.value %>" <%= isSelected('pageScope', option.value) %> data-required-for="new-website" data-contact-event="page_scope_selected">
                      <span><%= option.label %></span>
                    </label>
                  <% }) %>
                </div>
              </div>
            </fieldset>

            <fieldset class="contact-form-section" data-contact-step="relaunchContext" data-contact-branch="relaunch">
              <legend><%= isEn ? 'Current website and relaunch reason' : 'Bestehende Website und Relaunch-Grund' %></legend>
              <p class="contact-help"><%= isEn ? 'A relaunch starts with the current website, the main problems and the target of the rebuild.' : 'Ein Relaunch startet mit der bestehenden Website, den Hauptproblemen und dem Ziel des Neuaufbaus.' %></p>
              <div class="contact-option-grid">
                <% getOptions('existingWebsiteStatus').forEach((option) => { %>
                  <label class="contact-option">
                    <input type="radio" name="existingWebsiteStatus" value="<%= option.value %>" <%= isSelected('existingWebsiteStatus', option.value) %> data-required-for="relaunch" data-contact-event="contact_form_field_select">
                    <span><%= option.label %></span>
                  </label>
                <% }) %>
              </div>
              <div class="contact-field contact-field--full">
                <label for="relaunchExistingWebsiteUrl"><%= isEn ? 'Current website URL' : 'Aktuelle Website-URL' %></label>
                <input id="relaunchExistingWebsiteUrl" name="existingWebsiteUrl" type="url" maxlength="220" placeholder="https://..." value="<%= inputValue('existingWebsiteUrl') %>">
              </div>
            </fieldset>

            <fieldset class="contact-form-section" data-contact-step="relaunchGoals" data-contact-branch="relaunch">
              <legend><%= isEn ? 'Relaunch goals' : 'Relaunch-Ziele' %></legend>
              <p class="contact-help"><%= isEn ? 'Select what should improve. Ranking preservation cannot be guaranteed.' : 'Wähle aus, was verbessert werden soll. Ein Ranking-Erhalt kann nicht garantiert werden.' %></p>
              <div class="contact-checkbox-grid">
                <% getOptions('relaunchGoals').forEach((option) => { %>
                  <label class="contact-check">
                    <input type="checkbox" name="relaunchGoals" value="<%= option.value %>" <%= isChecked('relaunchGoals', option.value) %> data-contact-event="contact_form_field_select">
                    <span><%= option.label %></span>
                  </label>
                <% }) %>
              </div>
            </fieldset>

            <fieldset class="contact-form-section" data-contact-step="seoContext" data-contact-branch="local-seo">
