      <section id="Preise">
        <h2 class="alignCenter animate-on-scroll">Kosten für eine Website</h2>
        <p class="alignCenter animate-on-scroll"><strong>Viele Café-Betreiber fragen: „Was kostet eine Website?“</strong></p>
        <div class="pricing-grid marginPricingGrid">
          <% packages.forEach(pkg=> { %>
          <% if(pkg.display){%>
          <div class="pricing-card animate-on-scroll" id="pkg-<%= pkg.id %>">
            <h3 class="alignCenter">
              <%= pkg.name %>
            </h3>
            <div class="p1rem alignCenter">
              <!-- Kurzbeschreibung -->
              <% if (pkg.description) { %>
              <p class="package-description"><%= pkg.description %></p>
              <% } %>

              <!-- Preis -->
              <p class="price alignCenter">
                <%= pkg.price %>
              </p>

              <!-- Bullet-Points -->
              <ul class="features-list alignCenter">
                <% pkg.features.forEach(feat=> { %>
                <li>
                  <%= feat %>
                </li>
                <% }); %>
              </ul>

              <!-- Button -->
              <a class="btn btn-primary alignCenter" href="/pakete/<%=pkg.name%>">Details</a>
            </div>
          </div>
          <% }}); %>
        </div>
        <p class="alignCenter underLindeText animate-on-scroll">Angesichts der Tatsache, dass ein einziges zusätzliches Stammkundenpaar pro Woche diese Kosten bereits deckt,
          lohnt sich die Investition schnell.</p>
      </section>

