<style>
  .linkColor {
    color: #d75b36;
  }

  .primaryColor {
    color: var(--color-primary);
  }

  .card-back a.btn.btn-tertiary {
    position: relative;
    bottom: 60px;
  }

  .hero-button {
    color: #fafafa;
    background-color: var(--color-primary);
  }

  .hero-button:hover {
    border-color: white;
  }

  .heroImage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .heroImage {
    position: absolute;
    width: 100%;
    z-index: -5;
    height: 1026px;
  }

  .review-card {
    align-items: center;
    display: flex;
    grid-template-columns: 1fr 2fr;
    height: 100%;
    justify-items: center;
    margin-top: -50px;
    padding: 1.5rem;
    text-align: center;
    flex-direction: column;
  }

  .badge {
    transition: all 0.2s ease;
  }

  .badge:hover {
    transform: scale(1.02) translateY(-2px);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  .service-list {
    margin-top: 1rem;
  }

  @media (max-width: 400px) {
    .hero-section {
      padding: 0px;
    }
  }

  @media (max-width: 768px) {
    .scroll-snap-align {
      scroll-snap-align: start;
    }

    .scroll-snap-container {
      scroll-snap-type: x mandatory;
      flex-wrap: nowrap;
      overflow-y: auto;
    }

    .heroImage {
      height: 1200px;
    }
  }

  @media (max-width: 1050px) {
    .latest-blog article h4 a {
      color: var(--color-primary);
      font-family: var(--font-heading);
      font-size: 1rem;
    }

    .home-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Trust-Sektion ---------- */
  .trust-summary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin: 1.5rem 0 2rem;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.05);
  }

  .trust-summary-score {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .trust-score-value {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  .trust-score-stars i,
  .trust-review-stars i {
    color: #f5b301;
    margin-right: 1px;
  }

  .trust-summary-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 0.95rem;
  }

  .trust-reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .trust-review-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.04);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .trust-review-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }

  .trust-review-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .trust-review-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .trust-review-avatar--initials,
  .review-avatar--initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.5px;
    font-family: "Poppins", "Inter", system-ui, -apple-system, sans-serif;
    text-transform: uppercase;
    user-select: none;
  }

  .trust-review-avatar--initials {
    font-size: 1rem;
    line-height: 1;
  }

  .review-avatar--initials {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin: 0 auto 1rem;
    font-size: 1.35rem;
    line-height: 1;
  }

  .trust-review-author {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .trust-review-stars {
    font-size: 0.85rem;
  }

  .trust-review-source {
    margin-left: auto;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .trust-review-content {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: #333;
    border-left: 3px solid var(--color-primary);
    padding-left: 0.85rem;
  }

  .trust-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
    justify-content: center;
  }

  .trust-empty {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.65);
    border: 1px dashed rgba(0, 0, 0, 0.15);
    border-radius: 12px;
    text-align: center;
  }

  .trust-empty h3 {
    margin-top: 0;
  }

  /* ---------- FAQ-Sektion ---------- */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.25rem;
  }

  .faq-item {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    padding: 0 1.25rem;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .faq-item[open] {
    border-color: var(--color-primary);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
    font-weight: 600;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: #222;
    cursor: pointer;
    list-style: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    transition: transform 0.2s ease;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 0 1rem;
    color: #444;
    line-height: 1.6;
  }

  .faq-answer p {
    margin: 0;
  }

  .faq-more-help {
    margin-top: 1.5rem;
    color: #555;
  }

  @media (max-width: 600px) {
    .trust-summary {
      flex-direction: column;
      align-items: flex-start;
    }

    .trust-summary-score {
      flex-direction: row;
      align-items: baseline;
      gap: 0.75rem;
    }

    .trust-review-content {
      font-size: 0.9rem;
    }

    .faq-question {
      font-size: 0.98rem;
    }
  }
</style>

