              <div class="home-pricing-controls" aria-label="<%= isEn ? 'Package slider controls' : 'Bedienung des Paket-Sliders' %>">
                <button class="home-pricing-control" type="button" data-pricing-prev aria-label="<%= isEn ? 'Previous package' : 'Vorheriges Paket' %>">
                  <i class="fas fa-chevron-left" aria-hidden="true"></i>
                </button>
                <button class="home-pricing-control" type="button" data-pricing-next aria-label="<%= isEn ? 'Next package' : 'Nächstes Paket' %>">
                  <i class="fas fa-chevron-right" aria-hidden="true"></i>
                </button>
              </div>
              <div class="home-pricing-track" data-pricing-slider tabindex="0" aria-label="<%= isEn ? 'Website packages, horizontally scrollable' : 'Website-Pakete, horizontal scrollbar' %>">
                <% homePackages.forEach((pkg) => { %>
                <% const packageSlug = String(pkg.slug || '').toLowerCase(); %>
