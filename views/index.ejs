                  <span class="home-price-tag"><%= isEn ? 'Often suitable' : 'Häufig passend' %></span>
                  <% } %>
                  <h3><%= pkg.name %></h3>
                  <div class="p1rem">
                    <% if (pkg.description) { %>
                    <p class="package-description"><%= pkg.description %></p>
                    <% } %>
                    <p class="price">
                      <%= pkg.priceLabel || pkg.price %>
                    </p>
                    <ul class="features-list">
