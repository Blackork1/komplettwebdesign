              </h1>
              <% if (copy.heroTitle2) { %>
              <p class="home-hero-claim home-hero-reveal home-hero-reveal--support animate-on-scroll"><%= copy.heroTitle2 %></p>
              <% } %>
              <h2 class="home-hero-reveal home-hero-reveal--support animate-on-scroll"><%= copy.heroSubline %></h2>
              <ul class="home-hero-bullets" role="list">
