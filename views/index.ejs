                    <a class="btn btn-primary" href="<%= homePackageTarget(pkg) %>" data-track="cta" data-cta-name="home_package_details_<%= pkg.slug %>" data-cta-location="home_pricing" data-package-id="<%= pkg.slug %>"><%= homePackageCtaLabel(pkg) %></a>
