      <div class="hero-section">
        <div class="container">
          <div class="hero-flex">
            <div class="hero-content home-hero-sequence">
              <span class="hero-badge mb-3 home-hero-reveal home-hero-reveal--support animate-on-scroll">
                <i class="fas fa-bolt"></i> <%= copy.heroBadge %>
