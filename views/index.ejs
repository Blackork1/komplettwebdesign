    <!-- 9) Trust und Referenz -->
    <section class="section" id="trust">
      <div class="container">
        <div class="outer-wrapper">
          <div class="inner-wrapper text-left animate-on-scroll">
            <span class="home-section-kicker"><i class="fas fa-star" aria-hidden="true"></i><%= isEn ? 'Trust' : 'Vertrauen' %></span>
            <h2><%= copy.trustTitle %></h2>
            <p class="home-section-lead"><%= copy.trustSubline %></p>
            <figure class="home-wide-media animate-on-scroll">
              <a href="/referenzen" class="home-wide-media-link" aria-label="<%= isEn ? 'View references' : 'Referenzen anzeigen' %>">
                <img src="/images/review-bg.webp" alt="<%= isEn ? 'Project preview and reference presentation' : 'Projektvorschau und Referenzdarstellung' %>" width="920" height="520" loading="lazy" decoding="async">
                <span class="home-wide-media-cta" aria-hidden="true"><%= isEn ? 'View references' : 'Referenzen anzeigen' %></span>
              </a>
            </figure>
            <% const hasTrustReviews = Array.isArray(trustReviews) && trustReviews.length > 0; %>
            <% if (reviewAggregate && reviewAggregate.count) { %>
            <div class="trust-summary">
              <div class="trust-summary-score">
                <span class="trust-score-value"><%= reviewAggregate.avg.toFixed(1) %></span>
                <span class="trust-score-stars" aria-hidden="true">
                  <% const full = Math.round(reviewAggregate.avg); %>
                  <% for (let i = 1; i <= 5; i++) { %>
                  <i class="fas fa-star<%= i <= full ? '' : '-half-alt' %>"></i>
                  <% } %>
                </span>
              </div>
              <div class="trust-summary-meta">
                <div><strong><%= copy.trustAverageLabel %></strong></div>
                <div><%= reviewAggregate.count %> <%= copy.trustCountLabel %></div>
                <div><a href="<%= googleProfileUrl %>" target="_blank" rel="noopener" class="linkColor"><%= copy.trustCtaAll %></a></div>
              </div>
            </div>
            <% } %>
            <% if (hasTrustReviews) { %>
            <div class="trust-reviews-grid">
              <% trustReviews.forEach((r) => { %>
              <article class="trust-review-card">
                <div class="trust-review-header">
                  <% if (hasAvatar(r.avatar_url)) { %>
                  <img src="<%= r.avatar_url %>" alt="<%= isEn ? 'Portrait of client' : 'Portrait des Kunden' %> <%= r.author %>" class="trust-review-avatar" loading="lazy" width="48" height="48" />
                  <% } else { %>
                  <div class="trust-review-avatar trust-review-avatar--initials trust-review-avatar--tone-<%= avatarToneIndex(r.author) %>" role="img" aria-label="<%= isEn ? 'Initials avatar of' : 'Initialen-Avatar von' %> <%= r.author %>">
                    <%= avatarInitials(r.author) %>
                  </div>
                  <% } %>
                  <div>
                    <div class="trust-review-author"><%= r.author %></div>
                    <div class="trust-review-stars" aria-label="<%= r.rating %> von 5 Sternen">
                      <% for (let i = 1; i <= 5; i++) { %>
                      <i class="fas fa-star<%= i <= r.rating ? '' : '-o' %>" aria-hidden="true"></i>
                      <% } %>
                    </div>
                  </div>
                  <span class="trust-review-source" aria-label="<%= isEn ? 'Google review source' : 'Quelle: Google-Bewertung' %>">Google</span>
                </div>
                <blockquote class="trust-review-content"><%= r.content %></blockquote>
              </article>
              <% }); %>
            </div>
            <div class="trust-actions">
              <a href="<%= googleProfileUrl %>" target="_blank" rel="noopener" class="btn btn-primary"><i class="fas fa-external-link-alt" aria-hidden="true"></i> <%= copy.trustCtaAll %></a>
              <a href="<%= googleReviewUrl %>" target="_blank" rel="noopener" class="btn btn-secondary"><i class="fas fa-pen" aria-hidden="true"></i> <%= copy.trustCtaWrite %></a>
            </div>
            <% } else { %>
            <div class="trust-empty">
              <h3><%= copy.trustNoReviewsHeadline %></h3>
              <p><%= copy.trustNoReviewsLead %></p>
              <a href="<%= googleProfileUrl %>" target="_blank" rel="noopener" class="btn btn-primary"><i class="fas fa-external-link-alt" aria-hidden="true"></i> <%= copy.trustCtaAll %></a>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </section>

