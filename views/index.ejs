    <!-- 5) Blog + Review Section (wird nur gerendert, wenn echter Inhalt vorliegt) -->
    <% const showBlogCard   = latestPost && !latestPost.isDefault && latestPost.slug; %>
    <% const showReviewCard = review && !review.isDefault; %>
    <% if (showBlogCard || showReviewCard) { %>
    <section class="section" id="blog-reviews">
      <div class="container animate-on-scroll">
        <section class="outer-wrapper">
          <div class="inner-wrapper">
            <h2 class="animate-on-scroll ">
              <%= copy.blogSectionTitle %>
            </h2>
            <div class="home-grid">
              <% if (showBlogCard) { %>
              <!-- Links: Aktueller Blog-Post (2/3) -->
              <div class="latest-blog">
                <article class="content-card animate-on-scroll">
                  <h3><%= copy.blogCardTitle %></h3>
                  <div class="p2rem">
                    <% const latestPostHref = `/blog/${latestPost.slug}`; %>
                    <!-- Titelbild -->
                    <div class="blog-image">
                      <a href="<%= latestPostHref %>">
                        <img src="<%= latestPost.image_url %>" alt="<%= isEn ? 'Cover image for article:' : 'Titelbild zum Artikel:' %> <%= latestPost.title %>" loading="lazy" />
                      </a>
                    </div>

                    <!-- Überschrift -->
                    <h4>
                      <a href="<%= latestPostHref %>"><%= latestPost.title %></a>
                    </h4>

                    <!-- Auszug -->
                    <p class="excerpt"><%= latestPost.excerpt %></p>

                    <!-- Datum -->
                    <p class="date">
                      <% const daysAgo = Math.floor((Date.now() - new Date(latestPost.created_at)) / (1000*60*60*24)); %>
                      <% if (lng === 'de') { %>
                        vor <%= daysAgo %> <%= copy.blogDaysAgo %>
                      <% } else { %>
                        <%= daysAgo %> <%= copy.blogDaysAgo %> ago
                      <% } %>
                    </p>

                    <!-- Link zum Artikel -->
                    <a href="<%= latestPostHref %>" class="btn btn-primary mb-2">
                      <%= copy.blogToArticle %>
                    </a>
                    <a href="/blog" class="btn btn-tertiary mb-2"><%= copy.blogToOverview %></a>
                  </div>
                </article>
              </div>
              <% } %>

              <% if (showReviewCard) { %>
              <!-- Rechts: Kunden-Rezension (1/3) -->
              <div class="testimonial">
                <div class="content-card animate-on-scroll">
                  <h3><%= copy.reviewCardTitle %></h3>
                  <div class="review-card">
                    <div class="p2rem">
                      <!-- Avatar (mit Initialen-Fallback, wenn keine avatar_url hinterlegt ist) -->
                      <% if (hasAvatar(review.avatar_url)) { %>
                      <img src="<%= review.avatar_url %>" alt="<%= isEn ? 'Portrait of client' : 'Portrait des Kunden' %> <%= review.author %>" class="review-avatar" loading="lazy" />
                      <% } else { %>
                      <div class="review-avatar review-avatar--initials" style="background-color: <%= avatarColor(review.author) %>;" role="img" aria-label="<%= isEn ? 'Initials avatar of' : 'Initialen-Avatar von' %> <%= review.author %>">
                        <%= avatarInitials(review.author) %>
                      </div>
                      <% } %>

                      <!-- Zitat -->
                      <blockquote>
                        <%- review.content.replace( /https?:\/\/[^\s]+/gi, match=> {
                              const display = match.replace(/^https?:\/\/(www\.)?/i, '');
                              return `<a href="${match}" target="_blank" rel="noopener">${display}</a>`;
                              }
                              )
                              %>
                      </blockquote>

                      <!-- Autor -->
                      <cite>— <%= review.author %></cite>
                    </div>
                    <a href="https://www.zuraltenbackstube.de" aria-label="<%= isEn ? 'Preview of the hero section on zuraltenbackstube.de – a reference website built by Komplett Webdesign.' : 'Vorschau des Hero-Bereichs der Website zuraltenbackstube.de – eine von Komplett Webdesign umgesetzte Referenz.' %>">
                      <picture>
                        <source media="(min-width: 1050px)" srcset="/images/review-bg.webp" type="image/webp">
                        <source media="(max-width: 1049px)" srcset="/images/review-bg-mobile.webp" type="image/webp">
                        <img src="/images/review-bg.webp" alt="<%= isEn ? 'Hero section screenshot of the zuraltenbackstube.de reference website' : 'Screenshot des Hero-Bereichs der Referenz-Website zuraltenbackstube.de' %>" fetchpriority="low" loading="lazy" decoding="async" style="width:100%;height:100%;max-height:300px;">
                      </picture>
                    </a>
                  </div>
                </div>
              </div>
              <% } %>
            </div>
          </div>
        </section>
      </div>
    </section>
    <% } %>

    <!-- 5b) Trust-Sektion: Google-Bewertungen -->
    <section class="section" id="trust">
      <div class="container animate-on-scroll">
        <div class="outer-wrapper">
          <div class="inner-wrapper text-left">
            <h2 class="animate-on-scroll">
              <%= copy.trustTitle %>
            </h2>
            <p class="text-muted animate-on-scroll"><%= copy.trustSubline %></p>

            <% const hasTrustReviews = Array.isArray(trustReviews) && trustReviews.length > 0; %>

            <% if (reviewAggregate && reviewAggregate.count) { %>
            <div class="trust-summary animate-on-scroll">
              <div class="trust-summary-score">
                <span class="trust-score-value"><%= reviewAggregate.avg.toFixed(1) %></span>
                <span class="trust-score-stars" aria-hidden="true">
                  <% const full = Math.round(reviewAggregate.avg); %>
                  <% for (let i = 1; i <= 5; i++) { %>
                    <i class="fas fa-star<%= i <= full ? '' : '-half-alt' %>"></i>
                  <% } %>
                </span>
              </div>
              <div class="trust-summary-meta">
                <div><strong><%= copy.trustAverageLabel %></strong></div>
                <div><%= reviewAggregate.count %> <%= copy.trustCountLabel %></div>
                <div>
                  <a href="<%= googleProfileUrl %>" target="_blank" rel="noopener" class="linkColor">
                    <%= copy.trustCtaAll %>
                  </a>
                </div>
              </div>
            </div>
            <% } %>

            <% if (hasTrustReviews) { %>
            <div class="trust-reviews-grid">
              <% trustReviews.forEach((r) => { %>
              <article class="trust-review-card animate-on-scroll" itemscope itemtype="https://schema.org/Review">
                <span itemprop="itemReviewed" itemscope itemtype="https://schema.org/LocalBusiness">
                  <meta itemprop="name" content="Komplett Webdesign" />
                  <meta itemprop="image" content="https://www.komplettwebdesign.de/images/LogoTransparent.webp" />
                  <meta itemprop="telephone" content="+49 1551 245048" />
                  <meta itemprop="priceRange" content="€€" />
                  <meta itemprop="url" content="https://www.komplettwebdesign.de/" />
                  <span itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                    <meta itemprop="streetAddress" content="Möllendorffstr 26" />
                    <meta itemprop="postalCode" content="10367" />
                    <meta itemprop="addressLocality" content="Berlin" />
                    <meta itemprop="addressCountry" content="DE" />
                  </span>
                </span>
                <div itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating" style="display:none">
                  <meta itemprop="ratingValue" content="<%= r.rating %>" />
                  <meta itemprop="bestRating" content="5" />
                  <meta itemprop="worstRating" content="1" />
                </div>
                <% if (r.created_at) { %>
                <meta itemprop="datePublished" content="<%= new Date(r.created_at).toISOString().split('T')[0] %>" />
                <% } %>
                <div class="trust-review-header">
                  <% if (hasAvatar(r.avatar_url)) { %>
                  <img src="<%= r.avatar_url %>"
                       alt="<%= isEn ? 'Portrait of client' : 'Portrait des Kunden' %> <%= r.author %>"
                       class="trust-review-avatar"
                       loading="lazy"
                       width="48" height="48" />
                  <% } else { %>
                  <div class="trust-review-avatar trust-review-avatar--initials" style="background-color: <%= avatarColor(r.author) %>;" role="img" aria-label="<%= isEn ? 'Initials avatar of' : 'Initialen-Avatar von' %> <%= r.author %>">
                    <%= avatarInitials(r.author) %>
                  </div>
                  <% } %>
                  <div>
                    <div class="trust-review-author" itemprop="author" itemscope itemtype="https://schema.org/Person">
                      <span itemprop="name"><%= r.author %></span>
                    </div>
                    <div class="trust-review-stars" aria-label="<%= r.rating %> von 5 Sternen">
                      <% for (let i = 1; i <= 5; i++) { %>
                        <i class="fas fa-star<%= i <= r.rating ? '' : '-o' %>" aria-hidden="true"></i>
                      <% } %>
                    </div>
                  </div>
                  <img src="/images/icons/google-g.svg"
                       alt="<%= isEn ? 'Google review source' : 'Quelle: Google-Bewertung' %>"
                       class="trust-review-source"
                       loading="lazy"
                       width="24" height="24"
                       onerror="this.style.display='none'" />
                </div>
                <blockquote class="trust-review-content" itemprop="reviewBody">
                  <%- r.content.replace(/https?:\/\/[^\s]+/gi, (m) => `<a href="${m}" target="_blank" rel="noopener">${m.replace(/^https?:\/\/(www\.)?/i,'')}</a>`) %>
                </blockquote>
              </article>
              <% }); %>
            </div>
            <div class="trust-actions animate-on-scroll">
              <a href="<%= googleProfileUrl %>" target="_blank" rel="noopener" class="btn btn-primary">
                <i class="fas fa-external-link-alt" aria-hidden="true"></i>
                <%= copy.trustCtaAll %>
              </a>
              <a href="<%= googleReviewUrl %>" target="_blank" rel="noopener" class="btn btn-tertiary">
                <i class="fas fa-pen" aria-hidden="true"></i>
                <%= copy.trustCtaWrite %>
              </a>
            </div>
            <% } else { %>
            <!-- Noch keine Bewertungen in der DB – Platzhalter mit Link zum Google-Profil -->
            <div class="trust-empty animate-on-scroll">
              <h3><%= copy.trustNoReviewsHeadline %></h3>
              <p><%= copy.trustNoReviewsLead %></p>
              <a href="<%= googleProfileUrl %>" target="_blank" rel="noopener" class="btn btn-primary">
                <i class="fas fa-external-link-alt" aria-hidden="true"></i>
                <%= copy.trustCtaAll %>
              </a>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </section>

    <!-- 6) Preis & Pakete -->
    <section class="section" id="preise">
      <div class="container animate-on-scroll">
        <section class="outer-wrapper">
          <div class="inner-wrapper">
            <h2 class="animate-on-scroll">
              <%= copy.pricingTitle %>
            </h2>
            <div class="readable pb2rem animate-on-scroll">
              <p>
                <% if (isEn) { %>
                In just four weeks your new website can be live and
                customers can find you in Berlin. Choose the package that fits and start your project.
                I have a matching package for every need – whether you want
                a simple website, a larger company presence or a
                custom solution. You can find more information on the
                <a href="/en/pakete" class="linkColor">packages</a> page.
                <% } else { %>
                Wähle das Paket, das zu deinem aktuellen Bedarf passt: Basis für eine professionelle digitale Visitenkarte,
                Business für eine mehrseitige Website mit klarer Anfrageführung oder Premium für ein umfangreicheres Online-Angebot mit Buchungssystem.
                Die Details findest du auf der Seite <a href="/pakete" class="linkColor">Pakete</a>.
                <% } %>
              </p>
              <p>
                <% if (isEn) { %>
                My offers are designed to cover different
                needs and help you get online quickly and easily.
                Every package includes what you need to get started:
                modern web design, responsive implementation,
                SEO optimization, and ongoing support. That way you
                can focus on your core business while I take care of your
                online presence.
                <% } else { %>
                Alle Pakete enthalten modernes Webdesign, responsive Umsetzung, Texte und SEO-Grundlagen.
                Hosting, Domain, E-Mail und Wartung bleiben transparent als monatliche Zusatzleistungen wählbar:
                Domain und Mail ab 10 € pro Monat, Hosting 10 € pro Monat und Wartung 5 € pro Monat.
                So kannst du klein starten und deine Website später sinnvoll erweitern.
                <% } %>
              </p>
            </div>
            <div class="pricing-grid">
              <% packages.forEach(pkg=> { %>
              <% if(pkg.display){%>
              <div class="pricing-card animate-on-scroll" id="pkg-<%= pkg.id %>">
                <h3>
                  <%= pkg.name %>
                </h3>
                <div class="p1rem">
                  <!-- Kurzbeschreibung -->
                  <% if (pkg.description) { %>
                  <p class="package-description"><%= pkg.description %></p>
                  <% } %>

                  <!-- Preis -->
                  <p class="price">
                    <%= pkg.price %>
                  </p>

                  <!-- Bullet-Points -->
                  <ul class="features-list">
                    <% pkg.features.forEach(feat=> { %>
                    <li>
                      <%= feat %>
                    </li>
                    <% }); %>
                  </ul>

                  <!-- Button -->
                  <a class="btn btn-primary" href="<%= isEn ? '/en' : '' %>/pakete/<%=pkg.slug%>" data-track="cta" data-cta-name="home_package_details_<%= pkg.slug %>" data-cta-location="home_pricing"><%= isEn ? 'View details' : 'Details' %></a>
                </div>
              </div>
              <% }}); %>
            </div>
            <p class="text-center mt-3 text-muted small"><%= copy.pricingTagline %></p>
          </div>
        </section>
      </div>
    </section>

    <!-- Kostenloser Website-Check -->
    <section class="section" id="website-check">
      <div class="container animate-on-scroll">
        <div class="outer-wrapper">
          <div class="inner-wrapper text-left">
            <span class="hero-badge"><%= isEn ? 'Free website check' : 'Kostenloser Website-Check' %></span>
            <h2 class="animate-on-scroll"><%= isEn ? 'Check first, then rebuild with a clear plan' : 'Erst prüfen, dann mit klarem Plan neu bauen' %></h2>
            <p>
              <%= isEn
                ? 'Use the website tester to check SEO basics, GEO signals, metadata and broken links before you request a project. The result helps us choose the right package and prioritize the most important improvements.'
                : 'Nutze den Website-Tester, um SEO-Grundlagen, GEO-Signale, Metadaten und kaputte Links zu prüfen, bevor du dein Projekt anfragst. Das Ergebnis hilft uns, das passende Paket zu wählen und die wichtigsten Verbesserungen zu priorisieren.'
              %>
            </p>
            <div class="hero-ctas">
              <a class="btn btn-primary" href="<%= isEn ? '/en/website-tester' : '/website-tester' %>" data-track="cta" data-cta-name="home_free_website_check" data-cta-location="home_website_check"><%= isEn ? 'Start free website check' : 'Kostenlosen Website-Check starten' %></a>
              <a class="btn btn-secondary" href="<%= isEn ? '/en/kontakt' : '/kontakt' %>" data-track="cta" data-cta-name="home_check_to_contact" data-cta-location="home_website_check"><%= isEn ? 'Discuss the result' : 'Ergebnis besprechen' %></a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 7) Branchen -->
    <section class="section" id="branchen">
      <div class="container animate-on-scroll">
        <div class="outer-wrapper">
          <div class="inner-wrapper text-left">
            <h2 class="animate-on-scroll">
              <%= copy.industryTitle %>
            </h2>
            <div class="readable pb2rem animate-on-scroll">
              <p>
                <% if (isEn) { %>
                <strong>Website development</strong> for different industries –
                I offer tailored solutions for businesses across Germany.
                Whether restaurant, trade business, café or educational institution:
                I have the right solution.
                If you want to <a href="/webdesign-berlin" class="linkColor">have your website built in Berlin</a>,
                I am the right partner for you.
                <% } else { %>
                <strong>Websiteerstellung</strong> für verschiedene Branchen –
                ich biete maßgeschneiderte Lösungen für Unternehmen deutschlandweit.
                Ob Restaurant, Handwerk, Café, Praxis oder lokaler Handel:
                Ich habe die passende Lösung.
                Wenn du deine <a href="/webdesign-berlin" class="linkColor">Webseite in Berlin erstellen lassen</a>
                möchtest, bin ich der richtige Partner für dich.
                <% } %>
              </p>
              <p>
                <% if (isEn) { %>
                I understand the specific requirements of each industry and
                implement them with focus. My websites are not only
                visually appealing but also functional and user-friendly.
                With your own professional website you reach your target audience
                effectively and attract new customers. A strong first
                impression helps people choose your business.
                <% } else { %>
                Ich verstehe die spezifischen Anforderungen jeder Branche und
                setze diese gezielt um. Meine Webseiten sind nicht nur
                optisch ansprechend, sondern auch funktional und benutzerfreundlich.
                Mit deiner eigenen professionellen Webseite sprichst du deine Zielgruppe
                effektiv an und gewinnst neue Kunden. Ein positiver erster
                Eindruck sorgt dafür, dass Kunden gerne in dein Geschäft kommen.
                <% } %>
              </p>
            </div>
            <div class="industry-grid">
              <div class="industry-item card-container animate-on-scroll">
                <div class="card-inner">
                  <div class="card-front">
                    <p class="header3"><a href="/branchen/webdesign-restaurant" class="primaryColor"><%= isEn ? 'Restaurants' : 'Restaurants' %></a></p>
                    <p>
                      <%= isEn ? 'I present your venue online in the best possible way – with appetising photos, digital menus, and easy reservation options.' : 'Ich präsentiere dein Lokal online von seiner besten Seite – mit appetitanregenden Fotos, digitaler Speisekarte und unkomplizierter Reservierungsfunktion.' %>
                    </p>
                  </div>
                  <div class="card-back card-back-image">
                    <img src="https://res.cloudinary.com/dvd2cd2be/image/upload/v1754413302/admin_gallery/mdikghhav7yyygsahmkh.webp" alt="<%= isEn ? 'Modern restaurant interior – example industry for a Berlin restaurant website' : 'Modernes Restaurant-Interieur – Beispielbranche für Webdesign Restaurant Berlin' %>" loading="lazy" />
                    <a href="/branchen/webdesign-restaurant" class="btn btn-tertiary"><%= isEn ? 'Restaurant website' : 'zur Restaurant Website' %></a>
                  </div>
                </div>
                <img class="click" src="/images/icons/click.svg" alt="<%= isEn ? 'Click here' : 'hier clicken' %>" loading="lazy" />
              </div>
              <div class="industry-item card-container animate-on-scroll">
                <div class="card-inner">
                  <div class="card-front">
                    <p class="header3"><a href="/handwerker" class="primaryColor"><%= isEn ? 'Trades' : 'Handwerksbetriebe' %></a></p>
                    <p>
                      <%= isEn ? 'Clear structure, meaningful photos of your work, and visible contact information convince potential clients.' : 'Klare Struktur, aussagekräftige Bilder deiner Arbeit und gut sichtbare Kontaktinformationen überzeugen potenzielle Kunden.' %>
                    </p>
                  </div>
                  <div class="card-back card-back-image">
                    <img src="/images/handwerker-min.webp" alt="<%= isEn ? 'Tradesperson at work – example industry for trades websites from Berlin' : 'Handwerker bei der Arbeit – Beispielbranche für Handwerker-Websites aus Berlin' %>" loading="lazy" />
                    <a href="/handwerker" class="btn btn-tertiary"><%= isEn ? 'Trades website' : 'zur Handwerker Website' %></a>
                  </div>
                </div>
              </div>
              <div class="industry-item card-container animate-on-scroll">
                <div class="card-inner">
                  <div class="card-front">
                    <p class="header3"><a href="/branchen/webdesign-cafe" class="primaryColor"><%= isEn ? 'Cafes' : 'Cafés' %></a></p>
                    <p>
                      <%= isEn ? 'A warm visual style, presentation of your specialties, opening hours, and map location help new guests find you.' : 'Stimmungsvoller Stil, Präsentation deiner Spezialitäten, Öffnungszeiten und Karte mit deinem Standort - so finden neue Gäste den Weg zu dir.' %>
                    </p>
                  </div>
                  <div class="card-back card-back-image">
                    <img src="/images/cafe-min.webp" alt="<%= isEn ? 'Cosy café interior – example industry for Berlin café websites' : 'Gemütliches Café-Interieur – Beispielbranche für Café-Websites in Berlin' %>" loading="lazy" />
                    <a href="/branchen/webdesign-cafe" class="btn btn-tertiary"><%= isEn ? 'Cafe website' : 'zur Café Website' %></a>
                  </div>
                </div>
              </div>
              <div class="industry-item card-container animate-on-scroll">
                <div class="card-inner">
                  <div class="card-front">
                    <p class="header3"><a href="/branchen/webdesign-blumenladen" class="primaryColor"><%= isEn ? 'Small retailers' : 'Kleine Händler' %></a></p>
                    <p>
                      <% if (isEn) { %>
                      Trustworthy <strong>web design</strong>, clear product presentation, local visibility, and simple request or order options.
                      <% } else { %>
                      Vertrauenswürdiges <strong>Webdesign</strong>, klare Produktpräsentation, lokale Sichtbarkeit und einfache Anfrage- oder Bestellmöglichkeiten.
                      <% } %>
                    </p>
                  </div>
                  <div class="card-back card-back-image">
                    <img src="https://res.cloudinary.com/dvd2cd2be/image/upload/v1758977436/admin_gallery/vycov9ggowbm7ql3ad3t.webp" alt="<%= isEn ? 'Flower shop as example industry for local retail websites' : 'Blumenladen als Beispielbranche für Websites lokaler Händler' %>" loading="lazy" />
                    <a href="/branchen/webdesign-blumenladen" class="btn btn-tertiary"><%= isEn ? 'Retail website' : 'zur Händler-Website' %></a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 7b) FAQ -->
    <% if (faqEntries.length) { %>
    <section class="section" id="faq" aria-labelledby="faq-title">
      <div class="container animate-on-scroll">
        <div class="outer-wrapper">
          <div class="inner-wrapper text-left">
            <h2 id="faq-title" class="animate-on-scroll">
              <%= copy.faqTitle %>
            </h2>
            <p class="text-muted animate-on-scroll"><%= copy.faqSubline %></p>

            <div class="faq-list animate-on-scroll">
              <% faqEntries.forEach((item, idx) => { %>
              <details class="faq-item"<%= idx === 0 ? ' open' : '' %>>
                <summary class="faq-question">
                  <span><%= item.q %></span>
                  <i class="fas fa-chevron-down faq-chevron" aria-hidden="true"></i>
                </summary>
                <div class="faq-answer">
                  <p><%= item.a %></p>
                </div>
              </details>
              <% }); %>
            </div>

            <p class="faq-more-help text-center animate-on-scroll mt-3">
              <% if (isEn) { %>
                Your question is not listed? <a href="/en/kontakt" class="linkColor" data-track="cta" data-cta-name="home_faq_contact" data-cta-location="home_faq">Get in touch</a> – I usually reply within 24 hours.
              <% } else { %>
                Deine Frage ist nicht dabei? <a href="/kontakt" class="linkColor" data-track="cta" data-cta-name="home_faq_contact" data-cta-location="home_faq">Schreib mir</a> – ich antworte in der Regel innerhalb von 24 Stunden.
              <% } %>
            </p>
          </div>
        </div>
      </div>
    </section>
    <% } %>

    <!-- 8) Call-to-Action -->
    <section class="section" id="cta">
      <div class="container animate-on-scroll">
        <div class="outer-wrapper background-gradient">
          <div class="inner-wrapper text-center">
            <%- include('partials/booking_widget') %>

          </div>
        </div>
      </div>
    </section>
    <%- include('partials/footer') %>

    <!-- Hier könnten später die Feature-Blöcke und Preise folgen -->
    <!-- Scroll-Indikator Leiste (fixed an linker Seite) -->
    <aside class="scroll-indicator">
      <!-- Vertikaler Strich -->
      <div class="progress-line">
        <div class="progress-fill"></div>
        <div class="section-icons">
          <a href="#hero" class="icon-link active" aria-label="<%= isEn ? 'To start section' : 'Zum Startbereich' %>">
            <!-- Hero Section Icon -->
            <i class="fas fa-home"></i> <!-- Beispiel Font Awesome Icon -->
          </a>
          <a href="#erklaerung" class="icon-link" aria-label="<%= isEn ? 'To explanation section' : 'Zum Erklärungsbereich' %>">
            <i class="fas fa-star"></i>
          </a>
          <a href="#features" class="icon-link" aria-label="<%= isEn ? 'To features section' : 'Zum Features-Bereich' %>">
            <i class="fas fa-list"></i>
          </a>
          <a href="#leistungen" class="icon-link" aria-label="<%= isEn ? 'To services section' : 'Zu den Leistungen' %>">
            <i class="fas fa-info-circle"></i>
          </a>
          <a href="#blog-reviews" class="icon-link" aria-label="<%= isEn ? 'To blog and review section' : 'Zum Blog- und Review-Bereich' %>">
            <i class="fas fa-thumbs-up"></i>
          </a>
          <a href="#trust" class="icon-link" aria-label="<%= isEn ? 'To client reviews section' : 'Zu den Kundenbewertungen' %>">
            <i class="fas fa-star"></i>
          </a>
          <a href="#preise" class="icon-link" aria-label="<%= isEn ? 'To pricing section' : 'Zu den Preisen' %>">
            <i class="fas fa-money-bill"></i>
          </a>
          <a href="#branchen" class="icon-link" aria-label="<%= isEn ? 'To industries section' : 'Zu den Branchen' %>">
            <i class="fas fa-layer-group"></i>
          </a>
          <a href="#faq" class="icon-link" aria-label="<%= isEn ? 'To FAQ section' : 'Zum FAQ-Bereich' %>">
            <i class="fas fa-question-circle"></i>
          </a>
          <a href="#cta" class="icon-link" aria-label="<%= isEn ? 'To call-to-action section' : 'Zum Call-to-Action-Bereich' %>">
            <i class="fas fa-envelope" style="transform: translateY(-5px);"></i>
          </a>
          <a href="#footer" class="icon-link" aria-label="<%= isEn ? 'To footer section' : 'Zum Footer-Bereich' %>">
            <i class="fas fa-shoe-prints" style="transform: translateY(10px);"></i>
          </a>
        </div>
      </div>
    </aside>
  </main>

