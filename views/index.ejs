                  <img src="/images/icons/check.svg" alt="check icon" width="26" height="26" />
                  <span><%= copy.heroBullet1 %></span>
                </li>
                <li class="home-hero-reveal home-hero-reveal--bullet animate-on-scroll">
                  <img src="/images/icons/check.svg" alt="check icon" width="26" height="26" />
                  <span><%= copy.heroBullet2 %></span>
                </li>
                <li class="home-hero-reveal home-hero-reveal--bullet animate-on-scroll">
                  <img src="/images/icons/check.svg" alt="check icon" width="26" height="26" />
                  <span><%= copy.heroBullet3 %></span>
                </li>
              </ul>
              <div class="hero-ctas home-hero-reveal home-hero-reveal--actions animate-on-scroll">
                <a href="<%= isEn ? '/en/kontakt' : '/kontakt' %>" class="btn btn-primary" data-track="cta" data-cta-name="home_hero_contact" data-cta-location="home_hero"><%= copy.heroCtaPrimary %></a>
                <a href="<%= isEn ? '/en/pakete' : '/pakete' %>" class="btn btn-secondary" data-track="cta" data-cta-name="home_hero_packages" data-cta-location="home_hero"><%= copy.heroCtaSecondary %></a>
              </div>
              <% if (copy.heroTrustNote) { %>
              <p class="home-hero-trust-note home-hero-reveal home-hero-reveal--trust animate-on-scroll"><%= copy.heroTrustNote %></p>
              <% } %>
            </div>
            <div class="home-hero-showcase home-hero-reveal home-hero-reveal--visual animate-on-scroll" aria-label="<%= isEn ? 'Website examples in desktop, booking and mobile views' : 'Website-Beispiele als Desktop-, Termin- und Mobile-Ansicht' %>">
              <figure class="home-hero-showcase__main">
                <img src="/images/home-hero-klarblick-desktop.webp" alt="<%= isEn ? 'Desktop website mockup for Klarblick Dental' : 'Desktop-Website-Mockup für Klarblick Dental' %>" width="1586" height="992" fetchpriority="high" loading="eager" decoding="async">
              </figure>
              <figure class="home-hero-showcase__detail">
                <img src="/images/home-hero-klarblick-termin-crop.webp" alt="<%= isEn ? 'Appointment booking and contact section of the Klarblick Dental website' : 'Termin- und Kontaktbereich der Klarblick-Dental-Website' %>" width="1180" height="557" loading="eager" decoding="async">
              </figure>
              <figure class="home-hero-showcase__phone">
                <img src="/images/home-hero-klarblick-mobile-screen.webp" alt="<%= isEn ? 'Mobile website screen view for Klarblick Dental' : 'Mobile Website-Screen-Ansicht für Klarblick Dental' %>" width="574" height="1344" loading="eager" decoding="async">
              </figure>
            </div>
          </div>
        </div>
      </div>

      <%- include('partials/hero-highlight-marquee', { heroBridgeHighlights: homeHeroBridgeHighlights, isEn, lng }) %>
    </section>

    <!-- 2) USP-Streifen -->
    <section class="section" id="usp-strip">
      <div class="container">
        <div class="home-usp-strip" aria-label="<%= isEn ? 'Key facts about the offer' : 'Kurzüberblick zum Angebot' %>">
          <div class="home-usp-item">
            <img class="home-usp-icon" src="/images/icons/gift1.svg" alt="" width="34" height="34" loading="lazy">
            <strong><%= isEn ? 'Personal implementation' : 'Persönliche Umsetzung' %></strong>
            <span><%= isEn ? 'One direct contact from first call to launch.' : 'Ein direkter Ansprechpartner vom Erstgespräch bis zum Launch.' %></span>
          </div>
          <div class="home-usp-item">
            <img class="home-usp-icon" src="/images/icons/individual1.svg" alt="" width="34" height="34" loading="lazy">
            <strong><%= isEn ? 'No builder templates' : 'Keine Standard-Templates' %></strong>
            <span><%= isEn ? 'Custom layouts instead of page-builder, WordPress template or theme work.' : 'Individuelle Layouts statt Baukasten, WordPress-Template oder Agentur-Schablone.' %></span>
          </div>
          <div class="home-usp-item">
            <img class="home-usp-icon" src="/images/icons/delivery1.svg" alt="" width="34" height="34" loading="lazy">
            <strong><%= isEn ? 'Technical foundation' : 'Technische Grundlage' %></strong>
            <span><%= isEn ? 'Node.js, EJS, CSS and JavaScript with server-rendered HTML.' : 'Node.js, EJS, CSS und JavaScript mit serverseitig gerendertem HTML.' %></span>
          </div>
          <div class="home-usp-item">
            <img class="home-usp-icon" src="/images/icons/support1.svg" alt="" width="34" height="34" loading="lazy">
            <strong><%= isEn ? `Packages from ${lowestPackagePriceLabel || 'EUR'}` : `Pakete ab ${lowestPackagePriceLabel || ''}` %></strong>
            <span><%= isEn ? 'Clear scope, separate add-ons and transparent running costs.' : 'Klarer Umfang, separate Zusatzleistungen und transparente laufende Kosten.' %></span>
          </div>
        </div>
      </div>
    </section>

    <!-- 3) Für wen das Angebot passt -->
    <section class="section" id="passt">
      <div class="container">
        <div class="outer-wrapper">
          <div class="inner-wrapper text-left animate-on-scroll">
            <span class="home-section-kicker"><i class="fas fa-user-check" aria-hidden="true"></i><%= isEn ? 'Fit' : 'Für wen das Angebot passt' %></span>
            <h2><%= isEn ? 'Custom websites for small businesses in Berlin' : 'Individuelle Websites für kleine Unternehmen in Berlin' %></h2>
            <p class="home-section-lead">
              <%= isEn
                ? 'Komplett Webdesign is a fit when you want a personal web designer, clear decisions and a website that is planned around inquiries, local visibility and maintainable technology.'
                : 'Komplett Webdesign passt, wenn du einen persönlichen Webdesigner suchst und eine Website brauchst, die auf Anfragen, lokale Sichtbarkeit und eine wartbare technische Grundlage ausgerichtet ist.'
              %>
            </p>
            <figure class="home-reference-band animate-on-scroll">
              <img src="/images/home-fit-beratung.webp" alt="<%= isEn ? 'Personal website consultation for a small local business' : 'Persönliches Website-Beratungsgespräch für ein kleines lokales Unternehmen' %>" width="1280" height="720" loading="lazy" decoding="async">
              <figcaption>
                <h3><%= isEn ? 'A website that explains your offer quickly' : 'Ein Auftritt, der dein Angebot schnell verständlich macht' %></h3>
                <p>
                  <%= isEn
                    ? 'Visitors should understand who you help, what they can request and which next step makes sense without searching through the page.'
                    : 'Besucher sollen ohne Suchen erkennen, wem du hilfst, welche Leistung sie anfragen können und welcher nächste Schritt sinnvoll ist.'
                  %>
                </p>
              </figcaption>
            </figure>
            <div class="home-split">
              <div class="home-card">
                <h3><%= isEn ? 'Good fit' : 'Passt gut, wenn' %></h3>
                <ul class="home-list">
                  <li><%= isEn ? 'you run a local service, practice, shop, restaurant, trade or consulting business.' : 'du lokaler Dienstleister, Praxis, Händler, Gastronomie, Handwerk oder Berater bist.' %></li>
                  <li><%= isEn ? 'you want a compact or structured business website without a generic template.' : 'du eine kompakte oder strukturierte Unternehmenswebsite ohne Standard-Template möchtest.' %></li>
                  <li><%= isEn ? 'you value clear package boundaries, realistic timelines and direct feedback loops.' : 'du klare Paketgrenzen, realistische Zeitpläne und direkte Abstimmung schätzt.' %></li>
                </ul>
              </div>
              <div class="home-card">
                <h3><%= isEn ? 'Not ideal' : 'Nicht ideal, wenn' %></h3>
                <ul class="home-list home-list--caution">
                  <li><%= isEn ? 'you need a finished enterprise platform without discovery or specification.' : 'du eine fertige Enterprise-Plattform ohne Konzept- und Leistungsabgrenzung erwartest.' %></li>
                  <li><%= isEn ? 'you need legal advice, guaranteed rankings or guaranteed customer growth.' : 'du Rechtsberatung, garantierte Rankings oder garantierte Kundengewinnung erwartest.' %></li>
                  <li><%= isEn ? 'you want booking, CMS or shop functionality included in every standard package.' : 'du Buchung, CMS oder Shop-Funktionen pauschal in jedem Standardpaket erwartest.' %></li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 4) Leistungen -->
    <section class="section" id="leistungen">
      <div class="container">
        <div class="outer-wrapper">
          <div class="inner-wrapper text-left animate-on-scroll">
            <span class="home-section-kicker"><i class="fas fa-layer-group" aria-hidden="true"></i><%= isEn ? 'Services' : 'Leistungen' %></span>
            <h2><%= copy.servicesTitle %></h2>
            <p class="home-section-lead">
              <%= isEn
                ? 'The homepage, package pages and inquiry path are planned together so visitors quickly understand your offer and can contact you without friction.'
                : 'Startseite, Paketlogik und Anfrageweg werden zusammen geplant, damit Besucher dein Angebot schnell verstehen und ohne Reibung Kontakt aufnehmen können.'
              %>
            </p>
            <div class="home-card-grid">
              <article class="home-card home-service-card animate-on-scroll">
                <figure class="home-card-media">
                  <img src="https://res.cloudinary.com/dvd2cd2be/image/upload/v1754413079/admin_gallery/eqsitsnild5vbpwp8th4.webp" alt="<%= isEn ? 'Custom web design example' : 'Beispiel für individuelles Webdesign' %>" width="540" height="338" loading="lazy" decoding="async">
                </figure>
                <div class="home-card-body">
                  <h3><%= isEn ? 'Website strategy and structure' : 'Website-Strategie und Struktur' %></h3>
                  <p><%= isEn ? 'Clear page architecture, priorities and content order before design starts.' : 'Klare Seitenstruktur, Prioritäten und Inhaltsreihenfolge, bevor das Design beginnt.' %></p>
                  <a href="/website-erstellen-lassen-berlin" class="linkColor"><%= isEn ? 'Website creation in Berlin' : 'Website erstellen lassen Berlin' %></a>
                </div>
              </article>
              <article class="home-card home-service-card animate-on-scroll">
                <figure class="home-card-media">
                  <img src="/images/code.webp" alt="<%= isEn ? 'Frontend code and technical implementation' : 'Frontend-Code und technische Umsetzung' %>" width="540" height="338" loading="lazy" decoding="async">
                </figure>
                <div class="home-card-body">
                  <h3><%= isEn ? 'Custom design and frontend' : 'Individuelles Design und Frontend' %></h3>
                  <p><%= isEn ? 'Responsive layouts for mobile, tablet and desktop, built to match your offer.' : 'Responsive Layouts für Smartphone, Tablet und Desktop, passend zu deinem Angebot.' %></p>
                  <a href="<%= isEn ? '/en/webdesign-berlin' : '/webdesign-berlin' %>" class="linkColor"><%= isEn ? 'View Webdesign Berlin' : 'Webdesign Berlin ansehen' %></a>
                </div>
              </article>
              <article class="home-card home-service-card animate-on-scroll">
                <figure class="home-card-media">
                  <img src="/images/seo.webp" alt="<%= isEn ? 'SEO structure and search visibility' : 'SEO-Struktur und Suchsichtbarkeit' %>" width="540" height="338" loading="lazy" decoding="async">
                </figure>
                <div class="home-card-body">
                  <h3><%= isEn ? 'Technical SEO basics' : 'Technische SEO-Grundlagen' %></h3>
                  <p><%= isEn ? 'Clean HTML, metadata, internal links and performance basics in the agreed scope.' : 'Sauberes HTML, Metadaten, interne Verlinkung und Performance-Grundlagen im vereinbarten Umfang.' %></p>
                  <a href="<%= isEn ? '/en/website-tester/seo' : '/website-tester/seo' %>" class="linkColor"><%= isEn ? 'Run SEO tester' : 'SEO-Tester starten' %></a>
                </div>
              </article>
              <article class="home-card home-service-card animate-on-scroll">
                <figure class="home-card-media">
                  <img src="/images/wartung.webp" alt="<%= isEn ? 'Website maintenance and relaunch planning' : 'Website-Wartung und Relaunch-Planung' %>" width="540" height="338" loading="lazy" decoding="async">
                </figure>
                <div class="home-card-body">
                  <h3><%= isEn ? 'Relaunch and expansion' : 'Relaunch und Ausbau' %></h3>
                  <p><%= isEn ? 'For existing websites with unclear structure, weak inquiries or outdated technical setup.' : 'Für bestehende Websites mit unklarer Struktur, schwachen Anfragen oder veralteter Technik.' %></p>
                  <a href="/leistungen/website-relaunch" class="linkColor"><%= isEn ? 'View relaunch page' : 'Relaunch-Seite ansehen' %></a>
                </div>
              </article>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 5) Paket-Teaser -->
    <section class="section" id="preise" data-reveal-immediate>
      <div class="container">
        <div class="outer-wrapper home-section-shell">
          <div class="inner-wrapper text-left animate-on-scroll">
            <span class="home-section-kicker"><i class="fas fa-euro-sign" aria-hidden="true"></i><%= isEn ? 'Packages' : 'Pakete' %></span>
            <h2><%= copy.pricingTitle %></h2>
            <p class="home-section-lead">
              <%= isEn
                ? 'The packages are fair, clearly scoped entry points, not bargain offers. Add-ons, running costs and custom functions are discussed separately before implementation.'
