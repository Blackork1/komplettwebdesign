<%- include('partials/head') %>
<% const isEn = typeof lng !== 'undefined' && lng === 'en'; %>
<body class="website-tester-page">
  <%- include('partials/header') %>

  <main id="hero">
    <link rel="stylesheet" href="/website-tester.css?v=<%= encodeURIComponent(assetVersion || '1') %>">

    <section class="wt-section wt-section-compact">
      <div class="wt-shell">
        <nav class="breadcrumbs" aria-label="breadcrumb">
          <ol>
            <li><a href="<%= isEn ? '/en' : '/' %>"><%= isEn ? 'Home' : 'Startseite' %></a></li>
            <li><a href="<%= isEn ? '/en/website-tester' : '/website-tester' %>"><%= isEn ? 'Website Tester' : 'Website-Tester' %></a></li>
            <li aria-current="page">SEO Tester</li>
          </ol>
        </nav>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-cta-card wt-cta-inline">
          <h2><%= isEn ? 'Want expert support for your SEO roadmap?' : 'Du möchtest Unterstützung bei deiner SEO-Roadmap?' %></h2>
          <p>
            <%= isEn
              ? 'We help you prioritize the highest-impact SEO fixes for better ranking, discoverability, and lead quality.'
              : 'Wir helfen dir, die wirkungsvollsten SEO-Maßnahmen für bessere Rankings, Auffindbarkeit und Lead-Qualität zu priorisieren.' %>
          </p>
          <div class="wt-result-meta">
            <a class="wt-button" href="<%= isEn ? '/en/kontakt' : '/kontakt' %>">
              <i class="fa-solid fa-comments"></i>
              <%= isEn ? 'Request consultation' : 'Beratung anfragen' %>
            </a>
            <a class="wt-button-secondary" href="/booking">
              <i class="fa-solid fa-calendar-check"></i>
              <%= isEn ? 'Book appointment' : 'Termin buchen' %>
            </a>
          </div>
        </article>
      </div>
    </section>

    <section class="wt-hero">
      <div class="wt-shell">
        <div class="wt-hero-grid">
          <div class="wt-hero-copy">
            <span class="wt-eyebrow">
              <i class="fa-solid fa-magnifying-glass-chart"></i>
              SEO Tester
            </span>
            <h1><%= isEn ? 'Audit your website SEO quality across subpages.' : 'Prüfe die SEO-Qualität deiner Website über Unterseiten.' %></h1>
            <p class="wt-lead">
              <%= isEn
                ? 'Run a focused on-site SEO + technical audit and identify optimization potential for classic and AI-driven search discovery.'
                : 'Starte einen fokussierten Onsite-SEO- und Technik-Audit und erkenne Optimierungspotenziale für klassische und AI-getriebene Suchauffindbarkeit.' %>
            </p>
            <ul class="wt-pill-list">
              <li><i class="fa-solid fa-sitemap"></i> <%= isEn ? 'Subpage crawl with configurable depth (admin)' : 'Unterseiten-Crawl mit konfigurierbarer Tiefe (Admin)' %></li>
              <li><i class="fa-solid fa-wrench"></i> <%= isEn ? 'On-page, indexing, technical, and schema checks' : 'OnPage-, Indexierungs-, Technik- und Schema-Checks' %></li>
              <li><i class="fa-solid fa-envelope-open-text"></i> <%= isEn ? 'Detailed report via double opt-in email flow' : 'Detaillierter Report via Double-Opt-in per E-Mail' %></li>
            </ul>
          </div>

          <div class="wt-form-card">
            <h2><%= isEn ? 'Start SEO audit' : 'SEO-Audit starten' %></h2>
            <p><%= isEn ? 'Enter URL and business context for realistic SEO scoring.' : 'Gib URL und Geschäftskontext für eine realistische SEO-Bewertung ein.' %></p>
            <form data-seo-tester-form>
              <div class="wt-context-grid">
                <input name="businessType" type="text" placeholder="<%= isEn ? 'Business type (e.g. law firm)' : 'Branche (z. B. Kanzlei)' %>" required>
                <input name="primaryService" type="text" placeholder="<%= isEn ? 'Primary service (e.g. family law)' : 'Hauptleistung (z. B. Familienrecht)' %>" required>
                <input name="targetRegion" type="text" placeholder="<%= isEn ? 'Target region (e.g. Berlin)' : 'Zielregion (z. B. Berlin)' %>" required>
              </div>
              <label class="visually-hidden" for="seo-url"><%= isEn ? 'Website URL' : 'Website-URL' %></label>
              <div class="wt-form-row">
                <input id="seo-url" name="url" type="text" inputmode="url" placeholder="<%= isEn ? 'https://your-website.com' : 'https://deine-website.de' %>" required>
                <button class="wt-button" type="submit">
                  <i class="fa-solid fa-bolt"></i>
                  <%= isEn ? 'Run SEO Audit' : 'SEO-Audit starten' %>
                </button>
              </div>
            </form>
            <p class="wt-form-note">
              <%= isEn
                ? 'You instantly see score and optimization potential. Detailed implementation actions are delivered after email confirmation.'
                : 'Du siehst sofort Score und Optimierungspotenzial. Detaillierte Umsetzungsmaßnahmen erhältst du nach E-Mail-Bestätigung.' %>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel" data-seo-loading hidden>
          <h3><%= isEn ? 'SEO audit in progress…' : 'SEO-Audit läuft…' %></h3>
          <p><%= isEn ? 'We are crawling your website and evaluating SEO/technical signals now.' : 'Wir crawlen deine Website und bewerten SEO-/Technik-Signale.' %></p>
          <ul class="wt-progress">
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Validate URL and website access' : 'URL validieren und Websitezugriff prüfen' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Crawl homepage and subpages' : 'Startseite und Unterseiten crawlen' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Evaluate on-page/indexing/technical signals' : 'OnPage-/Indexierungs-/Technik-Signale auswerten' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Build score and potential summary' : 'Score und Potenzial-Zusammenfassung erstellen' %></span></li>
          </ul>
        </div>

        <div class="wt-error" data-seo-error hidden></div>
        <div id="seo-results" class="wt-results" data-seo-results hidden></div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel wt-methodology">
          <h2><%= isEn ? 'How the SEO tester works — 24 signals in 6 categories' : 'So arbeitet der SEO-Tester — 24 Signale in 6 Kategorien' %></h2>
          <p>
            <%= isEn
              ? 'The SEO tester crawls your homepage plus up to 25 subpages in under a minute and evaluates 24 individual ranking signals across six categories: on-page structure, indexing, technical quality, content, internal linking, and structured data. Each signal is scored independently, then aggregated into category scores and an overall 0–100 SEO score. The scoring logic is based on Google Search Central guidelines and real-world ranking data from German SMB sites we have audited since 2021.'
              : 'Der SEO-Tester crawlt Startseite plus bis zu 25 Unterseiten in unter einer Minute und bewertet 24 einzelne Ranking-Signale in sechs Kategorien: OnPage-Struktur, Indexierung, Technik, Content, interne Verlinkung und strukturierte Daten. Jedes Signal wird einzeln bewertet und zu Kategorie-Scores sowie einem Gesamt-SEO-Score von 0–100 aggregiert. Die Scoring-Logik basiert auf den Google-Search-Central-Guidelines und realen Ranking-Daten aus deutschen KMU-Audits, die wir seit 2021 durchführen.' %>
          </p>
          <div class="wt-method-grid">
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-code"></i> <%= isEn ? 'On-page structure' : 'OnPage-Struktur' %></h3>
              <p><%= isEn
                ? 'Title lengths and uniqueness, meta description quality, H1 hierarchy, heading order, alt text coverage, URL patterns, and language declaration. Weak signals here often cost 15–30% of organic CTR.'
                : 'Title-Längen & Einmaligkeit, Description-Qualität, H1-Hierarchie, Überschriften-Reihenfolge, Alt-Text-Abdeckung, URL-Muster und Sprachdeklaration. Schwache Signale kosten oft 15–30% der organischen CTR.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-magnifying-glass"></i> <%= isEn ? 'Indexing signals' : 'Indexierungs-Signale' %></h3>
              <p><%= isEn
                ? 'Robots.txt directives, sitemap.xml presence and reachability, canonical tags, noindex flags, hreflang consistency. A single wrong noindex has taken down six-figure monthly traffic in cases we audited.'
                : 'Robots.txt-Direktiven, Sitemap.xml-Präsenz und -Erreichbarkeit, Canonical-Tags, Noindex-Flags, Hreflang-Konsistenz. Ein falsches Noindex hat in unseren Audits schon sechsstelligen monatlichen Traffic gekostet.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-gauge-high"></i> <%= isEn ? 'Technical quality' : 'Technik-Qualität' %></h3>
              <p><%= isEn
                ? 'HTTPS, HTTP/2, compression, response times, image weight, render-blocking resources, mobile viewport, and Core Web Vitals proxies. Weighted heavily because Google uses them as ranking factors directly.'
                : 'HTTPS, HTTP/2, Komprimierung, Antwortzeiten, Bild-Gewicht, render-blockierende Ressourcen, Mobile-Viewport und Core-Web-Vitals-Proxies. Stark gewichtet, weil Google sie direkt als Ranking-Faktoren nutzt.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-file-lines"></i> <%= isEn ? 'Content quality' : 'Content-Qualität' %></h3>
              <p><%= isEn
                ? 'Word count per page, thin-content detection, keyword-topic alignment, duplicate-content risk, paragraph structure, and readability. Good for classic search and for being cited by AI answer systems.'
                : 'Wortzahl pro Seite, Thin-Content-Erkennung, Keyword-Thema-Abgleich, Duplicate-Content-Risiko, Absatzstruktur und Lesbarkeit. Relevant für klassische Suche und für Zitierungen in KI-Antwort-Systemen.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-diagram-project"></i> <%= isEn ? 'Internal linking' : 'Interne Verlinkung' %></h3>
              <p><%= isEn
                ? 'Link depth from the homepage, anchor text variance, orphan pages, link equity distribution, and navigation clarity. Often the fastest lever to raise rankings without creating new content.'
                : 'Link-Tiefe ab Startseite, Anchor-Text-Varianz, Orphan Pages, Link-Equity-Verteilung und Navigations-Klarheit. Oft der schnellste Hebel, um Rankings ohne neuen Content anzuheben.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-diagram-next"></i> <%= isEn ? 'Structured data' : 'Strukturierte Daten' %></h3>
              <p><%= isEn
                ? 'Organization, LocalBusiness, Service, FAQPage, BreadcrumbList, and Product schemas in JSON-LD. Correctly implemented, this unlocks rich snippets and AI answer citations.'
                : 'Organization, LocalBusiness, Service, FAQPage, BreadcrumbList und Product-Schemas als JSON-LD. Korrekt umgesetzt, erschließt das Rich-Snippets und KI-Antwort-Zitierungen.' %></p>
            </div>
          </div>
          <p>
            <%= isEn
              ? 'After the audit, you see the score, the six category scores, and the top three optimization areas directly in your browser. A detailed PDF report with every finding, its priority, the concrete implementation steps, and before/after examples is delivered via email after double opt-in — that report has an average of 28 pages and is typically worth 2–4 hours of consulting work.'
              : 'Nach dem Audit siehst du Score, die sechs Kategorie-Scores und die drei wichtigsten Potenzialbereiche sofort im Browser. Der detaillierte PDF-Report mit allen Befunden, Prioritäten, konkreten Umsetzungsschritten und Vorher/Nachher-Beispielen wird nach Double-Opt-in per Mail zugestellt — durchschnittlich 28 Seiten, typischerweise 2–4 Stunden Beratungsarbeit wert.' %>
          </p>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel">
          <h2><%= isEn ? 'What clients say about the audit' : 'Was Kunden zur Analyse sagen' %></h2>
          <div class="wt-reviews-grid">
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“The SEO audit gave us a clear picture of where we were losing traffic. The recommendations were concrete and we saw rankings move within four weeks.”'
                : '„Die SEO-Analyse hat uns klar gezeigt, wo wir Traffic verlieren. Die Empfehlungen waren konkret und wir haben innerhalb von vier Wochen Ranking-Verbesserungen gesehen."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“Very professional. Sören explained every finding in a way we could act on immediately, without buzzwords.”'
                : '„Sehr professionell. Sören hat jeden Befund so erklärt, dass wir sofort umsetzen konnten — ohne Buzzwords."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“Fair pricing, fast delivery, and the report pays for itself after the first ranking jump.”'
                : '„Faire Preise, schnelle Umsetzung — der Report amortisiert sich mit dem ersten Ranking-Sprung."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
          </div>
          <p class="wt-reviews-link">
            <a href="https://www.google.com/search?q=komplett+webdesign+bewertungen" target="_blank" rel="noopener">
              <i class="fa-brands fa-google"></i>
              <%= isEn ? 'Read all Google reviews' : 'Alle Google-Bewertungen lesen' %>
            </a>
          </p>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel wt-trust-panel">
          <h3><%= isEn ? 'Transparent and privacy-friendly' : 'Transparent und datenschutzfreundlich' %></h3>
          <ul class="wt-trust-list">
            <li><i class="fa-solid fa-shield-halved"></i> <%= isEn ? 'We respect robots.txt and crawl a maximum of 25 subpages per audit.' : 'Wir respektieren robots.txt und crawlen maximal 25 Unterseiten pro Audit.' %></li>
            <li><i class="fa-solid fa-clock"></i> <%= isEn ? 'Scan timeout 45 seconds — no long background load on your server.' : 'Scan-Timeout 45 Sekunden — keine lange Hintergrundlast auf deinem Server.' %></li>
            <li><i class="fa-solid fa-database"></i> <%= isEn ? 'Anonymous audit data is kept for up to 14 days for quality assurance only.' : 'Anonyme Audit-Daten werden ausschließlich für bis zu 14 Tage zur Qualitätssicherung gespeichert.' %></li>
            <li><i class="fa-solid fa-envelope-open"></i> <%= isEn ? 'We use double opt-in for email delivery. Unsubscribe in one click any time.' : 'Wir nutzen Double-Opt-in für Mail-Versand. Abmeldung jederzeit mit einem Klick.' %></li>
          </ul>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel">
          <h2><%= isEn ? 'FAQ: SEO tester' : 'FAQ: SEO-Tester' %></h2>
          <div class="wt-faq">
            <% (typeof faq !== 'undefined' && Array.isArray(faq) ? faq : []).forEach(function(item){ %>
              <details>
                <summary><%= item.q %></summary>
                <p><%= item.a %></p>
              </details>
            <% }); %>
          </div>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-cta-card">
          <h2><%= isEn ? 'Ready to turn SEO findings into measurable results?' : 'Bereit, SEO-Befunde in messbare Ergebnisse umzusetzen?' %></h2>
          <p>
            <%= isEn
              ? 'We help you turn SEO findings into a practical roadmap with measurable visibility impact.'
              : 'Wir helfen dir, SEO-Befunde in eine praktische Roadmap mit messbarem Sichtbarkeits-Impact zu übersetzen.' %>
          </p>
          <div class="wt-result-meta">
            <a class="wt-button" href="<%= isEn ? '/en/kontakt' : '/kontakt' %>">
              <i class="fa-solid fa-paper-plane"></i>
              <%= isEn ? 'Request SEO consultation' : 'SEO-Beratung anfragen' %>
            </a>
            <a class="wt-button-secondary" href="/booking">
              <i class="fa-solid fa-calendar-days"></i>
              <%= isEn ? 'Book a call' : 'Call buchen' %>
            </a>
          </div>
        </article>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <style>
    .wt-section-compact { padding-top: 16px; padding-bottom: 0; }
    .breadcrumbs ol { margin: 0; padding: 0; list-style: none; display: flex; gap: 10px; flex-wrap: wrap; }
    .breadcrumbs li { color: #6b7280; font-size: .95rem; }
    .breadcrumbs li+li::before { content: '›'; margin-right: 10px; color: #9ca3af; }
    .breadcrumbs a { color: #374151; text-decoration: none; }
    .breadcrumbs a:hover { text-decoration: underline; }
    .wt-cta-inline { padding: 1rem; }
    .wt-faq details { border-top: 1px solid #e5e7eb; padding: 14px 0; }
    .wt-faq summary { cursor: pointer; font-weight: 600; }
    .wt-faq p { margin: 10px 0 0; }
  </style>

  <script>
    window.SEO_TESTER_CONFIG = {
      locale: "<%= isEn ? 'en' : 'de' %>",
      endpoint: "/api/seo-audit",
      leadEndpoint: "/api/seo-audit/lead",
      i18n: {
        scoreOf: "<%= isEn ? 'of 100' : 'von 100' %>",
        seoAuditFor: "<%= isEn ? 'SEO audit for' : 'SEO-Analyse für' %>",
        modeLabel: "<%= isEn ? 'Mode' : 'Modus' %>",
        scannedPages: "<%= isEn ? 'Scanned pages' : 'Gescannten Seiten' %>",
        partialResult: "<%= isEn ? 'Partial result' : 'Teil-Ergebnis' %>",
        timeoutReached: "<%= isEn ? 'Timeout reached' : 'Zeitlimit erreicht' %>",
        categoryScoresTitle: "<%= isEn ? 'SEO category scores' : 'SEO-Kategorien' %>",
        potentialTitle: "<%= isEn ? 'Optimization potential' : 'Optimierungspotenzial' %>",
        topPotentialAreasTitle: "<%= isEn ? 'Top potential areas' : 'Top-Potenzialbereiche' %>",
        lockedTitle: "<%= isEn ? 'Detailed SEO implementation report' : 'Detaillierter SEO-Umsetzungsreport' %>",
        lockedText: "<%= isEn ? 'Get the detailed step-by-step report by confirming your email (double opt-in). Newsletter signup is required for delivery.' : 'Erhalte den detaillierten Schritt-für-Schritt-Report per E-Mail-Bestätigung (Double-Opt-in). Für den Versand ist die Newsletter-Anmeldung erforderlich.' %>",
        leadName: "<%= isEn ? 'Name (optional)' : 'Name (optional)' %>",
        leadEmail: "<%= isEn ? 'Email address' : 'E-Mail-Adresse' %>",
        leadConsent: "<%= isEn ? 'I agree to newsletter signup, want to receive the requested detailed SEO report by email, and have read the privacy policy.' : 'Ich stimme der Newsletter-Anmeldung zu, möchte den angeforderten detaillierten SEO-Report per E-Mail erhalten und habe die Datenschutzerklärung gelesen.' %>",
        privacyHref: "/datenschutz",
        privacyLabel: "<%= isEn ? 'Privacy policy' : 'Datenschutzerklärung' %>",
        leadSubmit: "<%= isEn ? 'Send confirmation link' : 'Bestätigungslink senden' %>",
        leadLoading: "<%= isEn ? 'Sending…' : 'Wird gesendet…' %>",
        leadSuccess: "<%= isEn ? 'Please check your inbox and confirm your email. We then send your detailed SEO report.' : 'Bitte prüfe dein Postfach und bestätige deine E-Mail. Danach senden wir deinen detaillierten SEO-Report.' %>",
        leadError: "<%= isEn ? 'The SEO report request could not be processed.' : 'Die SEO-Report-Anfrage konnte nicht verarbeitet werden.' %>",
        noPotentials: "<%= isEn ? 'No specific potential areas detected yet.' : 'Es wurden noch keine spezifischen Potenzialbereiche erkannt.' %>",
        noCategories: "<%= isEn ? 'No category data available.' : 'Keine Kategoriedaten verfügbar.' %>",
        contextRequired: "<%= isEn ? 'Please provide business type, primary service, and target region.' : 'Bitte ergänze Branche, Hauptleistung und Zielregion.' %>",
        errorFallback: "<%= isEn ? 'The SEO audit could not be completed.' : 'Das SEO-Audit konnte nicht durchgeführt werden.' %>",
        ctaTitle: "<%= isEn ? 'Turn findings into execution' : 'Befunde direkt umsetzen' %>",
        ctaText: "<%= isEn ? 'Book a short consultation to prioritize implementation and impact.' : 'Buche eine kurze Beratung, um Umsetzung und Impact zu priorisieren.' %>",
        ctaPrimary: "<%= isEn ? 'Request consultation' : 'Beratung anfragen' %>",
        ctaSecondary: "<%= isEn ? 'Book appointment' : 'Termin buchen' %>",
        contactHref: "<%= isEn ? '/en/kontakt' : '/kontakt' %>",
        categoryLabels: {
          onpage: "<%= isEn ? 'On-page structure' : 'OnPage-Struktur' %>",
          indexing: "<%= isEn ? 'Indexing signals' : 'Indexierungs-Signale' %>",
          technical: "<%= isEn ? 'Technical quality' : 'Technik-Qualität' %>",
          content: "<%= isEn ? 'Content quality' : 'Content-Qualität' %>",
          internal_linking: "<%= isEn ? 'Internal linking' : 'Interne Verlinkung' %>",
          structured_data: "<%= isEn ? 'Structured data' : 'Strukturierte Daten' %>"
        }
      }
    };
  </script>
  <script src="/js/tester-utils.js?v=<%= encodeURIComponent(assetVersion || '1') %>" defer></script>
  <script src="/js/seo-tester.js?v=<%= encodeURIComponent(assetVersion || '1') %>" defer></script>
</body>
</html>
