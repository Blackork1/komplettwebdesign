<!-- views/blog/show.ejs -->
<%- include('../partials/head', { title, description, seoExtra, ogImage, canonicalUrl }) %>
<%- include('../partials/header') %>

<link rel="stylesheet" href="<%= cssAsset('ratgeber.css') %>" />
<link rel="stylesheet" href="<%= cssAsset('blog.css') %>" />

<main class="rg-page blog-page blog-detail-page" id="hero">
  <section class="rg-detail-hero blog-detail-hero unified-hero" aria-labelledby="blog-detail-title">
    <div class="container rg-detail-hero-inner unified-hero__grid">
      <div class="rg-detail-copy unified-hero__copy">
        <nav class="unified-hero__breadcrumbs" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Startseite</a></li>
            <li><a href="/blog">Blog</a></li>
            <li aria-current="page"><%= post.title %></li>
          </ol>
        </nav>

        <h1 id="blog-detail-title"><%= post.title %></h1>
        <% if (post.excerpt || post.description) { %>
        <p class="rg-detail-lead unified-hero__lead"><%= post.excerpt || post.description %></p>
        <% } %>

        <div class="rg-detail-meta blog-detail-meta">
          <span>
            Veröffentlicht am
            <time datetime="<%= new Date(post.created_at).toISOString() %>"><%= new Date(post.created_at).toLocaleDateString('de-DE') %></time>
          </span>
        </div>

        <div class="rg-detail-actions unified-hero__actions">
          <a href="/blog" class="btn btn-primary">Alle Artikel</a>
          <a href="/website-tester" class="btn btn-secondary">Website prüfen</a>
        </div>
      </div>

      <figure class="rg-detail-media blog-hero__media unified-hero__media-frame">
        <img src="<%= post.image_url || '/images/default-blog.webp' %>" alt="<%= post.image_alt || post.title %>" loading="eager" fetchpriority="high">
      </figure>
    </div>
  </section>

  <div class="container rg-detail-layout">
    <article class="rg-article" aria-label="Blogartikel Inhalt">
      <div class="rg-article-body">
        <%- renderedContent %>
      </div>

      <section id="blog-comments" class="comment-section" data-post-slug="<%= post.slug %>" data-recaptcha-sitekey="<%= process.env.RECAPTCHA_SITEKEY || '' %>">
        <div class="comment-section-head">
          <div>
            <p class="rg-section-kicker">Feedback</p>
            <h2>Kommentare &amp; Fragen</h2>
            <p>Stelle Fragen, teile Anregungen oder hinterlasse deine Meinung zu diesem Artikel.</p>
          </div>
          <div class="comment-security-badge">
            Spam-geschützt mit reCAPTCHA
          </div>
        </div>

        <div class="comment-card position-relative" data-comment-body>
          <div class="comment-consent-overlay d-none" data-consent-overlay>
            <div>
              <p class="mb-1 fw-semibold">Kommentare deaktiviert</p>
              <p class="mb-0 small">Zum Kommentieren und Liken müssen die Cookie-Einstellungen akzeptiert werden.</p>
            </div>
          </div>

          <form class="comment-form" data-comment-form novalidate>
            <div class="row g-3 align-items-start">
              <div class="col-12 col-md-4">
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" placeholder="Dein Name" maxlength="80" aria-describedby="comment-name-help" required />
                <small id="comment-name-help" class="form-help">Bitte gib den Namen ein, der beim Kommentar angezeigt werden soll.</small>
              </div>
              <div class="col-12 col-md-8">
                <label class="form-label">Kommentar</label>
                <textarea name="comment" class="form-control" rows="3" placeholder="Teile deine Frage oder Meinung..." maxlength="1500" aria-describedby="comment-text-help" required></textarea>
                <small id="comment-text-help" class="form-help">Bitte schreibe mindestens einen kurzen Kommentar. Maximal 1.500 Zeichen.</small>
                <input type="hidden" name="parentId" value="" />
                <div class="comment-form-actions">
                  <small>Pflichtfelder müssen ausgefüllt sein. Der Spamschutz wird beim Absenden geprüft.</small>
                  <button type="submit" class="btn btn-primary" data-submit-btn>
                    Kommentar senden
                  </button>
                </div>
              </div>
            </div>
          </form>

          <div class="comment-reply-indicator d-none" data-reply-indicator>
            <div class="small text-muted">
              Antwort auf <span class="fw-semibold" data-reply-target></span>
            </div>
            <button type="button" class="btn btn-link p-0 small" data-cancel-reply>Abbrechen</button>
          </div>

          <div class="comment-feedback small" data-comment-feedback role="status"></div>
        </div>

        <div class="comment-list" data-comment-list>
          <p class="text-muted" data-empty-state>Sei die erste Person, die einen Kommentar hinterlässt.</p>
        </div>
      </section>
    </article>

    <aside class="rg-detail-side" aria-label="Newsletter und nächste Schritte">
      <div class="rg-sticky-wrap">
        <section class="rg-newsletter-card">
          <p class="rg-panel-eyebrow">Newsletter</p>
          <h3>Neue Blogartikel direkt ins Postfach</h3>
          <p>Kurze Tipps zu Webdesign, Performance und SEO mit Fokus auf kleine Unternehmen in Berlin.</p>
          <div class="rg-newsletter-form">
            <%- include('../partials/newsletter_form') %>
          </div>
        </section>

        <section class="rg-other-guides" aria-labelledby="blog-next-title">
          <h3 id="blog-next-title">Weiterlesen</h3>
          <div class="rg-other-list">
            <a href="/ratgeber" class="rg-other-item">
              <strong>Ratgeber</strong>
              <p>Strukturierte Grundlagen zu Kosten, Ablauf, Relaunch und lokaler Sichtbarkeit.</p>
            </a>
            <a href="/webdesign-berlin" class="rg-other-item">
              <strong>Webdesign Berlin</strong>
              <p>Die wichtigste Seite für dein Website-Projekt mit Komplett Webdesign.</p>
            </a>
          </div>
        </section>
      </div>
    </aside>
  </div>
</main>
<script src="<%= (typeof jsAsset === 'function' ? jsAsset('js/blog-comments.js') : '/js/blog-comments.js?v=' + encodeURIComponent(assetVersion || '1')) %>" defer></script>

<%- include('../partials/footer') %>
