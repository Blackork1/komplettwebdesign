<header>
  <% const isEn = typeof lng !== 'undefined' && lng === 'en'; %>
  <% const homeHref = isEn ? '/en' : '/'; %>
  <% const currentPath = (typeof currentPathname !== 'undefined' && currentPathname)
    ? currentPathname
    : '/'; %>
  <% const currentSearchPart = (typeof currentSearch !== 'undefined' && currentSearch) ? currentSearch : ''; %>
  <% const normalizedCurrentPath = currentPath.replace(/\/+$/, '') || '/'; %>
  <% const districtPathPattern = /^\/webdesign-berlin\/(friedrichshain|prenzlauer-berg|kreuzberg|charlottenburg|lichtenberg|mitte)$/; %>
  <% const enDistrictPathPattern = /^\/en\/webdesign-berlin\/(friedrichshain|prenzlauer-berg|kreuzberg|charlottenburg|lichtenberg|mitte)$/; %>
  <% const isDeDistrictPath = districtPathPattern.test(normalizedCurrentPath); %>
  <% const isEnDistrictPath = enDistrictPathPattern.test(normalizedCurrentPath); %>
  <% const isDeServicePath = normalizedCurrentPath.startsWith('/webdesign-berlin/') && !isDeDistrictPath; %>
  <% const isEnServicePath = normalizedCurrentPath.startsWith('/en/webdesign-berlin/') && !isEnDistrictPath; %>
  <% const deToEnMap = { '/': '/en', '/kontakt': '/en/kontakt', '/webdesign-berlin': '/en/webdesign-berlin', '/pakete': '/en/pakete', '/website-tester': '/en/website-tester', '/website-tester/broken-links': '/en/website-tester/broken-links', '/website-tester/geo': '/en/website-tester/geo', '/website-tester/seo': '/en/website-tester/seo', '/website-tester/meta': '/en/website-tester/meta', '/website-tester/report-confirm': '/en/website-tester/report-confirm', '/website-tester/geo/report-confirm': '/en/website-tester/geo/report-confirm', '/website-tester/seo/report-confirm': '/en/website-tester/seo/report-confirm', '/website-tester/meta/report-confirm': '/en/website-tester/meta/report-confirm' }; %>
  <% const enToDeMap = { '/en': '/', '/en/kontakt': '/kontakt', '/en/webdesign-berlin': '/webdesign-berlin', '/en/pakete': '/pakete', '/en/website-tester': '/website-tester', '/en/website-tester/broken-links': '/website-tester/broken-links', '/en/website-tester/geo': '/website-tester/geo', '/en/website-tester/seo': '/website-tester/seo', '/en/website-tester/meta': '/website-tester/meta', '/en/website-tester/report-confirm': '/website-tester/report-confirm', '/en/website-tester/geo/report-confirm': '/website-tester/geo/report-confirm', '/en/website-tester/seo/report-confirm': '/website-tester/seo/report-confirm', '/en/website-tester/meta/report-confirm': '/website-tester/meta/report-confirm' }; %>
  <% const switchToEnPath = deToEnMap[normalizedCurrentPath]
    || (isDeDistrictPath ? `/en${normalizedCurrentPath}` : null)
    || (normalizedCurrentPath.startsWith('/pakete/') ? `/en${normalizedCurrentPath}` : null)
    || (isDeServicePath ? normalizedCurrentPath : null)
    || (normalizedCurrentPath.startsWith('/en/') ? normalizedCurrentPath : '/en'); %>
  <% const switchToDePath = enToDeMap[normalizedCurrentPath]
    || (isEnDistrictPath ? normalizedCurrentPath.replace(/^\/en/, '') : null)
    || (normalizedCurrentPath.startsWith('/en/pakete/') ? normalizedCurrentPath.replace(/^\/en/, '') : null)
    || (isEnServicePath ? normalizedCurrentPath.replace(/^\/en/, '') : null)
    || (normalizedCurrentPath.startsWith('/en/') ? '/' : '/'); %>
  <% const switchToEnHref = `${switchToEnPath}${currentSearchPart}`; %>
  <% const switchToDeHref = `${switchToDePath}${currentSearchPart}`; %>
  <% const toEnLabel = (label) => {
    const map = {
      Restaurants: 'Restaurants',
      Handwerksbetriebe: 'Trades',
      Cafés: 'Cafes',
      Cafe: 'Cafe',
      Kontakt: 'Contact',
      Preise: 'Pricing',
      Ratgeber: 'Guides',
      Branchen: 'Industries'
    };
    return map[label] || label;
  }; %>
  <% const isExcludedIndustryNavItem = (item = {}) => {
    const text = [item.nav, item.name, item.slug].filter(Boolean).join(' ').toLowerCase();
    return ['kita', 'kitas', 'schule', 'schulen', 'school', 'schools', 'daycare', 'daycares', 'kindergarten'].some((needle) => text.includes(needle));
  }; %>
  <% const visibleNavPages = ((typeof navPages !== 'undefined' && navPages) ? navPages : []).filter((page) => !isExcludedIndustryNavItem(page)); %>
  <% const visibleNavIndustries = ((typeof navIndustries !== 'undefined' && navIndustries) ? navIndustries : []).filter((industry) => !isExcludedIndustryNavItem(industry)); %>
  <div class="topWhiteGradient">
    <div class="topWhiteGradients"></div>

    <div class="hero-nav">
      <div class="navigation" id="navigation" aria-label="Komplett Webdesign">
        <a href="<%= homeHref %>" class="logo" aria-label="<%= isEn ? 'To homepage' : 'Zur Startseite' %>">
          <img src="/images/LogoTransparent.webp" alt="<%= isEn ? 'Icon to go to homepage' : 'Icon um zur Startseite zu kommen' %>" role="presentation" />
        </a>
        <div class="nav-right">
          <img src="/images/Nav-Bar-Icon.svg" alt="Menu Icon" class="menu-icon" id="menu-icon" />
          <div class="links heroLinks" id="nav-links">
            <a href="<%= homeHref %>">Home</a>
            <a href="<%= isEn ? '/en/kontakt' : '/kontakt' %>"><%= isEn ? 'Contact' : 'Kontakt' %></a>
            <a href="<%= isEn ? '/en/pakete' : '/pakete' %>"><%= isEn ? 'Pricing' : 'Preise' %></a>
            <nav class="main-nav">
              <ul>
                <li class="dropdown">
                  <div class="dropdown-toggle">
                    <a href="<%= isEn ? '/en/webdesign-berlin' : '/webdesign-berlin' %>">Webdesign Berlin</a>
                    <button class="dropdown-toggle-btn" type="button" aria-label="<%= isEn ? 'Open Webdesign Berlin submenu' : 'Webdesign Berlin Untermenü öffnen' %>">
                      ▾
                    </button>
                  </div>
                  <ul class="dropdown-menu">
                    <li><a href="<%= isEn ? '/en/webdesign-berlin/kreuzberg' : '/webdesign-berlin/kreuzberg' %>" class="main-color">Kreuzberg</a></li>
                    <li><a href="<%= isEn ? '/en/webdesign-berlin/friedrichshain' : '/webdesign-berlin/friedrichshain' %>" class="main-color">Friedrichshain</a></li>
                    <li><a href="<%= isEn ? '/en/webdesign-berlin/charlottenburg' : '/webdesign-berlin/charlottenburg' %>" class="main-color">Charlottenburg</a></li>
                    <li><a href="<%= isEn ? '/en/webdesign-berlin/lichtenberg' : '/webdesign-berlin/lichtenberg' %>" class="main-color">Lichtenberg</a></li>
                    <li><a href="<%= isEn ? '/en/webdesign-berlin/mitte' : '/webdesign-berlin/mitte' %>" class="main-color">Mitte</a></li>
                    <li><a href="<%= isEn ? '/en/webdesign-berlin/prenzlauer-berg' : '/webdesign-berlin/prenzlauer-berg' %>" class="main-color">Prenzlauer-Berg</a></li>
                  </ul>
                </li>
              </ul>
            </nav>
            <nav class="main-nav">
              <ul>
                <li class="dropdown">
                  <div class="dropdown-toggle">
                    <a href="/branchen"><%= isEn ? 'Industries' : 'Branchen' %></a>
                    <button class="dropdown-toggle-btn" type="button" aria-label="<%= isEn ? 'Open industries submenu' : 'Branchen Untermenü öffnen' %>">
                      ▾
                    </button>
                  </div>
                  <ul class="dropdown-menu">
                    <% visibleNavPages.forEach(page=> { %>
                    <li><a href="/<%= page.slug %>" class="main-color">
                        <%= isEn ? toEnLabel(page.nav) : page.nav %>
                      </a></li>
                    <% }) %>
                    <% visibleNavIndustries.forEach(industry => { %>
                    <% const slug = industry.slug || ''; %>
                    <% const href = `/branchen/${slug.startsWith('webdesign-') ? slug : `webdesign-${slug}`}`; %>
                    <li><a href="<%= href %>" class="main-color"><%= isEn ? toEnLabel(industry.name) : industry.name %></a></li>
                    <% }) %>
                  </ul>
                </li>
              </ul>
            </nav>
            <nav class="main-nav">
              <ul>
                <li class="dropdown">
                  <div class="dropdown-toggle">
                    <a href="<%= isEn ? '/en/website-tester' : '/website-tester' %>">Website Tester</a>
                    <button class="dropdown-toggle-btn" type="button" aria-label="<%= isEn ? 'Open website tester submenu' : 'Website-Tester Untermenü öffnen' %>">
                      ▾
                    </button>
                  </div>
                  <ul class="dropdown-menu">
                    <li><a href="<%= isEn ? '/en/website-tester' : '/website-tester' %>" class="main-color"><%= isEn ? 'Complete Test' : 'Komplett Test' %></a></li>
                    <li><a href="<%= isEn ? '/en/website-tester/broken-links' : '/website-tester/broken-links' %>" class="main-color"><%= isEn ? 'Broken Links' : 'Fehlerhafte Links' %></a></li>
                    <li><a href="<%= isEn ? '/en/website-tester/geo' : '/website-tester/geo' %>" class="main-color">GEO Tester</a></li>
                    <li><a href="<%= isEn ? '/en/website-tester/seo' : '/website-tester/seo' %>" class="main-color">SEO Tester</a></li>
                    <li><a href="<%= isEn ? '/en/website-tester/meta' : '/website-tester/meta' %>" class="main-color">Meta Tester</a></li>
                  </ul>
                </li>
              </ul>
            </nav>
            <a href="/blog">Blog</a>
            <a href="<%= isEn ? '/en/booking' : '/booking' %>" class="btn btn-tertiary"><%= isEn ? 'Book a call' : 'Termin buchen' %></a>
            <a href="<%= isEn ? switchToDeHref : switchToEnHref %>" class="btn btn-secondary"><%= isEn ? 'DE' : 'EN' %></a>
            <!-- <a href="/reservation" class="reserve-button">Reservierung</a> -->
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
