<header>
  <% const isEn = typeof lng !== 'undefined' && lng === 'en'; %>
  <% const homeHref = isEn ? '/en' : '/'; %>
  <% const currentPath = (typeof currentPathname !== 'undefined' && currentPathname)
    ? currentPathname
    : '/'; %>
  <% const currentSearchPart = (typeof currentSearch !== 'undefined' && currentSearch) ? currentSearch : ''; %>
  <% const normalizedCurrentPath = currentPath.replace(/\/+$/, '') || '/'; %>
  <% const districtPathPattern = /^\/webdesign-berlin\/(friedrichshain|prenzlauer-berg|kreuzberg|charlottenburg|lichtenberg|mitte)$/; %>
  <% const enDistrictPathPattern = /^\/en\/webdesign-berlin\/(friedrichshain|prenzlauer-berg|kreuzberg|charlottenburg|lichtenberg|mitte)$/; %>
  <% const isDeDistrictPath = districtPathPattern.test(normalizedCurrentPath); %>
  <% const isEnDistrictPath = enDistrictPathPattern.test(normalizedCurrentPath); %>
  <% const isDeServicePath = normalizedCurrentPath.startsWith('/webdesign-berlin/') && !isDeDistrictPath; %>
  <% const isEnServicePath = normalizedCurrentPath.startsWith('/en/webdesign-berlin/') && !isEnDistrictPath; %>
  <% const deToEnMap = { '/': '/en', '/kontakt': '/en/kontakt', '/webdesign-berlin': '/en/webdesign-berlin', '/pakete': '/en/pakete', '/website-tester': '/en/website-tester', '/website-tester/broken-links': '/en/website-tester/broken-links', '/website-tester/geo': '/en/website-tester/geo', '/website-tester/seo': '/en/website-tester/seo', '/website-tester/meta': '/en/website-tester/meta', '/website-tester/report-confirm': '/en/website-tester/report-confirm', '/website-tester/geo/report-confirm': '/en/website-tester/geo/report-confirm', '/website-tester/seo/report-confirm': '/en/website-tester/seo/report-confirm', '/website-tester/meta/report-confirm': '/en/website-tester/meta/report-confirm' }; %>
  <% const enToDeMap = { '/en': '/', '/en/kontakt': '/kontakt', '/en/webdesign-berlin': '/webdesign-berlin', '/en/pakete': '/pakete', '/en/website-tester': '/website-tester', '/en/website-tester/broken-links': '/website-tester/broken-links', '/en/website-tester/geo': '/website-tester/geo', '/en/website-tester/seo': '/website-tester/seo', '/en/website-tester/meta': '/website-tester/meta', '/en/website-tester/report-confirm': '/website-tester/report-confirm', '/en/website-tester/geo/report-confirm': '/website-tester/geo/report-confirm', '/en/website-tester/seo/report-confirm': '/website-tester/seo/report-confirm', '/en/website-tester/meta/report-confirm': '/website-tester/meta/report-confirm' }; %>
  <% const switchToEnPath = deToEnMap[normalizedCurrentPath]
    || (isDeDistrictPath ? `/en${normalizedCurrentPath}` : null)
    || (normalizedCurrentPath.startsWith('/pakete/') ? `/en${normalizedCurrentPath}` : null)
    || (isDeServicePath ? normalizedCurrentPath : null)
    || (normalizedCurrentPath.startsWith('/en/') ? normalizedCurrentPath : '/en'); %>
  <% const switchToDePath = enToDeMap[normalizedCurrentPath]
    || (isEnDistrictPath ? normalizedCurrentPath.replace(/^\/en/, '') : null)
    || (normalizedCurrentPath.startsWith('/en/pakete/') ? normalizedCurrentPath.replace(/^\/en/, '') : null)
    || (isEnServicePath ? normalizedCurrentPath.replace(/^\/en/, '') : null)
    || (normalizedCurrentPath.startsWith('/en/') ? '/' : '/'); %>
  <% const switchToEnHref = `${switchToEnPath}${currentSearchPart}`; %>
  <% const switchToDeHref = `${switchToDePath}${currentSearchPart}`; %>
  <% const navItems = (typeof headerNavigation !== 'undefined' && Array.isArray(headerNavigation)) ? headerNavigation : []; %>
  <% const navCta = (typeof headerCta !== 'undefined' && headerCta) ? headerCta : { label: 'Projekt anfragen', labelEn: 'Request project', href: '/kontakt', hrefEn: '/en/kontakt' }; %>
  <% const navHref = (item = {}) => (isEn && item.hrefEn ? item.hrefEn : item.href); %>
  <% const navLabel = (item = {}) => (isEn && item.labelEn ? item.labelEn : item.label); %>
  <% const normalizeNavPath = (href = '/') => {
    const path = String(href || '/').split('?')[0].replace(/\/+$/, '');
    return path || '/';
  }; %>
  <% const normalizeIconPath = (href = '/') => normalizeNavPath(href).replace(/^\/en(?=\/|$)/, '') || '/'; %>
  <% const navIconMap = {
    '/': '/images/nav-icons/start.svg',
    '/webdesign-berlin': '/images/nav-icons/webdesign.svg',
    '/pakete': '/images/nav-icons/packages.svg',
    '/leistungen': '/images/nav-icons/services.svg',
    '/leistungen/website-relaunch': '/images/nav-icons/relaunch.svg',
    '/leistungen/local-seo': '/images/nav-icons/local-seo.svg',
    '/leistungen/landingpage-erstellen-lassen': '/images/nav-icons/landingpage.svg',
    '/leistungen/website-audit': '/images/nav-icons/audit.svg',
    '/leistungen/responsives-design-mobile': '/images/nav-icons/responsive.svg',
    '/leistungen/inhalte-texte-content': '/images/nav-icons/content.svg',
    '/leistungen/rechtliches-sicherheit': '/images/nav-icons/legal-security.svg',
    '/leistungen/website-wartung': '/images/nav-icons/maintenance.svg',
    '/leistungen/zusatzleistungen-webdesign': '/images/nav-icons/addons.svg',
    '/leistungen/laufende-kosten-website': '/images/nav-icons/running-costs.svg',
    '/referenzen': '/images/nav-icons/references.svg',
    '/branchen': '/images/nav-icons/industries.svg',
    '/kontakt': '/images/nav-icons/contact.svg'
  }; %>
  <% const navDescriptionMap = {
    de: {
      '/leistungen': 'Alle Leistungen im Überblick.',
      '/leistungen/website-relaunch': 'Bestehende Website geordnet erneuern.',
      '/leistungen/local-seo': 'Lokale Sichtbarkeit sauber vorbereiten.',
      '/leistungen/landingpage-erstellen-lassen': 'Gezielte Seite für Kampagnen und Anfragen.',
      '/leistungen/website-audit': 'Website prüfen und konkrete Schritte ableiten.',
      '/leistungen/responsives-design-mobile': 'Mobile Darstellung und Bedienung sauber planen.',
      '/leistungen/inhalte-texte-content': 'Texte und Inhalte verständlich strukturieren.',
      '/leistungen/rechtliches-sicherheit': 'Rechtstexte technisch einbinden und Risiken einordnen.',
      '/leistungen/website-wartung': 'Technische Betreuung nach dem Launch.',
      '/leistungen/zusatzleistungen-webdesign': 'Erweiterungen separat und klar kalkulieren.',
      '/leistungen/laufende-kosten-website': 'Domain, Hosting, Tools und Betrieb einordnen.',
      '/branchen': 'Branchen-Websites passend einordnen.'
    },
    en: {
      '/leistungen': 'Overview of all services.',
      '/leistungen/website-relaunch': 'Renew an existing website in a structured way.',
      '/leistungen/local-seo': 'Prepare clean local visibility signals.',
      '/leistungen/landingpage-erstellen-lassen': 'Focused pages for campaigns and enquiries.',
      '/leistungen/website-audit': 'Review your website and define next steps.',
      '/leistungen/responsives-design-mobile': 'Plan mobile layout and usability cleanly.',
      '/leistungen/inhalte-texte-content': 'Structure copy and content clearly.',
      '/leistungen/rechtliches-sicherheit': 'Integrate legal texts technically and frame risks.',
      '/leistungen/website-wartung': 'Technical support after launch.',
      '/leistungen/zusatzleistungen-webdesign': 'Plan add-ons clearly and separately.',
      '/leistungen/laufende-kosten-website': 'Understand domain, hosting, tools and operation.',
      '/branchen': 'Structure industry websites clearly.'
    }
  }; %>
  <% const navIcon = (item = {}) => navIconMap[normalizeIconPath(navHref(item))] || '/images/nav-icons/services.svg'; %>
  <% const navDescription = (item = {}) => {
    const key = normalizeIconPath(navHref(item));
    return (isEn ? navDescriptionMap.en[key] : navDescriptionMap.de[key]) || '';
  }; %>
  <% const isActiveNavItem = (item = {}) => {
    const hrefPath = normalizeNavPath(navHref(item));
    const children = Array.isArray(item.children) ? item.children : [];
    const isSameOrChildPath = (candidatePath, targetPath) => {
      if (!targetPath || targetPath === '/') {
        return candidatePath === targetPath;
      }
      return candidatePath === targetPath || candidatePath.startsWith(`${targetPath}/`);
    };
    return isSameOrChildPath(normalizedCurrentPath, hrefPath)
      || children.some(child => isSameOrChildPath(normalizedCurrentPath, normalizeNavPath(navHref(child))));
  }; %>
  <% const isActiveSubNavItem = (item = {}) => normalizedCurrentPath === normalizeNavPath(navHref(item)); %>
  <div class="topWhiteGradient">
    <div class="topWhiteGradients"></div>

    <div class="hero-nav">
      <div class="navigation" id="navigation" aria-label="Komplett Webdesign">
        <a href="<%= homeHref %>" class="logo" aria-label="<%= isEn ? 'To homepage' : 'Zur Startseite' %>">
          <img src="/images/LogoTransparent.webp" alt="<%= isEn ? 'Icon to go to homepage' : 'Icon um zur Startseite zu kommen' %>" role="presentation" />
        </a>
        <div class="nav-right">
          <button
            type="button"
            class="menu-icon"
            id="menu-icon"
            aria-controls="nav-links"
            aria-expanded="false"
            data-label-open="<%= isEn ? 'Open main navigation' : 'Hauptnavigation öffnen' %>"
            data-label-close="<%= isEn ? 'Close main navigation' : 'Hauptnavigation schließen' %>"
            aria-label="<%= isEn ? 'Open main navigation' : 'Hauptnavigation öffnen' %>"
          >
            <img src="/images/Nav-Bar-Icon.svg" alt="" aria-hidden="true" />
          </button>
          <button type="button" class="mobile-nav-backdrop" id="mobile-nav-backdrop" hidden aria-label="<%= isEn ? 'Close navigation' : 'Navigation schließen' %>"></button>
          <div class="links heroLinks mobile-nav-panel" id="nav-links" aria-label="<%= isEn ? 'Main navigation' : 'Hauptnavigation' %>">
            <div class="mobile-nav-panel__header">
              <button type="button" class="mobile-nav-close" id="mobile-nav-close" aria-label="<%= isEn ? 'Close navigation' : 'Navigation schließen' %>">×</button>
              <a href="<%= homeHref %>" class="mobile-nav-brand" aria-label="<%= isEn ? 'To homepage' : 'Zur Startseite' %>">
                <img src="/images/LogoTransparent.webp" alt="Komplett Webdesign" />
              </a>
            </div>
            <% navItems.forEach((item) => { %>
              <% const itemChildren = Array.isArray(item.children) ? item.children : []; %>
              <% const itemHref = navHref(item); %>
              <% if (itemChildren.length) { %>
                <nav class="main-nav" aria-label="<%= navLabel(item) %>">
                  <ul>
                    <li class="dropdown <%= isActiveNavItem(item) ? 'is-active' : '' %>">
                      <div class="dropdown-toggle">
                        <a href="<%= itemHref %>" class="nav-link-item <%= isActiveNavItem(item) ? 'is-active' : '' %>">
                          <span class="mobile-nav-icon"><img src="<%= navIcon(item) %>" alt="" aria-hidden="true" loading="lazy" /></span>
                          <span class="mobile-nav-label"><%= navLabel(item) %></span>
                        </a>
                        <button class="dropdown-toggle-btn" type="button" aria-expanded="false" aria-label="<%= isEn ? `Open ${navLabel(item)} submenu` : `${navLabel(item)} Untermenü öffnen` %>">
                          ▾
                        </button>
                      </div>
                      <ul class="dropdown-menu">
                        <% itemChildren.forEach((child) => { %>
                          <li>
                            <a href="<%= navHref(child) %>" class="main-color nav-sub-link <%= isActiveSubNavItem(child) ? 'is-active' : '' %>">
                              <span class="mobile-nav-icon"><img src="<%= navIcon(child) %>" alt="" aria-hidden="true" loading="lazy" /></span>
                              <span class="mobile-nav-copy">
                                <span class="mobile-nav-label"><%= navLabel(child) %></span>
                                <% if (navDescription(child)) { %>
                                  <span class="mobile-nav-description"><%= navDescription(child) %></span>
                                <% } %>
                              </span>
                            </a>
                          </li>
                        <% }) %>
                      </ul>
                    </li>
                  </ul>
                </nav>
              <% } else { %>
                <a href="<%= itemHref %>" class="nav-link-item <%= isActiveNavItem(item) ? 'is-active' : '' %>">
                  <span class="mobile-nav-icon"><img src="<%= navIcon(item) %>" alt="" aria-hidden="true" loading="lazy" /></span>
                  <span class="mobile-nav-label"><%= navLabel(item) %></span>
                </a>
              <% } %>
            <% }) %>
            <div class="mobile-nav-actions">
              <a href="<%= navHref(navCta) %>" class="btn btn-primary" data-track="cta" data-cta-name="header_project_request" data-cta-location="global_header">
                <span class="mobile-nav-icon"><img src="<%= navIcon(navCta) %>" alt="" aria-hidden="true" loading="lazy" /></span>
                <span><%= navLabel(navCta) %></span>
              </a>
              <a href="<%= isEn ? switchToDeHref : switchToEnHref %>" class="btn btn-secondary"><%= isEn ? 'DE' : 'EN' %></a>
              <span class="mobile-nav-note"><%= isEn ? 'Personal and clearly scoped' : 'Unverbindlich und persönlich' %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
