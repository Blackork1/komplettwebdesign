<!DOCTYPE html>
<html lang="de">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= typeof title !=='undefined' ? title + ' – Admin' : 'Admin – Komplett Webdesign' %>
  </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="<%= cssAsset('admin.css') %>">
</head>

<body>
  <%
    const adminCurrentPath = typeof currentPathname !== 'undefined' && currentPathname
      ? currentPathname
      : '';
    const isActivePath = (href) => {
      if (!adminCurrentPath) return false;
      if (href === '/admin') return adminCurrentPath === '/admin';
      return adminCurrentPath === href || adminCurrentPath.startsWith(href + '/');
    };
  %>
  <header class="admin-topbar">
    <div class="admin-topbar__inner">
      <a href="/admin" class="admin-brand" aria-label="Admin-Startseite">
        <span class="admin-brand__badge">K</span>
        <span class="admin-brand__label">
          Komplett Webdesign
          <small>Admin Backend</small>
        </span>
      </a>

      <button type="button" class="admin-burger" aria-label="Menü öffnen" id="adminBurger">
        <i class="fa-solid fa-bars"></i>
      </button>

      <nav class="admin-nav" id="adminNav" aria-label="Admin Navigation">
        <a href="/admin" class="<%= isActivePath('/admin') ? 'is-active' : '' %>">
          <span class="ico"><i class="fa-solid fa-gauge-high"></i></span> Start
        </a>

        <div class="admin-dropdown">
          <a href="#" class="admin-dropdown__toggle" data-admin-dropdown>
            <span class="ico"><i class="fa-solid fa-calendar-days"></i></span> Termine
          </a>
          <div class="admin-dropdown__menu">
            <a href="/admin/appointments"><i class="fa-solid fa-calendar"></i> Termin-Kalender</a>
            <a href="/admin/bookings"><i class="fa-solid fa-check-double"></i> Buchungen</a>
            <a href="/admin/auto-config"><i class="fa-solid fa-wand-magic-sparkles"></i> Termin-Automatik</a>
          </div>
        </div>

        <div class="admin-dropdown">
          <a href="#" class="admin-dropdown__toggle" data-admin-dropdown>
            <span class="ico"><i class="fa-solid fa-file-lines"></i></span> Inhalte
          </a>
          <div class="admin-dropdown__menu">
            <a href="/admin/blog"><i class="fa-solid fa-newspaper"></i> Blog</a>
            <a href="/admin/ratgeber"><i class="fa-solid fa-book-open"></i> Ratgeber</a>
            <a href="/admin/pages"><i class="fa-solid fa-file-pen"></i> Seitenerstellung</a>
            <a href="/admin/gallery"><i class="fa-solid fa-images"></i> Galerie</a>
          </div>
        </div>

        <div class="admin-dropdown">
          <a href="#" class="admin-dropdown__toggle" data-admin-dropdown>
            <span class="ico"><i class="fa-solid fa-industry"></i></span> Branchen
          </a>
          <div class="admin-dropdown__menu">
            <a href="/admin/industries"><i class="fa-solid fa-list"></i> Übersicht</a>
            <a href="/admin/industries/import"><i class="fa-solid fa-file-import"></i> Import</a>
          </div>
        </div>

        <a href="/admin/website-tester" class="<%= isActivePath('/admin/website-tester') ? 'is-active' : '' %>">
          <span class="ico"><i class="fa-solid fa-magnifying-glass-chart"></i></span> Website-Tester
        </a>

        <a href="/admin/mailversand" class="<%= isActivePath('/admin/mailversand') ? 'is-active' : '' %>">
          <span class="ico"><i class="fa-solid fa-paper-plane"></i></span> Mailversand
        </a>

        <a href="/admin/newsletter" class="<%= isActivePath('/admin/newsletter') ? 'is-active' : '' %>">
          <span class="ico"><i class="fa-solid fa-envelope-circle-check"></i></span> Newsletter
        </a>

        <a href="/admin/logs" class="<%= isActivePath('/admin/logs') ? 'is-active' : '' %>">
          <span class="ico"><i class="fa-solid fa-clipboard-list"></i></span> Logs
        </a>

        <a href="/logout" class="admin-nav__logout">
          <span class="ico"><i class="fa-solid fa-right-from-bracket"></i></span> Logout
        </a>
      </nav>
    </div>
  </header>

  <script>
    (function () {
      var burger = document.getElementById('adminBurger');
      var nav = document.getElementById('adminNav');
      if (burger && nav) {
        burger.addEventListener('click', function () {
          nav.classList.toggle('is-open');
        });
      }
      document.querySelectorAll('[data-admin-dropdown]').forEach(function (toggle) {
        toggle.addEventListener('click', function (e) {
          e.preventDefault();
          var parent = toggle.closest('.admin-dropdown');
          if (!parent) return;
          var wasOpen = parent.classList.contains('is-open');
          document.querySelectorAll('.admin-dropdown.is-open').forEach(function (el) {
            el.classList.remove('is-open');
          });
          if (!wasOpen) parent.classList.add('is-open');
        });
      });
      document.addEventListener('click', function (e) {
        if (!e.target.closest('.admin-dropdown')) {
          document.querySelectorAll('.admin-dropdown.is-open').forEach(function (el) {
            el.classList.remove('is-open');
          });
        }
      });
    })();
  </script>

  <main class="admin-shell">
