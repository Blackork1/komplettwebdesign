<!-- views/partials/newsletter_form.ejs -->


<form action="/newsletter/signup" method="POST" class="newsletter-form" data-recaptcha="v3" data-recaptcha-action="newsletter_signup">
  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <input type="hidden" name="token">
  <input type="hidden" name="newsletter_started_at" value="<%= Date.now() %>">
  <div class="newsletter-form__trap form-honeypot" aria-hidden="true">
    <label for="newsletterCompanyWebsite">Website</label>
    <input type="text" name="company_website" id="newsletterCompanyWebsite" tabindex="-1" autocomplete="off">
  </div>
  <div class="mb-3">
    <label for="newsletterEmail" class="form-label">E-Mail-Adresse</label>
    <input type="email" name="email" id="newsletterEmail" class="form-control" placeholder="Deine E-Mail" autocomplete="email" aria-describedby="newsletterEmailHelp" required>
    <small id="newsletterEmailHelp" class="form-help">Bitte gib eine gültige E-Mail-Adresse ein. Du erhältst danach eine Bestätigung per E-Mail.</small>
  </div>
  <button type="submit" class="btn btn-primary w-100">Anmelden</button>
  <p class="form-status" data-form-status role="alert" aria-live="polite" hidden></p>
</form>
