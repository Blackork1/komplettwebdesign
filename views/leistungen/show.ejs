<%
  // Basis-Variablen für Schema.org
  const baseUrl = (typeof canonicalBaseUrl !== 'undefined'
    ? canonicalBaseUrl
    : 'https://komplettwebdesign.de'
  ).replace(/\/$/, '');

  const pageSlug = page.slug || '';
  const isPricePage = pageSlug === 'kosten-preise-pakete';
  const canonicalPath = page.canonicalPath || (isPricePage ? `/webdesign-berlin/${pageSlug}` : `/leistungen/${pageSlug}`);
  const pageUrl = `${baseUrl}${canonicalPath}`;
  const parentBreadcrumb = isPricePage
    ? { label: 'Webdesign Berlin', href: '/webdesign-berlin' }
    : { label: 'Leistungen', href: '/leistungen' };
  const pageName = (page.hero && page.hero.title) || page.title || title || 'Leistung';
  const pageDesc = description || page.meta_description || (page.hero && page.hero.subtitle) || '';
  const updatedDate = page.updatedAt ? new Date(page.updatedAt) : null;
  const updatedIso = updatedDate && !Number.isNaN(updatedDate.getTime()) ? updatedDate.toISOString() : null;
  const orgName = typeof schemaOrgName !== 'undefined' ? schemaOrgName : 'Komplett Webdesign';
  const orgLogo = typeof schemaOrgLogo !== 'undefined' ? schemaOrgLogo : `${baseUrl}/images/LogoWhite.svg`;
  const orgSameAs = (typeof schemaOrgSameAs !== 'undefined' && Array.isArray(schemaOrgSameAs))
    ? schemaOrgSameAs
    : [];
  const escapeFallback = (value) => String(value || '').replace(/[&<>"']/g, function(ch) {
    return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[ch];
  });
  const safeHtml = typeof sanitizeHtml === 'function' ? sanitizeHtml : escapeFallback;

  // Organization
  const orgSchema = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": baseUrl + "#organization",
    "name": orgName,
    "url": baseUrl,
    "logo": {
      "@type": "ImageObject",
      "url": orgLogo
    }
  };
  if (orgSameAs.length) {
    orgSchema.sameAs = orgSameAs;
  }

  // WebSite
  const websiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": baseUrl + "#website",
    "url": baseUrl,
    "name": orgName,
    "publisher": {
      "@id": baseUrl + "#organization"
    }
  };

  // BreadcrumbList
  const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": pageUrl + "#breadcrumb",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Startseite",
        "item": baseUrl + "/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": parentBreadcrumb.label,
        "item": baseUrl + parentBreadcrumb.href
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": pageName,
        "item": pageUrl
      }
    ]
  };

  // Service-Schema ohne Angebotskatalog, weil die sichtbaren Leistungen projektabhängig kalkuliert werden.
  const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": pageUrl + "#service",
    "serviceType": pageName,
    "name": pageName,
    "url": pageUrl,
    "description": pageDesc,
    "provider": {
      "@id": baseUrl + "#organization"
    }
  };

  // WebPage (verweist auf Service & Breadcrumb)
  const webPageSchema = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": pageUrl + "#webpage",
    "url": pageUrl,
    "name": pageName,
    "description": pageDesc,
    "isPartOf": {
      "@id": baseUrl + "#website"
    },
    "about": {
      "@id": pageUrl + "#service"
    },
    "breadcrumb": {
      "@id": pageUrl + "#breadcrumb"
    }
  };

  if (ogImage) {
    webPageSchema.primaryImageOfPage = {
      "@type": "ImageObject",
      "url": ogImage
    };
  }
  if (updatedIso) {
    webPageSchema.dateModified = updatedIso;
    webPageSchema.datePublished = updatedIso;
  }

  const faqSchema = (page.faqItems && page.faqItems.length)
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "@id": pageUrl + "#faq",
        "mainEntity": page.faqItems.map(function(item) {
          return {
            "@type": "Question",
            "name": item.q,
            "acceptedAnswer": {
              "@type": "Answer",
              "text": item.a
            }
          };
        })
      }
    : null;

  const structuredDataBlocks = [
    orgSchema,
    websiteSchema,
    breadcrumbSchema,
    serviceSchema,
    webPageSchema,
    faqSchema
  ].filter(Boolean);
%>
<%- include('../partials/head', { title, description, ogImage, structuredDataBlocks, extraCssAssets: ['leistungen.css'] }) %>
<%- include('../partials/header') %>

<%
  const serviceHeroKickers = {
    'design-ux-ui': { icon: 'fa-arrows-rotate', label: 'Website-Relaunch' },
    'seo-sichtbarkeit-einsteiger': { icon: 'fa-magnifying-glass-location', label: 'Lokale Sichtbarkeit' },
    'responsives-design-mobile': { icon: 'fa-mobile-screen-button', label: 'Mobile Nutzerführung' },
    'domain-hosting-technik': { icon: 'fa-server', label: 'Technische Grundlage' },
    'inhalte-texte-content': { icon: 'fa-file-lines', label: 'Website-Inhalte' },
    'rechtliches-sicherheit': { icon: 'fa-shield-halved', label: 'Technik & Vertrauen' },
    'kosten-preise-pakete': { icon: 'fa-euro-sign', label: 'Kostenklarheit' }
  };
  const serviceHeroPanels = {
    'design-ux-ui': {
      title: 'Was du realistisch bekommst',
      text: 'Ein Relaunch wird als strukturierte Erneuerung geplant. Ich prüfe, welche Inhalte, Nutzerwege und technischen Schritte für deinen Umfang sinnvoll sind.',
      items: [
        { icon: 'fa-sitemap', text: 'Bestehende Struktur, Inhalte und Ziele sauber einordnen.' },
        { icon: 'fa-arrow-right-arrow-left', text: 'Weiterleitungen und wichtige URLs bewusst planen.' },
        { icon: 'fa-list-check', text: 'Design, Technik und SEO-Risiken vor dem Launch prüfen.' }
      ]
    },
    'seo-sichtbarkeit-einsteiger': {
      title: 'Was du realistisch bekommst',
      text: 'Local SEO wird als Grundlage und Zusatzleistung geplant. Ich prüfe, welche lokalen Seiten, Profilangaben und technischen Signale für deinen Umfang sinnvoll sind.',
      items: [
        { icon: 'fa-location-dot', text: 'Lokale Suchintention und Einzugsgebiet klären.' },
        { icon: 'fa-building-circle-check', text: 'Website, Profil und Kontaktwege zusammen denken.' },
        { icon: 'fa-receipt', text: 'Preisrahmen vor der Umsetzung sauber abgrenzen.' }
      ]
    },
    'responsives-design-mobile': {
      title: 'Was du realistisch bekommst',
      text: 'Mobile Optimierung wird als Nutzerführung geplant. Ich prüfe, welche Inhalte, CTAs und technischen Grenzen auf Smartphone und Desktop funktionieren müssen.',
      items: [
        { icon: 'fa-mobile-screen-button', text: 'Lesbarkeit, Abstände und Bedienung mobil prüfen.' },
        { icon: 'fa-bolt', text: 'Ladezeit und technische Basis realistisch einordnen.' },
        { icon: 'fa-phone-volume', text: 'Kontaktwege auf mobilen Geräten klar erreichbar machen.' }
      ]
    },
    'domain-hosting-technik': {
      title: 'Was du realistisch bekommst',
      text: 'Domain, Hosting und Technik werden als Betriebsgrundlage geplant. Ich ordne Setup, Zuständigkeiten und laufende Kosten vor der Umsetzung nachvollziehbar ein.',
      items: [
        { icon: 'fa-server', text: 'Hosting, Domain und E-Mail sauber trennen.' },
        { icon: 'fa-shield-halved', text: 'Backups, SSL und Monitoring passend zum Setup prüfen.' },
        { icon: 'fa-screwdriver-wrench', text: 'Wartung und Support als laufenden Rahmen abgrenzen.' }
      ]
    },
    'inhalte-texte-content': {
      title: 'Was du realistisch bekommst',
      text: 'Website-Texte werden als Teil der Nutzerführung geplant. Ich kläre, welche Aussagen, Leistungsseiten und Kontaktimpulse für dein Angebot nötig sind.',
      items: [
        { icon: 'fa-comments', text: 'Angebot, Zielgruppe und Einwände sprachlich klären.' },
        { icon: 'fa-layer-group', text: 'Startseite, Leistungen und Kontaktwege zusammen denken.' },
        { icon: 'fa-magnifying-glass', text: 'Suchintention und Lesbarkeit ohne Keyword-Überladung verbinden.' }
      ]
    },
    'rechtliches-sicherheit': {
      title: 'Was du realistisch bekommst',
      text: 'Rechtliches und Sicherheit werden technisch sauber vorbereitet. Ich ordne vorhandene Texte, Einbindungen und Sicherheitsgrundlagen ohne Rechtsberatung ein.',
      items: [
        { icon: 'fa-scale-balanced', text: 'Impressum, Datenschutz und Cookie-Logik technisch berücksichtigen.' },
        { icon: 'fa-lock', text: 'SSL, Backups und Basis-Sicherheit sauber einplanen.' },
        { icon: 'fa-triangle-exclamation', text: 'Grenzen und externe Rechtsprüfung transparent benennen.' }
      ]
    },
    'kosten-preise-pakete': {
      title: 'Was du realistisch einordnen kannst',
      text: 'Website-Preise werden als Rahmen geplant. Ich trenne Projektkosten, laufende Kosten und Zusatzleistungen, bevor ein Angebot entsteht.',
      items: [
        { icon: 'fa-layer-group', text: 'Paketumfang und Seitenstruktur klären.' },
        { icon: 'fa-server', text: 'Betriebskosten separat betrachten.' },
        { icon: 'fa-receipt', text: 'Zusatzleistungen vorab abgrenzen.' }
      ]
    }
  };
  const fallbackPanelItems = [];
  if (page.proofBlock && page.proofBlock.title) fallbackPanelItems.push({ icon: 'fa-list-check', text: page.proofBlock.title });
  if (page.trustBlock && page.trustBlock.title) fallbackPanelItems.push({ icon: 'fa-shield-halved', text: page.trustBlock.title });
  if (!fallbackPanelItems.length) {
    fallbackPanelItems.push(
      { icon: 'fa-layer-group', text: 'Projektumfang sauber klären.' },
      { icon: 'fa-receipt', text: 'Kosten, Betrieb und Zusatzleistungen getrennt einordnen.' },
      { icon: 'fa-comments', text: 'Klare Anfragewege und nächste Schritte sichtbar machen.' }
    );
  }
  const serviceHeroKicker = serviceHeroKickers[pageSlug] || { icon: 'fa-layer-group', label: 'Leistung' };
  const serviceHeroPanel = serviceHeroPanels[pageSlug] || {
    title: 'Was du realistisch bekommst',
    text: page.answerBlock || 'Die Leistung wird mit klarem Umfang geplant. Ich ordne Ziele, Inhalte und technische Anforderungen vor der Umsetzung nachvollziehbar ein.',
    items: fallbackPanelItems.slice(0, 3)
  };
  const heroImage = page.heroImage || null;
%>
<main class="service-page service-page--leistungen leistungen-page">
  <section class="service-hero hero leistungen-service-hero unified-hero"<% if (heroImage?.src) { %> style="--service-hero-image: url('<%= heroImage.src %>');"<% } %>>
    <div class="service-shell leistungen-hero-shell">
      <div class="service-hero__grid leistungen-hero-grid unified-hero__grid">
        <div class="hero-content unified-hero__copy">
          <nav class="service-hero-breadcrumbs unified-hero__breadcrumbs" aria-label="Breadcrumb">
            <ol>
              <li><a href="/">Startseite</a></li>
              <li><a href="<%= parentBreadcrumb.href %>"><%= parentBreadcrumb.label %></a></li>
              <li aria-current="page"><%- safeHtml(page.title) %></li>
            </ol>
          </nav>
          <p class="service-kicker leistungen-service-kicker service-hero-kicker home-hero-reveal home-hero-reveal--support animate-on-scroll"><i class="fa-solid <%= serviceHeroKicker.icon %>" aria-hidden="true"></i><%= serviceHeroKicker.label %></p>
          <h1 class="home-hero-reveal home-hero-reveal--h1 animate-on-scroll"><%= page.hero.title %></h1>

          <% if (page.hero.subtitle) { %>
          <p class="hero-subtitle unified-hero__lead home-hero-reveal home-hero-reveal--support animate-on-scroll"><%= page.hero.subtitle %></p>
          <% } %>
          <% if (page.ctaVariants && page.ctaVariants.length) { %>
          <div class="service-hero__actions hero-cta-variants unified-hero__actions" aria-label="Anfrageoptionen">
            <% page.ctaVariants.forEach(function(item, index) { %>
            <a href="<%= item.href %>" class="btn <%= index === 0 ? 'btn-primary' : 'btn-secondary' %> home-hero-reveal home-hero-reveal--actions animate-on-scroll"><%= item.label %></a>
            <% }) %>
          </div>
          <% } %>
        </div>
        <aside class="service-hero__panel leistungen-hero-panel unified-hero__panel" aria-label="Kurzüberblick">
          <div class="leistungen-hero-panel__reveal home-hero-reveal home-hero-reveal--visual animate-on-scroll">
            <h2><%= serviceHeroPanel.title %></h2>
            <p><%= serviceHeroPanel.text %></p>
            <div class="leistungen-hero-mini-list">
              <% serviceHeroPanel.items.forEach(function(item) { %>
              <div><i class="fa-solid <%= item.icon %>" aria-hidden="true"></i><span><%= item.text %></span></div>
              <% }) %>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <div class="container leistungen-content">
    <% if (page.answerBlock) { %>
    <section class="leistungen-answer-summary" aria-label="Kurzantwort">
      <p><%= page.answerBlock %></p>
    </section>
    <% } %>

    <% if (page.proofBlock || page.trustBlock) { %>
    <section class="proof-trust-grid">
      <% if (page.proofBlock) { %>
      <article class="proof-card">
        <h2><%= page.proofBlock.title %></h2>
        <p><%= page.proofBlock.text %></p>
      </article>
      <% } %>
      <% if (page.trustBlock) { %>
      <article class="trust-card">
        <h2><%= page.trustBlock.title %></h2>
        <p><%= page.trustBlock.text %></p>
      </article>
      <% } %>
    </section>
    <% } %>

    <% if (page.costPageContent) { %>
    <% const cost = page.costPageContent; %>
    <% if (cost.pricePrinciples && cost.pricePrinciples.length) { %>
    <section class="cost-page-section" aria-labelledby="cost-principles-title">
      <h2 id="cost-principles-title">So entstehen realistische Website-Kosten</h2>
      <p>Die Preise sind bewusst als nachvollziehbare Rahmen formuliert. Entscheidend ist, welcher Umfang wirklich gebraucht wird und welche laufenden Kosten nach dem Livegang entstehen.</p>
      <div class="cost-principle-grid">
        <% cost.pricePrinciples.forEach(function(principle) { %>
        <article class="cost-card">
          <h3><%= principle.title %></h3>
          <p><%= principle.text %></p>
        </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (cost.packages && cost.packages.length) { %>
    <section class="cost-page-section" aria-labelledby="cost-packages-title">
      <h2 id="cost-packages-title">Aktuelle Paketpreise</h2>
      <p>Die Paketgrenzen helfen dir, dein Projekt grob einzuordnen. Sonderfunktionen, größere Inhalte und laufender Betrieb werden vorab separat abgegrenzt.</p>
      <div class="cost-package-slider package-slider-scroll" data-package-slider tabindex="0" aria-label="Aktuelle Paketpreise horizontal scrollen">
        <% cost.packages.forEach(function(pkg) { %>
        <% const packageName = String(pkg.name || '').trim(); %>
        <% const isIndividualPackage = pkg.id === 'individuell' || packageName === 'Individuelles Projekt' || packageName === 'Individuell'; %>
        <% const packageButtonLabel = isIndividualPackage ? 'Individuelles Projekt-Paket ansehen' : (/paket$/i.test(packageName) ? packageName + ' ansehen' : packageName + '-Paket ansehen'); %>
        <article class="cost-card cost-package-card <%= pkg.recommended ? 'cost-card--recommended' : '' %>">
          <div class="cost-package-card__head">
            <% if (pkg.recommended && pkg.recommendationLabel) { %>
            <span class="cost-card__badge"><%= pkg.recommendationLabel %></span>
            <% } else { %>
            <span class="cost-card__badge cost-card__badge--placeholder" aria-hidden="true">Paket</span>
            <% } %>
            <h3><%= pkg.name %></h3>
          </div>
          <span class="cost-price"><%= pkg.priceLabel %></span>
          <span class="cost-meta"><%= pkg.scope %></span>
          <p><%= pkg.description %></p>
          <% if (pkg.included && pkg.included.length) { %>
          <ul aria-label="Enthaltene Leistungen">
            <% pkg.included.slice(0, 4).forEach(function(item) { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
          <% } %>
          <a class="btn btn-primary" href="<%= pkg.href %>"><%= packageButtonLabel %></a>
        </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <section class="cost-page-section" aria-labelledby="cost-scope-title">
      <h2 id="cost-scope-title">Was enthalten ist und was separat geplant wird</h2>
      <div class="cost-two-column">
        <% if (cost.included && cost.included.length) { %>
        <article>
          <h3>Im vereinbarten Paketrahmen</h3>
          <ul class="cost-bullet-list">
            <% cost.included.forEach(function(item) { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </article>
        <% } %>
        <% if (cost.notIncluded && cost.notIncluded.length) { %>
        <article>
          <h3>Nicht automatisch enthalten</h3>
          <ul class="cost-bullet-list">
            <% cost.notIncluded.forEach(function(item) { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </article>
        <% } %>
      </div>
    </section>

    <% if (cost.priceFactors && cost.priceFactors.length) { %>
    <section class="cost-page-section" aria-labelledby="cost-factors-title">
      <h2 id="cost-factors-title">Diese Faktoren verändern den Preis</h2>
      <ul class="cost-bullet-list">
        <% cost.priceFactors.forEach(function(item) { %>
        <li><%= item %></li>
        <% }) %>
      </ul>
    </section>
    <% } %>

    <% if (cost.costSplit && cost.costSplit.length) { %>
    <section class="cost-page-section" aria-labelledby="cost-split-title">
      <h2 id="cost-split-title">Einmalige Erstellung und laufende Kosten</h2>
      <div class="cost-split-grid">
        <% cost.costSplit.forEach(function(group) { %>
        <article class="cost-card">
          <h3><%= group.title %></h3>
          <p><%= group.text %></p>
          <% if (group.items && group.items.length) { %>
          <ul>
            <% group.items.forEach(function(item) { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
          <% } %>
        </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (cost.maintenancePlans && cost.maintenancePlans.length) { %>
    <section class="cost-page-section" aria-labelledby="cost-maintenance-title">
      <h2 id="cost-maintenance-title">Wartung, Hosting, Domain und E-Mail</h2>
      <p>Wartung und Betrieb sind laufende Themen und werden passend zum Setup vereinbart. Domain, E-Mail und Hosting können über externe Anbieter oder ein separat abgestimmtes Setup laufen.</p>
      <div class="cost-maintenance-grid">
        <% cost.maintenancePlans.forEach(function(plan) { %>
        <article class="cost-card">
          <h3><%= plan.name %></h3>
          <span class="cost-price"><%= plan.priceLabel %></span>
          <p><%= plan.shortDescription %></p>
          <ul>
            <li>Reaktion: <%= plan.responseTime %></li>
            <li>Inhalte: <%= plan.contentChangeAllowance %></li>
          </ul>
        </article>
        <% }) %>
      </div>
      <% if (cost.thirdPartyCosts && cost.thirdPartyCosts.length) { %>
      <div class="cost-note-box">
        <% cost.thirdPartyCosts.forEach(function(item) { %>
        <p><%= item %></p>
        <% }) %>
      </div>
      <% } %>
    </section>
    <% } %>

    <% if (cost.addOns && cost.addOns.length) { %>
    <section class="cost-page-section" aria-labelledby="cost-addons-title">
      <h2 id="cost-addons-title">Typische Zusatzleistungen</h2>
      <p>Diese Leistungen sind nicht automatisch Teil jedes Standardpakets. Sie werden nur eingeplant, wenn sie für dein Projekt sinnvoll sind.</p>
      <div class="cost-addons-grid">
        <% cost.addOns.forEach(function(addOn) { %>
        <article class="cost-card">
          <span class="cost-card__badge"><%= addOn.category %></span>
          <h3><%= addOn.name %></h3>
          <span class="cost-price"><%= addOn.priceLabel %></span>
          <p><%= addOn.shortDescription %></p>
          <p><%= addOn.whenUseful %></p>
        </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <section class="cost-page-section" aria-labelledby="cost-payment-title">
      <h2 id="cost-payment-title">Zahlung, Freigabe und rechtliche Abgrenzung</h2>
      <div class="cost-two-column">
        <% if (cost.paymentAndLaunch && cost.paymentAndLaunch.length) { %>
        <article>
          <h3>Projektablauf</h3>
          <ul class="cost-bullet-list">
            <% cost.paymentAndLaunch.forEach(function(item) { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </article>
        <% } %>
        <% if (cost.legalNotes && cost.legalNotes.length) { %>
        <article>
          <h3>Wichtige Hinweise</h3>
          <ul class="cost-bullet-list">
            <% cost.legalNotes.forEach(function(item) { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </article>
        <% } %>
      </div>
    </section>
    <% } %>

    <% if (page.exampleCalculations && page.exampleCalculations.length) { %>
    <section class="leistungen-examples" aria-labelledby="leistungen-examples-title">
      <h2 id="leistungen-examples-title">Beispielrechnungen für typische Website-Projekte</h2>
      <p>Diese Beispiele zeigen, wie sich einmalige Erstellungskosten und laufende Kosten 2026 realistisch einordnen lassen.</p>
      <div class="leistungen-example-grid">
        <% page.exampleCalculations.forEach(function(example) { %>
        <article class="leistungen-example">
          <h3><%= example.title %></h3>
          <dl>
            <div>
              <dt>Setup</dt>
              <dd><%= example.setup %></dd>
            </div>
            <div>
              <dt>Einmalig</dt>
              <dd><%= example.oneTime %></dd>
            </div>
            <div>
              <dt>Laufend</dt>
              <dd><%= example.recurring %></dd>
            </div>
          </dl>
          <% if (example.note) { %>
          <p><%= example.note %></p>
          <% } %>
        </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- Problem & Solution Cards -->
    <% if ( (page.intro.problem && (page.intro.problem.title ||
    page.intro.problem.text)) || (page.intro.solution &&
    (page.intro.solution.title || page.intro.solution.text)) ) { %>
    <section class="problem-solution">
      <% if (page.intro.problem && (page.intro.problem.title ||
      page.intro.problem.text)) { %>
      <div class="card problem-card">
        <div class="card-header">
          <div class="card-icon">
            <i class="fas fa-exclamation-triangle"></i>
          </div>
          <h2><%= page.intro.problem.title || 'Das Problem' %></h2>
        </div>
        <% if (page.intro.problem.text) { %>
        <p><%= page.intro.problem.text %></p>
        <% } %>
      </div>
      <% } %> <% if (page.intro.solution && (page.intro.solution.title ||
      page.intro.solution.text)) { %>
      <div class="card solution-card">
        <div class="card-header">
          <div class="card-icon">
            <i class="fas fa-check-circle"></i>
          </div>
          <h2><%= page.intro.solution.title || 'Unsere Lösung' %></h2>
        </div>
        <% if (page.intro.solution.text) { %>
        <p><%= page.intro.solution.text %></p>
        <% } %>
      </div>
      <% } %>
    </section>
    <% } %>

    <!-- Description / Einleitungstexte -->
    <% if (page.description && page.description.length) { %>
    <section class="services-intro">
      <h2>Unsere Leistungen im Detail</h2>
      <% page.description.forEach(function(paragraph) { %>
      <p><%= paragraph %></p>
      <% }) %>
    </section>
    <% } %>

    <!-- Services Grid (Akkordeon) -->
    <% if (page.services && page.services.length) { %>
    <section class="services-grid">
      <% page.services.forEach(function(service) { %>
      <div class="service-item">
        <div class="service-header">
          <% if (service.icon) { %>
          <i class="fas <%= service.icon %> service-icon"></i>
          <% } %>
          <span class="service-title"><%= service.title %></span>
          <i class="fas fa-chevron-down expand-indicator"></i>
        </div>
        <div class="service-content">
          <% if (service.intro) { %>
          <p><%= service.intro %></p>
          <% } %> <% if (service.content && service.content.length) { %> <%
          service.content.forEach(function(block) { %>
          <p><%= block %></p>
          <% }) %> <% } %> <% if (service.highlights &&
          service.highlights.length) { %>
          <ul>
            <% service.highlights.forEach(function(item) { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
          <% } %>
        </div>
      </div>
      <% }) %>
    </section>
    <% } %>

    <!-- Risk Assessment Section -->
    <% if ( (page.risks && (page.risks.title || page.risks.intro)) ||
    (page.risks.items && page.risks.items.length) || (page.risks.conclusion &&
    page.risks.conclusion.length) ) { %>
    <section class="risk-section">
      <% if (page.risks.title) { %>
      <h2>
        <i class="fas fa-exclamation-circle"></i>
        <%= page.risks.title %>
      </h2>
      <% } %>

      <div class="risk-content">
        <% if (page.risks.intro) { %>
        <p class="risk-intro">
          <%= page.risks.intro %>
        </p>
        <% } %> <% if (page.risks.items && page.risks.items.length) { %>
        <div class="risk-list">
          <% page.risks.items.forEach(function(risk) { %>
          <div class="risk-item">
            <% if (risk.icon) { %>
            <i class="fas <%= risk.icon %>"></i>
            <% } %> <% if (risk.title) { %>
            <strong><%= risk.title %></strong>
            <% } %> <% if (risk.description) { %>
            <span><%= risk.description %></span>
            <% } %>
          </div>
          <% }) %>
        </div>
        <% } %> <% if (page.risks.conclusion && page.risks.conclusion.length) {
        %> <% page.risks.conclusion.forEach(function(text) { %>
        <p class="risk-conclusion">
          <%= text %>
        </p>
        <% }) %> <% } %>
      </div>
    </section>
    <% } %>

    <% if (page.internalLinks && page.internalLinks.length) { %>
    <section class="context-links" aria-labelledby="context-links-title">
      <h2 id="context-links-title">Passende nächste Schritte</h2>
      <ul>
        <% page.internalLinks.forEach(function(linkItem) { %>
        <li><a href="<%= linkItem.href %>"><%= linkItem.label %></a></li>
        <% }) %>
      </ul>
    </section>
    <% } %>

    <% if (page.faqItems && page.faqItems.length) { %>
    <section class="service-faq" aria-labelledby="service-faq-title">
      <h2 id="service-faq-title">Häufige Fragen</h2>
      <% page.faqItems.forEach(function(item, index) { %>
      <details <%= index === 0 ? 'open' : '' %>>
        <summary><%= item.q %></summary>
        <p><%= item.a %></p>
      </details>
      <% }) %>
    </section>
    <% } %>

    <!-- CTA Section -->
    <% if (page.cta && (page.cta.title || page.cta.text)) { %>
    <section class="cta-section">
      <% if (page.cta.title) { %>
      <h2><%= page.cta.title %></h2>
      <% } %> <% if (page.cta.text) { %>
      <p><%= page.cta.text %></p>
      <% } %> <% if (page.cta.buttonLink && page.cta.buttonText) { %>
      <a href="<%= page.cta.buttonLink %>" class="btn btn-primary">
        <i class="fas fa-envelope"></i> <%= page.cta.buttonText %>
      </a>
      <% } %>
    </section>
    <% } %>
  </div>
</main>

<script>
  // Toggle service items (Akkordeon)
  document.querySelectorAll(".service-item").forEach((item) => {
    item.addEventListener("click", function(e) {
      if (e.target.tagName === "A" || e.target.closest("a")) return;

      const wasActive = this.classList.contains("active");

      document.querySelectorAll(".service-item").forEach((other) => {
        other.classList.remove("active");
      });

      if (!wasActive) {
        this.classList.add("active");
      }
    });
  });

  // Hover-Effekt für Hero-Icons
  document.querySelectorAll(".hero-icon-item").forEach((item) => {
    item.addEventListener("mouseenter", function() {
      this.classList.add("is-hovered");
    });

    item.addEventListener("mouseleave", function() {
      this.classList.remove("is-hovered");
    });
  });
</script>

<%- include('../partials/footer') %>
