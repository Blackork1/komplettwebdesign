<%- include("../partials/head") %>
<%- include('../partials/header') %>
<% const isEn = typeof lng !== 'undefined' && lng === 'en'; %>

<section class="section booking-page-hero">
  <div class="container">
    <h1 class="white"><%= isEn ? 'Book a free consultation' : 'Beratungstermin buchen' %></h1>
    <p class="booking-intro white">
      <%= isEn
        ? 'Pick a slot that works for you — we call you on time and the first call is free and non-binding.'
        : 'Such dir im Kalender einen passenden Slot aus – wir melden uns pünktlich zum vereinbarten Zeitpunkt. Das Erstgespräch ist unverbindlich und kostenlos.' %>
    </p>

    <% if (typeof booking_context !== 'undefined' && booking_context) { %>
      <div class="booking-context-banner">
        <strong><%= isEn ? 'Your context:' : 'Dein Kontext:' %></strong>
        <% if (booking_context.domain) { %><span><%= isEn ? 'Website' : 'Website' %>: <%= booking_context.domain %></span><% } %>
        <% if (booking_context.score) { %><span>Score: <%= booking_context.score %>/100</span><% } %>
        <% if (booking_context.src) { %><span><%= isEn ? 'Source' : 'Anlass' %>: <%= booking_context.src %></span><% } %>
      </div>
    <% } %>

    <%- include('../partials/booking_widget') %>
  </div>
</section>

<style>
  .booking-page-hero {
    padding: clamp(32px, 6vw, 64px) 0;
  }
  .booking-page-hero h1.white {
    color: var(--color-accent);
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  .booking-page-hero p.booking-intro.white {
    color: #d6e2ef;
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  .booking-page-hero .kwd-booking-copy-title {
    color: #e2ebf5;
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 0.75rem;
  }
  .booking-page-hero .kwd-booking-copy-text {
    color: #cfdceb;
    font-weight: 500;
    line-height: 1.6;
    text-align: center;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 0.85rem;
  }
  .booking-page-hero .kwd-booking-copy-text:last-of-type {
    margin-bottom: 1.25rem;
  }
  .booking-intro {
    max-width: 680px;
    margin-bottom: 24px;
  }
  .booking-context-banner {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    margin-bottom: 24px;
    font-size: 14px;
    color: #fff;
  }
  .booking-context-banner strong {
    color: #fff;
  }
  .booking-context-banner span {
    padding: 2px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
  }
</style>

<%- include('../partials/footer') %>
