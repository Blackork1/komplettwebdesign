<%- include('partials/head') %>
<% const isEn = typeof lng !== 'undefined' && lng === 'en'; %>
<body class="website-tester-page">
  <%- include('partials/header') %>

  <main id="hero">
    <link rel="stylesheet" href="<%= cssAsset('website-tester.css') %>">

    <section class="wt-section wt-section-compact">
      <div class="wt-shell">
        <nav class="breadcrumbs" aria-label="breadcrumb">
          <ol>
            <li><a href="<%= isEn ? '/en' : '/' %>"><%= isEn ? 'Home' : 'Startseite' %></a></li>
            <li><a href="<%= isEn ? '/en/website-tester' : '/website-tester' %>"><%= isEn ? 'Website Tester' : 'Website-Tester' %></a></li>
            <li aria-current="page">Meta Tester</li>
          </ol>
        </nav>
      </div>
    </section>

    <section class="wt-hero">
      <div class="wt-shell">
        <div class="wt-hero-grid">
          <div class="wt-hero-copy">
            <span class="wt-eyebrow">
              <i class="fa-solid fa-code"></i>
              Meta Tester
            </span>
            <h1><%= isEn ? 'Find header meta problems on your website in minutes.' : 'Finde Header-Meta-Probleme auf deiner Website in wenigen Minuten.' %></h1>
            <p class="wt-lead">
              <%= isEn
                ? 'Run a complete website header checker for title, meta description, H1, canonical, robots, Open Graph, Twitter cards, icons, and technical head tags.'
                : 'Starte einen vollständigen Header-Meta-Check für Title, Meta-Description, H1, Canonical, Robots, Open Graph, Twitter Cards, Icons und technische Head-Tags.' %>
            </p>
            <ul class="wt-pill-list">
              <li><i class="fa-solid fa-house"></i> <%= isEn ? 'Homepage titles and descriptions at a glance' : 'Title und Description der Startseite auf einen Blick' %></li>
              <li><i class="fa-solid fa-sitemap"></i> <%= isEn ? 'Shows whether your search snippet fits your offer' : 'Zeigt, ob dein Suchergebnis zu deinem Angebot passt' %></li>
              <li><i class="fa-solid fa-file-lines"></i> <%= isEn ? 'Clear fixes for stronger click-through rates' : 'Klare Verbesserungen für stärkere Klickraten' %></li>
            </ul>
          </div>

          <div class="wt-form-card">
            <h2><%= isEn ? 'Start meta check' : 'Meta-Check starten' %></h2>
            <p><%= isEn ? 'Add website URL and market context so we can check title/description relevance for your industry and region.' : 'Gib URL und Marktkontext an, damit wir Title/Description auf Branchen- und Regions-Fit prüfen können.' %></p>

            <form data-meta-tester-form>
              <div class="wt-context-grid">
                <div class="wt-input-shell">
                  <i class="fa-solid fa-briefcase" aria-hidden="true"></i>
                  <input name="businessType" type="text" placeholder="<%= isEn ? 'Business type (e.g. dental clinic)' : 'Branche (z. B. Zahnarztpraxis)' %>" required>
                </div>
                <div class="wt-input-shell">
                  <i class="fa-solid fa-bullseye" aria-hidden="true"></i>
                  <input name="primaryService" type="text" placeholder="<%= isEn ? 'Primary service (e.g. dental implants)' : 'Hauptleistung (z. B. Zahnimplantate)' %>" required>
                </div>
                <div class="wt-input-shell">
                  <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                  <input name="targetRegion" type="text" placeholder="<%= isEn ? 'Target region (e.g. Berlin)' : 'Zielregion (z. B. Berlin)' %>" required>
                </div>
              </div>
              <label class="visually-hidden" for="meta-url"><%= isEn ? 'Website URL' : 'Website-URL' %></label>
              <div class="wt-form-row">
                <div class="wt-input-shell wt-input-shell--url">
                  <i class="fa-solid fa-globe" aria-hidden="true"></i>
                  <input id="meta-url" name="url" type="text" inputmode="url" placeholder="<%= isEn ? 'https://your-website.com' : 'https://deine-website.de' %>" required>
                </div>
                <button class="wt-button" type="submit">
                  <i class="fa-solid fa-bolt"></i>
                  <%= isEn ? 'Start meta check' : 'Meta-Check starten' %>
                </button>
              </div>
            </form>

            <p class="wt-form-note">
              <%= isEn
                ? 'Length checks use practical SERP targets: title around 55-60 chars (max around 600px), description 120-155 chars, and concise H1 below 80 chars.'
                : 'Die Längenprüfung nutzt praxisnahe SERP-Ziele: Title ideal 55-60 Zeichen (max. ca. 600px), Description 120-155 Zeichen und prägnante H1 unter 80 Zeichen.' %>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel" data-meta-loading hidden>
          <h3><%= isEn ? 'Meta check in progress…' : 'Meta-Check läuft…' %></h3>
          <p><%= isEn ? 'We are scanning your homepage head-tags and evaluating SEO/social readiness now.' : 'Wir analysieren jetzt die Head-Tags deiner Startseite und bewerten SEO-/Social-Readiness.' %></p>
          <ul class="wt-progress">
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Validate domain and load homepage only' : 'Domain validieren und ausschließlich Startseite laden' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Analyze title, description, H1 and pixel width' : 'Title, Description, H1 und Pixelbreite prüfen' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Check canonical, robots, OG, Twitter and icons' : 'Canonical, Robots, OG, Twitter und Icons prüfen' %></span></li>
            <li data-progress-item><i class="fa-regular fa-circle"></i><span><%= isEn ? 'Evaluate industry/region relevance and build action list' : 'Branchen-/Regions-Fit auswerten und Maßnahmenliste erstellen' %></span></li>
          </ul>
        </div>

        <div class="wt-error" data-meta-error hidden></div>
        <div id="meta-results" class="wt-results" data-meta-results hidden></div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-check-grid">
          <article class="wt-check-card">
            <i class="fa-solid fa-heading"></i>
            <h3><%= isEn ? 'SERP Snippet Fit' : 'SERP-Snippet-Fit' %></h3>
            <p><%= isEn ? 'Checks title/meta/H1 length and pixel-width so snippets are less likely to be truncated.' : 'Prüft Title/Meta/H1 auf Zeichen- und Pixelgrenzen, damit Snippets seltener abgeschnitten werden.' %></p>
          </article>
          <article class="wt-check-card">
            <i class="fa-solid fa-share-nodes"></i>
            <h3><%= isEn ? 'Social Preview Tags' : 'Social-Preview-Tags' %></h3>
            <p><%= isEn ? 'Validates Open Graph and Twitter Card tags for stable link previews across platforms.' : 'Validiert Open-Graph- und Twitter-Card-Tags für stabile Link-Vorschauen auf Plattformen.' %></p>
          </article>
          <article class="wt-check-card">
            <i class="fa-solid fa-image"></i>
            <h3><%= isEn ? 'Icons & Assets' : 'Icons & Assets' %></h3>
            <p><%= isEn ? 'Verifies favicon, apple-touch-icon, manifest, and key technical head assets.' : 'Prüft Favicon, Apple-Touch-Icon, Manifest und wichtige technische Head-Assets.' %></p>
          </article>
          <article class="wt-check-card">
            <i class="fa-solid fa-location-dot"></i>
            <h3><%= isEn ? 'Industry/Region Fit' : 'Branchen-/Regions-Fit' %></h3>
            <p><%= isEn ? 'Evaluates whether title/description/H1 match your business type, service, and target region.' : 'Bewertet, ob Title/Description/H1 zu Branche, Leistung und Zielregion passen.' %></p>
          </article>
        </div>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel wt-methodology">
          <h2><%= isEn ? 'How the Meta Tester analyzes your website head' : 'So analysiert der Meta-Tester den Website-Header' %></h2>
          <p>
            <%= isEn
              ? 'The Meta Tester fetches your homepage head section plus up to 5 subpages and validates 30+ individual head signals: title, meta description, H1, canonical, hreflang, robots directive, Open Graph, Twitter Cards, favicon, apple-touch-icon, manifest, viewport, theme-color, language declaration, and structured-data JSON-LD. Each signal is checked for presence, length, uniqueness, and intent fit against the business context you provide.'
              : 'Der Meta-Tester holt den Head-Bereich deiner Startseite plus bis zu 5 Unterseiten und prüft 30+ Head-Signale: Title, Meta-Description, H1, Canonical, Hreflang, Robots-Direktive, Open Graph, Twitter Cards, Favicon, Apple-Touch-Icon, Manifest, Viewport, Theme-Color, Sprachdeklaration und strukturierte Daten (JSON-LD). Jedes Signal wird auf Präsenz, Länge, Einmaligkeit und Intent-Fit gegen deinen Geschäftskontext geprüft.' %>
          </p>
          <div class="wt-method-grid">
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-heading"></i> <%= isEn ? 'Title & description quality' : 'Title- & Description-Qualität' %></h3>
              <p><%= isEn
                ? 'Length in pixels (not just chars), keyword density, duplicate titles across subpages, CTA presence, and intent match with your service and region.'
                : 'Länge in Pixel (nicht nur Zeichen), Keyword-Dichte, doppelte Titles über Unterseiten, CTA-Präsenz und Intent-Match mit Leistung und Region.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-share-nodes"></i> <%= isEn ? 'Social preview readiness' : 'Social-Preview-Readiness' %></h3>
              <p><%= isEn
                ? 'OG tags (og:title, og:description, og:image, og:url, og:type, og:locale) plus Twitter Card set, image dimensions ≥ 1200×630, absolute URLs only.'
                : 'OG-Tags (og:title, og:description, og:image, og:url, og:type, og:locale) plus Twitter-Card-Set, Bildmaße ≥ 1200×630, nur absolute URLs.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-link"></i> <%= isEn ? 'Canonical & indexing' : 'Canonical & Indexierung' %></h3>
              <p><%= isEn
                ? 'Self-referencing canonical, hreflang consistency, robots meta, noindex audit. One wrong noindex on marketing pages can kill organic traffic overnight.'
                : 'Self-referencing Canonical, Hreflang-Konsistenz, Robots-Meta, Noindex-Audit. Ein falsches Noindex auf Marketing-Seiten killt organischen Traffic über Nacht.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-icons"></i> <%= isEn ? 'Icons & PWA signals' : 'Icons & PWA-Signale' %></h3>
              <p><%= isEn
                ? 'Favicon.ico, SVG favicon, apple-touch-icon.png, manifest.json, theme-color, maskable icons, viewport meta. Matters for mobile UX and home-screen installs.'
                : 'Favicon.ico, SVG-Favicon, apple-touch-icon.png, manifest.json, Theme-Color, Maskable Icons, Viewport-Meta. Relevant für Mobile-UX und Home-Screen-Installationen.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-code-branch"></i> <%= isEn ? 'Structured data' : 'Strukturierte Daten' %></h3>
              <p><%= isEn
                ? 'JSON-LD schema presence, type correctness, required-field validation. Unlocks rich snippets and AI answer citations in one go.'
                : 'JSON-LD-Schema-Präsenz, Typ-Korrektheit, Pflichtfeld-Validierung. Erschließt Rich-Snippets und KI-Antwort-Zitierungen in einem Schritt.' %></p>
            </div>
            <div class="wt-method-card">
              <h3><i class="fa-solid fa-language"></i> <%= isEn ? 'Language & region' : 'Sprache & Region' %></h3>
              <p><%= isEn
                ? 'html lang attribute, content-language meta, hreflang alternates, geo-meta tags. Critical for multilingual and regional sites.'
                : 'html-lang-Attribut, content-language-Meta, Hreflang-Alternates, Geo-Meta-Tags. Kritisch für mehrsprachige und regionale Sites.' %></p>
            </div>
          </div>
          <p>
            <%= isEn
              ? 'You see the full homepage head audit directly in your browser, with every finding tagged priority-high, medium, or low. The short report delivered after email confirmation extends the audit to up to 5 subpages; the full guide can cover larger page sets with step-by-step fix instructions, ready-to-paste HTML snippets, and a prioritized rollout checklist.'
              : 'Du siehst direkt im Browser, ob Title, Description, H1 und wichtige Vorschau-Daten klar genug sind. Die Empfehlungen zeigen, welche Anpassungen mehr Klicks aus Google und Social-Vorschauen bringen können.' %>
          </p>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel">
          <h2><%= isEn ? 'What clients say' : 'Was Kunden sagen' %></h2>
          <div class="wt-reviews-grid">
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“The meta audit surfaced 14 concrete fixes we rolled out in one morning. Social CTR doubled within a week.”'
                : '„Die Meta-Analyse hat 14 konkrete Fixes aufgezeigt, die wir an einem Vormittag umgesetzt haben. Social-CTR hat sich innerhalb einer Woche verdoppelt."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“Very precise, no filler. We finally understood why our titles were being rewritten by Google.”'
                : '„Sehr präzise, kein Blabla. Wir haben endlich verstanden, warum Google unsere Titles umgeschrieben hat."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
            <figure class="wt-review">
              <div class="wt-review-stars" aria-label="5 of 5 stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
              <blockquote><%= isEn
                ? '“The canonical / noindex audit alone saved us a whole SEO disaster after a CMS migration.”'
                : '„Allein der Canonical/Noindex-Check hat uns nach einem CMS-Umzug ein SEO-Desaster erspart."' %></blockquote>
              <figcaption><%= isEn ? 'Verified Google review' : 'Verifizierte Google-Bewertung' %></figcaption>
            </figure>
          </div>
          <p class="wt-reviews-link">
            <a href="https://www.google.com/search?q=komplett+webdesign+bewertungen" target="_blank" rel="noopener">
              <i class="fa-brands fa-google"></i>
              <%= isEn ? 'Read all Google reviews' : 'Alle Google-Bewertungen lesen' %>
            </a>
          </p>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <article class="wt-panel wt-trust-panel">
          <h3><%= isEn ? 'Transparent and privacy-friendly' : 'Transparent und datenschutzfreundlich' %></h3>
          <ul class="wt-trust-list">
            <li><i class="fa-solid fa-shield-halved"></i> <%= isEn ? 'The check only uses publicly visible website information.' : 'Der Check nutzt nur öffentlich sichtbare Website-Informationen.' %></li>
            <li><i class="fa-solid fa-clock"></i> <%= isEn ? 'You receive a compact result quickly.' : 'Du erhältst schnell ein kompaktes Ergebnis.' %></li>
            <li><i class="fa-solid fa-database"></i> <%= isEn ? 'Anonymous check data is used only for quality assurance.' : 'Anonyme Check-Daten werden nur zur Qualitätssicherung genutzt.' %></li>
            <li><i class="fa-solid fa-envelope-open"></i> <%= isEn ? 'We use double opt-in for email delivery. Unsubscribe in one click any time.' : 'Wir nutzen Double-Opt-in für Mail-Versand. Abmeldung jederzeit mit einem Klick.' %></li>
          </ul>
        </article>
      </div>
    </section>

    <section class="wt-section">
      <div class="wt-shell">
        <div class="wt-panel">
          <h2><%= isEn ? 'FAQ: Header Meta Test' : 'FAQ: Header-Meta-Test' %></h2>
          <div class="wt-faq">
            <% (typeof faq !== 'undefined' && Array.isArray(faq) ? faq : []).forEach(function(item){ %>
              <details>
                <summary><%= item.q %></summary>
                <p><%= item.a %></p>
              </details>
            <% }); %>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <style>
    .wt-section-compact { padding-top: 16px; padding-bottom: 0; }
    .breadcrumbs ol { margin: 0; padding: 0; list-style: none; display: flex; gap: 10px; flex-wrap: wrap; }
    .breadcrumbs li { color: #6b7280; font-size: .95rem; }
    .breadcrumbs li+li::before { content: '›'; margin-right: 10px; color: #9ca3af; }
    .breadcrumbs a { color: #374151; text-decoration: none; }
    .breadcrumbs a:hover { text-decoration: underline; }
    .wt-faq details { border-top: 1px solid #e5e7eb; padding: 14px 0; }
    .wt-faq summary { cursor: pointer; font-weight: 600; }
    .wt-faq p { margin: 10px 0 0; }
  </style>

  <script>
    window.META_TESTER_CONFIG = {
      locale: "<%= isEn ? 'en' : 'de' %>",
      endpoint: "/api/meta-audit",
      leadEndpoint: "/api/meta-audit/lead",
      i18n: {
        scoreOf: "<%= isEn ? 'of 100' : 'von 100' %>",
        metaAuditFor: "<%= isEn ? 'Meta audit for' : 'Meta-Analyse für' %>",
        modeLabel: "<%= isEn ? 'Scope' : 'Umfang' %>",
        scannedPages: "<%= isEn ? 'Scanned pages' : 'Gescannten Seiten' %>",
        checkOverview: "<%= isEn ? 'Head checks (homepage)' : 'Head-Checks (Startseite)' %>",
        categoryScoresTitle: "<%= isEn ? 'Meta categories' : 'Meta-Kategorien' %>",
        recommendationsTitle: "<%= isEn ? 'Priority actions' : 'Priorisierte Maßnahmen' %>",
        findingsTitle: "<%= isEn ? 'Findings' : 'Befunde' %>",
        contextFitTitle: "<%= isEn ? 'Industry/region relevance' : 'Branchen-/Regions-Relevanz' %>",
        contextFitDetails: "<%= isEn ? 'Title, description, and H1 fit your context' : 'Title, Description und H1 passen zu deinem Kontext' %>",
        lockedTitle: "<%= isEn ? 'Get short report (up to 5 pages)' : 'Kurzreport erhalten (bis zu 5 Seiten)' %>",
        lockedText: "<%= isEn ? 'Confirm your email to receive the short report with additional page checks. The complete full guide can be sent separately after review.' : 'Bestätige deine E-Mail, um den Kurzreport mit zusätzlichen Seitenchecks zu erhalten. Die vollständige Vollanleitung kann nach Prüfung separat zugestellt werden.' %>",
        leadName: "<%= isEn ? 'Name (optional)' : 'Name (optional)' %>",
        leadEmail: "<%= isEn ? 'Email address' : 'E-Mail-Adresse' %>",
        leadConsent: "<%= isEn ? 'I agree to newsletter signup, want to receive the requested meta report by email, and have read the privacy policy.' : 'Ich stimme der Newsletter-Anmeldung zu, möchte den angeforderten Meta-Report per E-Mail erhalten und habe die Datenschutzerklärung gelesen.' %>",
        privacyHref: "/datenschutz",
        privacyLabel: "<%= isEn ? 'Privacy policy' : 'Datenschutzerklärung' %>",
        leadSubmit: "<%= isEn ? 'Send confirmation link' : 'Bestätigungslink senden' %>",
        leadLoading: "<%= isEn ? 'Sending…' : 'Wird gesendet…' %>",
        leadSuccess: "<%= isEn ? 'Please check your inbox and confirm your email. We then send your detailed meta report.' : 'Bitte prüfe dein Postfach und bestätige deine E-Mail. Danach senden wir deinen detaillierten Meta-Report.' %>",
        leadError: "<%= isEn ? 'The meta report request could not be processed.' : 'Die Meta-Report-Anfrage konnte nicht verarbeitet werden.' %>",
        contextRequired: "<%= isEn ? 'Please provide business type, primary service, and target region.' : 'Bitte ergänze Branche, Hauptleistung und Zielregion.' %>",
        errorFallback: "<%= isEn ? 'The meta audit could not be completed.' : 'Der Meta-Audit konnte nicht durchgeführt werden.' %>",
        noData: "<%= isEn ? 'No data available.' : 'Keine Daten verfügbar.' %>",
        ctaTitle: "<%= isEn ? 'Need support with implementation?' : 'Du brauchst Unterstützung bei der Umsetzung?' %>",
        ctaText: "<%= isEn ? 'Book a short consulting call to prioritize your highest-impact metadata fixes.' : 'Buche ein kurzes Beratungsgespräch, um die wichtigsten Meta-Maßnahmen zu priorisieren.' %>",
        ctaPrimary: "<%= isEn ? 'Request consultation' : 'Beratung anfragen' %>",
        ctaSecondary: "<%= isEn ? 'Book appointment' : 'Termin buchen' %>",
        contactHref: "<%= isEn ? '/en/kontakt' : '/kontakt' %>",
        checkLabelMap: {
          title_length: "<%= isEn ? 'Title length' : 'Title-Länge' %>",
          title_pixels: "<%= isEn ? 'Title pixel width' : 'Title-Pixelbreite' %>",
          meta_description: "<%= isEn ? 'Meta description' : 'Meta-Description' %>",
          description_pixels: "<%= isEn ? 'Description pixel width' : 'Description-Pixelbreite' %>",
          h1: "H1",
          directives: "<%= isEn ? 'Directives & canonical' : 'Direktiven & Canonical' %>",
          open_graph: "Open Graph",
          twitter: "Twitter",
          icons: "<%= isEn ? 'Icons & manifest' : 'Icons & Manifest' %>",
          structured_data: "<%= isEn ? 'Structured data' : 'Strukturierte Daten' %>",
          hreflang: "hreflang",
          intent_fit: "<%= isEn ? 'Industry/region fit' : 'Branchen-/Regions-Fit' %>",
          head_tech: "<%= isEn ? 'Head technical completeness' : 'Head technische Vollständigkeit' %>"
        }
      }
    };
  </script>
  <script src="/js/tester-utils.js?v=<%= encodeURIComponent(assetVersion || '1') %>" defer></script>
  <script src="/js/meta-tester.js?v=<%= encodeURIComponent(assetVersion || '1') %>" defer></script>
</body>
</html>
