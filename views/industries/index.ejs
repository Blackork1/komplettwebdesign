<!-- views/industries/index.ejs -->
<%
const structuredDataBlocks = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Startseite", item: `${baseUrl || ''}/` },
      { "@type": "ListItem", position: 2, name: "Branchen", item: `${baseUrl || ''}/branchen` }
    ]
  }
];
%>
<%- include('../partials/head', { title, description, structuredDataBlocks }) %>
<%- include('../partials/header') %>

<link rel="preload" href="<%= cssAsset('branchen.css') %>" as="style" onload="this.rel='stylesheet'">
<noscript>
  <link rel="stylesheet" href="<%= cssAsset('branchen.css') %>">
</noscript>

<main class="industries-index-page" id="hero">
<!-- ────────── Hero ────────── -->
  <section class="heroB industries-hero unified-hero d-flex align-items-center" aria-labelledby="industries-hero-title">
    <div class="unified-hero__container unified-hero__grid">
      <div class="hero-content unified-hero__copy">
        <nav class="unified-hero__breadcrumbs" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Startseite</a></li>
            <li aria-current="page">Branchen</li>
          </ol>
        </nav>
        <h1 id="industries-hero-title" class="display-5 fw-bold mb-3 home-hero-reveal home-hero-reveal--h1 animate-on-scroll">Webdesign für Berliner Branchen.</h1>
        <p class="lead mb-4 unified-hero__lead home-hero-reveal home-hero-reveal--support animate-on-scroll">
          Finde deine Branche mit Beispielen, Funktionen, SEO-Tipps und passenden Paketempfehlungen.
        </p>
        <div class="industries-hero__actions unified-hero__actions home-hero-reveal home-hero-reveal--actions animate-on-scroll">
          <a class="btn btn-primary" href="/kontakt">Projekt anfragen</a>
          <a class="btn btn-secondary" href="/pakete">Pakete ansehen</a>
        </div>
      </div>

      <aside class="industries-hero__panel unified-hero__panel home-hero-reveal home-hero-reveal--visual animate-on-scroll">
        <figure class="industries-hero__media unified-hero__media-frame">
          <img src="/images/branchen/features.webp" alt="Website-Funktionen für Branchen-Websites" loading="eager" fetchpriority="high">
        </figure>
        <p>
          Priorisiert werden Branchen, bei denen klare Leistungen, lokale Sichtbarkeit und schnelle Kontaktwege besonders wichtig sind.
        </p>
      </aside>
    </div>
  </section>

<div class="container my-5">
  <section class="mb-5" aria-labelledby="industries-intro-title">
    <div class="row g-4 align-items-start">
      <div class="col-lg-7">
        <p class="text-uppercase fw-bold accentColor mb-2">Einordnung</p>
        <h2 id="industries-intro-title" class="mb-3">Branchen-Websites brauchen mehr als ein austauschbares Layout</h2>
        <p>
          Eine Website für einen Blumenladen, ein Café, eine Reinigungsfirma oder einen Handwerksbetrieb muss schnell erklären,
          welche Leistung angeboten wird, für wen sie passt und welcher nächste Kontaktweg sinnvoll ist. Deshalb sammelt diese
          Übersicht Branchen, bei denen Angebotsstruktur, lokale Sichtbarkeit, Bilder, Öffnungszeiten, Anfragewege und spätere
          Erweiterungen unterschiedlich gewichtet werden.
        </p>
        <p>
          Die Seiten sind als Orientierung gedacht. Sie ersetzen kein individuelles Angebot, helfen dir aber dabei,
          typische Inhalte, sinnvolle Zusatzleistungen und passende Paketgrößen früh einzuordnen. Preise, laufende Kosten,
          Buchungssysteme, CMS, Tracking oder Local SEO werden nicht pauschal versprochen, sondern vor der Umsetzung abgegrenzt.
        </p>
      </div>
      <div class="col-lg-5">
        <div class="border rounded-3 p-4 h-100 card-shadow">
          <h3 class="h5">Sinnvolle nächste Seiten</h3>
          <ul class="list-unstyled mb-0">
            <li class="mb-2"><a href="/webdesign-berlin">Webdesign Berlin als Hauptleistung ansehen</a></li>
            <li class="mb-2"><a href="/pakete">Start, Business, Wachstum und Individuell vergleichen</a></li>
            <li class="mb-2"><a href="/leistungen/zusatzleistungen-webdesign">Zusatzleistungen sauber abgrenzen</a></li>
            <li><a href="/kontakt">Projekt unverbindlich einordnen lassen</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="row">
    <!-- Hauptliste der Blogposts (linke Spalte) -->
    <div class="col-md-8">
      <h2 class="mb-4">Wichtige Branchen</h2>
      <div class="post-list">
        <!-- <<< Neuer Wrapper -->
        <% (others && others.length ? others : []).forEach(function(ind){ %>
        <div class="post-card mb-4">
          <!-- Verlinkter Artikel -->
          <a href="<%= toPath(ind) %>" class="post-card-link">
            <!-- Hintergrundbild + Overlay -->
            <div class="post-card-bg">
              <% if (ind.og_image_url) { %>
                <img class="post-card-bg__image" src="<%= ind.og_image_url %>" alt="" loading="lazy" decoding="async">
              <% } %>
              <div class="post-card-content">
                <div class="post-card-overlay">
                  <h2 class="post-card-title alignCenter">
                    <%= ind.name %>
                  </h2>
                </div>
              </div>
            </div>
          </a>
        </div>
        <% }); %>
      </div>
    </div>

    <!-- Featured Posts Sidebar (nur Desktop, rechts) -->
    <div class="col-md-4 d-none d-md-block">
      <h3>Neue Branchen</h3>
      <% featured.forEach(function(ind){ %>
      <div class="featured-post-card mb-3">
        <a href="<%= toPath(ind) %>" class="d-flex">
          <img src="<%= ind.og_image_url %>" alt="<%= ind.title %>" class="featured-post-img" />
          <div class="featured-post-info">
            <h5 class="featured-post-title">
              <%= ind.title %>
            </h5>
            <p class="featured-post-excerpt">
              <%= (ind.excerpt) %>
            </p>
          </div>
        </a>
      </div>
      <% }); %>
    </div>
  </div>

  <!-- Featured Posts horizontal (mobil sichtbar) -->
  <div class="d-block d-md-none mt-4">
    <h4>Neue Branchen</h4>
    <div class="featured-mobile-scroll d-flex">
      <% featured.forEach(function(ind){  %>
      <div class="featured-post-card-mobile me-3">
        <a href="<%= toPath(ind) %>">
          <img src="<%= ind.og_image_url %>" alt="<%= ind.title %>" class="featured-post-img-mobile" />
          <h5 class="featured-post-title-mobile">
            <%= ind.title %>
          </h5>
        </a>
      </div>
      <% }); %>
    </div>
  </div>
</div>

</main>

<%- include('../partials/footer') %>
