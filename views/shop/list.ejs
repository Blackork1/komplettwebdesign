<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>Pakete – Shop</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="<%= cssAsset('shop.css') %>">
  </head>
  <body>
    <h1>Pakete</h1>
    <div class="grid">
      <% packages.forEach(p => { %>
      <div class="card">
        <% if (p.image) { %><img
          src="/images/<%= p.image %>"
          alt="<%= p.name %>"
        /><% } %>
        <h3><%= p.name %></h3>
        <% if (p.description) { %>
        <p><%= p.description %></p>
        <% } %>
        <div class="price">
          <%= (p.amount_cents/100).toFixed(2) %> <%= (p.currency ||
          'eur').toUpperCase() %>
        </div>
        <a class="btn btn-primary" href="/checkout/<%= p.id %>">Jetzt kaufen</a>
      </div>
      <% }) %>
    </div>
  </body>
</html>
